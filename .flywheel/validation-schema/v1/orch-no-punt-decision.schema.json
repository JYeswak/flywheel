{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zeststream.ai/schemas/flywheel/v1/orch-no-punt-decision.schema.json",
  "title": "Orchestrator no-punt output gate decision",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "version",
    "ts",
    "session",
    "decision",
    "reason",
    "punt_pattern_matched",
    "panes_waiting",
    "ready_beads",
    "blocker_class_matched",
    "ledger_appended",
    "warnings",
    "ledger_written"
  ],
  "properties": {
    "schema_version": {
      "const": "orch-no-punt-decision/v1"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "session": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "enum": ["allow", "refuse"]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "punt_pattern_matched": {
      "type": ["string", "null"]
    },
    "panes_waiting": {
      "type": "array",
      "items": {
        "type": ["integer", "string"]
      }
    },
    "ready_beads": {
      "type": "integer",
      "minimum": 0
    },
    "blocker_class_matched": {
      "type": ["string", "null"]
    },
    "ledger_appended": {
      "type": "string",
      "minLength": 1
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ledger_written": {
      "type": "boolean"
    }
  }
}
