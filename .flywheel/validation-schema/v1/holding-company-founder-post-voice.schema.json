{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zeststream.local/flywheel/holding-company-founder-post-voice/v1/schema.json",
  "title": "ZestStream Holding Company Founder Post Voice v1",
  "description": "Ledger for Joshua post/public-share voice alignment: posts must carry holding-company positioning, receipt-led claims, fact-check clearance, human ratification, and no builder framing.",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "gate",
    "required_positioning",
    "clear_count",
    "posts",
    "next_action"
  ],
  "properties": {
    "schema_version": {
      "const": "zeststream.holding_company_founder_post_voice.v1"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "gate": {
      "const": "founder_post_anti_pitch_voice"
    },
    "required_positioning": {
      "const": "sharpen_legacy_incubate_new_not_builder"
    },
    "clear_count": {
      "type": "integer",
      "minimum": 0
    },
    "posts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/post"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "$defs": {
    "post": {
      "type": "object",
      "required": [
        "post_id",
        "channel",
        "status",
        "draft_ref",
        "publisher_receipt_ref",
        "fact_check_ref",
        "human_ratification_required",
        "holding_company_positioning_present",
        "receipt_story_present",
        "claim_fact_check_status",
        "builder_framing_hits",
        "proof_or_receipt_refs",
        "evidence_refs"
      ],
      "properties": {
        "post_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,128}$"
        },
        "channel": {
          "type": "string",
          "enum": [
            "linkedin",
            "x",
            "blog",
            "newsletter"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "blocked",
            "needs_revision",
            "clear",
            "ratified",
            "deferred"
          ]
        },
        "draft_ref": {
          "type": "string",
          "minLength": 1
        },
        "publisher_receipt_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "fact_check_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "human_ratification_required": {
          "type": "boolean"
        },
        "holding_company_positioning_present": {
          "type": "boolean"
        },
        "receipt_story_present": {
          "type": "boolean"
        },
        "claim_fact_check_status": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "not_checked",
            "no_claims"
          ]
        },
        "builder_framing_hits": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/builder_hit"
          }
        },
        "proof_or_receipt_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "builder_hit": {
      "type": "object",
      "required": [
        "frame",
        "path",
        "line",
        "excerpt"
      ],
      "properties": {
        "frame": {
          "type": "string",
          "enum": [
            "workflow_builder",
            "custom_app_builder",
            "custom_app",
            "automation_positioning",
            "build_apps_story"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "excerpt": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
