{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "flywheel.jeff-daily-diff-report.v1",
  "title": "Jeffrey Emanuel daily corpus diff snapshot",
  "description": "Raw aggregated GitHub-API activity for Dicklesworthstone/* repos in a 24h window. Bead flywheel-ys7em.",
  "type": "object",
  "required": [
    "schema_version",
    "ts_started",
    "ts_completed",
    "since",
    "owner",
    "repo_count",
    "repos",
    "total_commits",
    "total_issues",
    "total_releases",
    "total_prs"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["jeff-daily-diff-collector.v1"]
    },
    "ts_started":   {"type": "string", "format": "date-time"},
    "ts_completed": {"type": "string", "format": "date-time"},
    "since":        {"type": "string", "format": "date-time"},
    "owner":        {"type": "string"},
    "repo_count":   {"type": "integer", "minimum": 0},
    "total_commits":  {"type": "integer", "minimum": 0},
    "total_issues":   {"type": "integer", "minimum": 0},
    "total_releases": {"type": "integer", "minimum": 0},
    "total_prs":      {"type": "integer", "minimum": 0},
    "errors":  {"type": "array"},
    "repos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["repo", "commits", "issues", "releases", "prs"],
        "properties": {
          "repo":     {"type": "string"},
          "commits":  {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["sha", "message", "author", "ts"],
              "properties": {
                "sha":     {"type": "string"},
                "message": {"type": "string"},
                "author":  {"type": ["string", "null"]},
                "ts":      {"type": ["string", "null"]}
              }
            }
          },
          "issues":   {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["number", "title", "url"],
              "properties": {
                "number": {"type": "integer"},
                "title":  {"type": "string"},
                "state":  {"type": ["string", "null"]},
                "ts":     {"type": ["string", "null"]},
                "url":    {"type": "string"}
              }
            }
          },
          "releases": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["tag", "url"],
              "properties": {
                "tag":  {"type": "string"},
                "name": {"type": ["string", "null"]},
                "ts":   {"type": ["string", "null"]},
                "url":  {"type": "string"}
              }
            }
          },
          "prs":      {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["number", "title", "url"],
              "properties": {
                "number": {"type": "integer"},
                "title":  {"type": "string"},
                "ts":     {"type": ["string", "null"]},
                "url":    {"type": "string"}
              }
            }
          }
        }
      }
    }
  }
}
