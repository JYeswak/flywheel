{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zeststream.local/flywheel/tick-receipt/v1/schema.json",
  "title": "Flywheel tick receipt v1",
  "description": "Canonical shape for flywheel-loop tick driver receipts, including the VALIDATE phase summary required before INTEGRATE.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "task_id",
    "phase",
    "phase_reason",
    "tick_class",
    "dispatch_status",
    "validation_summary"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "phase": {
      "enum": ["INIT", "RESEARCH", "PLAN", "BEADS", "DISPATCH", "VALIDATE", "INTEGRATE", "LEARN"]
    },
    "phase_reason": {
      "type": "string",
      "minLength": 1
    },
    "tick_class": {
      "type": "string",
      "minLength": 1
    },
    "dispatch_status": {
      "enum": ["sent", "dry_run", "failed", "blocked_frozen_detector", "blocked_canonical_pull", "hold"]
    },
    "hold_reason": {
      "type": ["string", "null"]
    },
    "mode": {
      "enum": ["SOFT", "WARN", "HALT"]
    },
    "checks_run": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "violations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["check_id", "failure_class", "mode", "status"]
      }
    },
    "phase_a": {
      "type": "object",
      "additionalProperties": true,
      "required": ["schema_version", "mode", "checks_run", "checks", "violations", "violation_count"],
      "properties": {
        "schema_version": {
          "const": "flywheel-tick-phase-a/v1"
        },
        "mode": {
          "enum": ["SOFT", "WARN", "HALT"]
        },
        "checks_run": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["check_id", "mode", "status", "failure_class"]
          }
        },
        "violations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["check_id", "failure_class", "mode", "status"]
          }
        },
        "violation_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "fuckup_to_bead_pipeline": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schema_version",
        "status",
        "source_rules",
        "required_steps",
        "unprocessed_count",
        "direct_bead_without_pipeline_count",
        "incomplete_processed_count"
      ],
      "properties": {
        "schema_version": {
          "const": "flywheel.fuckup_to_bead_pipeline.v1"
        },
        "status": {
          "enum": ["pass", "pending", "warn"]
        },
        "source_rules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "required_steps": {
          "type": "array",
          "items": {
            "enum": ["planning-workflow", "jeff-convergence-audit", "beads-workflow"]
          }
        },
        "unprocessed_count": {
          "type": "integer",
          "minimum": 0
        },
        "direct_bead_without_pipeline_count": {
          "type": "integer",
          "minimum": 0
        },
        "incomplete_processed_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "callback_validation": {
      "type": "object"
    },
    "tick_contract": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schema_version",
        "contract_id",
        "active_cadence_tier",
        "cadence_tiers",
        "check_count",
        "receipt_fields"
      ],
      "properties": {
        "schema_version": {
          "const": "tick-contract/v1"
        },
        "contract_id": {
          "type": "string",
          "minLength": 1
        },
        "registry_path": {
          "type": "string",
          "minLength": 1
        },
        "active_cadence_tier": {
          "enum": ["doctrine", "active_high", "active_normal", "inactive"]
        },
        "active_interval": {
          "type": ["string", "null"]
        },
        "cadence_tiers": {
          "type": "object",
          "additionalProperties": {
            "type": "object"
          }
        },
        "check_count": {
          "type": "integer",
          "minimum": 0
        },
        "receipt_fields": {
          "type": "array",
          "items": {
            "enum": ["tick_contract", "tick_contract_checks", "tick_contract_graduation"]
          }
        }
      }
    },
    "tick_contract_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "owner_class",
          "source_rule",
          "default_mode",
          "failure_class",
          "producer",
          "measurement",
          "consumer",
          "promotion_path",
          "mode",
          "event_count_7d"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "owner_class": {
            "enum": ["orchestrator", "worker"]
          },
          "source_rule": {
            "type": "string",
            "minLength": 1
          },
          "default_mode": {
            "enum": ["SOFT", "WARN", "HALT"]
          },
          "failure_class": {
            "type": "string",
            "minLength": 1
          },
          "producer": {
            "type": "string",
            "minLength": 1
          },
          "measurement": {
            "type": "string",
            "minLength": 1
          },
          "consumer": {
            "type": "string",
            "minLength": 1
          },
          "promotion_path": {
            "type": "string",
            "minLength": 1
          },
          "mode": {
            "enum": ["SOFT", "WARN", "HALT"]
          },
          "computed_mode": {
            "enum": ["SOFT", "WARN", "HALT"]
          },
          "effective_mode": {
            "enum": ["SOFT", "WARN", "HALT"]
          },
          "event_count_7d": {
            "type": "integer",
            "minimum": 0
          },
          "critical_seen": {
            "type": "boolean"
          },
          "graduation_reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "tick_contract_graduation": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schema_version",
        "source_rule",
        "evidence_window",
        "thresholds",
        "mode_counts",
        "checks_total"
      ],
      "properties": {
        "schema_version": {
          "const": "tick-contract-graduation-result/v1"
        },
        "source_rule": {
          "type": "string",
          "minLength": 1
        },
        "evidence_window": {
          "const": "7d"
        },
        "evidence_window_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "thresholds": {
          "type": "object"
        },
        "mode_counts": {
          "type": "object",
          "required": ["SOFT", "WARN", "HALT"],
          "properties": {
            "SOFT": {
              "type": "integer",
              "minimum": 0
            },
            "WARN": {
              "type": "integer",
              "minimum": 0
            },
            "HALT": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "checks_total": {
          "type": "integer",
          "minimum": 0
        },
        "graduated_checks": {
          "type": "array"
        }
      }
    },
    "validation_summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "action",
        "status",
        "callbacks_unvalidated_count",
        "pending_callback_count",
        "unknown_count",
        "failed_count",
        "passed_count",
        "integration_allowed"
      ],
      "properties": {
        "action": {
          "type": "string",
          "minLength": 1
        },
        "task_id": {
          "type": ["string", "null"]
        },
        "status": {
          "enum": ["pass", "fail", "unknown", "none"]
        },
        "receipt_path": {
          "type": ["string", "null"]
        },
        "failure_classes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "summary_allowed": {
          "type": "boolean"
        },
        "integration_allowed": {
          "type": "boolean"
        },
        "remediation_required": {
          "type": "boolean"
        },
        "remediation_present": {
          "type": "boolean"
        },
        "callbacks_unvalidated_count": {
          "type": "integer",
          "minimum": 0
        },
        "pending_callback_count": {
          "type": "integer",
          "minimum": 0
        },
        "unknown_count": {
          "type": "integer",
          "minimum": 0
        },
        "failed_count": {
          "type": "integer",
          "minimum": 0
        },
        "passed_count": {
          "type": "integer",
          "minimum": 0
        },
        "next_phase": {
          "type": ["string", "null"]
        },
        "chain_blocked_reason": {
          "type": ["string", "null"]
        }
      }
    },
    "dispatch_capacity": {
      "type": "object",
      "additionalProperties": true
    },
    "pane_work_signal_sampled": {
      "type": "boolean"
    },
    "pane_work_signal_disabled": {
      "type": "boolean"
    },
    "pane_work_signal_disabled_reason": {
      "type": ["string", "null"],
      "enum": ["pws_disabled_via_env", "pws_disabled_via_file", null]
    },
    "pane_work_signal_by_pane": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "required": ["agent_kind", "ntm_status", "ntm_activity", "truth_state", "truth_source", "truth_reason"],
        "properties": {
          "agent_kind": {
            "type": "string"
          },
          "ntm_status": {
            "type": "string"
          },
          "ntm_activity": {
            "type": "string"
          },
          "truth_state": {
            "type": "string"
          },
          "truth_source": {
            "type": "string"
          },
          "truth_reason": {
            "type": "string"
          },
          "disagrees_with_ntm_health": {
            "type": "boolean"
          }
        }
      }
    },
    "pane_work_signal_disagreements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["pane", "ntm_activity", "ntm_status", "truth_state"]
      }
    },
    "pane_work_signal_soft_violations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "idle_capacity_source": {
      "enum": ["pane_work_signal_for_codex", "ntm_health"]
    },
    "value_gap": {
      "type": "object",
      "additionalProperties": true
    },
    "value_gap_dimension_scanned": {
      "type": ["string", "null"]
    },
    "value_gap_finding": {
      "type": ["string", "null"]
    },
    "bead_filed_id": {
      "type": ["string", "null"]
    },
    "jeff_status": {
      "type": "object",
      "additionalProperties": true
    },
    "jeff_fixes": {
      "type": "object",
      "additionalProperties": true
    },
    "jeff_status_stale_open_count": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "jeff_tracked_issue_count": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "jeff_fixes_status": {
      "type": ["string", "null"]
    },
    "agent_mail_fd": {
      "type": "object",
      "additionalProperties": true
    },
    "agent_mail_fd_status": {
      "type": ["string", "null"]
    },
    "agent_mail_fd_total_fds": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "agent_mail_fd_lock_fd_count": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "agent_mail_fd_exit_code": {
      "type": ["integer", "null"]
    },
    "agent_mail_fd_warnings": {
      "type": "array"
    },
    "mobile_eats_receipt": {
      "type": "object",
      "additionalProperties": true
    },
    "mobile_eats_receipt_status": {
      "type": ["string", "null"]
    },
    "mobile_eats_last_run_ts": {
      "type": ["string", "null"]
    },
    "mobile_eats_latest_tick_decision": {
      "type": ["string", "null"]
    },
    "mobile_eats_closed_beads_since": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "mobile_eats_bridge_warnings": {
      "type": "array"
    },
    "skillos_loop": {
      "type": "object",
      "additionalProperties": true
    },
    "daily_jeff_ingest": {
      "type": "object",
      "additionalProperties": true
    },
    "daily_jeff_ingest_status": {
      "type": ["string", "null"]
    },
    "daily_jeff_ingest_sources_file": {
      "type": ["string", "null"]
    },
    "daily_jeff_ingest_deps_missing": {
      "type": "array"
    },
    "daily_jeff_ingest_warnings": {
      "type": "array"
    },
    "fleet_onboard": {
      "type": "object",
      "additionalProperties": true
    },
    "fleet_onboard_status": {
      "type": ["string", "null"]
    },
    "fleet_onboard_checked_repos": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "fleet_onboard_limping_repos": {
      "type": "array"
    },
    "fleet_onboard_missing_repos": {
      "type": "array"
    },
    "fleet_onboard_warnings": {
      "type": "array"
    },
    "frozen_detector_self_test": {
      "type": "object",
      "additionalProperties": true
    },
    "frozen_detector": {
      "type": "object",
      "additionalProperties": true
    },
    "frozen_detector_dispatch_block_reason": {
      "type": ["string", "null"]
    },
    "frozen_detector_source_health_status": {
      "type": ["string", "null"]
    },
    "frozen_detector_frozen_panes_detected": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "frozen_detector_unknown_panes_detected": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "frozen_detector_stale_template_prompt_count": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "frozen_detector_queued_not_submitted_count": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "frozen_detector_respawn_suppressed_count": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "frozen_detector_recovery_suppressed_count": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "frozen_detector_l60_signals_present": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      }
    },
    "frozen_detector_l60_signal_present_count": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "frozen_detector_l60_signal_expected_count": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "frozen_detector_l60_signal_missing": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "frozen_detector_l60_all_present": {
      "type": "boolean"
    },
    "frozen_detector_soft_violations": {
      "type": "array"
    },
    "frozen_detector_l60_signal_decrement_count": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "frozen_detector_durable_receipts": {
      "type": "array"
    },
    "frozen_pane_source_health_status": {
      "type": ["string", "null"]
    }
  }
}
