{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zeststream.ai/schemas/flywheel/skillos-template-handshake/v1/request.schema.json",
  "title": "Flywheel skillos template handshake request v1",
  "description": "Request row for flywheel-to-skillos skill-template injection coordination.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "idempotency_key",
    "producer_version_required",
    "requested_template_class",
    "requested_skills",
    "ttl_seconds",
    "requestor_orch",
    "requestor_session",
    "requested_at"
  ],
  "properties": {
    "schema_version": { "const": "skillos-template-handshake-request/v1" },
    "type": { "const": "skillos_template_handshake_request" },
    "idempotency_key": {
      "type": "string",
      "pattern": "^(sha256:[0-9a-f]{64}|[A-Za-z0-9][A-Za-z0-9._:-]{5,159})$"
    },
    "producer_version_required": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/+-]{1,127}$"
    },
    "requested_template_class": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_.-]{1,80}$"
    },
    "requested_skills": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/+-]{1,127}$"
      }
    },
    "ttl_seconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 86400
    },
    "requestor_orch": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{1,127}$"
    },
    "requestor_session": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{1,127}$"
    },
    "requested_at": {
      "type": "string",
      "format": "date-time"
    },
    "request_expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "dispatch_target_bead_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{1,191}$"
    }
  }
}
