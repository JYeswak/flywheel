{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zeststream.ai/flywheel/evidence-pack-v2.schema.json",
  "title": "Flywheel Evidence Pack v2",
  "description": "Relational evidence pack with stable evidence IDs, resolvable excerpt anchors, and evidence-to-claim edges.",
  "type": "object",
  "required": [
    "evidence_pack_version",
    "items",
    "claims"
  ],
  "properties": {
    "evidence_pack_version": {
      "const": 2
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/evidence_item"
      }
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/claim"
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "evidence_id": {
      "type": "string",
      "pattern": "^EV-[0-9]{3}$"
    },
    "claim_id": {
      "type": "string",
      "pattern": "^C-[0-9]{3}$"
    },
    "excerpt_anchor": {
      "type": "string",
      "pattern": "^.+:[0-9]+-[0-9]+$"
    },
    "edge": {
      "type": "object",
      "required": [
        "relation",
        "claim_id",
        "confidence"
      ],
      "properties": {
        "relation": {
          "enum": [
            "supports",
            "refutes",
            "informs"
          ]
        },
        "claim_id": {
          "$ref": "#/$defs/claim_id"
        },
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        }
      },
      "additionalProperties": true
    },
    "evidence_item": {
      "type": "object",
      "required": [
        "id",
        "description",
        "excerpt_anchor",
        "edges"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/evidence_id"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "excerpt_anchor": {
          "$ref": "#/$defs/excerpt_anchor"
        },
        "edges": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/edge"
          }
        }
      },
      "additionalProperties": true
    },
    "claim": {
      "type": "object",
      "required": [
        "id",
        "statement",
        "status",
        "evidence_supporting",
        "evidence_refuting"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/claim_id"
        },
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "confirmed",
            "refuted",
            "partial",
            "unverified"
          ]
        },
        "evidence_supporting": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_id"
          },
          "uniqueItems": true
        },
        "evidence_refuting": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_id"
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    }
  }
}
