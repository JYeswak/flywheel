{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zeststream.ai/schemas/flywheel/orchestrator-callback-artifact-decision/v1/orchestrator-callback-artifact-decision.schema.json",
  "title": "Orchestrator callback artifact decision v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "version",
    "ts",
    "repo_path",
    "dispatch_file",
    "callback",
    "artifact_status",
    "total_artifacts",
    "fulfilled_count",
    "missing_artifacts",
    "malformed_artifacts",
    "subthreshold_artifacts",
    "evidence_missing_artifacts",
    "evidence_extra_paths",
    "decision",
    "reason",
    "exit_code",
    "fix_bead_id",
    "ledger_path",
    "warnings"
  ],
  "properties": {
    "schema_version": { "const": "orchestrator-callback-artifact-decision/v1" },
    "version": { "type": "string", "minLength": 1 },
    "ts": { "type": "string", "format": "date-time" },
    "repo_path": { "type": "string", "minLength": 1 },
    "dispatch_file": { "type": "string", "minLength": 1 },
    "callback": {
      "type": "object",
      "additionalProperties": true,
      "required": ["ok", "raw", "task_id", "bead", "evidence_raw", "evidence_paths"],
      "properties": {
        "ok": { "type": "boolean" },
        "raw": { "type": "string" },
        "task_id": { "type": "string" },
        "bead": { "type": "string" },
        "evidence_raw": { "type": "string" },
        "evidence_paths": { "type": "array", "items": { "type": "string" } }
      }
    },
    "artifact_status": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact_status" }
    },
    "total_artifacts": { "type": "integer", "minimum": 0 },
    "fulfilled_count": { "type": "integer", "minimum": 0 },
    "missing_artifacts": { "type": "array", "items": { "type": "string" } },
    "malformed_artifacts": { "type": "array", "items": { "type": "string" } },
    "subthreshold_artifacts": { "type": "array", "items": { "type": "string" } },
    "evidence_missing_artifacts": { "type": "array", "items": { "type": "string" } },
    "evidence_extra_paths": { "type": "array", "items": { "type": "string" } },
    "decision": { "enum": ["PASS", "REFUSE", "UNVERIFIABLE"] },
    "reason": {
      "enum": [
        "pass",
        "artifact_missing",
        "artifact_malformed",
        "artifact_subthreshold",
        "evidence_artifact_mismatch",
        "required_artifacts_section_missing",
        "dispatch_parse_error",
        "callback_malformed"
      ]
    },
    "exit_code": { "enum": [0, 1, 2] },
    "fix_bead_id": { "type": ["string", "null"] },
    "ledger_path": { "type": "string", "minLength": 1 },
    "warnings": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "artifact_status": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "path",
        "type",
        "expected_shape",
        "resolved_path",
        "exists",
        "bytes",
        "min_bytes",
        "shape_ok",
        "shape_errors",
        "fulfilled"
      ],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "type": { "enum": ["script", "test", "schema", "markdown", "json", "file"] },
        "expected_shape": { "type": "string", "minLength": 1 },
        "resolved_path": { "type": "string", "minLength": 1 },
        "exists": { "type": "boolean" },
        "bytes": { "type": "integer", "minimum": 0 },
        "min_bytes": { "type": "integer", "minimum": 0 },
        "shape_ok": { "type": "boolean" },
        "shape_errors": { "type": "array", "items": { "type": "string" } },
        "fulfilled": { "type": "boolean" }
      }
    }
  }
}
