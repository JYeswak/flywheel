		<key>HOME</key>
		<string>/Users/josh</string>
		<key>PATH</key>
		<string>/Users/josh/.cargo/bin:/Users/josh/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
	</dict>
</dict>
</plist>
