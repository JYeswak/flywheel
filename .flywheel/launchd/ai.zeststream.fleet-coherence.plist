	<true/>
	<key>StandardOutPath</key>
	<string>/Users/josh/.local/logs/fleet-coherence-launchd.out.log</string>
	<key>StandardErrorPath</key>
	<string>/Users/josh/.local/logs/fleet-coherence-launchd.err.log</string>
