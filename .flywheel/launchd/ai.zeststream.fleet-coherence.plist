<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.zeststream.flywheel.fleet-coherence</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>-lc</string>
		<string>exec /Users/josh/Developer/flywheel/.flywheel/scripts/fleet-coherence-launchd.sh run --json</string>
	</array>
	<key>StartInterval</key>
	<integer>60</integer>
