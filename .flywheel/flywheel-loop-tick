callback_validation_summary() {
  local summary
  summary="$(jq -c '
    def result: (.result // {});
    def receipt: (result.validation_receipt // {});
    def chain: (receipt.chain_blocker // {});
    {
      action:(.action // "missing"),
      task_id:(.task_id // null),
      status:(result.status // "none"),
      validator_exit:(.validator_exit // null),
      receipt_path:(result.receipt_path // null),
      failure_classes:(result.failure_classes // []),
      orch_callback_missing_l61_fields:(if ((result.failure_classes // []) | index("orch_callback_missing_l61_fields")) then 1 else 0 end),
      summary_allowed:(result.summary_allowed // false),
      integration_allowed:(result.integration_allowed // false),
      remediation_required:(result.remediation_required // false),
      remediation_present:(result.remediation_present // false),
      callbacks_unvalidated_count:(if (.action == "skipped" and .reason == "callback_not_found") then 1 else 0 end),
      pending_callback_count:(if (.action == "skipped" and .reason == "callback_not_found") then 1 else 0 end),
      unknown_count:(if (result.status == "unknown") then 1 else 0 end),
      failed_count:(if (result.status == "fail") then 1 else 0 end),
      passed_count:(if (result.status == "pass") then 1 else 0 end),
      next_phase:(chain.next_phase // null),
      chain_blocked_reason:(chain.chain_blocked_reason // null)
    }' <<<"${CALLBACK_VALIDATION_RESULT:-{}}" 2>/dev/null | tail -n 1 || true)"
  if jq -e . >/dev/null 2>&1 <<<"$summary"; then
    printf '%s\n' "$summary"
  else
    jq -nc '{action:"missing",status:"none",callbacks_unvalidated_count:0,pending_callback_count:0,unknown_count:0,failed_count:0,passed_count:0,integration_allowed:false}'
  fi
}

validation_fix_bead_plan() {
  local status task_id receipt_path helper output exit_code
  status="$(callback_validation_status)"
  task_id="$(callback_validation_task_id)"
  receipt_path="$(jq -r '.result.receipt_path // empty' <<<"${CALLBACK_VALIDATION_RESULT:-{}}" 2>/dev/null | tail -n 1 || true)"
  helper="$REPO/.flywheel/scripts/validation-fix-bead.py"
  if [[ "$status" == "pass" || "$status" == "none" ]]; then
    jq -nc --arg status "$status" '{action:"skipped",reason:"validation_not_failed",validation_status:$status}'
    return 0
  fi
  if [[ -z "$receipt_path" || "$receipt_path" == "null" ]]; then
    jq -nc --arg status "$status" '{action:"skipped",reason:"missing_receipt_path",validation_status:$status}'
    return 0
  fi
  if [[ ! -x "$helper" ]]; then
    jq -nc --arg helper "$helper" '{action:"skipped",reason:"helper_missing",helper:$helper}'
    return 0
  fi
  set +e
  if [[ "$status" == "unknown" ]]; then
    output="$("$helper" --repo "$REPO" --receipt "$receipt_path" --parent "$task_id" --dry-run --no-bead-reason "runtime validation unknown; explicit review required before integration" --json 2>&1)"
  else
    output="$("$helper" --repo "$REPO" --receipt "$receipt_path" --parent "$task_id" --dry-run --json 2>&1)"
  fi
  exit_code=$?
  set -e
  if jq -e . >/dev/null 2>&1 <<<"$output"; then
    jq -nc --argjson exit_code "$exit_code" --argjson result "$output" '{action:"planned",helper_exit:$exit_code,result:$result}'
  else
    jq -nc --argjson exit_code "$exit_code" --arg raw "$output" '{action:"error",helper_exit:$exit_code,raw:$raw}'
  fi
}

validated_integration_phase() {
  local status task_id remediation_present
  status="$(callback_validation_status)"
  task_id="$(callback_validation_task_id)"
  remediation_present="$(jq -r '.result.remediation_present // false' <<<"${CALLBACK_VALIDATION_RESULT:-{}}" 2>/dev/null || printf false)"
  case "$status" in
    pass)
      emit_phase "INTEGRATE" "callback_validation_pass:${task_id}"
      return 0 ;;
    fail)
      if [[ "$remediation_present" == "true" ]]; then
        emit_phase "VALIDATE" "callback_validation_fail_remediated:${task_id}"
      else
        emit_phase "VALIDATE" "callback_validation_fail_unremediated:${task_id}"
      fi
      return 0 ;;
    unknown)
      emit_phase "VALIDATE" "callback_validation_unknown:${task_id}"
      return 0 ;;
    *)
      if [[ "$(jq -r '.action // empty' <<<"${CALLBACK_VALIDATION_RESULT:-{}}" 2>/dev/null | tail -n 1)" == "skipped" \
        && "$(jq -r '.reason // empty' <<<"${CALLBACK_VALIDATION_RESULT:-{}}" 2>/dev/null | tail -n 1)" == "callback_not_found" ]]; then
        emit_phase "VALIDATE" "callback_pending_unvalidated:${task_id}"
        return 0
      fi
      emit_phase "VALIDATE" "callback_validation_missing:${task_id}"
      return 0 ;;
  esac
}

