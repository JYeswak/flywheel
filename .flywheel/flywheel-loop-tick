json_or_raw() {
  local raw="${1:-}"
  if jq -e . >/dev/null 2>&1 <<<"$raw"; then
    printf '%s\n' "$raw"
  else
    jq -nc --arg raw "$raw" '{action:"error",raw:$raw}'
  fi
}

codex_watchtower_probe() {
  local summary doctor frozen high_count strike_count candidate promotion_result desc create_out existing
  summary="$("$HOME/.local/bin/codex-watchtower-daily.sh" --summary --json 2>&1 || printf '{"status":"UNKNOWN_UNHEALTHY","warnings":["summary_probe_failed"]}')"
  summary="$(json_or_raw "$summary")"
  doctor="$("$HOME/.claude/skills/codex-cli-tracker/scripts/codex-tracker-probe.sh" --doctor --json 2>&1 || printf '{"success":false,"warnings":["tracker_doctor_failed"]}')"
  doctor="$(json_or_raw "$doctor")"
  frozen="$("$REPO/.flywheel/scripts/frozen-pane-detector.sh" --session=all --json 2>&1 || printf '{"success":false,"warnings":["frozen_pane_probe_failed"]}')"
  frozen="$(json_or_raw "$frozen")"
  high_count="$(jq '(.codex_relevant_issues // []) | length' <<<"$summary" 2>/dev/null || printf '0')"
  strike_count="$(jq '[.. | objects | (.strike_count_7d? // .strikes_7d? // .strike_count? // empty)] | map(select(type == "number")) | max // 0' <<<"$frozen" 2>/dev/null || printf '0')"
  candidate=false
  promotion_result="$(jq -nc '{action:"skipped",reason:"threshold_not_met"}')"
  if [[ "$high_count" =~ ^[0-9]+$ && "$strike_count" =~ ^[0-9]+$ && "$high_count" -gt 0 && "$strike_count" -ge 3 ]]; then
    candidate=true
    if [[ "$DRY_RUN" == "1" ]]; then
      promotion_result="$(jq -nc '{action:"skipped",reason:"dry_run"}')"
    else
      existing="$(cd "$REPO" && br list --json 2>/dev/null | jq '[.[]? | select((.title // "") == "[codex-watchtower] upstream high-relevance Codex issue strike triage")] | length' 2>/dev/null || printf '0')"
      if [[ "$existing" =~ ^[0-9]+$ && "$existing" -gt 0 ]]; then
        promotion_result="$(jq -nc '{action:"skipped",reason:"existing_bead"}')"
      elif command -v br >/dev/null 2>&1; then
        desc="$(printf 'Auto-filed by /flywheel:tick Step 4t codex-watchtower-probe.\n\nTrigger: HIGH-relevance Codex upstream issue count >0 and frozen-pane strike count >=3.\nParent: flywheel-ezyf.\nAcceptance gates:\n- Re-run codex-watchtower-daily.sh --summary --json and record relevant issue IDs.\n- Re-run frozen-pane-detector.sh --session=all --json and record strike count.\n- Decide whether to append an upstream candidate row to codex-cli-tracker/references/UPSTREAM-COMMENTS.md.\n- Close with no public post unless Joshua approved upstream coordination.\n')"
        if create_out="$(cd "$REPO" && br create "[codex-watchtower] upstream high-relevance Codex issue strike triage" --priority P1 --type task --parent flywheel-ezyf --description "$desc" --json 2>&1)"; then
          promotion_result="$(json_or_raw "$create_out")"
        else
          promotion_result="$(jq -nc --arg raw "$create_out" '{action:"error",raw:$raw}')"
        fi
      else
        promotion_result="$(jq -nc '{action:"error",reason:"br_missing"}')"
      fi
    fi
  fi
  jq -nc \
    --arg action "checked" \
    --argjson summary "$summary" \
    --argjson doctor "$doctor" \
    --argjson frozen_pane "$frozen" \
    --argjson high_count "$high_count" \
    --argjson frozen_strike_count "$strike_count" \
    --argjson auto_bead_candidate "$candidate" \
    --argjson promotion "$promotion_result" \
    '{action:$action, summary:$summary, doctor:$doctor, frozen_pane:$frozen_pane, high_relevance_count:$high_count, frozen_strike_count:$frozen_strike_count, auto_bead_candidate:$auto_bead_candidate, promotion:$promotion}'
}

frozen_detector_probe() {
  local output exit_code
  set +e
  output="$("$REPO/.flywheel/scripts/frozen-pane-detector.sh" --session=all --json 2>&1)"
  exit_code=$?
  set -e
  if jq -e . >/dev/null 2>&1 <<<"$output"; then
    jq -c --argjson exit_code "$exit_code" 'if type == "object" then . + {probe_exit_code:$exit_code} else . end' <<<"$output"
  else
    jq -nc --arg raw "$output" --argjson exit_code "$exit_code" '{success:false,status:"error",source_health:{status:"unhealthy"},probe_exit_code:$exit_code,warnings:["invalid_frozen_detector_json"],raw:$raw}'
  fi
}

sanitize_frozen_detector_json() {
  local raw="${1:-}" trimmed
  if jq -c . >/dev/null 2>&1 <<<"$raw"; then
    jq -c . <<<"$raw"
    return 0
  fi
  trimmed="${raw%?}"
  if [[ "$raw" == *'}' ]] && jq -c . >/dev/null 2>&1 <<<"$trimmed"; then
    jq -c . <<<"$trimmed"
    return 0
  fi
  jq -nc --arg raw "$raw" '{success:false,status:"error",source_health:{status:"unhealthy"},warnings:["invalid_frozen_detector_json"],raw:$raw}'
}

frozen_detector_summary() {
  local summary detector_source="${1:-${FROZEN_DETECTOR_RESULT:-{}}}"
  summary="$(python3 -c '
import json, sys
try:
    raw = sys.stdin.read()
    data = None
    candidates = [raw, raw.rstrip()]
    trimmed = raw.rstrip()
    for _ in range(4):
        if trimmed.endswith("}"):
            trimmed = trimmed[:-1]
            candidates.append(trimmed)
    for candidate in candidates:
        try:
            data = json.loads(candidate)
            break
        except Exception:
            pass
    if data is None:
        raise ValueError("invalid detector json")
    d = data.get("frozen_pane", data) if isinstance(data, dict) else {}
    signals = d.get("l60_signals_present") or {}
    keys = ["no_silent_darkness", "live_truth_delta", "unknown_separated", "recovery_budget", "recovery_lease"]
    missing = [k for k in keys if signals.get(k) is not True]
    print(json.dumps({
        "schema_version": d.get("schema_version"),
        "success": d.get("success", False),
        "source_health_status": (d.get("source_health") or {}).get("status"),
        "frozen_panes_detected": d.get("frozen_panes_detected", 0),
        "unknown_panes_detected": d.get("unknown_panes_detected", 0),
        "stale_template_prompt_count": d.get("template_stub_prompt_count", 0),
        "queued_not_submitted_count": d.get("queued_not_submitted_count", 0),
        "respawn_suppressed_count": d.get("respawn_suppressed_count", 0),
        "recovery_suppressed_count": d.get("recovery_suppressed_count", 0),
        "frozen_panes_respawned": d.get("frozen_panes_respawned", 0),
        "frozen_panes_relaunched": d.get("frozen_panes_relaunched", 0),
        "silent_dark_minutes": d.get("silent_dark_minutes", 0),
        "blackout_detection_latency_p95": d.get("blackout_detection_latency_p95", 0),
        "false_recovery_count": d.get("false_recovery_count", 0),
        "unknown_auto_recovery_count": d.get("unknown_auto_recovery_count", 0),
        "l60_signals_present": signals,
        "l60_signal_expected_count": len(keys),
        "l60_signal_present_count": len([k for k in keys if signals.get(k) is True]),
        "l60_signal_missing": missing,
        "l60_all_present": len(missing) == 0,
        "soft_violations": d.get("soft_violations") or [],
        "durable_receipts": d.get("durable_receipts") or [],
    }, separators=(",", ":")))
except Exception:
    sys.exit(1)
' <<<"$detector_source")" || summary=""
  if jq -e . >/dev/null 2>&1 <<<"$summary"; then
    printf '%s\n' "$summary"
  else
    jq -nc '{success:false,source_health_status:"invalid",frozen_panes_detected:0,unknown_panes_detected:1,stale_template_prompt_count:0,queued_not_submitted_count:0,respawn_suppressed_count:0,recovery_suppressed_count:0,l60_signals_present:{},l60_signal_expected_count:5,l60_signal_present_count:0,l60_signal_missing:["no_silent_darkness","live_truth_delta","unknown_separated","recovery_budget","recovery_lease"],l60_all_present:false,soft_violations:[],durable_receipts:[]}'
  fi
}

frozen_detector_block_reason() {
  local summary="${1:-}" override="${FROZEN_DETECTOR_OVERRIDE:-0}"
  if [[ "$override" == "1" || "$override" == "true" ]]; then
    printf 'none\n'
    return 0
  fi
  jq -r '
    if (.success != true) then "frozen_detector_unhealthy"
    elif ((.source_health_status // "") != "healthy") then "frozen_detector_source_unhealthy"
    elif ((.frozen_panes_detected // 0) > 0) then "frozen_panes_detected"
    elif ((.unknown_panes_detected // 0) > 0) then "unknown_panes_detected"
    elif (.l60_all_present != true) then "l60_signals_missing"
    else "none" end
  ' <<<"$summary" 2>/dev/null || printf 'frozen_detector_invalid\n'
}

