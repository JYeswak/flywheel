fleet_onboard_probe() {
  local roster tmp repo output exit_code
  roster="${FLYWHEEL_FLEET_ROSTER:-$HOME/.local/state/flywheel/fleet-roster.json}"
  tmp="$(mktemp "${TMPDIR:-/tmp}/fleet-onboard.XXXXXX")"
  if [[ -f "$roster" ]]; then
    jq -r '
      if type == "array" then .[]? | (.repo // .path // empty)
      elif (.repos? | type == "array") then .repos[]? | (.repo // .path // empty)
      else empty end
    ' "$roster" 2>/dev/null | sort -u | while IFS= read -r repo; do
      [[ -n "$repo" ]] || continue
      set +e
      output="$("$REPO/.flywheel/scripts/flywheel-onboard.sh" --repo "$repo" --dry-run --doctor --json 2>&1)"
      exit_code=$?
      set -e
      if jq -e . >/dev/null 2>&1 <<<"$output"; then
        jq -c --argjson exit_code "$exit_code" '. + {probe_exit_code:$exit_code}' <<<"$output" >>"$tmp"
      else
        jq -nc --arg repo "$repo" --arg raw "$output" --argjson exit_code "$exit_code" '{repo:$repo,status:"UNKNOWN",success:false,probe_exit_code:$exit_code,warnings:["invalid_onboard_json"],raw:$raw}' >>"$tmp"
      fi
    done
  fi
  jq -s --arg roster "$roster" '{
    action:"checked",
    roster:$roster,
    checked_repos:length,
    rows:.,
    status:(if length == 0 then "UNKNOWN" elif any(.[]; (.status // "") != "HEALTHY") then "PARTIAL" else "HEALTHY" end),
    limping_repos:[.[] | select((.status // "") == "LIMPING") | (.repo // .project // "unknown")],
    missing_repos:[.[] | select((.status // "") == "MISSING") | (.repo // .project // "unknown")],
    warnings:([.[] | .warnings[]?] + if length == 0 then ["fleet_roster_empty_or_missing"] else [] end)
  }' "$tmp"
  rm -f "$tmp"
}

valid_phase() {
  case "${1:-}" in
    INIT|RESEARCH|PLAN|BEADS|DISPATCH|VALIDATE|INTEGRATE|LEARN) return 0 ;;
    *) return 1 ;;
  esac
}

tick_class_for_phase() {
  case "${1:-}" in
    INIT|VALIDATE) printf 'validation\n' ;;
    RESEARCH|PLAN) printf 'architecture_decision\n' ;;
    BEADS|LEARN) printf 'planning\n' ;;
    DISPATCH|INTEGRATE) printf 'dispatch_reap\n' ;;
    *) printf 'planning\n' ;;
  esac
}

emit_phase() {
  local phase="$1" reason="$2"
  printf '%s\n' "$reason" >"$STATE_DIR/phase_reason.txt"
  printf '%s\n' "$phase"
}

first_existing_dir() {
  local path
  for path in "$@"; do
    [[ -d "$path" ]] && { printf '%s\n' "$path"; return 0; }
  done
  return 1
}

dir_has_files() {
  local dir="${1:-}"
  [[ -n "$dir" && -d "$dir" ]] || return 1
  find "$dir" -maxdepth 3 -type f 2>/dev/null | head -1 | grep -q .
}

latest_mtime() {
  local dir="${1:-}" pattern="${2:-*}"
  [[ -n "$dir" && -d "$dir" ]] || { printf '0\n'; return 0; }
  find "$dir" -type f -name "$pattern" -exec stat -f '%m' {} + 2>/dev/null | sort -nr | head -n 1 | grep -E '^[0-9]+$' || printf '0\n'
}

jsonl_open_bead_count() {
  local issues="$REPO/.beads/issues.jsonl"
  [[ -f "$issues" ]] || { printf '0\n'; return 0; }
  jq -s '[.[]? | select((.status // "open") != "closed")] | length' "$issues" 2>/dev/null || printf '0\n'
}

jsonl_total_bead_count() {
  local issues="$REPO/.beads/issues.jsonl"
  [[ -f "$issues" ]] || { printf '0\n'; return 0; }
  jq -s 'length' "$issues" 2>/dev/null || wc -l <"$issues" | tr -d ' '
}

br_ready_count() {
  local out
  command -v br >/dev/null 2>&1 || return 1
  out="$(cd "$REPO" && br ready --json 2>/dev/null)" || return 1
  jq 'if type=="array" then length else (.issues // [] | length) end' 2>/dev/null <<<"$out" || return 1
}

capacity_available() {
  jq -e '(.panes // []) | any((.gate.verdict // "") | test("^(ready|idle|available|ok)$"; "i"))' >/dev/null 2>&1 <<<"${1:-{}}"
}

unprocessed_fuckup_count() {
  local log="${FLYWHEEL_FUCKUP_LOG:-$HOME/.local/state/flywheel/fuckup-log.jsonl}"
  [[ -f "$log" ]] || { printf '0\n'; return 0; }
  jq -s '[.[]? | select((.processed_at // .promoted_at // .resolved_at // "") == "")] | length' "$log" 2>/dev/null || printf '0\n'
}

latest_callback_next_phase() {
  local last_task_id tail_file latest_callback next_phase
  [[ -f "$LAST" ]] || return 1
  last_task_id="$(jq -r '.task_id // empty' "$LAST" 2>/dev/null || true)"
  [[ -n "$last_task_id" ]] || return 1
  command -v "$NTM" >/dev/null 2>&1 || return 1
  tail_file="$STATE_DIR/pane-${TARGET_PANE}-tail.txt"
  "$NTM" copy "$SESSION:$TARGET_PANE" -l 320 --output "$tail_file" --quiet 2>/dev/null || true
  latest_callback="$(
    grep -E "Callback: task_id=${last_task_id}[[:space:]]" "$tail_file" 2>/dev/null \
      | tail -n 1 \
      || true
  )"
  [[ -n "$latest_callback" ]] || return 1
  next_phase="$(sed -n 's/.*next_phase=\([A-Z_]*\).*/\1/p' <<<"$latest_callback")"
  valid_phase "$next_phase" || return 1
  printf '%s\n' "callback_next_phase:${next_phase}" >"$STATE_DIR/phase_reason.txt"
  printf '%s\n' "$next_phase"
}

detect_phase() {
  local fw="$REPO/.flywheel" phase ready_count open_jsonl total_beads plans_dir research_dir docs_dir
  local latest_research_mtime latest_plan_mtime in_flight

  PHASE_REASON="default"

  if [[ -f "$fw/next_tick_override.json" ]]; then
    phase="$(jq -r '.phase // .next_phase // empty' "$fw/next_tick_override.json" 2>/dev/null || true)"
    if valid_phase "$phase"; then
      emit_phase "$phase" "next_tick_override"
      return 0
    fi
  fi

  phase="$(latest_callback_next_phase || true)"
  if valid_phase "$phase"; then
    printf '%s\n' "$phase"
    return 0
  fi

  for f in MISSION.md GOAL.md STATE.md; do
    [[ -f "$fw/$f" ]] || { emit_phase "INIT" "missing_flywheel_doc:$f"; return 0; }
    grep -qE '^status:[[:space:]]*(locked|ready)' "$fw/$f" || { emit_phase "INIT" "unlocked_flywheel_doc:$f"; return 0; }
  done

  if [[ -f "$LOG" ]]; then
    in_flight="$(jq -s '[.[]? | select((((.callback_status // "") | test("^(dispatched|pending|overdue|partial)$")) or (((.event // "") | test("ntm_dispatch_sent|tick_dispatch|dispatch_sent")) and (.callback_received_at // null) == null and ((.dispatch_status // "") != "dry_run"))))] | length' "$LOG" 2>/dev/null || echo 0)"
    if [[ "${in_flight:-0}" -gt 0 ]]; then
      validated_integration_phase
      return 0
    fi
  fi

  if ready_count="$(br_ready_count)"; then
    if [[ "${ready_count:-0}" -gt 0 ]]; then
      emit_phase "DISPATCH" "br_ready:${ready_count}"
      return 0
    fi
  else
    PHASE_REASON="br_unavailable_jsonl_fallback"
  fi

  open_jsonl="$(jsonl_open_bead_count)"
  if [[ "${open_jsonl:-0}" -gt 0 ]]; then
    emit_phase "DISPATCH" "jsonl_open_beads:${open_jsonl}"
    return 0
  fi

  plans_dir="$(first_existing_dir "$fw/plans" "$fw/PLANS" || true)"
  research_dir="$(first_existing_dir "$fw/research" "$fw/RESEARCH" || true)"
  docs_dir="$(first_existing_dir "$REPO/docs" "$REPO/doc" || true)"
  latest_research_mtime="$(latest_mtime "$research_dir" '*.md')"
  latest_plan_mtime="$(latest_mtime "$plans_dir" '*.md')"
  if [[ "${latest_research_mtime:-0}" -gt "${latest_plan_mtime:-0}" ]]; then
    emit_phase "PLAN" "research_newer_than_plan"
    return 0
  fi

  total_beads="$(jsonl_total_bead_count)"
  if [[ "${total_beads:-0}" -eq 0 ]] && { dir_has_files "$plans_dir" || dir_has_files "$docs_dir"; }; then
    emit_phase "BEADS" "plan_or_docs_without_beads"
    return 0
  fi

  if [[ "${open_jsonl:-0}" -eq 0 && "${total_beads:-0}" -gt 0 ]] && dir_has_files "$plans_dir"; then
    emit_phase "BEADS" "all_closed_with_plan"
    return 0
  fi

  if { dir_has_files "$research_dir" || dir_has_files "$docs_dir"; } && ! dir_has_files "$plans_dir"; then
    emit_phase "PLAN" "research_or_docs_without_plan"
    return 0
  fi

  if [[ "$PHASE_REASON" == "br_unavailable_jsonl_fallback" ]]; then
    emit_phase "LEARN" "br_unavailable_no_jsonl_state"
    return 0
  fi

  emit_phase "RESEARCH" "greenfield_or_stale_context"
}

dispatch_capacity_snapshot() {
  local panes="${DISPATCH_CAPACITY_PANES:-2 3 4}" pane gate_output gate_exit gate_json tmp
  tmp="$(mktemp "${TMPDIR:-/tmp}/dispatch-capacity.XXXXXX")"

  for pane in $panes; do
    set +e
    gate_output="$(bash "$REPO/.flywheel/scripts/dispatch-capacity-gate.sh" "$SESSION" "$pane" 2>&1)"
    gate_exit=$?
    set -e

    if jq -e . >/dev/null 2>&1 <<<"$gate_output"; then
      gate_json="$gate_output"
    else
      gate_json="$(jq -nc --arg raw "$gate_output" '{verdict:"error",reason:"invalid_gate_json",raw:$raw}')"
    fi

    jq -nc \
      --arg pane "$pane" \
      --argjson exit_code "$gate_exit" \
      --argjson gate "$gate_json" \
      '{pane:($pane|tonumber? // $pane),exit_code:$exit_code,gate:$gate}' >>"$tmp"
  done

  jq -s --arg session "$SESSION" '{session:$session,panes:.}' "$tmp"
  rm -f "$tmp"
}

l70_chain_decision_json() {
  local phase="$1" reason="$2" capacity_json="$3" source="none" from_phase="" to_phase="" chain_required=false chained=false blocked_reason=""
  case "$reason" in
    callback_next_phase:*)
      source="worker_callback"
      to_phase="${reason#callback_next_phase:}"
      chain_required=true
      chained=true
      ;;
    plan_or_docs_without_beads|all_closed_with_plan)
      source="dispatch_no_ready_plan_artifacts"
      from_phase="DISPATCH"
      to_phase="BEADS"
      chain_required=true
      chained=true
      ;;
    in_flight_dispatch)
      if [[ "$(unprocessed_fuckup_count)" -gt 0 ]]; then
        source="integrate_unprocessed_fuckups"
        from_phase="INTEGRATE"
        to_phase="LEARN"
        chain_required=true
        if [[ "$phase" == "LEARN" ]]; then
          chained=true
        elif capacity_available "$capacity_json"; then
          blocked_reason=""
        else
          blocked_reason="capacity_exhausted"
        fi
      fi
      ;;
  esac
  jq -nc \
    --arg source "$source" \
    --arg from_phase "$from_phase" \
    --arg to_phase "$to_phase" \
    --arg selected_phase "$phase" \
    --arg phase_reason "$reason" \
    --arg chain_blocked_reason "$blocked_reason" \
    --argjson chain_required "$chain_required" \
    --argjson chained "$chained" \
    '{source:$source,from_phase:(if $from_phase=="" then null else $from_phase end),to_phase:(if $to_phase=="" then null else $to_phase end),selected_phase:$selected_phase,phase_reason:$phase_reason,chain_required:$chain_required,chained:$chained,chain_blocked_reason:(if $chain_blocked_reason=="" then null else $chain_blocked_reason end)}'
}

callback_validation_reaper_gate() {
  local last_task_id tail_file latest_callback task_description validation_output validation_exit validation_json
  if [[ ! -f "$LAST" ]]; then
    jq -nc '{action:"skipped",reason:"missing_last_run"}'
    return 0
  fi
  last_task_id="$(jq -r '.task_id // empty' "$LAST" 2>/dev/null || true)"
  if [[ -z "$last_task_id" ]]; then
    jq -nc '{action:"skipped",reason:"missing_task_id"}'
    return 0
  fi
  command -v "$NTM" >/dev/null 2>&1 || {
    jq -nc '{action:"skipped",reason:"ntm_unavailable"}'
    return 0
  }
  tail_file="$STATE_DIR/pane-${TARGET_PANE}-validation-tail.txt"
  "$NTM" copy "$SESSION:$TARGET_PANE" -l 360 --output "$tail_file" --quiet 2>/dev/null || true
  latest_callback="$(
    grep -E "(Callback: task_id=${last_task_id}[[:space:]]|DONE .*${last_task_id}|BLOCKED .*${last_task_id}|TIMEOUT .*${last_task_id})" "$tail_file" 2>/dev/null \
      | tail -n 1 \
      || true
  )"
  if [[ -z "$latest_callback" ]]; then
    jq -nc --arg task_id "$last_task_id" '{action:"skipped",reason:"callback_not_found",task_id:$task_id}'
    return 0
  fi
  task_description="$(dispatch_task_description "$last_task_id")"
  set +e
  validation_output="$("$HOME/.claude/skills/.flywheel/bin/flywheel-loop" validate-callback \
    --repo "$REPO" \
    --dispatch-id "$last_task_id" \
    --task-description "$task_description" \
    --callback-ref "$latest_callback" \
    --write-receipt \
    --json 2>&1)"
  validation_exit=$?
  set -e
  if jq -e . >/dev/null 2>&1 <<<"$validation_output"; then
    validation_json="$validation_output"
  else
    validation_json="$(jq -nc --arg raw "$validation_output" '{status:"fail",failure_classes:["validator_output_invalid"],raw:$raw}')"
  fi
  jq -nc \
    --arg task_id "$last_task_id" \
    --arg callback_sha256 "$(printf '%s' "$latest_callback" | shasum -a 256 | awk '{print $1}')" \
    --argjson validation_exit "$validation_exit" \
    --argjson result "$validation_json" \
    '{action:"validated",task_id:$task_id,callback_sha256:$callback_sha256,validator_exit:$validation_exit,result:$result}'
}

dispatch_task_description() {
  local task_id="$1" row task_file summary
  [[ -f "$LOG" ]] || return 0
  row="$(jq -c --arg id "$task_id" 'select((.task_id // "") == $id)' "$LOG" 2>/dev/null | tail -n 1 || true)"
  [[ -n "$row" ]] || return 0
  summary="$(jq -r '.task_summary // .bead_title // .title // empty' <<<"$row" 2>/dev/null || true)"
  task_file="$(jq -r '.task_file // empty' <<<"$row" 2>/dev/null || true)"
  [[ -n "$summary" && "$summary" != "null" ]] && printf '%s\n' "$summary"
  if [[ -n "$task_file" && "$task_file" != "null" && -f "$task_file" ]]; then
    head -c 40000 "$task_file" 2>/dev/null || true
  fi
}

