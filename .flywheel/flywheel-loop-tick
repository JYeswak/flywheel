      respawn_suppressed_count:($d.respawn_suppressed_count // 0),
      recovery_suppressed_count:($d.recovery_suppressed_count // 0),
      frozen_panes_respawned:($d.frozen_panes_respawned // 0),
      frozen_panes_relaunched:($d.frozen_panes_relaunched // 0),
      silent_dark_minutes:($d.silent_dark_minutes // 0),
      blackout_detection_latency_p95:($d.blackout_detection_latency_p95 // 0),
      false_recovery_count:($d.false_recovery_count // 0),
