      "name": "cli-registry-emit.sh",
      "path": ".flywheel/scripts/cli-registry-emit.sh",
      "lane": "cli-registry",
      "owner": "flywheel",
      "schema_id": "flywheel-cli-registry.emit/v1",
      "summary": "Emit canonical help, info, examples, and schema text from .flywheel/cli-registry.json.",
      "usage": "cli-registry-emit.sh SCRIPT [--mode help|info|examples|schema] [--registry PATH] [--json]",
      "args": [
        {"flag": "SCRIPT", "value_hint": "", "desc": "Registered script name, path, or basename.", "required": true},
        {"flag": "--mode", "value_hint": "MODE", "desc": "One of help, info, examples, or schema. Defaults to help.", "required": false},
        {"flag": "--registry", "value_hint": "PATH", "desc": "Override registry path.", "required": false},
        {"flag": "--json", "value_hint": "", "desc": "Emit machine-readable info or examples where supported.", "required": false},
        {"flag": "-h, --help", "value_hint": "", "desc": "Emit bootstrap helper usage.", "required": false}
      ],
      "examples": [
        {"name": "tmp_prune_help", "command": "cli-registry-emit.sh tmp-prune.sh --mode help"},
        {"name": "tmp_prune_info_json", "command": "cli-registry-emit.sh tmp-prune.sh --mode info --json"},
        {"name": "registry_schema", "command": "cli-registry-emit.sh tmp-prune.sh --mode schema"}
      ],
      "output_formats": ["text", "json"],
      "exit_codes": {"0": "emitted", "1": "surface not registered", "2": "usage error", "3": "registry read error", "69": "jq missing"},
      "notes": [
        "This helper is the bootstrap consumer for registry-backed CLI help.",
        "Scripts can call it for --help while retaining a local fallback for older template copies."
      ]
    },
    {
      "name": "tmp-prune.sh",
      "path": ".flywheel/scripts/tmp-prune.sh",
      "lane": "storage",
      "owner": "flywheel",
      "schema_id": "tmp-prune/v1",
      "summary": "Prune allowlisted stale fleet scratch directories under a selected temporary root.",
      "usage": "tmp-prune.sh [--root PATH] [--days N] [--dry-run|--apply --idempotency-key KEY] [--json]",
      "args": [
        {"flag": "--root", "value_hint": "PATH", "desc": "Temporary root to scan. Allowed roots are /private/tmp, /tmp, and /var/folders descendants.", "required": false},
        {"flag": "--days", "value_hint": "N", "desc": "Minimum age in mtime days. Defaults to FLYWHEEL_TMP_PRUNE_DAYS or 1.", "required": false},
        {"flag": "--dry-run", "value_hint": "", "desc": "Plan only. This is the default mode.", "required": false},
        {"flag": "--apply", "value_hint": "", "desc": "Delete allowlisted candidates after requiring --idempotency-key.", "required": false},
        {"flag": "--idempotency-key", "value_hint": "KEY", "desc": "Required with --apply; recorded in the receipt.", "required": false},
        {"flag": "--json", "value_hint": "", "desc": "Emit the receipt JSON to stdout.", "required": false},
        {"flag": "-h, --help", "value_hint": "", "desc": "Emit help from .flywheel/cli-registry.json.", "required": false}
      ],
      "examples": [
        {"name": "dry_run_json", "command": "tmp-prune.sh --root /private/tmp --days 1 --dry-run --json"},
        {"name": "apply_with_key", "command": "tmp-prune.sh --root /private/tmp --days 7 --apply --idempotency-key weekly-prune --json"},
        {"name": "fixture_root", "command": "FLYWHEEL_TMP_PRUNE_RECEIPT_DIR=/tmp/receipts tmp-prune.sh --root /tmp/fixture --dry-run --json"}
      ],
      "output_formats": ["text", "json"],
      "exit_codes": {"0": "success", "2": "usage error", "3": "candidate escaped allowlist guard"},
      "notes": [
        "Default is dry-run.",
        "Candidates are limited to explicit fleet scratch prefixes under the selected tmp root.",
        "Forbidden prefixes such as com.apple.* and launchd-* are counted but never pruned."
      ]
    },
