{
  "schema_version": "secret-pattern-corpus/v1",
  "synthetic_only": true,
  "redaction_policy": {
    "emit_values": false,
    "emit_fragments": false,
    "allowed_outputs": [
      "class",
      "count",
      "path",
      "line",
      "field_path",
      "redaction_label"
    ]
  },
  "patterns": [
    {
      "id": "aws_access_key_id_canary",
      "class": "aws_access_key_id",
      "severity": "critical",
      "regex": "CANARY_TEST_AKIA[A-Z0-9]{16}",
      "description": "Synthetic AWS access key id canary."
    },
    {
      "id": "aws_secret_access_key_canary",
      "class": "aws_secret_access_key",
      "severity": "critical",
      "regex": "CANARY_TEST_AWS_SECRET_[A-Za-z0-9/+=]{32,}",
      "description": "Synthetic AWS secret access key canary."
    },
    {
      "id": "github_pat_canary",
      "class": "github_pat",
      "severity": "critical",
      "regex": "CANARY_TEST_GITHUB_PAT_[A-Za-z0-9_]{24,}",
      "description": "Synthetic GitHub personal access token canary."
    },
    {
      "id": "openai_api_key_canary",
      "class": "openai_api_key",
      "severity": "high",
      "regex": "CANARY_TEST_OPENAI_SK_[A-Za-z0-9_-]{24,}",
      "description": "Synthetic OpenAI API key canary."
    },
    {
      "id": "anthropic_api_key_canary",
      "class": "anthropic_api_key",
      "severity": "high",
      "regex": "CANARY_TEST_ANTHROPIC_SK_[A-Za-z0-9_-]{24,}",
      "description": "Synthetic Anthropic API key canary."
    },
    {
      "id": "bearer_token_canary",
      "class": "bearer_token",
      "severity": "high",
      "regex": "CANARY_TEST_BEARER_[A-Za-z0-9._-]{24,}",
      "description": "Synthetic bearer token canary."
    },
    {
      "id": "agent_mail_registration_token_canary",
      "class": "agent_mail_registration_token",
      "severity": "high",
      "regex": "CANARY_TEST_AGENTMAIL_REG_[A-Za-z0-9_-]{24,}",
      "description": "Synthetic Agent Mail registration token canary."
    },
    {
      "id": "agent_mail_bearer_token_canary",
      "class": "agent_mail_bearer_token",
      "severity": "high",
      "regex": "CANARY_TEST_AGENTMAIL_BEARER_[A-Za-z0-9._-]{24,}",
      "description": "Synthetic Agent Mail bearer token canary."
    },
    {
      "id": "env_secret_canary",
      "class": "env_secret",
      "severity": "high",
      "regex": "CANARY_TEST_ENV_SECRET_[A-Za-z0-9_-]{24,}",
      "description": "Synthetic generic environment secret canary."
    },
    {
      "id": "stripe_secret_key_canary",
      "class": "stripe_secret_key",
      "severity": "critical",
      "regex": "CANARY_TEST_STRIPE_SK_[A-Za-z0-9_-]{24,}",
      "description": "Synthetic Stripe secret key canary."
    },
    {
      "id": "slack_bot_token_canary",
      "class": "slack_bot_token",
      "severity": "high",
      "regex": "CANARY_TEST_SLACK_XOXB_[A-Za-z0-9_-]{24,}",
      "description": "Synthetic Slack bot token canary."
    },
    {
      "id": "cloudflare_token_canary",
      "class": "cloudflare_token",
      "severity": "critical",
      "regex": "CANARY_TEST_CLOUDFLARE_[A-Za-z0-9_-]{24,}",
      "description": "Synthetic Cloudflare token canary."
    },
    {
      "id": "supabase_service_role_canary",
      "class": "supabase_service_role",
      "severity": "critical",
      "regex": "CANARY_TEST_SUPABASE_SERVICE_ROLE_[A-Za-z0-9_-]{24,}",
      "description": "Synthetic Supabase service-role canary."
    },
    {
      "id": "jwt_canary",
      "class": "jwt",
      "severity": "high",
      "regex": "CANARY_TEST_JWT_[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+",
      "description": "Synthetic JWT canary."
    },
    {
      "id": "private_key_pem_canary",
      "class": "private_key_pem",
      "severity": "critical",
      "regex": "-----BEGIN CANARY TEST PRIVATE KEY-----[\\s\\S]*?-----END CANARY TEST PRIVATE KEY-----",
      "description": "Synthetic private key PEM canary."
    },
    {
      "id": "database_url_canary",
      "class": "database_url",
      "severity": "critical",
      "regex": "CANARY_TEST_DATABASE_URL_[A-Za-z0-9_:@./-]{24,}",
      "description": "Synthetic database URL canary."
    },
    {
      "id": "npm_token_canary",
      "class": "npm_token",
      "severity": "high",
      "regex": "CANARY_TEST_NPM_TOKEN_[A-Za-z0-9_-]{24,}",
      "description": "Synthetic npm token canary."
    }
  ]
}
