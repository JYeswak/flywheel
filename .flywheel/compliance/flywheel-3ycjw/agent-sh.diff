+orphaned_mcp_tool_call_json() {
+    local probe="${FLYWHEEL_ORPHANED_MCP_TOOL_CALL_PROBE:-$HOME/Developer/flywheel/.flywheel/scripts/orphaned-mcp-tool-call-probe.py}" output timeout_bin probe_timeout
+    if [[ ! -x "$probe" ]]; then
+        jq -nc --arg probe "$probe" '{
+          schema_version:"orphaned-mcp-tool-call-doctor/v1",
+          status:"warn",
+          source:null,
+          checked_at:null,
+          orphaned_mcp_tool_call_count:0,
+          evidence_refs:[],
+          errors:[],
+          warnings:[{code:"orphaned_mcp_tool_call_probe_missing",message:"orphaned MCP tool-call probe is missing or not executable",path:$probe}]
+        }'
+        return 0
+    fi
+    timeout_bin="${FLYWHEEL_TIMEOUT_BIN:-timeout}"
+    probe_timeout="${FLYWHEEL_ORPHANED_MCP_TOOL_CALL_TIMEOUT_SECONDS:-${FLYWHEEL_DOCTOR_PROBE_TIMEOUT_SECONDS:-1}}"
+    if command -v "$timeout_bin" >/dev/null 2>&1; then
