+    else
+        output="$("$probe" --doctor --json --repo "$REPO_ABS" 2>/dev/null)" || true
+    fi
+    if jq -e '.schema_version == "orphaned-mcp-tool-call-doctor/v1"' >/dev/null 2>&1 <<<"$output"; then
+        jq -c '
+          .status = ((.status // "pass") | ascii_downcase | if . == "fail" then "error" elif . == "pass" then "ok" else . end)
+          | .orphaned_mcp_tool_call_count = (.orphaned_mcp_tool_call_count // 0)
+          | .evidence_refs = (.evidence_refs // [])
+          | .errors = (.errors // [])
+          | .warnings = (.warnings // [])
+        ' <<<"$output"
+        return 0
+    fi
+    jq -nc --arg probe "$probe" '{
+      schema_version:"orphaned-mcp-tool-call-doctor/v1",
+      status:"warn",
+      source:null,
+      checked_at:null,
+      orphaned_mcp_tool_call_count:0,
+      evidence_refs:[],
+      errors:[],
+      warnings:[{code:"orphaned_mcp_tool_call_probe_invalid_json",message:"orphaned MCP tool-call probe did not return valid JSON",path:$probe}]
+    }'
+}
