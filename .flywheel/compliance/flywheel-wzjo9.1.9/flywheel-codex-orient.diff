+scaffold_cmd_validate() {
+  local subject=""
+  while [[ $# -gt 0 ]]; do
+    case "$1" in
+      --json) shift ;;
+      -h|--help) scaffold_emit_topic_help validate; return 0 ;;
+      --*) shift ;;
+      *) subject="$1"; shift ;;
+    esac
+  done
+  if [[ -z "$subject" ]]; then
+    jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+      '{schema_version:$sv,command:"validate",status:"info",reason:"no subject specified",valid_subjects:["snapshot","binaries","config"]}'
+    return 0
+  fi
+  local status="fail" reason="unknown"
+  case "$subject" in
+    snapshot)
+      if [[ -f "$OUT" ]]; then
+        local epoch; epoch="$(snapshot_epoch "$OUT" 2>/dev/null || true)"
+        if [[ -n "$epoch" ]]; then
+          local age; age="$(snapshot_age "$OUT" 2>/dev/null || echo 0)"
+          if (( age <= STALE_SECONDS )); then
+            status="pass"; reason="snapshot present, epoch parseable, age $age <= threshold $STALE_SECONDS"
+          else
+            reason="snapshot present but stale (age=$age > threshold=$STALE_SECONDS)"
+          fi
+        else
+          reason="snapshot present but epoch unparseable"
+        fi
+      else
+        reason="snapshot file $OUT does not exist"
+      fi
+      ;;
+    binaries)
+      if [[ -x "$FW" && -x "$SNAPSHOT_BIN" ]]; then
+        status="pass"; reason="FW and SNAPSHOT_BIN both executable"
+      elif [[ ! -x "$FW" ]]; then
+        reason="FW binary not executable: $FW"
+      else
+        reason="SNAPSHOT_BIN not executable: $SNAPSHOT_BIN"
+      fi
+      ;;
+    config)
+      if [[ "$STALE_SECONDS" =~ ^[0-9]+$ && "$STALE_SECONDS" -gt 0 ]]; then
+        local out_dir out_writable=0
+        out_dir="$(dirname "$OUT")"
+        if [[ -d "$out_dir" && -w "$out_dir" ]]; then out_writable=1
+        elif [[ -f "$OUT" && -w "$OUT" ]]; then out_writable=1; fi
+        if [[ "$out_writable" -eq 1 ]]; then
+          status="pass"; reason="STALE_SECONDS=$STALE_SECONDS is positive int; OUT parent writable"
+        else
+          reason="STALE_SECONDS valid but OUT parent ($out_dir) not writable"
+        fi
+      else
+        reason="STALE_SECONDS=$STALE_SECONDS is not a positive integer"
+      fi
+      ;;
+    *)
+      printf 'ERR: unknown validate subject %s (snapshot|binaries|config)\n' "$subject" >&2
+      return 64
+      ;;
+  esac
+  jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg subject "$subject" --arg status "$status" --arg reason "$reason" \
+    '{schema_version:$sv,command:"validate",subject:$subject,status:$status,reason:$reason}'
+  if command -v cli_audit_append >/dev/null 2>&1; then
+    cli_audit_append "$SCAFFOLD_AUDIT_LOG" "validate" "$status" "$(jq -nc --arg s "$subject" --arg r "$reason" '{subject:$s,reason:$r}')" >/dev/null 2>&1 || true
+  fi
+  return 0
+}
