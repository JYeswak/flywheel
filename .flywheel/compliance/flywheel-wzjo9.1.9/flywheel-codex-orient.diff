+scaffold_cmd_why() {
+  local id="${1:-}"
+  if [[ -z "$id" ]]; then
+    printf 'ERR: why requires <id> argument\n' >&2; return 64
+  fi
+  local resolution="not_found" explanation=""
+  case "$id" in
+    stale)
+      if [[ -f "$OUT" ]]; then
+        local age; age="$(snapshot_age "$OUT" 2>/dev/null || echo 0)"
+        resolution="found"
+        explanation="snapshot age $age s vs STALE_SECONDS=$STALE_SECONDS; stale=$([[ $age -gt $STALE_SECONDS ]] && echo true || echo false). Threshold sourced from FLYWHEEL_CODEX_STALE_SECONDS env, default 21600 (6h)."
+      else
+        resolution="unavailable"
+        explanation="snapshot file $OUT does not exist; staleness cannot be computed"
+      fi
+      ;;
+    snapshot)
+      resolution="found"
+      explanation="snapshot path resolves from CODEX_CURRENT_DELTAS env (default ~/.codex/CURRENT-DELTAS.md). Current: $OUT. Refreshed by $SNAPSHOT_BIN when stale."
+      ;;
+    refresh)
+      if [[ -x "$SNAPSHOT_BIN" ]]; then
+        resolution="found"
+        explanation="refresh path: $SNAPSHOT_BIN invoked with CODEX_CURRENT_DELTAS + FLYWHEEL_CODEX_STALE_SECONDS + FLYWHEEL_CODEX_FLYWHEEL_BIN env. Refresh writes a new snapshot at $OUT and short-circuits if still fresh."
+      else
+        resolution="unavailable"
+        explanation="snapshot binary $SNAPSHOT_BIN not executable; refresh cannot run"
+      fi
+      ;;
+    *)
