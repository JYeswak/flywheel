+scaffold_cmd_health() {
+  local snap_age="null" recent_runs=0 last_run_ts="null" status="pass"
+  if [[ -f "$OUT" ]]; then
+    local age; age="$(snapshot_age "$OUT" 2>/dev/null || true)"
+    if [[ -n "$age" ]]; then snap_age="$age"; fi
+  fi
+  if [[ -f "$SCAFFOLD_AUDIT_LOG" ]]; then
+    recent_runs="$(wc -l <"$SCAFFOLD_AUDIT_LOG" 2>/dev/null | tr -d ' ' || echo 0)"
+    [[ -n "$recent_runs" ]] || recent_runs=0
+    local last_line; last_line="$(tail -n 1 "$SCAFFOLD_AUDIT_LOG" 2>/dev/null)"
+    if [[ -n "$last_line" ]]; then
+      last_run_ts="\"$(jq -r '.ts // ""' <<<"$last_line" 2>/dev/null || true)\""
+    fi
+  fi
+  local audit_log_stale="false"
+  if [[ -f "$SCAFFOLD_AUDIT_LOG" ]]; then
+    local mtime now age_s
+    mtime="$(stat -f '%m' "$SCAFFOLD_AUDIT_LOG" 2>/dev/null || stat -c '%Y' "$SCAFFOLD_AUDIT_LOG" 2>/dev/null || echo 0)"
+    now="$(date +%s)"
+    age_s=$(( now - mtime ))
+    if (( age_s > 86400 )); then audit_log_stale="true"; fi
+  fi
+  if [[ "$snap_age" != "null" ]] && (( snap_age > STALE_SECONDS )); then status="warn"; fi
+  if [[ ! -x "$FW" || ! -x "$SNAPSHOT_BIN" ]]; then status="fail"; fi
+  jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
+    --arg status "$status" --argjson age "$snap_age" --argjson runs "$recent_runs" \
+    --argjson last "$last_run_ts" --argjson stale "$audit_log_stale" \
+    --arg audit_log "$SCAFFOLD_AUDIT_LOG" \
+    '{schema_version:$sv,command:"health",ts:$ts,status:$status,snapshot_age_seconds:$age,stale_threshold_seconds:'"$STALE_SECONDS"',recent_runs:$runs,last_run_ts:$last,audit_log:$audit_log,audit_log_stale:$stale}'
+  if command -v cli_audit_append >/dev/null 2>&1; then
+    cli_audit_append "$SCAFFOLD_AUDIT_LOG" "health" "$status" "$(jq -nc --argjson a "$snap_age" --argjson r "$recent_runs" '{snapshot_age_seconds:$a,recent_runs:$r}')" >/dev/null 2>&1 || true
+  fi
+  if [[ "$status" == "fail" ]]; then return 1; fi
+  return 0
+}
