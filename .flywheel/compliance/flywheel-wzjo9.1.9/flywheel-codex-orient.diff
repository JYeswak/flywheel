+scaffold_cmd_doctor() {
+  local home_status="fail" fw_status="fail" snap_bin_status="fail" snap_file_status="fail" stale_cfg_status="fail" jq_status="fail" helper_status="fail" audit_status="fail"
+  local snap_age="null"
+  if [[ -d "$FLYWHEEL_HOME" ]]; then home_status="pass"; fi
+  if [[ -x "$FW" ]]; then fw_status="pass"; fi
+  if [[ -x "$SNAPSHOT_BIN" ]]; then snap_bin_status="pass"; fi
+  if [[ -f "$OUT" ]]; then
+    snap_file_status="pass"
+    local age
+    age="$(snapshot_age "$OUT" 2>/dev/null || true)"
+    if [[ -n "$age" ]]; then snap_age="$age"; fi
+  fi
+  if [[ "$STALE_SECONDS" =~ ^[0-9]+$ && "$STALE_SECONDS" -gt 0 ]]; then stale_cfg_status="pass"; fi
+  if command -v jq >/dev/null 2>&1; then jq_status="pass"; fi
+  if command -v cli_audit_append >/dev/null 2>&1; then helper_status="pass"; fi
+  local audit_dir; audit_dir="$(dirname "$SCAFFOLD_AUDIT_LOG")"
+  if [[ -d "$audit_dir" && -w "$audit_dir" ]] || [[ -f "$SCAFFOLD_AUDIT_LOG" && -w "$SCAFFOLD_AUDIT_LOG" ]]; then audit_status="pass"; fi
+  local aggregate="pass"
+  for status in "$home_status" "$fw_status" "$snap_bin_status" "$stale_cfg_status" "$jq_status"; do
+    if [[ "$status" != "pass" ]]; then aggregate="fail"; fi
+  done
+  if [[ "$aggregate" == "pass" && ("$snap_file_status" != "pass" || "$audit_status" != "pass") ]]; then aggregate="warn"; fi
+  jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
+    --arg agg "$aggregate" --arg home "$home_status" --arg fw "$fw_status" --arg sb "$snap_bin_status" \
+    --arg sf "$snap_file_status" --arg sc "$stale_cfg_status" --arg jq_s "$jq_status" --arg hl "$helper_status" --arg au "$audit_status" \
+    --arg home_path "$FLYWHEEL_HOME" --arg fw_path "$FW" --arg snap_bin "$SNAPSHOT_BIN" --arg out_path "$OUT" --arg audit_log "$SCAFFOLD_AUDIT_LOG" \
+    --argjson age "$snap_age" \
+    '{schema_version:$sv,command:"doctor",ts:$ts,status:$agg,paths:{flywheel_home:$home_path,fw:$fw_path,snapshot_bin:$snap_bin,out:$out_path,audit_log:$audit_log},snapshot_age_seconds:$age,checks:[
+        {name:"flywheel_home",status:$home},
+        {name:"fw_binary",status:$fw},
+        {name:"snapshot_bin",status:$sb},
+        {name:"snapshot_file",status:$sf},
+        {name:"stale_seconds_config",status:$sc},
+        {name:"dependency:jq",status:$jq_s},
+        {name:"helper_lib_loaded",status:$hl},
+        {name:"audit_log_writable",status:$au}
+    ]}'
+  if command -v cli_audit_append >/dev/null 2>&1; then
+    cli_audit_append "$SCAFFOLD_AUDIT_LOG" "doctor" "$aggregate" '{}' >/dev/null 2>&1 || true
+  fi
+  if [[ "$aggregate" == "fail" ]]; then return 1; fi
+  return 0
+}
