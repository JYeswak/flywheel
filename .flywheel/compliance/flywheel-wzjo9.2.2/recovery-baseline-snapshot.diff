+            && cli_emit_completion_zsh "recovery-baseline-snapshot" "doctor,health,repair,validate,audit,why,quickstart,help,completion" \
+            || printf '# helper lib missing — completion unavailable\n' ;;
+    *) printf 'ERR: unknown shell %s (use bash|zsh)\n' "$shell" >&2; return 64 ;;
+  esac
+}
