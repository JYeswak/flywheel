+scaffold_cmd_health() {
+  local manifest_count=0 latest="null" latest_age="null" audit_log_stale="false" status="pass"
+  if [[ -d "$RBS_SNAPSHOT_DIR" ]]; then
+    manifest_count="$(find "$RBS_SNAPSHOT_DIR" -maxdepth 1 -name 'baseline-*.manifest.json' -type f 2>/dev/null | wc -l | tr -d ' ')"
+    [[ -z "$manifest_count" ]] && manifest_count=0
+    local newest
+    newest="$(find "$RBS_SNAPSHOT_DIR" -maxdepth 1 -name 'baseline-*.manifest.json' -type f -print 2>/dev/null | sort | tail -n 1 || true)"
+    if [[ -n "$newest" && -f "$newest" ]]; then
+      latest="\"$newest\""
+      local mtime now
+      mtime="$(stat -f '%m' "$newest" 2>/dev/null || stat -c '%Y' "$newest" 2>/dev/null || echo 0)"
+      now="$(date +%s)"
+      latest_age=$(( now - mtime ))
+      if (( latest_age > 86400 )); then status="warn"; fi
+    fi
+  fi
+  if [[ "$manifest_count" -eq 0 ]]; then status="warn"; fi
+  if [[ -f "$SCAFFOLD_AUDIT_LOG" ]]; then
+    local amtime now age_s
+    amtime="$(stat -f '%m' "$SCAFFOLD_AUDIT_LOG" 2>/dev/null || stat -c '%Y' "$SCAFFOLD_AUDIT_LOG" 2>/dev/null || echo 0)"
+    now="$(date +%s)"
+    age_s=$(( now - amtime ))
+    if (( age_s > 86400 )); then audit_log_stale="true"; fi
+  fi
+  jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
+    --arg status "$status" --argjson latest "$latest" --argjson age "$latest_age" \
+    --argjson count "$manifest_count" --argjson stale "$audit_log_stale" \
+    --arg snap "$RBS_SNAPSHOT_DIR" --arg al "$SCAFFOLD_AUDIT_LOG" \
+    '{schema_version:$sv,command:"health",ts:$ts,status:$status,latest_manifest:$latest,latest_manifest_age_seconds:$age,manifest_count:$count,snapshot_dir:$snap,audit_log:$al,audit_log_stale:$stale}'
+  if command -v cli_audit_append >/dev/null 2>&1; then
+    cli_audit_append "$SCAFFOLD_AUDIT_LOG" "health" "$status" "$(jq -nc --argjson c "$manifest_count" --argjson a "$latest_age" '{manifest_count:$c,latest_manifest_age_seconds:$a}')" >/dev/null 2>&1 || true
+  fi
+}
