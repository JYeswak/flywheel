+scaffold_cmd_validate() {
+  local subject=""
+  while [[ $# -gt 0 ]]; do
+    case "$1" in
+      --json) shift ;;
+      -h|--help) scaffold_emit_topic_help validate; return 0 ;;
+      --*) shift ;;
+      *) subject="$1"; shift ;;
+    esac
+  done
+  if [[ -z "$subject" ]]; then
+    jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+      '{schema_version:$sv,command:"validate",status:"info",reason:"no subject specified",valid_subjects:["manifest","config","snapshot-dir"]}'
+    return 0
+  fi
+  local status="fail" reason="unknown"
+  case "$subject" in
+    manifest)
+      local newest
+      newest="$(find "$RBS_SNAPSHOT_DIR" -maxdepth 1 -name 'baseline-*.manifest.json' -type f -print 2>/dev/null | sort | tail -n 1 || true)"
+      if [[ -z "$newest" ]]; then
+        reason="no baseline manifest in $RBS_SNAPSHOT_DIR"
+      elif [[ ! -r "$newest" ]]; then
+        reason="latest manifest $newest not readable"
+      else
+        local sv
+        sv="$(jq -r '.schema_version // ""' "$newest" 2>/dev/null || true)"
+        if [[ "$sv" == "$RBS_MANIFEST_SCHEMA" ]]; then
+          status="pass"; reason="manifest $newest carries schema_version=$RBS_MANIFEST_SCHEMA"
+        else
+          reason="manifest $newest schema_version='$sv' (want '$RBS_MANIFEST_SCHEMA')"
+        fi
+      fi
+      ;;
+    config)
+      local missing=()
+      command -v python3 >/dev/null 2>&1 || missing+=("python3")
+      command -v jq >/dev/null 2>&1 || missing+=("jq")
+      [[ -d "$RBS_STATE_DIR" ]] || missing+=("state_dir:$RBS_STATE_DIR")
+      [[ -d "$(dirname "$RBS_SNAPSHOT_DIR")" ]] || missing+=("snapshot_dir_parent:$(dirname "$RBS_SNAPSHOT_DIR")")
+      if [[ ${#missing[@]} -eq 0 ]]; then
+        status="pass"; reason="python3 + jq present; state_dir + snapshot_dir parent both exist"
+      else
+        reason="missing dependencies/paths: $(IFS=,; echo "${missing[*]}")"
+      fi
+      ;;
+    snapshot-dir)
+      if [[ -d "$RBS_SNAPSHOT_DIR" && -w "$RBS_SNAPSHOT_DIR" ]]; then
+        status="pass"; reason="snapshot dir $RBS_SNAPSHOT_DIR exists and is writable"
+      elif [[ ! -e "$RBS_SNAPSHOT_DIR" ]]; then
+        reason="snapshot dir $RBS_SNAPSHOT_DIR does not exist; run repair --scope snapshot-dir --apply --idempotency-key <k>"
+      else
+        reason="snapshot dir $RBS_SNAPSHOT_DIR exists but is not writable"
+      fi
+      ;;
+    *)
+      printf 'ERR: unknown validate subject %s (manifest|config|snapshot-dir)\n' "$subject" >&2
+      return 64
+      ;;
+  esac
+  jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg subject "$subject" --arg status "$status" --arg reason "$reason" \
+    '{schema_version:$sv,command:"validate",subject:$subject,status:$status,reason:$reason}'
+  if command -v cli_audit_append >/dev/null 2>&1; then
+    cli_audit_append "$SCAFFOLD_AUDIT_LOG" "validate" "$status" "$(jq -nc --arg s "$subject" --arg r "$reason" '{subject:$s,reason:$r}')" >/dev/null 2>&1 || true
+  fi
+  return 0
+}
