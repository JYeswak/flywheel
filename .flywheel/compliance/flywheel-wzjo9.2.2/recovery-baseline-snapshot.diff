+scaffold_emit_topic_help() {
+  local topic="${1:-}"
+  case "$topic" in
+    run)      printf 'topic: run — invokes python3 heredoc to write a baseline snapshot tarball + manifest (defaults to snapshot dir %s).\n' "$RBS_SNAPSHOT_DIR" ;;
+    doctor)   printf 'topic: doctor — probes python3, snapshot dir writability, state dir, ntm config, jq, helper lib, audit log writability, source-plan presence.\n' ;;
+    health)   printf 'topic: health — reports latest manifest path + age + manifest count + audit-log staleness (>24h).\n' ;;
+    repair)   printf 'topic: repair — --scope snapshot-dir creates snapshot directory; --scope audit-log ensures audit log dir; --apply requires --idempotency-key.\n' ;;
+    validate) printf 'topic: validate — subjects: manifest (schema_version=flywheel-recovery-baseline/v1), config (deps + writable paths), snapshot-dir (existence + writability).\n' ;;
+    audit)    printf 'topic: audit — tails recent invocations from SCAFFOLD_AUDIT_LOG (~/.local/state/flywheel/recovery-baseline-snapshot-runs.jsonl).\n' ;;
+    why)      printf 'topic: why — explains ids: baseline (source plan + schema), retention (daily=14, weekly=8), protected (alpsinsurance+picoz no-restore), trigger (manual|nightly|pre-reboot|post-reboot|drill).\n' ;;
+    *)        printf 'topics: run | doctor | health | repair | validate | audit | why\n' ;;
+  esac
+}
