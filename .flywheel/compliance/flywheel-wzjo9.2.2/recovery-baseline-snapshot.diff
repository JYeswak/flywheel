+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+        '{schema_version:$sv,command:"doctor",title:"recovery-baseline-snapshot doctor",type:"object",required:["command","status","checks"],properties:{command:{type:"string"},status:{enum:["pass","warn","fail"]},checks:{type:"array"},paths:{type:"object"}}}'
+      ;;
+    health)
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+        '{schema_version:$sv,command:"health",title:"recovery-baseline-snapshot health",type:"object",required:["command","status"],properties:{command:{type:"string"},status:{enum:["pass","warn","fail"]},latest_manifest:{type:["string","null"]},latest_manifest_age_seconds:{type:["integer","null"]},manifest_count:{type:"integer"},audit_log_stale:{type:"boolean"}}}'
+      ;;
+    repair)
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+        '{schema_version:$sv,command:"repair",title:"recovery-baseline-snapshot repair",type:"object",required:["command","scope","mode"],properties:{command:{type:"string"},scope:{enum:["snapshot-dir","audit-log","none"]},mode:{enum:["dry_run","apply"]},idempotency_key:{type:"string"},planned_actions:{type:"array"},actual_actions:{type:"array"}}}'
+      ;;
+    validate)
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+        '{schema_version:$sv,command:"validate",title:"recovery-baseline-snapshot validate",type:"object",required:["command","subject","status"],properties:{command:{type:"string"},subject:{enum:["manifest","config","snapshot-dir"]},status:{enum:["pass","fail"]},reason:{type:"string"}}}'
+      ;;
+    audit)
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+        '{schema_version:$sv,command:"audit",title:"recovery-baseline-snapshot audit",type:"object",required:["command"],properties:{command:{type:"string"},audit_log:{type:"string"},row_count:{type:"integer"},recent:{type:"array"}}}'
+      ;;
+    why)
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+        '{schema_version:$sv,command:"why",title:"recovery-baseline-snapshot why",type:"object",required:["command","id","resolution"],properties:{command:{type:"string"},id:{type:"string"},resolution:{enum:["found","not_found","unavailable"]},explanation:{type:"string"}}}'
+      ;;
