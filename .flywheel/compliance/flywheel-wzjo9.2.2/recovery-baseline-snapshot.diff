+      ;;
+    manifest)
+      jq -nc --arg sv "$RBS_MANIFEST_SCHEMA" \
+        '{schema_version:$sv,command:"manifest",title:"flywheel-recovery-baseline manifest",type:"object",required:["schema_version","created_at","trigger","sessions"],properties:{schema_version:{const:"flywheel-recovery-baseline/v1"},created_at:{type:"string"},trigger:{enum:["manual","nightly","pre-reboot","post-reboot","drill"]},sessions:{type:"array"},protected_sessions_restore_blocked:{type:"array"},retention:{type:"object"}}}'
+      ;;
+    *)
