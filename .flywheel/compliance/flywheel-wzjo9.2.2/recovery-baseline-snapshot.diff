+scaffold_cmd_doctor() {
+  local python3_status="fail" snap_dir_status="fail" state_dir_status="fail" ntm_cfg_status="fail" jq_status="fail" helper_status="fail" audit_status="fail" source_plan_status="fail"
+  if command -v python3 >/dev/null 2>&1; then python3_status="pass"; fi
+  if [[ -d "$RBS_SNAPSHOT_DIR" && -w "$RBS_SNAPSHOT_DIR" ]]; then
+    snap_dir_status="pass"
+  elif [[ ! -e "$RBS_SNAPSHOT_DIR" ]]; then
+    local parent; parent="$(dirname "$RBS_SNAPSHOT_DIR")"
+    if [[ -d "$parent" && -w "$parent" ]]; then snap_dir_status="warn"; fi
+  fi
+  if [[ -d "$RBS_STATE_DIR" ]]; then state_dir_status="pass"; fi
+  if [[ -r "$RBS_NTM_CONFIG" ]]; then ntm_cfg_status="pass"; else ntm_cfg_status="warn"; fi
+  if command -v jq >/dev/null 2>&1; then jq_status="pass"; fi
+  if command -v cli_audit_append >/dev/null 2>&1; then helper_status="pass"; fi
+  local audit_dir; audit_dir="$(dirname "$SCAFFOLD_AUDIT_LOG")"
+  if [[ -d "$audit_dir" && -w "$audit_dir" ]] || [[ -f "$SCAFFOLD_AUDIT_LOG" && -w "$SCAFFOLD_AUDIT_LOG" ]]; then audit_status="pass"; fi
+  if [[ -r "$RBS_SOURCE_PLAN" ]]; then source_plan_status="pass"; else source_plan_status="warn"; fi
+  local aggregate="pass"
+  for status in "$python3_status" "$jq_status"; do
+    if [[ "$status" != "pass" ]]; then aggregate="fail"; fi
+  done
+  if [[ "$aggregate" == "pass" ]]; then
+    for status in "$snap_dir_status" "$state_dir_status" "$ntm_cfg_status" "$audit_status" "$source_plan_status"; do
+      if [[ "$status" == "fail" ]]; then aggregate="fail"; break; fi
+      if [[ "$status" == "warn" && "$aggregate" == "pass" ]]; then aggregate="warn"; fi
+    done
+  fi
+  jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
+    --arg agg "$aggregate" --arg py "$python3_status" --arg sd "$snap_dir_status" --arg st "$state_dir_status" \
+    --arg nt "$ntm_cfg_status" --arg jq_s "$jq_status" --arg hl "$helper_status" --arg au "$audit_status" --arg sp "$source_plan_status" \
+    --arg snap "$RBS_SNAPSHOT_DIR" --arg state "$RBS_STATE_DIR" --arg ntm "$RBS_NTM_CONFIG" --arg al "$SCAFFOLD_AUDIT_LOG" --arg plan "$RBS_SOURCE_PLAN" \
+    '{schema_version:$sv,command:"doctor",ts:$ts,status:$agg,paths:{snapshot_dir:$snap,state_dir:$state,ntm_config:$ntm,audit_log:$al,source_plan:$plan},checks:[
+        {name:"dependency:python3",status:$py},
+        {name:"snapshot_dir",status:$sd},
+        {name:"state_dir",status:$st},
+        {name:"ntm_config_readable",status:$nt},
+        {name:"dependency:jq",status:$jq_s},
+        {name:"helper_lib_loaded",status:$hl},
+        {name:"audit_log_writable",status:$au},
+        {name:"source_plan_readable",status:$sp}
+    ]}'
+  if command -v cli_audit_append >/dev/null 2>&1; then
+    cli_audit_append "$SCAFFOLD_AUDIT_LOG" "doctor" "$aggregate" '{}' >/dev/null 2>&1 || true
+  fi
+  if [[ "$aggregate" == "fail" ]]; then return 1; fi
+  return 0
+}
