 Live source command:
   gh repo list Dicklesworthstone --limit 200 --json name,description,isArchived,updatedAt,defaultBranchRef
 
@@ -57,6 +65,8 @@ json_summary() {
     --arg sources_file "$SOURCES_FILE" \
