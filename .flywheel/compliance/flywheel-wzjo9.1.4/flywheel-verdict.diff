+cmd_why() {
+    local subject="${1:-verdict}"
+    local resolution="not_found"
+    local explanation=""
+    case "$subject" in
+        verdict)
+            resolution="found"
+            explanation="Joshua verdicts preserve explicit taste signals with target provenance and audit rows."
+            ;;
+        target)
+            if [[ -n "$delta_id$source_id$source_url" ]]; then
+                resolution="found"
+                explanation="Target selector resolves to delta/source by id or url; record path inserts a row into joshua_verdicts with target_kind+target_id."
+            else
+                resolution="unavailable"
