+doctor_payload() {
+    local db_status="OK" verdicts_status="FAIL" deltas_status="FAIL" sources_status="FAIL" events_status="FAIL" jq_status="FAIL" sqlite3_status="FAIL" audit_status="FAIL" helper_status="FAIL"
+    [[ -f "$FLYWHEEL_DB" ]] || db_status="FAIL"
+    db_has_table "joshua_verdicts" && verdicts_status="OK"
+    db_has_table "deltas" && deltas_status="OK"
+    db_has_table "sources" && sources_status="OK"
+    db_has_table "events" && events_status="OK"
+    command -v jq >/dev/null 2>&1 && jq_status="OK"
+    command -v sqlite3 >/dev/null 2>&1 && sqlite3_status="OK"
+    audit_log_writable && audit_status="OK"
+    command -v cli_audit_append >/dev/null 2>&1 && helper_status="OK"
+    local aggregate="OK"
+    for status in "$db_status" "$verdicts_status" "$deltas_status" "$sources_status" "$events_status" "$jq_status"; do
+        [[ "$status" == "OK" ]] || aggregate="FAIL"
+    done
+    jq -nc --arg command "doctor" --arg status "$aggregate" --arg db "$FLYWHEEL_DB" \
+        --arg db_status "$db_status" --arg verdicts "$verdicts_status" --arg deltas "$deltas_status" \
+        --arg sources "$sources_status" --arg events "$events_status" --arg jq_status "$jq_status" \
+        --arg sqlite3_status "$sqlite3_status" --arg audit_status "$audit_status" --arg helper_status "$helper_status" \
+        --arg audit_log "$SCAFFOLD_AUDIT_LOG" \
+        '{command:$command,status:$status,generated_at:(now|todate),paths:{state_db:$db,audit_log:$audit_log},checks:[
+            {name:"state_db",status:$db_status},
+            {name:"table:joshua_verdicts",status:$verdicts},
+            {name:"table:deltas",status:$deltas},
+            {name:"table:sources",status:$sources},
+            {name:"table:events",status:$events},
+            {name:"dependency:jq",status:$jq_status},
+            {name:"dependency:sqlite3",status:$sqlite3_status},
+            {name:"audit_log_writable",status:$audit_status},
+            {name:"helper_lib_loaded",status:$helper_status}
+        ]}'
+}
+
+cmd_doctor() {
+    local payload status
+    payload="$(doctor_payload)"
+    status="$(jq -r '.status' <<<"$payload")"
+    if [[ "$json_out" -eq 1 ]]; then
+        echo "$payload"
+    else
+        jq -r '"flywheel-verdict doctor: " + .status, (.checks[] | "  " + .name + "=" + .status)' <<<"$payload"
+    fi
+    if command -v cli_audit_append >/dev/null 2>&1; then
+        cli_audit_append "$SCAFFOLD_AUDIT_LOG" "doctor" "$status" '{}' >/dev/null 2>&1 || true
+    fi
+    [[ "$status" == "OK" ]] || exit 1
+}
+
+audit_log_stale() {
+    [[ -f "$SCAFFOLD_AUDIT_LOG" ]] || { printf 'false'; return; }
+    local mtime now age_s
+    if mtime="$(stat -f '%m' "$SCAFFOLD_AUDIT_LOG" 2>/dev/null)"; then :;
+    elif mtime="$(stat -c '%Y' "$SCAFFOLD_AUDIT_LOG" 2>/dev/null)"; then :;
+    else printf 'false'; return; fi
+    now="$(date +%s)"
+    age_s=$(( now - mtime ))
+    if (( age_s > 86400 )); then printf 'true'; else printf 'false'; fi
+}
+
+cmd_health() {
+    local payload status verdict_count="0" stale out
+    payload="$(doctor_payload)"
+    status="$(jq -r '.status' <<<"$payload")"
+    if db_has_table "joshua_verdicts"; then
+        verdict_count="$(fw_sql "SELECT count(*) FROM joshua_verdicts;" 2>/dev/null || echo 0)"
+    fi
+    stale="$(audit_log_stale)"
+    if [[ "$json_out" -eq 1 ]]; then
+        out="$(jq -nc --arg command "health" --arg status "$status" --argjson verdict_count "$verdict_count" --argjson stale "$stale" '{command:$command,status:$status,verdict_count:$verdict_count,audit_log_stale:$stale,generated_at:(now|todate)}')"
+    else
+        out="flywheel-verdict health: $status verdict_count=$verdict_count audit_log_stale=$stale"
+    fi
+    echo "$out"
+    if command -v cli_audit_append >/dev/null 2>&1; then
+        cli_audit_append "$SCAFFOLD_AUDIT_LOG" "health" "$status" "$(jq -nc --argjson c "$verdict_count" --argjson s "$stale" '{verdict_count:$c,audit_log_stale:$s}')" >/dev/null 2>&1 || true
+    fi
+    [[ "$status" == "OK" ]] || exit 1
+}
+
+cmd_health_loop() {
+    while :; do
+        cmd_health
+        sleep "$interval"
+    done
+    return 0
+}
+
+cmd_repair() {
+    [[ "$scope" == "state" || "$scope" == "dirs" || "$scope" == "audit-log" ]] || usage_error "repair supports --scope state|dirs|audit-log"
+    local mode="dry_run"
+    if [[ "$apply" -eq 1 && "$dry_run" -eq 0 ]]; then mode="apply"; fi
+    if [[ "$mode" == "apply" && -z "$idempotency_key" ]]; then
+        if command -v cli_refuse_apply_without_idem_key >/dev/null 2>&1; then
+            cli_refuse_apply_without_idem_key "$SCAFFOLD_SCHEMA_VERSION" "repair" "$scope"
+        else
+            jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg scope "$scope" \
+                '{schema_version:$sv,command:"repair",status:"refused",mode:"apply",scope:$scope,reason:"--apply requires --idempotency-key"}'
+        fi
+        exit 3
+    fi
+    local state_dir log_dir audit_dir
+    state_dir="$(dirname "$FLYWHEEL_DB")"
+    log_dir="$(dirname "$FLYWHEEL_LOG")"
+    audit_dir="$(dirname "$SCAFFOLD_AUDIT_LOG")"
+    case "$scope" in
+        state|dirs)
+            [[ "$mode" == "apply" ]] && mkdir -p "$state_dir" "$log_dir"
+            if [[ "$json_out" -eq 1 ]]; then
+                jq -nc --arg command "repair" --arg scope "$scope" --arg mode "$mode" \
+                    --arg state_dir "$state_dir" --arg log_dir "$log_dir" --arg audit_log "$FLYWHEEL_LOG" \
+                    --arg idempotency_key "$idempotency_key" --argjson explain "$(json_bool "$explain")" \
+                    '{command:$command,scope:$scope,mode:$mode,dry_run:($mode=="dry_run"),explain:$explain,idempotency_key:$idempotency_key,audit_log:$audit_log,planned_actions:["ensure state/log directories exist"],actual_actions:(if $mode == "apply" then ["directories ensured"] else [] end),would_write:(if $mode == "dry_run" then [$state_dir,$log_dir] else [] end),would_delete:[],would_call_external:[]}'
+            else
+                echo "repair scope=$scope mode=$mode"
+            fi
+            ;;
+        audit-log)
+            [[ "$mode" == "apply" ]] && mkdir -p "$audit_dir"
+            if [[ "$json_out" -eq 1 ]]; then
+                jq -nc --arg command "repair" --arg scope "$scope" --arg mode "$mode" \
+                    --arg dir "$audit_dir" --arg audit_log "$SCAFFOLD_AUDIT_LOG" \
+                    --arg idempotency_key "$idempotency_key" --argjson explain "$(json_bool "$explain")" \
+                    '{command:$command,scope:$scope,mode:$mode,dry_run:($mode=="dry_run"),explain:$explain,idempotency_key:$idempotency_key,audit_log:$audit_log,planned_actions:["ensure audit-log directory exists"],actual_actions:(if $mode == "apply" then ["audit_log_dir_ensured"] else [] end),would_write:(if $mode == "dry_run" then [$dir] else [] end),would_delete:[],would_call_external:[]}'
+            else
+                echo "repair scope=$scope mode=$mode"
+            fi
+            ;;
+    esac
+    if command -v cli_audit_append >/dev/null 2>&1; then
+        cli_audit_append "$SCAFFOLD_AUDIT_LOG" "repair" "$mode" "$(jq -nc --arg s "$scope" --arg k "$idempotency_key" '{scope:$s,idempotency_key:$k}')" >/dev/null 2>&1 || true
+    fi
+}
+
+cmd_validate() {
+    local thing="${1:-db}"
+    local valid=0
+    local reason="unknown"
+    case "$thing" in
+        db)
+            if [[ -f "$FLYWHEEL_DB" ]] && db_has_table "joshua_verdicts"; then valid=1; reason="state db and joshua_verdicts table present"; else reason="missing state db or joshua_verdicts table"; fi
+            ;;
+        target)
+            if [[ -n "$delta_id$source_id$source_url" ]]; then valid=1; reason="target selector present"; else reason="target selector missing"; fi
+            ;;
+        binary)
+            if [[ -x "$0" ]]; then valid=1; reason="binary executable"; else reason="binary not executable"; fi
+            ;;
+        *) usage_error "validate target must be db, target, or binary" ;;
+    esac
+    local status_label
+    if [[ "$valid" -eq 1 ]]; then status_label="pass"; else status_label="fail"; fi
+    if [[ "$json_out" -eq 1 ]]; then
+        jq -nc --arg command "validate" --arg thing "$thing" --arg status "$status_label" --arg reason "$reason" '{command:$command,thing:$thing,status:$status,reason:$reason}'
+    else
+        echo "validate $thing: $status_label - $reason"
+    fi
+    if command -v cli_audit_append >/dev/null 2>&1; then
+        cli_audit_append "$SCAFFOLD_AUDIT_LOG" "validate" "$status_label" "$(jq -nc --arg t "$thing" --arg r "$reason" '{thing:$t,reason:$r}')" >/dev/null 2>&1 || true
+    fi
+    [[ "$valid" -eq 1 ]] || exit 1
+}
+
+cmd_audit() {
+    local rows="[]"
+    if db_has_table "joshua_verdicts"; then
+        rows="$(fw_sql -json "SELECT id,target_kind,target_id,verdict,note,created_at FROM joshua_verdicts ORDER BY id DESC LIMIT 20;" 2>/dev/null || echo '[]')"
+        [[ -n "$rows" ]] || rows="[]"
+    fi
+    local audit_tail="[]"
+    if [[ -f "$SCAFFOLD_AUDIT_LOG" ]] && command -v cli_emit_audit_tail >/dev/null 2>&1; then
+        audit_tail="$(cli_emit_audit_tail "$SCAFFOLD_AUDIT_LOG" "$SCAFFOLD_SCHEMA_VERSION" 20 2>/dev/null | jq -c '.recent // []' 2>/dev/null || echo '[]')"
+    fi
+    if [[ "$json_out" -eq 1 ]]; then
+        jq -nc --arg command "audit" --argjson rows "$rows" --argjson tail "$audit_tail" --arg audit_log "$SCAFFOLD_AUDIT_LOG" \
+            '{command:$command,rows:$rows,audit_rows:($rows|length),audit_log:$audit_log,recent_invocations:$tail}'
+    else
+        jq -r '.[] | "id=\(.id) target=\(.target_kind):\(.target_id) verdict=\(.verdict)"' <<<"$rows"
+    fi
+}
