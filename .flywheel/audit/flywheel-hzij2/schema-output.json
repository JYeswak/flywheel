{
  "schema_version": "tmp-aggressive-prune.v1",
  "tool": "tmp-aggressive-prune",
  "output_modes": [
    {
      "mode": "dry-run",
      "fields": [
        "status",
        "apply",
        "ts",
        "root",
        "candidates_count",
        "protected_count",
        "sample_size_failures",
        "max_mtime_days",
        "sample",
        "protected_sample"
      ]
    },
    {
      "mode": "apply",
      "fields": [
        "status",
        "apply",
        "ts",
        "root",
        "idempotency_key",
        "candidates_count",
        "protected_count",
        "sample_size_failures",
        "deleted_count",
        "max_mtime_days",
        "free_after_gb"
      ]
    }
  ],
  "exit_codes": {
    "0": "success",
    "1": "lock_conflict",
    "2": "validation_failure"
  }
}
