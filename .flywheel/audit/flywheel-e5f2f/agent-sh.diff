Author: Josh <joshua@zeststream.ai>
Date:   Sun May 10 14:14:59 2026 -0600

    fix(agent.sh): resolve identity-doctor probe via absolute flywheel-loop path [flywheel-e5f2f]
    
    agent_mail_identity_registry_doctor_json() shelled into "$0" identity --doctor
    --json, which fails when $0 is anything other than flywheel-loop (e.g.,
    flywheel CLI binary, bash -c sourcing, or a pane-PATH variant). The fall-
    through synth-fail explicitly emitted identity_registry_drift=1 and
    status=fail, causing flywheel-loop doctor --json to synth-fail fleet-wide
    per skillos-ubh3 trauma class.
    
    Fix: resolve probe to ${FLYWHEEL_HOME:-$HOME/.claude/skills/.flywheel}/bin/
    flywheel-loop, matching the canonical sister-probe pattern at agent.sh:4
    (agent_mail_fd_pressure_json) and agent.sh:167 (agent_mail_registration_
    broadcast_doctor_json). Add probe-missing branch returning warn+drift=0
    (NOT synth-fail) — sister pattern; "missing" ≠ "drift detected".
    
    AC: flywheel-loop doctor --json returns status=pass|warn with
    identity_registry_drift=0 — verified at probe layer (status=pass drift=0
    total_registered=20). Regression test at flywheel:tests/agent-mail-identity-
    registry-doctor-probe.sh (7 tests pass).
    
    Co-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>

diff --git a/skills/.flywheel/lib/agent.sh b/skills/.flywheel/lib/agent.sh
index 8e3dbe7..f282126 100644
--- a/skills/.flywheel/lib/agent.sh
+++ b/skills/.flywheel/lib/agent.sh
@@ -78,8 +78,34 @@ agent_browser_leak_doctor_json() {
 }
 
 agent_mail_identity_registry_doctor_json() {
-    local output
-    output="$("$0" identity --doctor --json 2>/dev/null)" || true
+    # flywheel-e5f2f fix: resolve probe to absolute flywheel-loop path instead
+    # of "$0". Under flywheel-loop sourcing, $0 may resolve to bash or to a
+    # caller binary without the `identity` subcommand, producing synth-fail.
+    # Sister probes (lines 4, 167) use absolute-path resolution. Override
+    # via FLYWHEEL_AGENT_MAIL_IDENTITY_PROBE for tests/alt-binaries.
+    local probe="${FLYWHEEL_AGENT_MAIL_IDENTITY_PROBE:-${FLYWHEEL_HOME:-$HOME/.claude/skills/.flywheel}/bin/flywheel-loop}"
+    local output timeout_bin probe_timeout
+    timeout_bin="${FLYWHEEL_TIMEOUT_BIN:-timeout}"
+    probe_timeout="${FLYWHEEL_AGENT_MAIL_IDENTITY_TIMEOUT_SECONDS:-${FLYWHEEL_DOCTOR_PROBE_TIMEOUT_SECONDS:-1}}"
+    if [[ ! -x "$probe" ]]; then
+        jq -nc --arg probe "$probe" '{
+          schema_version:"agent-mail-identity-registry-doctor/v1",
+          status:"warn",
+          total_registered:0,
+          drift_count:0,
+          identity_registry_drift:0,
+          orphan_token_count:0,
+          identity_token_orphan:0,
+          rows:[],
+          errors:[{code:"identity_registry_doctor_probe_missing", probe:$probe}]
+        }'
+        return 0
+    fi
+    if command -v "$timeout_bin" >/dev/null 2>&1; then
+        output="$("$timeout_bin" "$probe_timeout" "$probe" identity --doctor --json 2>/dev/null)" || true
+    else
+        output="$("$probe" identity --doctor --json 2>/dev/null)" || true
+    fi
     if jq -e . >/dev/null 2>&1 <<<"$output"; then
         jq -c '.' <<<"$output"
         return 0
