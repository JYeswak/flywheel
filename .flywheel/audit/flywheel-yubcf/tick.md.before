jq -c --arg since "$LAST_TS" 'select((.event=="coord_message" or .task_id) and (.ts // "" >= $since))' /Users/josh/Developer/flywheel/.flywheel/dispatch-log.jsonl 2>/dev/null > /tmp/flywheel-coord-messages.jsonl
jq -s '{cross_session_messages:length, ntm_only:map(select(.channel=="ntm" and (.agent_mail_message_id == null)))|length, mail_only:map(select(.channel=="agent_mail" and (.ntm_poke_ts == null)))|length}' /tmp/flywheel-coord-messages.jsonl
```

