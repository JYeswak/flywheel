+scaffold_cmd_doctor() {
+  local audit_log_dir; audit_log_dir="$(dirname "$SCAFFOLD_AUDIT_LOG")"
+  local handoff_dir="${CROSS_TIME_HANDOFF_DIR:-$_SCAFFOLD_REPO_ROOT/.flywheel/handoffs}"
+  local bash_s=fail jq_s=fail py_s=fail handoff_s=warn audit_s=fail
+  command -v bash >/dev/null 2>&1 && bash_s=pass
+  command -v jq >/dev/null 2>&1 && jq_s=pass
+  command -v python3 >/dev/null 2>&1 && py_s=pass
+  [[ -d "$handoff_dir" && -r "$handoff_dir" ]] && handoff_s=pass
+  [[ -d "$audit_log_dir" && -w "$audit_log_dir" ]] && audit_s=pass
+  local overall=pass
+  for st in "$bash_s" "$jq_s" "$py_s"; do [[ "$st" == fail ]] && overall=fail; done
+  if [[ "$overall" == pass ]]; then
+    for st in "$handoff_s" "$audit_s"; do [[ "$st" == warn || "$st" == fail ]] && overall=warn; done
+  fi
+  local ts; ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
+  jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg ts "$ts" --arg overall "$overall" \
+    --arg bash_s "$bash_s" --arg jq_s "$jq_s" --arg py_s "$py_s" --arg ho_s "$handoff_s" --arg ad_s "$audit_s" \
+    --arg ho "$handoff_dir" --arg ad "$audit_log_dir" \
+    '{schema_version:$sv,command:"doctor",ts:$ts,status:$overall,
+      checks:[
+        {name:"bash_available",status:$bash_s},
+        {name:"jq_available",status:$jq_s},
+        {name:"python3_available",status:$py_s,detail:"load-bearing — coverage ratio uses python3 for floating-point round"},
+        {name:"handoff_dir_readable",status:$ho_s,path:$ho},
+        {name:"audit_log_dir_writable",status:$ad_s,path:$ad}
+      ]}'
+}
