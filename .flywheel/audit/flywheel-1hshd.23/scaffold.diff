+scaffold_cmd_validate() {
+  local subject="${1:-}"; shift || true
+  local arg="${1:-}"
+  local ts; ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
+  case "$subject" in
+    handoff-dir-path)
+      [[ -z "$arg" ]] && { printf 'ERR: validate handoff-dir-path requires VALUE\n' >&2; return 64; }
+      if [[ -d "$arg" && -r "$arg" ]]; then
+        jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg ts "$ts" --arg p "$arg" \
+          '{schema_version:$sv,command:"validate",subject:"handoff-dir-path",ts:$ts,status:"ok",value:$p}'
+        return 0
+      fi
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg ts "$ts" --arg p "$arg" \
+        '{schema_version:$sv,command:"validate",subject:"handoff-dir-path",ts:$ts,status:"reject",value:$p,reason:"directory_not_readable"}'
+      return 1 ;;
+    sample-n)
+      [[ -z "$arg" ]] && { printf 'ERR: validate sample-n requires VALUE\n' >&2; return 64; }
+      if [[ "$arg" =~ ^[0-9]+$ ]] && (( arg >= 1 && arg <= 1000 )); then
+        jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg ts "$ts" --argjson v "$arg" \
+          '{schema_version:$sv,command:"validate",subject:"sample-n",ts:$ts,status:"ok",value:$v}'
+        return 0
+      fi
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg ts "$ts" --arg v "$arg" \
+        '{schema_version:$sv,command:"validate",subject:"sample-n",ts:$ts,status:"reject",value:$v,reason:"out_of_range_or_not_integer",valid_range:"[1, 1000]",default:10}'
+      return 1 ;;
+    tomorrow-header-regex)
+      [[ -z "$arg" ]] && { printf 'ERR: validate tomorrow-header-regex requires VALUE\n' >&2; return 64; }
+      # grep -qE exit codes: 0=match, 1=no-match, >=2=bad regex.
+      # Under set -e, capture rc via `|| rc=$?` so non-match doesn't exit.
+      local rc=0
+      echo "test" | grep -qE "$arg" >/dev/null 2>&1 || rc=$?
+      if [[ "$rc" -le 1 ]]; then
+        jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg ts "$ts" --arg r "$arg" \
+          '{schema_version:$sv,command:"validate",subject:"tomorrow-header-regex",ts:$ts,status:"ok",value:$r}'
+        return 0
+      fi
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg ts "$ts" --arg r "$arg" \
+        '{schema_version:$sv,command:"validate",subject:"tomorrow-header-regex",ts:$ts,status:"reject",value:$r,reason:"regex_compile_failure"}'
+      return 1 ;;
+    "")
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+        '{schema_version:$sv,command:"validate",status:"refused",reason:"missing_subject",valid_subjects:["handoff-dir-path","sample-n","tomorrow-header-regex"]}'
+      return 64 ;;
+    *)
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg subj "$subject" \
+        '{schema_version:$sv,command:"validate",status:"refused",subject:$subj,reason:"unknown_subject",valid_subjects:["handoff-dir-path","sample-n","tomorrow-header-regex"]}'
+      return 64 ;;
+  esac
+}
