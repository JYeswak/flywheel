+    doctor)      printf 'topic: doctor — substrate probes: bash, jq, python3 (load-bearing for coverage ratio rounding), handoff_dir_present, ledger_dir_writable; emits .checks array (canonical AG3.4) bridging to native --doctor envelope\n' ;;
+    health)      printf 'topic: health — tail $SCAFFOLD_AUDIT_LOG (= $CROSS_TIME_LEDGER); report last_run_ts, age_seconds, recent_runs, total_runs; status=warn at >7d stale (weekly probe cadence)\n' ;;
+    repair)      printf 'topic: repair --scope <audit_log_dir|handoff_dir_path> [--dry-run|--apply --idempotency-key KEY] — apply contract: --apply requires --idempotency-key (rc=3); scopes: audit_log_dir (mkdir -p), handoff_dir_path (REPORT-ONLY — verifies $CROSS_TIME_HANDOFF_DIR readable; handoffs are written by /flywheel:handoff, not this surface)\n' ;;
