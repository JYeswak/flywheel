+    if head == "why":
+        return _scaffold_cmd_why(argv[1:])
+    if head == "quickstart":
+        return _scaffold_emit_quickstart()
+    if head == "doctor":
+        return _scaffold_cmd_doctor()
+    if head == "health":
+        return _scaffold_cmd_health()
