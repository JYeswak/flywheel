+scaffold_cmd_audit() {
+  local limit=20
+  while [[ $# -gt 0 ]]; do
+    case "$1" in
+      -h|--help) scaffold_emit_topic_help audit; return 0 ;;
+      --limit) limit="${2:-20}"; shift 2 ;;
+      --limit=*) limit="${1#--limit=}"; shift ;;
+      --json) shift ;;
