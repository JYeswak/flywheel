+scaffold_cmd_doctor() {
+  local fw_root="${HOME}/.claude/skills/.flywheel"
+  local config="${fw_root}/sync-config.env"
+  local lock="${fw_root}/.sync.lock"
+  local log_dir="${fw_root}/logs"
+  local db="${fw_root}/state.db"
+  local wal="${db}-wal"
+  local checks=() overall="pass" sync_remote_set="false" wal_size=0
+  local fw_root_status="fail" config_status="fail" log_dir_status="fail"
+  local rsync_status="fail" flock_status="fail" db_status="warn" wal_status="pass"
+  local sync_remote_status="fail"
+
+  if [[ -d "$fw_root" ]]; then fw_root_status="pass"; fi
+  if [[ -r "$config" ]]; then
+    config_status="pass"
+    # extract SYNC_REMOTE without sourcing (avoid arbitrary code execution)
+    if grep -qE '^[[:space:]]*SYNC_REMOTE=[^[:space:]]+' "$config" 2>/dev/null; then
+      sync_remote_set="true"; sync_remote_status="pass"
+    fi
+  fi
+  if [[ -d "$log_dir" && -w "$log_dir" ]]; then log_dir_status="pass"; fi
+  if command -v rsync >/dev/null 2>&1; then rsync_status="pass"; fi
+  if command -v flock >/dev/null 2>&1; then flock_status="pass"; fi
+  if [[ -r "$db" ]]; then db_status="pass"; fi
+  if [[ -f "$wal" ]]; then
+    wal_size="$(/usr/bin/stat -f%z "$wal" 2>/dev/null || /usr/bin/stat -c%s "$wal" 2>/dev/null || echo 0)"
+    if [[ "${wal_size:-0}" -gt 0 ]]; then wal_status="warn"; fi
+  fi
+
+  for st in "$fw_root_status" "$config_status" "$log_dir_status" "$rsync_status" "$flock_status" "$sync_remote_status"; do
+    if [[ "$st" == "fail" ]]; then overall="fail"; fi
+  done
+  if [[ "$overall" == "pass" ]]; then
+    for st in "$db_status" "$wal_status"; do
+      if [[ "$st" == "warn" ]]; then overall="warn"; fi
+    done
+  fi
+
+  jq -nc \
+    --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+    --arg ts "$(iso_now 2>/dev/null || date -u +%Y-%m-%dT%H:%M:%SZ)" \
+    --arg overall "$overall" \
+    --arg fw_root "$fw_root" --arg fw_root_status "$fw_root_status" \
+    --arg config "$config" --arg config_status "$config_status" \
+    --arg sync_remote_set "$sync_remote_set" --arg sync_remote_status "$sync_remote_status" \
+    --arg log_dir "$log_dir" --arg log_dir_status "$log_dir_status" \
+    --arg rsync_status "$rsync_status" \
+    --arg flock_status "$flock_status" \
+    --arg db "$db" --arg db_status "$db_status" \
+    --arg wal "$wal" --arg wal_status "$wal_status" --argjson wal_size "${wal_size:-0}" \
+    --arg lock "$lock" \
+    '{schema_version:$sv,command:"doctor",ts:$ts,status:$overall,
+      checks:[
+        {name:"fw_root", path:$fw_root, status:$fw_root_status},
+        {name:"config_file", path:$config, status:$config_status},
+        {name:"sync_remote_set", status:$sync_remote_status, detail:$sync_remote_set},
+        {name:"log_dir_writable", path:$log_dir, status:$log_dir_status},
+        {name:"rsync_available", status:$rsync_status},
+        {name:"flock_available", status:$flock_status},
+        {name:"state_db", path:$db, status:$db_status},
+        {name:"wal_state", path:$wal, status:$wal_status, size_bytes:$wal_size}
+      ],
+      lock_path:$lock,
+      thresholds:{wal_size_max_bytes:0, log_age_max_seconds:86400}
+    }'
+}
