+scaffold_cmd_validate() {
+  local subject="${1:-}" target="${2:-}"
+  case "$subject" in
+    config)
+      local cfg="${target:-${HOME}/.claude/skills/.flywheel/sync-config.env}"
+      if [[ ! -r "$cfg" ]]; then
+        jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg p "$cfg" \
+          '{schema_version:$sv,command:"validate",subject:"config",status:"fail",path:$p,reason:"missing_or_unreadable"}'
+        return 1
+      fi
+      if grep -qE '^[[:space:]]*SYNC_REMOTE=[^[:space:]]+' "$cfg" 2>/dev/null; then
+        local has_mode="false"
+        if grep -qE '^[[:space:]]*SYNC_MODE=' "$cfg" 2>/dev/null; then has_mode="true"; fi
+        jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg p "$cfg" --arg mode "$has_mode" \
+          '{schema_version:$sv,command:"validate",subject:"config",status:"pass",path:$p,sync_remote_set:true,sync_mode_set:($mode=="true")}'
+        return 0
+      fi
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg p "$cfg" \
+        '{schema_version:$sv,command:"validate",subject:"config",status:"fail",path:$p,reason:"missing_required:SYNC_REMOTE"}'
+      return 1
+      ;;
+    manifest)
+      local mf="${target:-}"
+      if [[ -z "$mf" || ! -r "$mf" ]]; then
+        jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg p "$mf" \
+          '{schema_version:$sv,command:"validate",subject:"manifest",status:"fail",path:$p,reason:"missing_or_unreadable"}'
+        return 1
+      fi
+      local count abs_count
+      count="$(wc -l < "$mf" | tr -d ' ')"
+      abs_count="$(grep -cE '^/' "$mf" 2>/dev/null || echo 0)"
+      if [[ "$abs_count" -gt 0 ]]; then
+        jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg p "$mf" --argjson n "$count" --argjson abs "$abs_count" \
+          '{schema_version:$sv,command:"validate",subject:"manifest",status:"fail",path:$p,total:$n,absolute_paths:$abs,reason:"absolute_paths_disallowed_in_manifest"}'
+        return 1
+      fi
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg p "$mf" --argjson n "$count" \
+        '{schema_version:$sv,command:"validate",subject:"manifest",status:"pass",path:$p,total:$n,absolute_paths:0}'
+      return 0
+      ;;
+    audit-row)
+      local row="${target:-}"
+      if [[ -z "$row" ]]; then
+        jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+          '{schema_version:$sv,command:"validate",subject:"audit-row",status:"fail",reason:"row_required"}'
+        return 1
+      fi
+      if jq -e '.ts and .command' >/dev/null 2>&1 <<<"$row"; then
+        jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+          '{schema_version:$sv,command:"validate",subject:"audit-row",status:"pass"}'
+        return 0
+      fi
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+        '{schema_version:$sv,command:"validate",subject:"audit-row",status:"fail",reason:"missing_required_fields:ts,command"}'
+      return 1
+      ;;
+    "")
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+        '{schema_version:$sv,command:"validate",status:"refused",reason:"--subject required",valid_subjects:["config","manifest","audit-row"]}'
+      return 64
+      ;;
+    *)
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg s "$subject" \
+        '{schema_version:$sv,command:"validate",status:"refused",reason:"unknown subject",subject:$s,valid_subjects:["config","manifest","audit-row"]}'
+      return 64
+      ;;
+  esac
+}
