+scaffold_cmd_repair() {
+  local scope="" mode="dry_run" idem_key=""
+  while [[ $# -gt 0 ]]; do
+    case "$1" in
+      -h|--help) scaffold_emit_topic_help repair; return 0 ;;
+      --scope) scope="${2:-}"; shift 2 ;;
+      --dry-run) mode="dry_run"; shift ;;
+      --apply) mode="apply"; shift ;;
+      --idempotency-key) idem_key="${2:-}"; shift 2 ;;
+      --idempotency-key=*) idem_key="${1#--idempotency-key=}"; shift ;;
+      --json) shift ;;
+      *) printf 'ERR: unknown repair arg %s\n' "$1" >&2; return 64 ;;
+    esac
+  done
+  if [[ "$mode" == "apply" && -z "$idem_key" ]]; then
+    if command -v cli_refuse_apply_without_idem_key >/dev/null; then
+      cli_refuse_apply_without_idem_key "$SCAFFOLD_SCHEMA_VERSION" "repair" "$scope"
+    else
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg scope "$scope" \
+        '{schema_version:$sv,command:"repair",status:"refused",mode:"apply",scope:$scope,reason:"--apply requires --idempotency-key"}'
+      exit 3
+    fi
+  fi
+  local fw_root="${HOME}/.claude/skills/.flywheel"
+  local log_dir="${fw_root}/logs"
+  local lock="${fw_root}/.sync.lock"
+  local action="" actions_json="[]" status="ok"
+  case "$scope" in
+    log_dir)
+      if [[ -d "$log_dir" ]]; then
+        action="log_dir_exists_noop"
+      elif [[ "$mode" == "apply" ]]; then
+        if mkdir -p "$log_dir" 2>/dev/null; then
+          action="log_dir_created"
+        else
+          action="log_dir_create_failed"; status="fail"
+        fi
+      else
+        action="log_dir_create_planned"
+      fi
+      ;;
+    stale_lock)
+      if [[ ! -f "$lock" ]]; then
+        action="lock_absent_noop"
+      else
+        local lock_holder
+        lock_holder="$(/usr/sbin/lsof -F p "$lock" 2>/dev/null | grep '^p' | head -1 | tr -d 'p' || true)"
+        if [[ -n "$lock_holder" ]] && kill -0 "$lock_holder" 2>/dev/null; then
+          action="lock_held_by_live_pid_${lock_holder}_skipped"
+        elif [[ "$mode" == "apply" ]]; then
+          if rm -f "$lock" 2>/dev/null; then
+            action="stale_lock_removed"
+          else
+            action="stale_lock_remove_failed"; status="fail"
+          fi
+        else
+          action="stale_lock_remove_planned"
+        fi
+      fi
+      ;;
+    "")
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+        '{schema_version:$sv,command:"repair",status:"refused",reason:"--scope required",valid_scopes:["log_dir","stale_lock"]}'
+      return 64
+      ;;
+    *)
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg scope "$scope" \
+        '{schema_version:$sv,command:"repair",status:"refused",reason:"unknown scope",scope:$scope,valid_scopes:["log_dir","stale_lock"]}'
+      return 64
+      ;;
+  esac
+  local envelope
+  envelope="$(jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg scope "$scope" --arg mode "$mode" --arg idem "$idem_key" --arg action "$action" --arg status "$status" \
+    '{schema_version:$sv,command:"repair",status:$status,mode:$mode,scope:$scope,idempotency_key:$idem,action:$action}')"
+  printf '%s\n' "$envelope"
+  if command -v cli_audit_append >/dev/null 2>&1; then
+    cli_audit_append "$SCAFFOLD_AUDIT_LOG" "repair" "$status" \
+      "$(jq -nc --arg scope "$scope" --arg mode "$mode" --arg idem "$idem_key" --arg act "$action" \
+          '{scope:$scope,mode:$mode,idempotency_key:$idem,action:$act}')"
+  fi
+}
