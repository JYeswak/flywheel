+scaffold_cmd_validate() {
+  local subject="${1:-}" target="${2:-}"
+  local canonical=("MISSION.md" "STATE.md" "GOAL.md" "AGENTS.md" "INCIDENTS.md")
+  local repo_root; repo_root="$(git rev-parse --show-toplevel 2>/dev/null || echo "")"
+  case "$subject" in
+    doctrine-path)
+      if [[ -z "$target" ]]; then
+        jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+          '{schema_version:$sv,command:"validate",subject:"doctrine-path",status:"fail",reason:"path_required"}'
+        return 1
+      fi
+      local in_set="false" c
+      for c in "${canonical[@]}"; do [[ "$target" == "$c" ]] && in_set="true"; done
+      if [[ "$in_set" != "true" ]]; then
+        jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg p "$target" \
+          '{schema_version:$sv,command:"validate",subject:"doctrine-path",status:"fail",path:$p,reason:"not_in_canonical_set",canonical_set:["MISSION.md","STATE.md","GOAL.md","AGENTS.md","INCIDENTS.md"]}'
+        return 1
+      fi
+      local head_size=0
+      [[ -n "$repo_root" ]] && head_size="$(git -C "$repo_root" show "HEAD:$target" 2>/dev/null | wc -c | tr -d ' ' || echo 0)"
+      if [[ "${head_size:-0}" -lt 10 ]]; then
+        jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg p "$target" --argjson sz "${head_size:-0}" \
+          '{schema_version:$sv,command:"validate",subject:"doctrine-path",status:"fail",path:$p,head_size_bytes:$sz,reason:"head_content_empty_or_too_small"}'
+        return 1
+      fi
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg p "$target" --argjson sz "${head_size:-0}" \
+        '{schema_version:$sv,command:"validate",subject:"doctrine-path",status:"pass",path:$p,head_size_bytes:$sz}'
+      return 0
+      ;;
+    canonical-set)
+      local missing=() c
+      if [[ -z "$repo_root" ]]; then
+        jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+          '{schema_version:$sv,command:"validate",subject:"canonical-set",status:"fail",reason:"not_in_git_repo"}'
+        return 1
+      fi
+      for c in "${canonical[@]}"; do [[ -f "$repo_root/$c" ]] || missing+=("$c"); done
+      if [[ "${#missing[@]}" -gt 0 ]]; then
+        local missing_json; missing_json="$(printf '%s\n' "${missing[@]}" | jq -R . | jq -s -c .)"
+        jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --argjson missing "$missing_json" \
+          '{schema_version:$sv,command:"validate",subject:"canonical-set",status:"fail",missing:$missing}'
+        return 1
+      fi
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+        '{schema_version:$sv,command:"validate",subject:"canonical-set",status:"pass",present:["MISSION.md","STATE.md","GOAL.md","AGENTS.md","INCIDENTS.md"]}'
+      return 0
+      ;;
+    recovery-row)
+      local row="${target:-}"
+      if [[ -z "$row" ]]; then
+        jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+          '{schema_version:$sv,command:"validate",subject:"recovery-row",status:"fail",reason:"row_required"}'
+        return 1
+      fi
+      if jq -e '.ts and .action' >/dev/null 2>&1 <<<"$row"; then
+        jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+          '{schema_version:$sv,command:"validate",subject:"recovery-row",status:"pass"}'
+        return 0
+      fi
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+        '{schema_version:$sv,command:"validate",subject:"recovery-row",status:"fail",reason:"missing_required_fields:ts,action"}'
+      return 1
+      ;;
+    "")
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+        '{schema_version:$sv,command:"validate",status:"refused",reason:"--subject required",valid_subjects:["doctrine-path","canonical-set","recovery-row"]}'
+      return 64
+      ;;
+    *)
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg s "$subject" \
+        '{schema_version:$sv,command:"validate",status:"refused",reason:"unknown subject",subject:$s,valid_subjects:["doctrine-path","canonical-set","recovery-row"]}'
+      return 64
+      ;;
+  esac
+}
