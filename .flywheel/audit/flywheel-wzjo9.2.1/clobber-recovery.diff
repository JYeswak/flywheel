+scaffold_cmd_doctor() {
+  local repo_root; repo_root="$(git rev-parse --show-toplevel 2>/dev/null || echo "")"
+  local recovery_log="$_SCAFFOLD_REPO_ROOT/.flywheel/clobber-recovery-log.jsonl"
+  local fuckup_log="$HOME/.local/state/flywheel/fuckup-log.jsonl"
+  local recovery_log_dir; recovery_log_dir="$(dirname "$recovery_log")"
+  local fuckup_log_dir; fuckup_log_dir="$(dirname "$fuckup_log")"
+  local git_status="fail" repo_status="fail" recovery_dir_status="fail" fuckup_dir_status="fail"
+  local doctrine_status="pass" head_status="pass" overall="pass"
+  local missing_doctrine=() empty_head=()
+
+  if command -v git >/dev/null 2>&1; then git_status="pass"; fi
+  if [[ -n "$repo_root" ]]; then repo_status="pass"; fi
+  if [[ -d "$recovery_log_dir" ]]; then recovery_dir_status="pass"; fi
+  if [[ -d "$fuckup_log_dir" ]]; then fuckup_dir_status="pass"; fi
+
+  if [[ -n "$repo_root" ]]; then
+    local d
+    for d in MISSION.md STATE.md GOAL.md AGENTS.md INCIDENTS.md; do
+      [[ -f "$repo_root/$d" ]] || missing_doctrine+=("$d")
+      local head_size
+      head_size="$(git -C "$repo_root" show "HEAD:$d" 2>/dev/null | wc -c | tr -d ' ' || echo 0)"
+      if [[ "${head_size:-0}" -lt 10 ]]; then empty_head+=("$d"); fi
+    done
+    [[ "${#missing_doctrine[@]}" -gt 0 ]] && doctrine_status="warn"
+    [[ "${#empty_head[@]}" -gt 0 ]] && head_status="fail"
+  fi
+
+  for st in "$git_status" "$repo_status" "$head_status"; do
+    if [[ "$st" == "fail" ]]; then overall="fail"; fi
+  done
+  if [[ "$overall" == "pass" ]]; then
+    for st in "$recovery_dir_status" "$fuckup_dir_status" "$doctrine_status"; do
+      if [[ "$st" == "warn" || "$st" == "fail" ]]; then overall="warn"; fi
+    done
+  fi
+
+  local missing_json="[]" empty_json="[]"
+  [[ "${#missing_doctrine[@]}" -gt 0 ]] && missing_json="$(printf '%s\n' "${missing_doctrine[@]}" | jq -R . | jq -s -c .)"
+  [[ "${#empty_head[@]}" -gt 0 ]] && empty_json="$(printf '%s\n' "${empty_head[@]}" | jq -R . | jq -s -c .)"
+
+  jq -nc \
+    --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+    --arg ts "$(iso_now 2>/dev/null || date -u +%Y-%m-%dT%H:%M:%SZ)" \
+    --arg overall "$overall" \
+    --arg git_status "$git_status" \
+    --arg repo_status "$repo_status" --arg repo "$repo_root" \
+    --arg recovery_dir_status "$recovery_dir_status" --arg recovery_dir "$recovery_log_dir" \
+    --arg fuckup_dir_status "$fuckup_dir_status" --arg fuckup_dir "$fuckup_log_dir" \
+    --arg doctrine_status "$doctrine_status" --argjson missing "$missing_json" \
+    --arg head_status "$head_status" --argjson empty "$empty_json" \
+    '{schema_version:$sv,command:"doctor",ts:$ts,status:$overall,
+      checks:[
+        {name:"git_available",status:$git_status},
+        {name:"in_git_repo",status:$repo_status,detail:$repo},
+        {name:"recovery_log_dir",status:$recovery_dir_status,path:$recovery_dir},
+        {name:"fuckup_log_dir",status:$fuckup_dir_status,path:$fuckup_dir},
+        {name:"canonical_doctrine_paths_present",status:$doctrine_status,missing:$missing},
+        {name:"head_content_nonempty",status:$head_status,empty_in_head:$empty}
+      ],
+      thresholds:{recovery_log_age_max_seconds:86400}
+    }'
+}
+
+scaffold_cmd_health() {
+  local audit_log="${SCAFFOLD_AUDIT_LOG:-$HOME/.local/state/flywheel/clobber-recovery-runs.jsonl}"
+  local recovery_log="$_SCAFFOLD_REPO_ROOT/.flywheel/clobber-recovery-log.jsonl"
+  local now ts last_run_ts="" age_seconds total_runs=0 recent_runs=0 status="pass"
+  local stale_threshold="${CLOBBER_HEALTH_STALE_THRESHOLD_SECONDS:-86400}"
+  ts="$(iso_now 2>/dev/null || date -u +%Y-%m-%dT%H:%M:%SZ)"
+  if [[ ! -r "$audit_log" ]]; then
+    jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg ts "$ts" --arg log "$audit_log" --arg recovery_log "$recovery_log" \
+      '{schema_version:$sv,command:"health",ts:$ts,status:"warn",audit_log:$log,recovery_log:$recovery_log,reason:"audit_log_missing",last_run_ts:null,age_seconds:null,recent_runs:0,total_runs:0}'
+    return 0
+  fi
+  total_runs="$(wc -l < "$audit_log" 2>/dev/null | tr -d ' ' || echo 0)"
+  recent_runs="$(tail -20 "$audit_log" 2>/dev/null | wc -l | tr -d ' ' || echo 0)"
+  last_run_ts="$(tail -1 "$audit_log" 2>/dev/null | jq -r '.ts // empty' 2>/dev/null || true)"
+  if [[ -n "$last_run_ts" ]]; then
+    now="$(date -u +%s)"
+    local last_epoch
+    last_epoch="$(date -u -j -f '%Y-%m-%dT%H:%M:%SZ' "$last_run_ts" +%s 2>/dev/null \
+                  || date -u -d "$last_run_ts" +%s 2>/dev/null \
+                  || echo 0)"
+    age_seconds=$((now - last_epoch))
+    if [[ "$age_seconds" -gt "$stale_threshold" ]]; then status="warn"; fi
+  else
+    age_seconds=null
+    status="warn"
+  fi
+  jq -nc \
+    --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg ts "$ts" --arg status "$status" \
+    --arg log "$audit_log" --arg recovery_log "$recovery_log" --arg last_run_ts "$last_run_ts" \
+    --argjson age "${age_seconds:-null}" \
+    --argjson total "$total_runs" --argjson recent "$recent_runs" \
+    --argjson stale "$stale_threshold" \
+    '{schema_version:$sv,command:"health",ts:$ts,status:$status,audit_log:$log,recovery_log:$recovery_log,
+      last_run_ts:(if $last_run_ts == "" then null else $last_run_ts end),
+      age_seconds:$age, recent_runs:$recent, total_runs:$total,
+      stale_threshold_seconds:$stale}'
+}
