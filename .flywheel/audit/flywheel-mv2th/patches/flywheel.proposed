#!/usr/bin/env bash
# Re-exec under bash >=4 if invoked under macOS bash 3.2 — substrate uses
# associative arrays + mapfile/readarray. Pane PATH varies; we cannot
# assume `bash` resolves to homebrew. Search canonical install paths.

# ====== BEGIN canonical-cli scaffold (bead flywheel-ws02m) ======
# flywheel-cli-surface: true
# canonical-cli-scoping: passing (TODO markers in stubs need fill-in)
# doctor-mode-tier: scaffolded (bead flywheel-ws02m)
#
# This block is APPENDED by scaffold-canonical-cli.sh. The original
# top-level dispatch is preserved as `cmd_run` (the new main routes
# default invocation through cmd_run for backward compat). Surface-
# specific logic stays as TODO markers — see grep '# TODO(canonical-cli-scaffold)'.

_SCAFFOLD_REPO_ROOT="${_SCAFFOLD_REPO_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd -P)}"
_SCAFFOLD_HELPER_LIB="${_SCAFFOLD_HELPER_LIB:-$_SCAFFOLD_REPO_ROOT/.flywheel/lib/canonical-cli-helpers.sh}"
if [[ -r "$_SCAFFOLD_HELPER_LIB" ]]; then
  # shellcheck source=/dev/null
  source "$_SCAFFOLD_HELPER_LIB"
fi

SCAFFOLD_SCHEMA_VERSION="flywheel/v1"
SCAFFOLD_AUDIT_LOG="${SCAFFOLD_AUDIT_LOG:-$HOME/.local/state/flywheel/flywheel-runs.jsonl}"

scaffold_usage() {
  cat <<'USG'
usage: flywheel [SUBCOMMAND] [OPTIONS]

Backward-compatible run mode: default invocation routes to the original
top-level logic (now exposed as `cmd_run`).

Canonical CLI surfaces:
  doctor [--json]          probe substrate health
  health [--json]          last-run status
  repair --scope <s>       repair misconfigured state
                            Default: --dry-run; mutate with --apply --idempotency-key KEY
  validate <subject> [...] validate per-subject contract (TODO: define subjects)
  audit [--json]           recent run history
  why <id>                 explain provenance for a given id (TODO: id semantics)
  docs <subcommand>        documentation scaffold (init: detect project type)
  quickstart [--json]      operator orientation
  help <topic>             topic help (run | doctor | health | repair | validate | docs)
  completion <shell>       emit bash or zsh completion

Introspection:
  --info --json            version, paths, env vars, dependencies, sha256
  --schema [<surface>]     JSON Schema for output envelopes
  --examples --json        curated workflow examples
  --help / -h              this help
USG
}

scaffold_emit_info() {
  if ! command -v cli_emit_info >/dev/null; then
    jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg name "flywheel" \
      '{schema_version:$sv,command:"info",name:$name,helper_lib_missing:true}'
    return 0
  fi
  cli_emit_info \
    "flywheel" \
    "scaffolded-v0" \
    "$SCAFFOLD_SCHEMA_VERSION" \
    "doctor,health,repair,validate,audit,why,quickstart,help,completion" \
    "SCAFFOLD_AUDIT_LOG" \
    '{}'
}

scaffold_emit_examples() {
  local jsonl
  jsonl="$(jq -nc '{name:"default run",invocation:"flywheel",purpose:"backward-compatible original behavior"}'
)"$'\n'"$(jq -nc '{name:"doctor",invocation:"flywheel doctor --json",purpose:"probe substrate health"}'
)"
  if command -v cli_emit_examples >/dev/null; then
    cli_emit_examples "$SCAFFOLD_SCHEMA_VERSION" "$jsonl"
  else
    jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" '{schema_version:$sv,command:"examples",helper_lib_missing:true}'
  fi
}

scaffold_emit_quickstart() {
  local steps
  steps="$(jq -nc '{step:1,action:"probe doctor",command:"flywheel doctor --json"}'
)"
  if command -v cli_emit_quickstart >/dev/null; then
    cli_emit_quickstart "$SCAFFOLD_SCHEMA_VERSION" "$steps" "doctor,health,repair"
  else
    jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" '{schema_version:$sv,command:"quickstart",helper_lib_missing:true}'
  fi
}

scaffold_emit_schema() {
  local surface="${1:-default}"
  jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg surface "$surface" \
    '{schema_version:$sv,command:"schema",surface:$surface,note:"TODO(canonical-cli-scaffold): per-surface schema fill-in"}'
}

scaffold_emit_topic_help() {
  local topic="${1:-}"
  case "$topic" in
    run)      printf 'topic: run — default backward-compatible invocation routes to cmd_run.\n' ;;
    doctor)   printf 'topic: doctor — TODO(canonical-cli-scaffold): document doctor checks specific to this surface.\n' ;;
    health)   printf 'topic: health — TODO(canonical-cli-scaffold): document health probes specific to this surface.\n' ;;
    repair)   printf 'topic: repair — TODO(canonical-cli-scaffold): document repair scopes + idempotency contract.\n' ;;
    validate) printf 'topic: validate — TODO(canonical-cli-scaffold): document validation subjects + contracts.\n' ;;
    *)        printf 'topics: run | doctor | health | repair | validate\n' ;;
  esac
}

scaffold_emit_completion() {
  local shell="${1:-bash}"
  case "$shell" in
    -h|--help) scaffold_emit_topic_help completion 2>/dev/null \
                 || printf 'topic: completion <bash|zsh> — emit shell completion script\n'
               return 0 ;;
    bash) command -v cli_emit_completion_bash >/dev/null \
            && cli_emit_completion_bash "flywheel" "doctor,health,repair,validate,audit,why,quickstart,help,completion" "--json,--apply,--dry-run,--idempotency-key,--info,--schema,--examples" \
            || printf '# helper lib missing — completion unavailable\n' ;;
    zsh)  command -v cli_emit_completion_zsh >/dev/null \
            && cli_emit_completion_zsh "flywheel" "doctor,health,repair,validate,audit,why,quickstart,help,completion" \
            || printf '# helper lib missing — completion unavailable\n' ;;
    *) printf 'ERR: unknown shell %s (use bash|zsh)\n' "$shell" >&2; return 64 ;;
  esac
}

# ---------- canonical-cli stubs (TODO markers preserved) ----------

scaffold_cmd_doctor() {
  # TODO(canonical-cli-scaffold): probe substrate this script depends on
  # (env vars, paths, external tools) and emit per-check status.
  jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg ts "$(iso_now 2>/dev/null || date -u +%Y-%m-%dT%H:%M:%SZ)" \
    '{schema_version:$sv,command:"doctor",ts:$ts,status:"todo",checks:[],note:"TODO(canonical-cli-scaffold): fill in doctor checks"}'
}

scaffold_cmd_health() {
  # TODO(canonical-cli-scaffold): summarize last-run state from audit log.
  jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg ts "$(iso_now 2>/dev/null || date -u +%Y-%m-%dT%H:%M:%SZ)" \
    '{schema_version:$sv,command:"health",ts:$ts,status:"todo",note:"TODO(canonical-cli-scaffold): fill in health probe from audit log"}'
}

scaffold_cmd_repair() {
  local scope="" mode="dry_run" idem_key=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) scaffold_emit_topic_help repair; return 0 ;;
      --scope) scope="${2:-}"; shift 2 ;;
      --dry-run) mode="dry_run"; shift ;;
      --apply) mode="apply"; shift ;;
      --idempotency-key) idem_key="${2:-}"; shift 2 ;;
      --idempotency-key=*) idem_key="${1#--idempotency-key=}"; shift ;;
      --json) shift ;;
      *) printf 'ERR: unknown repair arg %s\n' "$1" >&2; return 64 ;;
    esac
  done
  if [[ "$mode" == "apply" && -z "$idem_key" ]]; then
    if command -v cli_refuse_apply_without_idem_key >/dev/null; then
      cli_refuse_apply_without_idem_key "$SCAFFOLD_SCHEMA_VERSION" "repair" "$scope"
    else
      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg scope "$scope" \
        '{schema_version:$sv,command:"repair",status:"refused",mode:"apply",scope:$scope,reason:"--apply requires --idempotency-key"}'
      exit 3
    fi
  fi
  # TODO(canonical-cli-scaffold): per-scope repair actions go here.
  jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg scope "$scope" --arg mode "$mode" --arg idem "$idem_key" \
    '{schema_version:$sv,command:"repair",status:"todo",mode:$mode,scope:$scope,idempotency_key:$idem,note:"TODO(canonical-cli-scaffold): fill in repair scope actions"}'
}

scaffold_cmd_validate() {
  # TODO(canonical-cli-scaffold): document validation subjects + contracts.
  jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
    '{schema_version:$sv,command:"validate",status:"todo",note:"TODO(canonical-cli-scaffold): fill in per-subject validation"}'
}

scaffold_cmd_audit() {
  # TODO(canonical-cli-scaffold): tail audit log; emit recent rows.
  jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg log "$SCAFFOLD_AUDIT_LOG" \
    '{schema_version:$sv,command:"audit",audit_log:$log,status:"todo",note:"TODO(canonical-cli-scaffold): fill in audit tail"}'
}

scaffold_cmd_why() {
  local id="${1:-}"
  if [[ -z "$id" ]]; then
    printf 'ERR: why requires <id> argument\n' >&2; return 64
  fi
  # TODO(canonical-cli-scaffold): explain why <id> is/isn't in scope.
  jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg id "$id" \
    '{schema_version:$sv,command:"why",id:$id,status:"todo",note:"TODO(canonical-cli-scaffold): fill in why-id semantics"}'
}

# ---------- docs subcommand (flywheel-mv2th Phase 1 of 38u3d) ----------
#
# `flywheel docs init` — detect project type + prepare Nextra scaffold.
#
# Phase 1 scope: subcommand + project-type detection only. Phase 2
# (flywheel-ti46c) wires the actual scaffold invocation via Jeff-skill
# `documentation-website-for-software-project/scripts/scaffold-nextra.sh`
# (Class 3 READ-ONLY consumer per cross-repo-consumer-vs-mutator-boundary
# doctrine).
#
# Project-type taxonomy (5 archetypes per bead body):
#   rust-lib       — Cargo.toml + src/lib.rs OR [lib] in Cargo.toml
#   python-lib     — pyproject.toml or setup.py without web-framework deps
#   ts-lib         — package.json with main/exports, no SPA/backend deps
#   frontend-spa   — package.json with React/Vue/Svelte/Next/Astro/Vite dep
#   backend-service — package.json with Express/Fastify/Koa OR python web
#                      framework (Django/Flask/FastAPI) OR manage.py
#
# Falls back to `unknown` when no archetype matches; operator should
# expand the heuristics or set --archetype explicitly.

scaffold_docs_detect_project_type() {
  local target="${1:-.}"
  local archetype=""
  local reasons=()

  if [[ ! -d "$target" ]]; then
    printf 'unknown\n'
    return 0
  fi

  # Rust lib
  if [[ -f "$target/Cargo.toml" ]]; then
    if [[ -f "$target/src/lib.rs" ]] || grep -qE '^\[lib\]' "$target/Cargo.toml" 2>/dev/null; then
      archetype="rust-lib"
      reasons+=("Cargo.toml present" "src/lib.rs or [lib] section")
    fi
  fi

  # Python lib (must NOT be a web framework)
  if [[ -z "$archetype" && ( -f "$target/pyproject.toml" || -f "$target/setup.py" ) ]]; then
    local has_web=0
    if grep -qE '(django|flask|fastapi|starlette|tornado|aiohttp)' "$target/pyproject.toml" "$target/setup.py" "$target/requirements.txt" 2>/dev/null; then
      has_web=1
    fi
    if [[ -f "$target/manage.py" ]]; then
      has_web=1
    fi
    if [[ "$has_web" -eq 0 ]]; then
      archetype="python-lib"
      reasons+=("pyproject.toml or setup.py present" "no web framework deps")
    fi
  fi

  # package.json heuristics (must come AFTER Rust + Python detection)
  if [[ -z "$archetype" && -f "$target/package.json" ]]; then
    local pkg
    pkg="$(cat "$target/package.json" 2>/dev/null)"
    # Frontend SPA
    if printf '%s' "$pkg" | grep -qE '"(react|vue|svelte|next|astro|vite|@vue/cli|@angular/core)"'; then
      archetype="frontend-spa"
      reasons+=("package.json has frontend framework dep")
    # Backend service
    elif printf '%s' "$pkg" | grep -qE '"(express|fastify|koa|hapi|nestjs|@nestjs/core)"'; then
      archetype="backend-service"
      reasons+=("package.json has backend framework dep")
    # TS lib (has main/exports, no SPA/backend deps)
    elif printf '%s' "$pkg" | grep -qE '"(main|exports)"[[:space:]]*:'; then
      archetype="ts-lib"
      reasons+=("package.json has main/exports without framework deps")
    fi
  fi

  # Python web (no package.json, has manage.py or web framework)
  if [[ -z "$archetype" && ( -f "$target/manage.py" || -f "$target/wsgi.py" || -f "$target/asgi.py" ) ]]; then
    archetype="backend-service"
    reasons+=("Python web framework markers present (manage.py/wsgi.py/asgi.py)")
  fi

  if [[ -z "$archetype" ]]; then
    archetype="unknown"
    reasons+=("no archetype matched; expand heuristics or pass --archetype")
  fi

  printf '%s\n' "$archetype"
}

scaffold_docs_usage() {
  cat <<'USG'
usage: flywheel docs <subcommand> [OPTIONS]

Subcommands:
  init [--target DIR] [--archetype NAME] [--json]
       Detect project type + prepare Nextra docs scaffold.
       (Phase 1: detection only. Phase 2 wires actual scaffold-nextra.sh.)

Detection archetypes (per bead body):
  rust-lib | python-lib | ts-lib | frontend-spa | backend-service | unknown

Flags:
  --target DIR        target directory (default: $PWD)
  --archetype NAME    skip detection; force archetype
  --json              machine-readable output (default for `init`)
  -h | --help         this help

Cross-refs:
  Jeff-skill: ~/.claude/skills/documentation-website-for-software-project
  Doctrine:   .flywheel/doctrine/substrate-boundary-three-class-taxonomy.md
              .flywheel/doctrine/cross-repo-consumer-vs-mutator-boundary.md
  Bead chain: flywheel-mv2th (Phase 1, this) -> ti46c (Phase 2 dogfood)
              -> sjr9e (Phase 3 alps+mobile-eats) -> ll107 (Phase 4)
USG
}

scaffold_cmd_docs_init() {
  local target="$PWD"
  local archetype_override=""
  local json_out=1  # default --json for `init`

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)        scaffold_docs_usage; return 0 ;;
      --target)         target="${2:-}"; shift 2 ;;
      --archetype)      archetype_override="${2:-}"; shift 2 ;;
      --json)           json_out=1; shift ;;
      *)
        printf 'ERR: unknown docs init arg: %s\n' "$1" >&2
        scaffold_docs_usage >&2
        return 64 ;;
    esac
  done

  local archetype
  if [[ -n "$archetype_override" ]]; then
    archetype="$archetype_override"
  else
    archetype="$(scaffold_docs_detect_project_type "$target")"
  fi

  jq -nc \
    --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
    --arg target "$target" \
    --arg archetype "$archetype" \
    --arg jeff_skill "~/.claude/skills/documentation-website-for-software-project" \
    --arg scaffold_script "scripts/scaffold-nextra.sh" \
    --arg phase "1-detection-only" \
    --arg phase_bead "flywheel-mv2th" \
    --arg parent_bead "flywheel-38u3d" \
    '{
      schema_version: $sv,
      command: "docs",
      subcommand: "init",
      target: $target,
      archetype: $archetype,
      jeff_skill_consumer: $jeff_skill,
      scaffold_script: $scaffold_script,
      phase: $phase,
      phase_bead: $phase_bead,
      parent_bead: $parent_bead,
      next_phase: "flywheel-ti46c-dogfood",
      mutates_state: false
    }'
  return 0
}

scaffold_cmd_docs() {
  if [[ $# -eq 0 ]]; then
    scaffold_docs_usage
    return 64
  fi
  case "$1" in
    -h|--help)  scaffold_docs_usage; return 0 ;;
    init)       shift; scaffold_cmd_docs_init "$@"; return $? ;;
    *)
      printf 'ERR: unknown docs subcommand: %s\n' "$1" >&2
      scaffold_docs_usage >&2
      return 64 ;;
  esac
}

# ---------- scaffolded main dispatcher ----------

# When the scaffolder appends this block, it expects the target's original
# top-level main is renamed to `cmd_run` (or the original final
# `main "$@"` line is replaced with this dispatcher). Default invocation
# falls through to the original logic for backward compat.
scaffold_main() {
  if [[ $# -eq 0 ]]; then
    scaffold_usage; exit 0
  fi
  case "$1" in
    -h|--help)    scaffold_usage; exit 0 ;;
    --info)       shift; scaffold_emit_info "$@"; exit 0 ;;
    --schema)     shift; scaffold_emit_schema "${1:-default}"; exit 0 ;;
    --examples)   shift; scaffold_emit_examples "$@"; exit 0 ;;
    doctor)       shift; scaffold_cmd_doctor "$@"; exit $? ;;
    health)       shift; scaffold_cmd_health "$@"; exit $? ;;
    repair)       shift; scaffold_cmd_repair "$@"; exit $? ;;
    validate)     shift; scaffold_cmd_validate "$@"; exit $? ;;
    audit)        shift; scaffold_cmd_audit "$@"; exit $? ;;
    why)          shift; scaffold_cmd_why "$@"; exit $? ;;
    docs)         shift; scaffold_cmd_docs "$@"; exit $? ;;
    quickstart)   shift; scaffold_emit_quickstart "$@"; exit 0 ;;
    help)         shift; scaffold_emit_topic_help "${1:-}"; exit 0 ;;
    completion)   shift; scaffold_emit_completion "${1:-bash}"; exit $? ;;
    *)
      printf 'ERR: unknown canonical subcommand: %s\n' "$1" >&2
      scaffold_usage >&2
      exit 64 ;;
  esac
}

# Early-dispatch intercept: if argv[0] looks like a canonical subcommand
# or introspection flag, run the canonical surface and exit BEFORE the
# target's original arg parser sees the args. Works for both `main "$@"`
# style and inline `while [[ $# -gt 0 ]]` style targets.
_scaffold_is_canonical_arg() {
  case "${1:-}" in
    doctor|health|repair|validate|audit|why|docs|quickstart|completion) return 0 ;;
    --info|--schema|--examples) return 0 ;;
    -h|--help) return 0 ;;
    help)
      # Intercept `help <topic>` and `help --help`; bare `help` could be
      # a legacy subcommand of the target so it falls through.
      case "${2:-}" in run|doctor|health|repair|validate|audit|why|-h|--help) return 0 ;; esac
      return 1 ;;
    *) return 1 ;;
  esac
}

if [[ $# -gt 0 ]] && _scaffold_is_canonical_arg "$@"; then
  scaffold_main "$@"
  exit $?
fi
# ====== END canonical-cli scaffold ======
if [[ -z "${BASH_VERSINFO:-}" || ${BASH_VERSINFO[0]:-0} -lt 4 ]]; then
    for _fw_bash in /opt/homebrew/bin/bash /usr/local/bin/bash; do
        if [[ -x "$_fw_bash" ]]; then exec "$_fw_bash" "$0" "$@"; fi
    done
    echo "flywheel: requires bash >=4 (macOS /bin/bash is 3.2; install via 'brew install bash')" >&2
    exit 64
fi

# flywheel — unified CLI for the dynamic-learning ecosystem.
# Subcommands manipulate state.db, drive refresh + summarize, expose dashboards.
#
# All state lives in ~/.claude/skills/.flywheel/state.db (SQLite, WAL).
# All scripts source lib/common.sh and log events to the events table.
#
# Usage:
#   flywheel init                     — create/migrate DB
#   flywheel doctor                   — health check (DB, schemas, deps, hooks)
#   flywheel sync-sources             — scan all skills' sources.txt → DB
#   flywheel refresh [skill]          — refresh source(s); writes snapshots+deltas
#   flywheel summarize <snapshot_id>  — generate Haiku 2-bullet summary
#   flywheel deltas [--unsurfaced]    — list deltas for hook injection
#   flywheel surface <delta_id>...    — mark deltas surfaced
#   flywheel anchor add ...           — add a repo_anchor (skill→repo bridge)
#   flywheel anchor query <skill>     — run socraticode for skill's anchors
#   flywheel anchor seed              — propose anchors for unwired skills
#   flywheel outcome ...              — record an outcome row
#   flywheel quality                  — recompute Thompson posteriors
#   flywheel freshness                — report GOAL.md freshness ratio
#   flywheel yuzu record|report       — record/report Peel/Press/Pour skill-load quality
#   flywheel verdict ...              — record a Joshua taste verdict (joshua_verdicts)
#   flywheel digest                   — generate Friday digest markdown
#   flywheel dashboard                — refresh LATEST-INDEX + telemetry
#   flywheel observe                  — show last 24h events + counts
#   flywheel test                     — run the test suite

set -euo pipefail

HERE="$(cd "$(dirname "$0")" && pwd)"
FLYWHEEL_HOME="$(cd "$HERE/.." && pwd)"
export FLYWHEEL_HOME
# shellcheck source=../lib/common.sh
source "$FLYWHEEL_HOME/lib/common.sh"

CMD="${1:-help}"; [[ $# -gt 0 ]] && shift || true

fw_cmd_timeout() {
    local seconds="$1"; shift
    if command -v python3 >/dev/null 2>&1; then
        python3 - "$seconds" "$@" <<'PYEOF'
import os, signal, subprocess, sys
timeout = float(sys.argv[1])
cmd = sys.argv[2:]
try:
    proc = subprocess.Popen(cmd, start_new_session=True)
    raise SystemExit(proc.wait(timeout=timeout))
except subprocess.TimeoutExpired:
    try:
        os.killpg(proc.pid, signal.SIGTERM)
        proc.wait(timeout=1)
    except Exception:
        try:
            os.killpg(proc.pid, signal.SIGKILL)
        except Exception:
            pass
    raise SystemExit(124)
PYEOF
    else
        "$@"
    fi
}

case "$CMD" in

# ───────────────────── init / doctor ─────────────────────
init)
    mkdir -p "$(dirname "$FLYWHEEL_DB")"
    sqlite3 "$FLYWHEEL_DB" < "$FLYWHEEL_HOME/sql/schema.sql"
    fw_event "init.ok" "" "" "{\"db\":\"$FLYWHEEL_DB\"}"
    echo "OK: flywheel DB initialized at $FLYWHEEL_DB"
    fw_sql "SELECT 'schema_version=' || version FROM schema_version;"
    ;;

doctor)
    DOCTOR_DEEP=0
    DOCTOR_JSON=0
    DOCTOR_REPO="${FLYWHEEL_DOCTOR_REPO:-$HOME/Developer/flywheel}"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --deep) DOCTOR_DEEP=1; shift ;;
            --fast) DOCTOR_DEEP=0; shift ;;
            --json) DOCTOR_JSON=1; shift ;;
            --repo=*) DOCTOR_REPO="${1#--repo=}"; shift ;;
            --repo)
                [[ -n "${2:-}" ]] || { echo "usage: flywheel doctor [--deep|--fast] [--json] [--repo PATH]" >&2; exit 64; }
                DOCTOR_REPO="$2"; shift 2 ;;
            *) echo "usage: flywheel doctor [--deep|--fast] [--json] [--repo PATH]" >&2; exit 64 ;;
        esac
    done
    export FLYWHEEL_DOCTOR_REPO="$DOCTOR_REPO"
    fw_dispatch_log_fitness_json() {
        local dlf_probe="$HOME/Developer/flywheel/.flywheel/scripts/dispatch-log-fitness-invariant.sh"
        local dlf_json
        if [[ -x "$dlf_probe" ]]; then
            dlf_json="$(fw_cmd_timeout 15 bash "$dlf_probe" --repo "$HOME/Developer/flywheel" --json 2>/dev/null || true)"
            if printf '%s\n' "$dlf_json" | jq -e 'type == "object" and .coverage_pct != null and .drift_count != null' >/dev/null 2>&1; then
                printf '%s\n' "$dlf_json"
                return 0
            fi
            jq -nc --arg probe "$dlf_probe" '{status:"FAIL",coverage_pct:0,drift_count:999,window:50,total:0,error:"dispatch_log_fitness_probe_invalid_json",probe:$probe}'
            return 0
        fi
        jq -nc --arg probe "$dlf_probe" '{status:"FAIL",coverage_pct:0,drift_count:999,window:50,total:0,error:"dispatch_log_fitness_probe_missing",probe:$probe}'
    }
    fw_ntm_doctor_json() {
        local ntm_bin="${NTM_BIN:-/Users/josh/.local/bin/ntm}"
        local doctor_json rc failed_count warning_count
        doctor_json="$(fw_cmd_timeout 20 "$ntm_bin" doctor --json 2>/dev/null)" && rc=0 || rc=$?
        if ! printf '%s\n' "$doctor_json" | jq -e 'type == "object"' >/dev/null 2>&1; then
            jq -nc --arg ntm_bin "$ntm_bin" --argjson exit_code "$rc" '{status:"FAIL",ntm_bin:$ntm_bin,exit_code:$exit_code,error:"ntm_doctor_invalid_json",failed_checks:[],failed_count:1,warning_count:0,soft_violation:"ntm_doctor_failed"}'
            return 0
        fi
        failed_count="$(printf '%s\n' "$doctor_json" | jq '[.. | objects | select(((.status? // .result? // .state? // "") | tostring | ascii_downcase) as $s | ($s | test("fail|error|down|missing|unhealthy")))] | length' 2>/dev/null || echo 0)"
        warning_count="$(printf '%s\n' "$doctor_json" | jq '[.. | objects | select(((.status? // .result? // .state? // "") | tostring | ascii_downcase) as $s | ($s | test("warn|degraded")))] | length' 2>/dev/null || echo 0)"
        jq -nc \
            --arg ntm_bin "$ntm_bin" \
            --argjson exit_code "$rc" \
            --argjson raw "$doctor_json" \
            --argjson failed_count "$failed_count" \
            --argjson warning_count "$warning_count" \
            '{
              status:(if $exit_code != 0 or $failed_count > 0 then "FAIL" elif $warning_count > 0 then "WARN" else "PASS" end),
              ntm_bin:$ntm_bin,
              exit_code:$exit_code,
              failed_count:$failed_count,
              warning_count:$warning_count,
              failed_checks:([ $raw | .. | objects | select(((.status? // .result? // .state? // "") | tostring | ascii_downcase) as $s | ($s | test("fail|error|down|missing|unhealthy"))) ] | .[0:20]),
              raw:$raw,
              soft_violation:(if $exit_code != 0 or $failed_count > 0 then "ntm_doctor_failed" else null end)
            }'
    }
    fw_ntm_config_json() {
        local ntm_bin="${NTM_BIN:-/Users/josh/.local/bin/ntm}"
        local show_json validate_json diff_json validate_rc
        show_json="$(fw_cmd_timeout 12 "$ntm_bin" config show --json 2>/dev/null || printf 'null\n')"
        validate_json="$(fw_cmd_timeout 12 "$ntm_bin" config validate --json 2>/dev/null)" && validate_rc=0 || validate_rc=$?
        diff_json="$(fw_cmd_timeout 12 "$ntm_bin" config diff --json 2>/dev/null || printf 'null\n')"
        if ! printf '%s\n' "$validate_json" | jq -e 'type == "object"' >/dev/null 2>&1; then
            validate_json='{"valid":false,"errors":["ntm_config_validate_invalid_json"]}'
            [[ "${validate_rc:-0}" -eq 0 ]] && validate_rc=1
        fi
        jq -nc \
            --arg ntm_bin "$ntm_bin" \
            --argjson show "$show_json" \
            --argjson validate "$validate_json" \
            --argjson diff "$diff_json" \
            --argjson validate_rc "${validate_rc:-0}" \
            '{
              status:(if $validate_rc != 0 or (($validate.valid // true) == false) or (($validate.errors // []) | length > 0) then "FAIL" else "PASS" end),
              ntm_bin:$ntm_bin,
              native_calls:["ntm config show --json","ntm config validate --json","ntm config diff --json"],
              show:$show,
              validate:$validate,
              diff:$diff,
              validate_exit_code:$validate_rc,
              soft_violation:(if $validate_rc != 0 or (($validate.valid // true) == false) or (($validate.errors // []) | length > 0) then "ntm_config_invalid" else null end)
            }'
    }
    fw_ntm_wrapper_adoption_json() {
        local repo="${FLYWHEEL_DOCTOR_REPO:-$HOME/Developer/flywheel}"
        python3 - "$repo" <<'PYEOF'
import json
import re
import sys
from pathlib import Path

repo = Path(sys.argv[1]).expanduser()
scripts = repo / ".flywheel" / "scripts"
classes = {
    "W0A": {"wrapper": ".flywheel/scripts/caam-auto-rotate-on-usage-limit.sh", "native_commands": ["rotate"]},
    "W1Q": {"wrapper": ".flywheel/scripts/ntm-quota-proactive-probe.sh", "native_commands": ["quota"]},
    "W1M": {"wrapper": ".flywheel/scripts/ntm-metrics-doctor-probe.sh", "native_commands": ["metrics"]},
    "W1S": {"wrapper": ".flywheel/scripts/ntm-serve-eventstream-bridge.sh", "native_commands": ["serve"]},
    "W2P": {"wrapper": ".flywheel/scripts/ntm-preflight-l91-wrapper.sh", "native_commands": ["preflight"]},
    "W2D": {"wrapper": ".flywheel/scripts/ntm-safety-dcg-sibling.sh", "native_commands": ["safety"]},
    "W2A": {"wrapper": ".flywheel/scripts/ntm-approve-human-gates.sh", "native_commands": ["approve"]},
    "W3bA": {"wrapper": ".flywheel/scripts/ntm-audit-receipts.sh", "native_commands": ["audit"]},
    "W3bP": {"wrapper": ".flywheel/scripts/ntm-policy-contracts.sh", "native_commands": ["policy"]},
    "W3bR": {"wrapper": ".flywheel/scripts/ntm-checkpoint-rollback-guard.sh", "native_commands": ["checkpoint", "rollback"]},
    "W3aC": {"wrapper": ".flywheel/scripts/ntm-coordinator-shadow.sh", "native_commands": ["coordinator"], "transitional": True},
    "W3aP": {"wrapper": ".flywheel/scripts/ntm-pipeline-shadow.sh", "native_commands": ["pipeline"], "transitional": True},
}
wrapper_paths = {v["wrapper"] for v in classes.values()}
by_class = {
    name: {
        "wrapper": cfg["wrapper"],
        "wrapper_exists": (repo / cfg["wrapper"]).is_file(),
        "native_commands": cfg["native_commands"],
        "bypass_count": 0,
        "bypasses": [],
        "transitional": bool(cfg.get("transitional", False)),
    }
    for name, cfg in classes.items()
}
if scripts.is_dir():
    for path in sorted(scripts.rglob("*")):
        if not path.is_file():
            continue
        rel = str(path.relative_to(repo))
        if rel in wrapper_paths or "__pycache__" in rel or ".bak" in path.name or path.suffix in {".pyc", ".db", ".png", ".jpg", ".webp"}:
            continue
        try:
            text = path.read_text(encoding="utf-8", errors="ignore")
        except OSError:
            continue
        first_line = text.splitlines()[0] if text.splitlines() else ""
        python_script = "python" in first_line
        for lineno, raw_line in enumerate(text.splitlines(), 1):
            line = raw_line.strip()
            if not line or line.startswith("#"):
                continue
            if re.match(r"^[A-Za-z_][A-Za-z0-9_]*=", line):
                continue
            for cls, cfg in classes.items():
                for cmd in cfg["native_commands"]:
                    shell_pat = re.compile(r'(^|[\s;&|({])(?:"?\$\{?(?:NTM|NTM_BIN)\}?"?|ntm)\s+' + re.escape(cmd) + r'\b')
                    py_pat = re.compile(r'["\']ntm["\']\s*,\s*["\']' + re.escape(cmd) + r'["\']')
                    if (py_pat.search(raw_line) if python_script else (shell_pat.search(raw_line) or py_pat.search(raw_line))):
                        by_class[cls]["bypasses"].append({"path": rel, "line": lineno, "command": cmd})
for cls, row in by_class.items():
    row["bypass_count"] = len(row["bypasses"])
total = sum(row["bypass_count"] for row in by_class.values())
print(json.dumps({
    "status": "FAIL" if total else "PASS",
    "repo": str(repo),
    "scan_root": str(scripts),
    "by_class": by_class,
    "total_bypass": total,
}, sort_keys=True, separators=(",", ":")))
PYEOF
    }
    fw_ntm_use_coverage_json() {
        local repo="${FLYWHEEL_DOCTOR_REPO:-$HOME/Developer/flywheel}"
        python3 - "$repo" <<'PYEOF'
import json
import re
import sys
from pathlib import Path

repo = Path(sys.argv[1]).expanduser()
surfaces = {
    "analytics": {"inventory_claim": "Wire into daily-report.sh", "expected_callsites_min": 1, "expected_tests_min": 1},
    "assign": {"inventory_claim": "Already wired in dispatch-and-log.sh", "expected_callsites_min": 1, "expected_tests_min": 1},
    "attach": {"inventory_claim": "Document as canonical operator-attach verb", "expected_callsites_min": 1, "expected_tests_min": 1},
    "bugs": {"inventory_claim": "Replace flywheel UBS aggregation with ntm bugs --json", "expected_callsites_min": 1, "expected_tests_min": 1},
    "checkpoint": {"inventory_claim": "Native snapshot behind dirty-worktree wrapper", "expected_callsites_min": 1, "expected_tests_min": 1},
}
scan_roots = [repo / ".flywheel" / "scripts", repo / "tests", repo / ".flywheel" / "tests", Path.home() / ".claude" / "commands" / "flywheel"]
skip_suffixes = {".pyc", ".db", ".png", ".jpg", ".webp"}

def text_files(root):
    if not root.exists():
        return
    for path in root.rglob("*"):
        if path.is_file() and path.suffix not in skip_suffixes and "__pycache__" not in str(path):
            yield path

rows = {}
for name, cfg in surfaces.items():
    callsites = []
    tests = set()
    call_pat = re.compile(r'(^|[\s;&|({])(?:"?\$\{?(?:NTM|NTM_BIN)\}?"?|ntm)\s+' + re.escape(name) + r'\b')
    py_pat = re.compile(r'["\']ntm["\']\s*,\s*["\']' + re.escape(name) + r'["\']')
    test_pat = re.compile(re.escape(name), re.IGNORECASE)
    for root in scan_roots:
        for path in text_files(root) or []:
            try:
                rel = str(path.relative_to(repo)) if path.is_relative_to(repo) else str(path)
            except AttributeError:
                try:
                    rel = str(path.relative_to(repo))
                except ValueError:
                    rel = str(path)
            try:
                text = path.read_text(encoding="utf-8", errors="ignore")
            except OSError:
                continue
            is_test = "/tests/" in f"/{rel}" or rel.startswith("tests/")
            if is_test and test_pat.search(rel + "\n" + text):
                tests.add(rel)
            for lineno, raw_line in enumerate(text.splitlines(), 1):
                line = raw_line.strip()
                if not line or line.startswith("#"):
                    continue
                if call_pat.search(raw_line) or py_pat.search(raw_line):
                    callsites.append({"path": rel, "line": lineno})
    rows[name] = {
        "inventory_claim": cfg["inventory_claim"],
        "expected_callsites_min": cfg["expected_callsites_min"],
        "expected_tests_min": cfg["expected_tests_min"],
        "callsites": len(callsites),
        "tests": len(tests),
        "callsite_samples": callsites[:10],
        "test_samples": sorted(tests)[:10],
    }
    rows[name]["pass"] = rows[name]["callsites"] >= cfg["expected_callsites_min"] and rows[name]["tests"] >= cfg["expected_tests_min"]
fail_count = sum(1 for row in rows.values() if not row["pass"])
print(json.dumps({
    "status": "FAIL" if fail_count else "PASS",
    "repo": str(repo),
    "surfaces_checked": len(rows),
    "fail_count": fail_count,
    **rows,
}, sort_keys=True, separators=(",", ":")))
PYEOF
    }
    fw_ntm_inventory_drift_json() {
        local repo="${FLYWHEEL_DOCTOR_REPO:-$HOME/Developer/flywheel}"
        local ntm_bin="${NTM_BIN:-ntm}"
        python3 - "$repo" "$ntm_bin" <<'PYEOF'
import json
import re
import subprocess
import sys
from pathlib import Path

repo = Path(sys.argv[1]).expanduser()
ntm_bin = sys.argv[2]
inventory = repo / ".flywheel" / "NTM-SURFACE-INVENTORY.md"
expected = set()
error = None
try:
    text = inventory.read_text(encoding="utf-8")
    for line in text.splitlines():
        if re.match(r"\|\s*\d+\s*\|", line):
            parts = line.split("|")
            if len(parts) < 3:
                continue
            for token in re.findall(r"`([^`]+)`", parts[2]):
                for alias in token.split("/"):
                    alias = alias.strip()
                    if alias:
                        expected.add(alias)
except Exception as exc:
    error = f"inventory_read_failed:{exc}"
actual = set()
help_error = None
try:
    proc = subprocess.run([ntm_bin, "--help"], text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, timeout=15, check=False)
    if proc.returncode != 0:
        help_error = f"ntm_help_rc_{proc.returncode}:{proc.stderr[-240:]}"
    in_commands = False
    for line in proc.stdout.splitlines():
        if line.strip() == "Available Commands:":
            in_commands = True
            continue
        if in_commands and line.strip() == "Flags:":
            break
        if in_commands and line.startswith("  ") and line.split():
            actual.add(line.split()[0])
except Exception as exc:
    help_error = f"ntm_help_failed:{exc}"
missing_in_help = sorted(expected - actual)
missing_in_inventory = sorted(actual - expected)
count = len(missing_in_help) + len(missing_in_inventory)
status = "FAIL" if count or error or help_error else "PASS"
print(json.dumps({
    "status": status,
    "inventory": str(inventory),
    "ntm_bin": ntm_bin,
    "expected_aliases": len(expected),
    "help_commands": len(actual),
    "missing_in_help": missing_in_help,
    "missing_in_inventory": missing_in_inventory,
    "count": count,
    "error": error,
    "help_error": help_error,
}, sort_keys=True, separators=(",", ":")))
PYEOF
    }
    fw_doctrine_version_current_json() {
        local repo="${FLYWHEEL_DOCTOR_REPO:-$HOME/Developer/flywheel}"
        local sync_bin="$HOME/Developer/flywheel/.flywheel/scripts/doctrine-sync.sh"
        local sync_json status current proposed soft
        if [[ ! -x "$sync_bin" ]]; then
            jq -nc --arg repo "$repo" --arg sync_bin "$sync_bin" '{status:"FAIL",repo:$repo,error:"doctrine_sync_missing",sync_bin:$sync_bin,soft_violation:"doctrine_behind_canonical"}'
            return 0
        fi
        sync_json="$(fw_cmd_timeout 20 "$sync_bin" --target-repo "$repo" --dry-run --json 2>/dev/null || true)"
        if ! printf '%s\n' "$sync_json" | jq -e 'type == "object"' >/dev/null 2>&1; then
            jq -nc --arg repo "$repo" --arg sync_bin "$sync_bin" '{status:"FAIL",repo:$repo,error:"doctrine_sync_invalid_json",sync_bin:$sync_bin,soft_violation:"doctrine_behind_canonical"}'
            return 0
        fi
        current="$(jq -r '.current_doctrine_version // empty' <<<"$sync_json" 2>/dev/null || true)"
        proposed="$(jq -r '.proposed_doctrine_version // empty' <<<"$sync_json" 2>/dev/null || true)"
        soft="$(jq -r '.soft_violation // empty' <<<"$sync_json" 2>/dev/null || true)"
        if [[ -n "$proposed" && "$current" == "$proposed" ]]; then
            status="PASS"
        else
            status="WARN"
            [[ -n "$soft" ]] || soft="doctrine_behind_canonical"
        fi
        jq -nc \
            --arg status "$status" \
            --arg soft "$soft" \
            --argjson sync "$sync_json" \
            '{status:$status,soft_violation:(if $soft == "" then null else $soft end),sync:$sync,current_doctrine_version:($sync.current_doctrine_version // null),proposed_doctrine_version:($sync.proposed_doctrine_version // null),missing_l_rules_count:($sync.missing_l_rules_count // null)}'
    }
    fw_idle_pane_windows_json() {
        local repo="${FLYWHEEL_DOCTOR_REPO:-$HOME/Developer/flywheel}"
        local probe="$HOME/Developer/flywheel/.flywheel/scripts/auto-refill-decision-log.sh"
        local metric_json
        if [[ ! -x "$probe" ]]; then
            jq -nc --arg probe "$probe" '{schema_version:"auto-refill-idle-window/v1",status:"WARN",probe:$probe,error:"auto_refill_probe_missing",ready_count:null,idle_pane_windows_over_2min_count:0,windows_over_2min:[],soft_violation:"idle_pane_window_probe_missing"}'
            return 0
        fi
        metric_json="$(fw_cmd_timeout 15 "$probe" --repo "$repo" --idle-window-metric --json 2>/dev/null || true)"
        if ! printf '%s\n' "$metric_json" | jq -e 'type == "object" and has("idle_pane_windows_over_2min_count")' >/dev/null 2>&1; then
            jq -nc --arg probe "$probe" '{schema_version:"auto-refill-idle-window/v1",status:"WARN",probe:$probe,error:"auto_refill_probe_invalid_json",ready_count:null,idle_pane_windows_over_2min_count:0,windows_over_2min:[],soft_violation:"idle_pane_window_probe_invalid"}'
            return 0
        fi
        printf '%s\n' "$metric_json"
    }
    if [[ "$DOCTOR_JSON" == "1" ]]; then
        dlf_json="$(fw_dispatch_log_fitness_json)"
        dlf_status="$(printf '%s\n' "$dlf_json" | jq -r '.status // "FAIL"' 2>/dev/null || echo FAIL)"
        ntm_doctor_json="$(fw_ntm_doctor_json)"
        ntm_config_json="$(fw_ntm_config_json)"
        wrapper_adoption_json="$(fw_ntm_wrapper_adoption_json)"
        ntm_use_coverage_json="$(fw_ntm_use_coverage_json)"
        ntm_inventory_drift_json="$(fw_ntm_inventory_drift_json)"
        doctrine_version_current_json="$(fw_doctrine_version_current_json)"
        idle_pane_windows_json="$(fw_idle_pane_windows_json)"
        ntm_doctor_status="$(printf '%s\n' "$ntm_doctor_json" | jq -r '.status // "FAIL"' 2>/dev/null || echo FAIL)"
        ntm_config_status="$(printf '%s\n' "$ntm_config_json" | jq -r '.status // "FAIL"' 2>/dev/null || echo FAIL)"
        wrapper_status="$(printf '%s\n' "$wrapper_adoption_json" | jq -r '.status // "FAIL"' 2>/dev/null || echo FAIL)"
        use_status="$(printf '%s\n' "$ntm_use_coverage_json" | jq -r '.status // "FAIL"' 2>/dev/null || echo FAIL)"
        inventory_status="$(printf '%s\n' "$ntm_inventory_drift_json" | jq -r '.status // "FAIL"' 2>/dev/null || echo FAIL)"
        doctrine_status="$(printf '%s\n' "$doctrine_version_current_json" | jq -r '.status // "FAIL"' 2>/dev/null || echo FAIL)"
        idle_window_status="$(printf '%s\n' "$idle_pane_windows_json" | jq -r '.status // "WARN"' 2>/dev/null || echo WARN)"
        jq -nc \
            --arg schema_version "flywheel.doctor.v1" \
            --arg mode "$([[ "$DOCTOR_DEEP" == "1" ]] && printf deep || printf fast)" \
            --arg status "$dlf_status" \
            --argjson dispatch_log_fitness "$dlf_json" \
            --arg ntm_doctor_status "$ntm_doctor_status" \
            --arg ntm_config_status "$ntm_config_status" \
            --arg wrapper_status "$wrapper_status" \
            --arg use_status "$use_status" \
            --arg inventory_status "$inventory_status" \
            --arg doctrine_status "$doctrine_status" \
            --arg idle_window_status "$idle_window_status" \
            --argjson ntm_doctor "$ntm_doctor_json" \
            --argjson ntm_config "$ntm_config_json" \
            --argjson wrapper_adoption "$wrapper_adoption_json" \
            --argjson ntm_use_coverage "$ntm_use_coverage_json" \
            --argjson ntm_inventory_drift "$ntm_inventory_drift_json" \
            --argjson doctrine_version_current "$doctrine_version_current_json" \
            --argjson idle_pane_windows "$idle_pane_windows_json" \
            '{
              schema_version:$schema_version,
              mode:$mode,
              status:(if [$status,$ntm_doctor_status,$ntm_config_status,$wrapper_status,$use_status,$inventory_status,$doctrine_status] | index("FAIL") then "FAIL" elif [$status,$ntm_doctor_status,$ntm_config_status,$wrapper_status,$use_status,$inventory_status,$doctrine_status,$idle_window_status] | index("WARN") then "WARN" else "PASS" end),
              dispatch_log_fitness:$dispatch_log_fitness,
              ntm_doctor:$ntm_doctor,
              ntm_config:$ntm_config,
              wrapper_adoption:$wrapper_adoption,
              ntm_use_coverage:$ntm_use_coverage,
              ntm_inventory_drift:$ntm_inventory_drift,
              doctrine_version_current:$doctrine_version_current,
              idle_pane_windows:$idle_pane_windows,
              soft_violations:([($ntm_doctor.soft_violation // empty),($ntm_config.soft_violation // empty),($doctrine_version_current.soft_violation // empty),($idle_pane_windows.soft_violation // empty)] | map(select(. != ""))),
              invariants:{dispatch_log_fitness_coverage:$dispatch_log_fitness,ntm_doctor:$ntm_doctor,ntm_config:$ntm_config,wrapper_adoption:$wrapper_adoption,ntm_use_coverage:$ntm_use_coverage,ntm_inventory_drift:$ntm_inventory_drift,doctrine_version_current:$doctrine_version_current,idle_pane_windows:$idle_pane_windows}
            }'
        [[ "$dlf_status" == "FAIL" || "$ntm_doctor_status" == "FAIL" || "$ntm_config_status" == "FAIL" || "$wrapper_status" == "FAIL" || "$use_status" == "FAIL" || "$inventory_status" == "FAIL" || "$doctrine_status" == "FAIL" ]] && exit 1 || exit 0
    fi
    fail=0; warn=0; ok=0
    echo "=== flywheel doctor ==="
    if [[ "$DOCTOR_DEEP" == "1" ]]; then
        echo "mode=deep (includes trend scans and expensive telemetry)"
    else
        echo "mode=fast (run: flywheel doctor --deep for trend scans and expensive telemetry)"
    fi
    echo "=== ntm doctor invariant ==="
    ntm_doctor_json="$(fw_ntm_doctor_json)"
    ntm_doctor_status="$(jq -r '.status // "FAIL"' <<<"$ntm_doctor_json" 2>/dev/null || echo FAIL)"
    ntm_doctor_failed="$(jq -r '.failed_count // 999' <<<"$ntm_doctor_json" 2>/dev/null || echo 999)"
    ntm_doctor_warnings="$(jq -r '.warning_count // 0' <<<"$ntm_doctor_json" 2>/dev/null || echo 0)"
    case "$ntm_doctor_status" in
        PASS) echo "✓ ntm doctor pass"; ok=$((ok+1)) ;;
        WARN) echo "⚠ ntm doctor warnings=$ntm_doctor_warnings"; warn=$((warn+1)) ;;
        *) echo "✗ ntm doctor failed_checks=$ntm_doctor_failed"; fail=$((fail+1)) ;;
    esac
    echo "=== ntm config invariant ==="
    ntm_config_json="$(fw_ntm_config_json)"
    ntm_config_status="$(jq -r '.status // "FAIL"' <<<"$ntm_config_json" 2>/dev/null || echo FAIL)"
    ntm_config_errors="$(jq -r '(.validate.errors // []) | length' <<<"$ntm_config_json" 2>/dev/null || echo 999)"
    case "$ntm_config_status" in
        PASS) echo "✓ ntm config validate pass"; ok=$((ok+1)) ;;
        *) echo "✗ ntm config validate errors=$ntm_config_errors"; fail=$((fail+1)) ;;
    esac
    echo "=== ntm wire-in doctor probes ==="
    wrapper_adoption_json="$(fw_ntm_wrapper_adoption_json)"
    wrapper_bypass_count="$(jq -r '.total_bypass // 0' <<<"$wrapper_adoption_json" 2>/dev/null || echo 999)"
    if [[ "$wrapper_bypass_count" =~ ^[0-9]+$ && "$wrapper_bypass_count" -eq 0 ]]; then
        echo "✓ wrapper_adoption total_bypass=0"; ok=$((ok+1))
    else
        echo "✗ wrapper_adoption total_bypass=$wrapper_bypass_count"; fail=$((fail+1))
    fi
    ntm_use_coverage_json="$(fw_ntm_use_coverage_json)"
    ntm_use_fail_count="$(jq -r '.fail_count // 999' <<<"$ntm_use_coverage_json" 2>/dev/null || echo 999)"
    if [[ "$ntm_use_fail_count" =~ ^[0-9]+$ && "$ntm_use_fail_count" -eq 0 ]]; then
        echo "✓ ntm_use_coverage all five USE surfaces have callsite+test coverage"; ok=$((ok+1))
    else
        echo "✗ ntm_use_coverage fail_count=$ntm_use_fail_count"; fail=$((fail+1))
    fi
    ntm_inventory_drift_json="$(fw_ntm_inventory_drift_json)"
    ntm_inventory_drift_count="$(jq -r '.count // 999' <<<"$ntm_inventory_drift_json" 2>/dev/null || echo 999)"
    if [[ "$ntm_inventory_drift_count" =~ ^[0-9]+$ && "$ntm_inventory_drift_count" -eq 0 ]]; then
        echo "✓ ntm_inventory_drift count=0"; ok=$((ok+1))
    else
        echo "✗ ntm_inventory_drift count=$ntm_inventory_drift_count"; fail=$((fail+1))
    fi
    doctrine_version_current_json="$(fw_doctrine_version_current_json)"
    doctrine_status="$(jq -r '.status // "FAIL"' <<<"$doctrine_version_current_json" 2>/dev/null || echo FAIL)"
    doctrine_current="$(jq -r '.current_doctrine_version // "null"' <<<"$doctrine_version_current_json" 2>/dev/null || echo null)"
    doctrine_proposed="$(jq -r '.proposed_doctrine_version // "unknown"' <<<"$doctrine_version_current_json" 2>/dev/null || echo unknown)"
    case "$doctrine_status" in
        PASS) echo "✓ doctrine_version_current current=$doctrine_current"; ok=$((ok+1)) ;;
        WARN) echo "⚠ doctrine_version_current current=$doctrine_current proposed=$doctrine_proposed soft=doctrine_behind_canonical"; warn=$((warn+1)) ;;
        *) echo "✗ doctrine_version_current probe failed"; fail=$((fail+1)) ;;
    esac
    echo "=== idle pane refill invariant ==="
    idle_pane_windows_json="$(fw_idle_pane_windows_json)"
    idle_windows_count="$(jq -r '.idle_pane_windows_over_2min_count // 999' <<<"$idle_pane_windows_json" 2>/dev/null || echo 999)"
    if [[ "$idle_windows_count" =~ ^[0-9]+$ && "$idle_windows_count" -eq 0 ]]; then
        echo "✓ idle_pane_windows_over_2min_count=0"; ok=$((ok+1))
    else
        echo "⚠ idle_pane_windows_over_2min_count=$idle_windows_count soft=idle_pane_window_over_2min"; warn=$((warn+1))
    fi
    set +e
    if [[ -f "$FLYWHEEL_DB" ]]; then echo "✓ DB exists ($FLYWHEEL_DB)"; ok=$((ok+1)); else echo "✗ DB missing"; fail=$((fail+1)); fi
    if [[ -f "$FLYWHEEL_DB" ]]; then
        v=$(fw_sql "SELECT MAX(version) FROM schema_version;" 2>/dev/null || echo "?")
        echo "✓ schema version = $v"; ok=$((ok+1))
        for tbl in sources snapshots deltas outcomes crosslinks repo_anchors joshua_verdicts events; do
            cnt=$(fw_sql "SELECT COUNT(*) FROM $tbl;" 2>/dev/null || echo "ERR")
            if [[ "$cnt" == "ERR" ]]; then echo "✗ table $tbl missing"; fail=$((fail+1));
            else echo "  · $tbl: $cnt rows"; fi
        done
    fi
    for cmd in sqlite3 jq curl; do
        if command -v "$cmd" >/dev/null 2>&1; then echo "✓ $cmd present"; ok=$((ok+1));
        else echo "✗ $cmd missing"; fail=$((fail+1)); fi
    done
    if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then echo "✓ ANTHROPIC_API_KEY set (summarizer can run)"; ok=$((ok+1));
    else echo "⚠ ANTHROPIC_API_KEY not set — summarizer will skip"; warn=$((warn+1)); fi
    if command -v x-cli >/dev/null 2>&1; then echo "✓ x-cli present"; ok=$((ok+1)); else echo "⚠ x-cli missing — X feeds will skip"; warn=$((warn+1)); fi
    # socraticode MCP via codebase_about
    echo "  · socraticode: checked at use-time (MCP)"
    # SessionStart hook wired?
    if grep -q 'flywheel.*session-start-deltas' ~/.claude/settings.json 2>/dev/null; then
        echo "✓ SessionStart hook wired"; ok=$((ok+1));
    else
        echo "⚠ SessionStart hook NOT wired (run: flywheel install-hooks)"; warn=$((warn+1));
    fi
    echo "=== flywheel /loop entrypoint ==="
    if [[ -x "$FLYWHEEL_HOME/bin/flywheel-loop" ]]; then
        echo "✓ flywheel-loop executable present"; ok=$((ok+1))
    else
        echo "✗ flywheel-loop executable missing"; fail=$((fail+1))
    fi
    if [[ -f "$HOME/.claude/commands/loop.md" ]] && grep -q 'flywheel-loop' "$HOME/.claude/commands/loop.md" 2>/dev/null; then
        echo "✓ Claude /loop command routes to flywheel-loop"; ok=$((ok+1))
    else
        echo "✗ Claude /loop command missing flywheel-loop route"; fail=$((fail+1))
    fi
    if [[ -f "$HOME/.codex/AGENTS.md" ]] && grep -q 'When Joshua sends `/loop`' "$HOME/.codex/AGENTS.md" 2>/dev/null && grep -q 'flywheel-loop' "$HOME/.codex/AGENTS.md" 2>/dev/null; then
        echo "✓ Codex /loop directive routes to flywheel-loop"; ok=$((ok+1))
    else
        echo "✗ Codex /loop directive missing flywheel-loop route"; fail=$((fail+1))
    fi
    if [[ -f "$FLYWHEEL_HOME/LOOP.md" ]]; then
        echo "✓ LOOP.md contract present"; ok=$((ok+1))
    else
        echo "✗ LOOP.md contract missing"; fail=$((fail+1))
    fi
    echo "=== W0 shared promotion invariants ==="
    SIGTERM_HELPER="$FLYWHEEL_HOME/scripts/sigterm-trap-helper.sh"
    BULK_BOUND="$FLYWHEEL_HOME/scripts/bulk-mutation-surgical-bound.sh"
    RAW_TMUX_AUDIT="$FLYWHEEL_HOME/scripts/raw-tmux-audit-doctor.sh"
    if [[ -x "$SIGTERM_HELPER" ]]; then
        sigterm_json="$(fw_cmd_timeout 10 "$SIGTERM_HELPER" --doctor --json 2>/dev/null || true)"
        sigterm_status="$(jq -r '.status // "error"' <<<"$sigterm_json" 2>/dev/null || echo error)"
        sigterm_missing="$(jq -r '.sigterm_trap_missing_count // "?"' <<<"$sigterm_json" 2>/dev/null || echo "?")"
        case "$sigterm_status" in
            pass|ok) echo "✓ sigterm_trap_helper doctor scope pass"; ok=$((ok+1)) ;;
            warn) echo "⚠ sigterm_trap_helper missing_count=$sigterm_missing"; warn=$((warn+1)) ;;
            *) echo "✗ sigterm_trap_helper doctor scope error"; fail=$((fail+1)) ;;
        esac
    else
        echo "✗ sigterm_trap_helper missing or not executable"; fail=$((fail+1))
    fi
    if [[ -x "$BULK_BOUND" ]]; then
        bulk_json="$(fw_cmd_timeout 10 "$BULK_BOUND" doctor --json 2>/dev/null || true)"
        bulk_status="$(jq -r '.status // "error"' <<<"$bulk_json" 2>/dev/null || echo error)"
        bulk_missing="$(jq -r '.bulk_mutation_surgical_bound_missing_count // "?"' <<<"$bulk_json" 2>/dev/null || echo "?")"
        case "$bulk_status" in
            pass|ok) echo "✓ bulk_mutation_surgical_bound doctor scope pass"; ok=$((ok+1)) ;;
            warn) echo "⚠ bulk_mutation_surgical_bound missing_count=$bulk_missing"; warn=$((warn+1)) ;;
            *) echo "✗ bulk_mutation_surgical_bound doctor scope error"; fail=$((fail+1)) ;;
        esac
    else
        echo "✗ bulk_mutation_surgical_bound missing or not executable"; fail=$((fail+1))
    fi
    if [[ -x "$RAW_TMUX_AUDIT" ]]; then
        raw_json="$(fw_cmd_timeout 15 "$RAW_TMUX_AUDIT" --doctor --json 2>/dev/null || true)"
        raw_status="$(jq -r '.status // "error"' <<<"$raw_json" 2>/dev/null || echo error)"
        raw_count="$(jq -r '.l29_raw_tmux_operational_violations_count // "?"' <<<"$raw_json" 2>/dev/null || echo "?")"
        case "$raw_status" in
            pass|ok) echo "✓ raw_tmux_audit doctor scope pass"; ok=$((ok+1)) ;;
            fail) echo "⚠ raw_tmux_audit operational_violations=$raw_count"; warn=$((warn+1)) ;;
            *) echo "✗ raw_tmux_audit doctor scope error"; fail=$((fail+1)) ;;
        esac
    else
        echo "✗ raw_tmux_audit_doctor missing or not executable"; fail=$((fail+1))
    fi
    echo "=== beads.jsonl.write_discipline ==="
    direct_candidates="$(mktemp "${TMPDIR:-/tmp}/beads-jsonl-direct-writes.XXXXXX")"
    dispatch_candidates="$(mktemp "${TMPDIR:-/tmp}/beads-jsonl-dispatch-hits.XXXXXX")"
    : >"$direct_candidates"
    : >"$dispatch_candidates"
    write_scan_roots=(
        "$HOME/.claude/commands/flywheel"
        "$HOME/.claude/skills/.flywheel/scripts"
        "$HOME/Developer/flywheel/.flywheel/scripts"
    )
    for scan_root in "${write_scan_roots[@]}"; do
        [[ -d "$scan_root" ]] || continue
        while IFS= read -r scan_file; do
            rg -n \
                -e '>>[[:space:]]*"?\$?[A-Za-z_][A-Za-z0-9_]*"?' \
                -e '>>.*issues\.jsonl' \
                -e 'open\(.*["'"'"']a["'"'"']' \
                -e '\.open\(.*["'"'"']a["'"'"']' \
                -e 'write_text\(' \
                -e 'cat[[:space:]].*>.*issues\.jsonl' \
                -e 'printf.*>.*issues\.jsonl' \
                "$scan_file" 2>/dev/null | sed "s#^#$scan_file:#" >>"$direct_candidates" || true
        done < <(rg -l --hidden --glob '*.sh' --glob '*.py' --glob '*.md' '\.beads/issues\.jsonl' "$scan_root" 2>/dev/null | sort -u)
    done
    for dispatch_log in "$HOME/.local/state/flywheel/dispatch-log.jsonl" "$HOME/Developer/flywheel/.flywheel/dispatch-log.jsonl"; do
        [[ -f "$dispatch_log" ]] || continue
        tail -n 800 "$dispatch_log" 2>/dev/null | rg -n -i '(\.beads/issues\.jsonl|issues_jsonl).*(jsonl_fallback|manual[ -]?append|fallback|append|write)' | sed "s#^#$dispatch_log:#" >>"$dispatch_candidates" || true
    done
    direct_count="$(wc -l <"$direct_candidates" | tr -d ' ')"
    dispatch_count="$(wc -l <"$dispatch_candidates" | tr -d ' ')"
    if [[ "$direct_count" =~ ^[0-9]+$ && "$dispatch_count" =~ ^[0-9]+$ && $((direct_count + dispatch_count)) -gt 0 ]]; then
        echo "⚠ direct issues.jsonl writer candidates=$direct_count dispatch_mentions=$dispatch_count"
        head -8 "$direct_candidates" | sed 's/^/  · /'
        head -3 "$dispatch_candidates" | sed 's/^/  · /'
        warn=$((warn+1))
    else
        echo "✓ no direct issues.jsonl writer candidates found in worker script scan"; ok=$((ok+1))
    fi
    rm -f "$direct_candidates" "$dispatch_candidates"

    echo "=== beads.recovery.bloat ==="
    recovery_warn=0
    recovery_seen=0
    recovery_max_kb="${FLYWHEEL_BEADS_RECOVERY_MAX_KB:-51200}"
    recovery_max_entries="${FLYWHEEL_BEADS_RECOVERY_MAX_ENTRIES:-1000}"
    if [[ -n "${FLYWHEEL_BEADS_RECOVERY_DIR:-}" ]]; then
        recovery_dirs=("$FLYWHEEL_BEADS_RECOVERY_DIR")
    else
        recovery_dirs=("$HOME/Developer/flywheel/.br_recovery" "$HOME/Developer/flywheel/.beads/.br_recovery")
    fi
    for recovery_dir in "${recovery_dirs[@]}"; do
        [[ -d "$recovery_dir" ]] || continue
        recovery_seen=$((recovery_seen + 1))
        recovery_kb="$(du -sk "$recovery_dir" 2>/dev/null | awk '{print $1+0}' || printf '0')"
        recovery_mb=$((recovery_kb / 1024))
        recovery_entries="$(find "$recovery_dir" -mindepth 1 -maxdepth 1 2>/dev/null | wc -l | tr -d ' ')"
        if (( recovery_kb > recovery_max_kb || recovery_entries > recovery_max_entries )); then
            echo "⚠ br_recovery_bloat path=$recovery_dir size_mb=$recovery_mb entries=$recovery_entries threshold_mb=$((recovery_max_kb / 1024)) threshold_entries=$recovery_max_entries"
            recovery_warn=$((recovery_warn + 1))
        else
            echo "✓ br_recovery_ok path=$recovery_dir size_mb=$recovery_mb entries=$recovery_entries"
        fi
    done
    if (( recovery_warn > 0 )); then
        warn=$((warn+1))
    elif (( recovery_seen > 0 )); then
        ok=$((ok+1))
    else
        echo "✓ br_recovery_not_present"
        ok=$((ok+1))
    fi

    echo "=== beads.sidecar.staleness ==="
    sidecar_tmp="$(mktemp "${TMPDIR:-/tmp}/beads-sidecar-stale.XXXXXX")"
    : >"$sidecar_tmp"
    sidecar_dir="${FLYWHEEL_BEADS_DIR:-$HOME/Developer/flywheel/.beads}"
    sidecar_days="${FLYWHEEL_BEADS_SIDECAR_STALE_DAYS:-7}"
    if [[ -d "$sidecar_dir" ]]; then
        find "$sidecar_dir" -maxdepth 1 -type f \( -name '*.aside.*' -o -name '*.bak.*' \) -mtime "+$sidecar_days" 2>/dev/null | sort >"$sidecar_tmp"
        sidecar_count="$(wc -l <"$sidecar_tmp" | tr -d ' ')"
        if [[ "$sidecar_count" =~ ^[0-9]+$ && "$sidecar_count" -gt 0 ]]; then
            echo "⚠ stale_beads_sidecars=$sidecar_count older_than_days=$sidecar_days dir=$sidecar_dir"
            head -8 "$sidecar_tmp" | sed 's/^/  · /'
            echo "  · recommended: .flywheel/scripts/storage-prune.sh --repo $HOME/Developer/flywheel --dry-run --json"
            warn=$((warn+1))
        else
            echo "✓ stale_beads_sidecars=0 older_than_days=$sidecar_days dir=$sidecar_dir"
            ok=$((ok+1))
        fi
    else
        echo "⚠ beads_dir_missing=$sidecar_dir"
        warn=$((warn+1))
    fi
    rm -f "$sidecar_tmp"

    echo "=== flywheel doctrine coverage invariant ==="
    doctrine_missing=0
    doctrine_scanned=0
    if [[ -d "$HOME/Developer" ]]; then
        while IFS= read -r repo; do
            commits_30d=$(git -C "$repo" log --since=30.days.ago --oneline 2>/dev/null | wc -l | tr -d ' ' || printf '0')
            [[ "$commits_30d" =~ ^[0-9]+$ ]] || commits_30d=0
            (( commits_30d > 0 )) || continue
            doctrine_scanned=$((doctrine_scanned + 1))
            if [[ -f "$repo/.flywheel-DISABLED" ]]; then
                continue
            fi
            if [[ ! -d "$repo/.flywheel" || ! -e "$repo/.flywheel/LOOP.md" ]]; then
                echo "⚠ project_missing_doctrine: $repo"
                doctrine_missing=$((doctrine_missing + 1))
            fi
        done < <(find "$HOME/Developer" -maxdepth 2 -type d -name .git -prune 2>/dev/null | while IFS= read -r gitdir; do dirname "$gitdir"; done | sort)
        if (( doctrine_missing > 0 )); then
            echo "⚠ project_missing_doctrine=$doctrine_missing"
            warn=$((warn + 1))
        else
            echo "✓ project_missing_doctrine=0"
            ok=$((ok + 1))
        fi
        echo "  · doctrine_active_projects_scanned=$doctrine_scanned"
    else
        echo "⚠ project_missing_doctrine=0"
        echo "  · doctrine_active_projects_scanned=0"
        echo "  · developer_root_missing=$HOME/Developer"
        warn=$((warn + 1))
    fi
    if grep -q 'CronDelete + CronCreate' "$HOME/.claude/references/claude-md-discipline.md" 2>/dev/null; then
        echo "✗ stale /loop cron doctrine still present in claude-md-discipline.md"; fail=$((fail+1))
    else
        echo "✓ stale /loop cron doctrine removed"; ok=$((ok+1))
    fi
    CODEX_DELTAS="${CODEX_CURRENT_DELTAS:-$HOME/.codex/CURRENT-DELTAS.md}"
    CODEX_LABEL="${FLYWHEEL_CODEX_LABEL:-ai.zeststream.flywheel-codex-snapshot}"
    CODEX_PLIST="$HOME/Library/LaunchAgents/${CODEX_LABEL}.plist"
    CODEX_STALE_SECONDS="${FLYWHEEL_CODEX_STALE_SECONDS:-21600}"
    CODEX_EPOCH=""
    if [[ -f "$CODEX_DELTAS" ]]; then
        CODEX_EPOCH=$(sed -nE 's/^- Generated: .*\(epoch ([0-9]+)\).*$/\1/p' "$CODEX_DELTAS" 2>/dev/null | head -1)
        if [[ -z "$CODEX_EPOCH" ]]; then
            CODEX_EPOCH=$(stat -f '%m' "$CODEX_DELTAS" 2>/dev/null || stat -c '%Y' "$CODEX_DELTAS" 2>/dev/null || true)
        fi
        if [[ "$CODEX_EPOCH" =~ ^[0-9]+$ ]]; then
            CODEX_AGE=$(( $(date -u +%s) - CODEX_EPOCH ))
            if (( CODEX_AGE <= CODEX_STALE_SECONDS )); then
                echo "✓ Codex CURRENT-DELTAS fresh (${CODEX_AGE}s old)"; ok=$((ok+1))
            elif (( CODEX_AGE <= CODEX_STALE_SECONDS * 2 )); then
                echo "⚠ Codex CURRENT-DELTAS stale (${CODEX_AGE}s old; run flywheel-codex-orient)"; warn=$((warn+1))
            else
                echo "✗ Codex CURRENT-DELTAS expired (${CODEX_AGE}s old; launchd snapshot may be down)"; fail=$((fail+1))
            fi
        else
            echo "✗ Codex CURRENT-DELTAS age unreadable ($CODEX_DELTAS)"; fail=$((fail+1))
        fi
    else
        echo "✗ Codex CURRENT-DELTAS missing ($CODEX_DELTAS)"; fail=$((fail+1))
    fi
    if [[ -f "$CODEX_PLIST" ]]; then
        echo "✓ Codex snapshot LaunchAgent plist present"; ok=$((ok+1))
    else
        echo "✗ Codex snapshot LaunchAgent plist missing ($CODEX_PLIST)"; fail=$((fail+1))
    fi
    if command -v launchctl >/dev/null 2>&1; then
        CODEX_LAUNCHD=$(launchctl print "gui/$(id -u)/${CODEX_LABEL}" 2>&1)
        CODEX_LAUNCHD_RC=$?
        if [[ "$CODEX_LAUNCHD_RC" -eq 0 ]] && printf '%s\n' "$CODEX_LAUNCHD" | grep -Eq 'last exit (code|status) = 0'; then
            echo "✓ Codex snapshot LaunchAgent last exit 0"; ok=$((ok+1))
        elif [[ "$CODEX_LAUNCHD_RC" -eq 0 ]]; then
            echo "⚠ Codex snapshot LaunchAgent loaded but last exit not proven 0"; warn=$((warn+1))
        else
            echo "✗ Codex snapshot LaunchAgent not loaded (${CODEX_LABEL})"; fail=$((fail+1))
        fi
    else
        echo "⚠ launchctl missing — Codex snapshot LaunchAgent status skipped"; warn=$((warn+1))
    fi
    set -e
    echo ""
    # ── docker / socraticode dependency (2026-04-27 trauma) ────
    echo "=== docker / socraticode dependency ==="
    set +e
    DOCKER_PROBE="$HOME/.claude/skills/docker-troubleshooting/scripts/health-probe.sh"
    ORPHAN_DETECT="$HOME/.claude/skills/docker-troubleshooting/scripts/preflight-orphan-detector.sh"
    if [[ -x "$DOCKER_PROBE" ]]; then
        probe_out=$("$DOCKER_PROBE" --json 2>/dev/null || true)
        probe_status=$(printf '%s' "$probe_out" | jq -r '.status // "UNKNOWN"' 2>/dev/null || echo "UNKNOWN")
        if [[ "$probe_status" == "STORAGE_CRITICAL" ]]; then
            # 2026-04-27 coupling: docker probe gates on storage probe.
            s_pct_embed=$(printf '%s' "$probe_out" | jq -r '.storage_state.free_pct // "?"' 2>/dev/null || echo "?")
            echo "✗ docker pre-flight failed: storage CRITICAL (${s_pct_embed}% free)"; fail=$((fail+1))
            echo "    → fix storage first: ~/.claude/skills/storage-health/scripts/recovery-ladder.sh 2"
        elif [[ "$probe_status" == "HEALTHY" ]]; then
            # G54 2026-04-27: probe now reports engine (orbstack | docker-desktop | none)
            probe_engine=$(printf '%s' "$probe_out" | jq -r '.engine // "unknown"' 2>/dev/null || echo "unknown")
            echo "✓ docker daemon healthy [engine=${probe_engine}]"; ok=$((ok+1))
            # uptime warning only meaningful for Docker Desktop's com.docker.backend
            if [[ "$probe_engine" == "docker-desktop" ]]; then
                max_etime=$( { pgrep -f 'com.docker.backend' 2>/dev/null | while read -r p; do ps -o etime= -p "$p" 2>/dev/null || true; done | sed -nE 's/^[[:space:]]*([0-9]+)-.*$/\1/p' | sort -n | tail -1; } || true )
                if [[ -n "${max_etime:-}" && "$max_etime" =~ ^[0-9]+$ && "$max_etime" -ge 7 ]]; then
                    echo "⚠ com.docker.backend uptime ${max_etime} days (>7 = silent-hang risk; restart Docker.app)"; warn=$((warn+1))
                fi
            fi
            # qdrant on :6433 reachable + collection count
            qcount=$(curl -s --max-time 3 http://localhost:6433/collections 2>/dev/null | jq -r '.result.collections | length' 2>/dev/null || echo "")
            if [[ -n "$qcount" && "$qcount" =~ ^[0-9]+$ ]]; then
                echo "✓ qdrant on :6433 reachable (collections=$qcount)"; ok=$((ok+1))
            else
                echo "✗ qdrant on :6433 unreachable"; fail=$((fail+1))
            fi
            # socraticode MCP container present
            if docker ps --format '{{.Names}}' 2>/dev/null | grep -qE '^(socraticode|qdrant-socraticode)'; then
                echo "✓ socraticode MCP container present"; ok=$((ok+1))
            else
                echo "✗ socraticode MCP container missing"; fail=$((fail+1))
            fi
            # orphan detection (advisory)
            if [[ -x "$ORPHAN_DETECT" ]]; then
                orphan_out=$("$ORPHAN_DETECT" 2>/dev/null || true)
                orphan_status=$(printf '%s' "$orphan_out" | jq -r '.status // "?"' 2>/dev/null || echo "?")
                orphans_n=$(printf '%s' "$orphan_out" | jq -r '.orphans // 0' 2>/dev/null || echo 0)
                if [[ "$orphan_status" == "CLEAN" ]]; then
                    echo "✓ no orphan duplicate-named containers"; ok=$((ok+1))
                elif [[ "$orphans_n" -gt 0 ]]; then
                    echo "⚠ orphan containers detected: $orphans_n (run preflight-orphan-detector.sh --verbose)"; warn=$((warn+1))
                else
                    echo "  · orphan detector: $orphan_status"
                fi
            fi
        else
            reason=$(printf '%s' "$probe_out" | jq -r '.reason // "unknown"' 2>/dev/null || echo "unknown")
            echo "✗ docker daemon $probe_status: $reason"; fail=$((fail+1))
            echo "    → run: ~/.claude/skills/docker-troubleshooting/scripts/recovery-ladder.sh 2"
        fi
    else
        echo "⚠ docker-troubleshooting health-probe missing"; warn=$((warn+1))
    fi
    # ── qdrant_unreachable_socraticode_will_fail invariant (G53 trauma 2026-04-27) ──
    # Always probe, even if docker probe says DOWN — OrbStack cutover broke the
    # Docker-Desktop-PID heuristic while qdrant was still reachable via OrbStack.
    qcheck=$(curl -s --max-time 3 http://localhost:6433/collections 2>/dev/null | jq -e '.result.collections' 2>/dev/null || true)
    if [[ -n "$qcheck" ]]; then
        qcount2=$(printf '%s' "$qcheck" | jq 'length' 2>/dev/null || echo "?")
        echo "✓ qdrant_unreachable_socraticode_will_fail: qdrant :6433 reachable (collections=$qcount2)"; ok=$((ok+1))
    else
        echo "✗ qdrant_unreachable_socraticode_will_fail: socraticode MCP will fail"; fail=$((fail+1))
        echo "    → recover: docker start qdrant-socraticode 2>/dev/null || docker run -d --name qdrant-socraticode --restart unless-stopped -p 6433:6333 -p 6434:6334 -v qdrant-socraticode:/qdrant/storage qdrant/qdrant:latest"
    fi
    set -e
    echo ""
    # ── socraticode serial-index invariant (2026-04-27 trauma) ───────────────
    # Parallel codebase_index calls saturate ollama+qdrant and freeze
    # codex/claude panes sharing socraticode MCP children. Lockfile wrapper at
    # ~/.claude/skills/socraticode/scripts/serial-index.sh enforces serial.
    # Doctor verifies: (1) wrapper exists+exec, (2) lock not stale >2h,
    # (3) jsonl shows no orphan acquired without completed/errored,
    # (4) at most one node-socraticode embedder process older than 30s.
    echo "=== socraticode serial-index invariant ==="
    set +e
    SI_WRAPPER="$HOME/.claude/skills/socraticode/scripts/serial-index.sh"
    SI_LOCK="$HOME/.local/state/socraticode/serial-index.lock"
    SI_LOG="$HOME/.claude/skills/reports/socraticode-serial-index.jsonl"
    if [[ ! -x "$SI_WRAPPER" ]]; then
        echo "✗ serial-index wrapper missing or non-executable: $SI_WRAPPER"; fail=$((fail+1))
    else
        echo "✓ serial-index wrapper present"; ok=$((ok+1))
    fi
    # (2) stale lock check
    if [[ -d "$SI_LOCK" ]]; then
        if [[ -f "$SI_LOCK/holder" ]]; then
            si_started=$(awk -F= '/^started=/{print $2; exit}' "$SI_LOCK/holder" 2>/dev/null || echo "")
            si_pid=$(awk -F= '/^pid=/{print $2; exit}' "$SI_LOCK/holder" 2>/dev/null || echo "")
            si_age_s=0
            if [[ -n "$si_started" ]]; then
                si_epoch=$(date -j -u -f "%Y-%m-%dT%H:%M:%SZ" "$si_started" "+%s" 2>/dev/null || echo 0)
                now=$(date -u +%s)
                si_age_s=$(( now - si_epoch ))
            fi
            if [[ -n "$si_pid" ]] && ! kill -0 "$si_pid" 2>/dev/null; then
                echo "⚠ serial-index lock held by dead pid=$si_pid — next caller will steal"; warn=$((warn+1))
            elif (( si_age_s > 7200 )); then
                echo "⚠ serial-index lock stale ${si_age_s}s (>2h) pid=$si_pid"; warn=$((warn+1))
            else
                echo "✓ serial-index lock active (pid=$si_pid age=${si_age_s}s)"; ok=$((ok+1))
            fi
        else
            echo "⚠ serial-index lock dir exists without holder file"; warn=$((warn+1))
        fi
    else
        echo "✓ serial-index lock free"; ok=$((ok+1))
    fi
    # (3) jsonl orphan-acquired check (≥2 acquired without intervening close = violation)
    if [[ -f "$SI_LOG" ]]; then
        si_orphans=$(awk -F'"action":"' '
            /"action":"/ {
                split($2,a,"\""); act=a[1]
                if (act=="acquired") open++
                else if (act=="completed" || act=="errored") { if(open>0) open-- }
            }
            END { print open }
        ' "$SI_LOG" 2>/dev/null || echo 0)
        if (( si_orphans >= 2 )); then
            echo "✗ serial-index: $si_orphans orphan 'acquired' events — concurrent index VIOLATION"; fail=$((fail+1))
        elif (( si_orphans == 1 )); then
            echo "✓ serial-index log healthy (1 in-flight acquired)"; ok=$((ok+1))
        else
            echo "✓ serial-index log healthy (no acquired without close)"; ok=$((ok+1))
        fi
    else
        echo "✓ serial-index log not yet created (no runs)"; ok=$((ok+1))
    fi
    # (4) socraticode embedder process count >30s old
    # Threshold >20 (not >1): each active claude/codex pane keeps a long-lived
    # MCP stdio child; the original 38-parallel trauma is detected by the
    # serial-index lockfile (above) and the serial-update invariant (below),
    # not by raw process count. >20 leaves headroom for ~16 panes + slack.
    si_old=$({ ps -axo pid,etimes,command 2>/dev/null || true; } | { awk '
        /node.*socraticode/ && $2 > 30 { n++ }
        END { print n+0 }
    ' 2>/dev/null || echo 0; } | tr -dc '0-9\n' | head -1)
    si_old="${si_old:-0}"
    [[ "$si_old" =~ ^[0-9]+$ ]] || si_old=0
    if [[ "$si_old" -gt 20 ]]; then
        echo "✗ serial-index: $si_old socraticode processes >30s old (>20) — possible parallel indexer storm; check lockfile + serial-update log"; fail=$((fail+1))
    else
        echo "✓ serial-index: $si_old long-running socraticode process(es) (1 per pane is normal)"; ok=$((ok+1))
    fi
    set -e
    echo ""
    # ── socraticode serial-update invariant (2026-04-27 G86 hardening) ───────
    # codebase_update shares the ollama+qdrant backend with codebase_index;
    # parallel updates re-create the freeze trauma. Lockfile wrapper at
    # ~/.claude/skills/socraticode/scripts/serial-update.sh enforces serial.
    # 3 sub-checks: (1) wrapper present, (2) lock free or active-non-stale,
    # (3) jsonl shows no orphan acquired without close.
    echo "=== socraticode serial-update invariant ==="
    set +e
    SU_WRAPPER="$HOME/.claude/skills/socraticode/scripts/serial-update.sh"
    SU_LOCK="$HOME/.local/state/socraticode/serial-update.lock"
    SU_LOG="$HOME/.claude/skills/reports/socraticode-serial-update.jsonl"
    if [[ ! -x "$SU_WRAPPER" ]]; then
        echo "✗ serial-update wrapper missing or non-executable: $SU_WRAPPER"; fail=$((fail+1))
    else
        echo "✓ serial-update wrapper present"; ok=$((ok+1))
    fi
    if [[ -d "$SU_LOCK" ]]; then
        if [[ -f "$SU_LOCK/holder" ]]; then
            su_started=$(awk -F= '/^started=/{print $2; exit}' "$SU_LOCK/holder" 2>/dev/null || echo "")
            su_pid=$(awk -F= '/^pid=/{print $2; exit}' "$SU_LOCK/holder" 2>/dev/null || echo "")
            su_age_s=0
            if [[ -n "$su_started" ]]; then
                su_epoch=$(date -j -u -f "%Y-%m-%dT%H:%M:%SZ" "$su_started" "+%s" 2>/dev/null || echo 0)
                now=$(date -u +%s)
                su_age_s=$(( now - su_epoch ))
            fi
            if [[ -n "$su_pid" ]] && ! kill -0 "$su_pid" 2>/dev/null; then
                echo "⚠ serial-update lock held by dead pid=$su_pid — next caller will steal"; warn=$((warn+1))
            elif (( su_age_s > 7200 )); then
                echo "⚠ serial-update lock stale ${su_age_s}s (>2h) pid=$su_pid"; warn=$((warn+1))
            else
                echo "✓ serial-update lock active (pid=$su_pid age=${su_age_s}s)"; ok=$((ok+1))
            fi
        else
            echo "⚠ serial-update lock dir exists without holder file"; warn=$((warn+1))
        fi
    else
        echo "✓ serial-update lock free"; ok=$((ok+1))
    fi
    if [[ -f "$SU_LOG" ]]; then
        su_orphans=$(awk -F'"action":"' '
            /"action":"/ {
                split($2,a,"\""); act=a[1]
                if (act=="acquired") open++
                else if (act=="completed" || act=="errored") { if(open>0) open-- }
            }
            END { print open }
        ' "$SU_LOG" 2>/dev/null || echo 0)
        if (( su_orphans >= 2 )); then
            echo "✗ serial-update: $su_orphans orphan 'acquired' events — concurrent update VIOLATION"; fail=$((fail+1))
        elif (( su_orphans == 1 )); then
            echo "✓ serial-update log healthy (1 in-flight acquired)"; ok=$((ok+1))
        else
            echo "✓ serial-update log healthy (no acquired without close)"; ok=$((ok+1))
        fi
    else
        echo "✓ serial-update log not yet created (no runs)"; ok=$((ok+1))
    fi
    set -e
    echo ""
    # ── socraticode serial-graph-build invariant (2026-04-27 G86 hardening) ──
    # codebase_graph_build is long-running CPU + qdrant write; parallel calls
    # stack minute-scale work and contend on graph collection.
    # ~/.claude/skills/socraticode/scripts/serial-graph-build.sh enforces serial.
    # 3 sub-checks: (1) wrapper present, (2) lock free or active-non-stale,
    # (3) jsonl shows no orphan acquired without close.
    echo "=== socraticode serial-graph-build invariant ==="
    set +e
    SG_WRAPPER="$HOME/.claude/skills/socraticode/scripts/serial-graph-build.sh"
    SG_LOCK="$HOME/.local/state/socraticode/serial-graph-build.lock"
    SG_LOG="$HOME/.claude/skills/reports/socraticode-serial-graph-build.jsonl"
    if [[ ! -x "$SG_WRAPPER" ]]; then
        echo "✗ serial-graph-build wrapper missing or non-executable: $SG_WRAPPER"; fail=$((fail+1))
    else
        echo "✓ serial-graph-build wrapper present"; ok=$((ok+1))
    fi
    if [[ -d "$SG_LOCK" ]]; then
        if [[ -f "$SG_LOCK/holder" ]]; then
            sg_started=$(awk -F= '/^started=/{print $2; exit}' "$SG_LOCK/holder" 2>/dev/null || echo "")
            sg_pid=$(awk -F= '/^pid=/{print $2; exit}' "$SG_LOCK/holder" 2>/dev/null || echo "")
            sg_age_s=0
            if [[ -n "$sg_started" ]]; then
                sg_epoch=$(date -j -u -f "%Y-%m-%dT%H:%M:%SZ" "$sg_started" "+%s" 2>/dev/null || echo 0)
                now=$(date -u +%s)
                sg_age_s=$(( now - sg_epoch ))
            fi
            if [[ -n "$sg_pid" ]] && ! kill -0 "$sg_pid" 2>/dev/null; then
                echo "⚠ serial-graph-build lock held by dead pid=$sg_pid — next caller will steal"; warn=$((warn+1))
            elif (( sg_age_s > 14400 )); then
                echo "⚠ serial-graph-build lock stale ${sg_age_s}s (>4h) pid=$sg_pid"; warn=$((warn+1))
            else
                echo "✓ serial-graph-build lock active (pid=$sg_pid age=${sg_age_s}s)"; ok=$((ok+1))
            fi
        else
            echo "⚠ serial-graph-build lock dir exists without holder file"; warn=$((warn+1))
        fi
    else
        echo "✓ serial-graph-build lock free"; ok=$((ok+1))
    fi
    if [[ -f "$SG_LOG" ]]; then
        sg_orphans=$(awk -F'"action":"' '
            /"action":"/ {
                split($2,a,"\""); act=a[1]
                if (act=="acquired") open++
                else if (act=="completed" || act=="errored") { if(open>0) open-- }
            }
            END { print open }
        ' "$SG_LOG" 2>/dev/null || echo 0)
        if (( sg_orphans >= 2 )); then
            echo "✗ serial-graph-build: $sg_orphans orphan 'acquired' events — concurrent build VIOLATION"; fail=$((fail+1))
        elif (( sg_orphans == 1 )); then
            echo "✓ serial-graph-build log healthy (1 in-flight acquired)"; ok=$((ok+1))
        else
            echo "✓ serial-graph-build log healthy (no acquired without close)"; ok=$((ok+1))
        fi
    else
        echo "✓ serial-graph-build log not yet created (no runs)"; ok=$((ok+1))
    fi
    set -e
    echo ""
    # ── storage health (2026-04-27 Tier-0) ─────────────────────
    echo "=== storage health ==="
    set +e
    STORAGE_PROBE="$HOME/.claude/skills/storage-health/scripts/health-probe.sh"
    if [[ -x "$STORAGE_PROBE" ]]; then
        s_out=$("$STORAGE_PROBE" --json 2>/dev/null || true)
        s_status=$(printf '%s' "$s_out" | jq -r '.status // "UNKNOWN"' 2>/dev/null || echo "UNKNOWN")
        s_tier=$(printf '%s' "$s_out" | jq -r '.tier // "?"' 2>/dev/null || echo "?")
        s_pct=$(printf '%s' "$s_out" | jq -r '.free_pct // "?"' 2>/dev/null || echo "?")
        s_gb=$(printf '%s' "$s_out" | jq -r '.free_gb // "?"' 2>/dev/null || echo "?")
        # G40 5-tier banner: visualize where we sit
        case "$s_tier" in
            comfortable) echo "  [tier banner] [COMFORTABLE >50%] *MONITOR 30-50  SOFT_PRUNE 15-30  CRITICAL 5-15  FIRE <5" ;;
            monitor)     echo "  [tier banner]  COMFORTABLE >50  [MONITOR 30-50%] SOFT_PRUNE 15-30  CRITICAL 5-15  FIRE <5" ;;
            soft_prune)  echo "  [tier banner]  COMFORTABLE >50   MONITOR 30-50  [SOFT_PRUNE 15-30%] CRITICAL 5-15  FIRE <5" ;;
            critical)    echo "  [tier banner]  COMFORTABLE >50   MONITOR 30-50   SOFT_PRUNE 15-30  [CRITICAL 5-15%] FIRE <5" ;;
            fire)        echo "  [tier banner]  COMFORTABLE >50   MONITOR 30-50   SOFT_PRUNE 15-30   CRITICAL 5-15  [FIRE <5%]" ;;
            *)           echo "  [tier banner]  (tier=$s_tier — schema mismatch)" ;;
        esac
        case "$s_status" in
            HEALTHY|COMFORTABLE|MONITOR)
                echo "✓ disk free ${s_pct}% (${s_gb} GB available) — tier=${s_tier}"; ok=$((ok+1))
                ;;
            WARN|SOFT_PRUNE)
                echo "⚠ disk free ${s_pct}% (${s_gb} GB) — SOFT_PRUNE — run: ~/.claude/skills/dev-cache-janitor/scripts/recovery-ladder.sh 0  (or storage-health L1)"; warn=$((warn+1))
                ;;
            CRITICAL)
                echo "✗ disk free ${s_pct}% (${s_gb} GB) — CRITICAL, run: ~/.claude/skills/storage-health/scripts/recovery-ladder.sh 1"; fail=$((fail+1))
                ;;
            FIRE)
                echo "🔥 disk free ${s_pct}% (${s_gb} GB) — FIRE: factory-reset/external-offload territory. Manual only. See orbstack-migration."; fail=$((fail+1))
                ;;
            ANOMALY)
                echo "⚠ disk free ${s_pct}% OK but bloater anomaly detected"; warn=$((warn+1))
                ;;
            *)
                echo "  · storage probe status=$s_status"
                ;;
        esac
        # docker volumes total (gate on docker healthy via earlier var)
        if [[ "${probe_status:-}" == "HEALTHY" ]] && command -v docker >/dev/null 2>&1; then
            v_total=$(docker system df 2>/dev/null | awk '/Local Volumes/ {for (i=1;i<=NF;i++) if ($i ~ /B$/) {print $i; exit}}')
            [[ -n "$v_total" ]] && echo "  · docker volumes total: $v_total"
        fi
        # flywheel logs dir
        if [[ -d "$FLYWHEEL_HOME/logs" ]]; then
            fw_logs_sz=$(du -sh "$FLYWHEEL_HOME/logs" 2>/dev/null | awk '{print $1}')
            echo "  · ~/.claude/skills/.flywheel/logs size: ${fw_logs_sz:-?}"
        fi
        # top bloater anomaly check (>50GB)
        anomaly=$(printf '%s' "$s_out" | jq -r '[.top_bloaters[] | select(.gb >= 50)] | length' 2>/dev/null || echo 0)
        if [[ "$anomaly" =~ ^[0-9]+$ && "$anomaly" -gt 0 ]]; then
            top=$(printf '%s' "$s_out" | jq -r '.top_bloaters | map(select(.gb >= 50)) | map(.label + "=" + (.gb|tostring) + "GB") | join(", ")' 2>/dev/null)
            echo "⚠ top-bloater >50GB anomalies: $top"; warn=$((warn+1))
        else
            echo "✓ no top-bloater >50GB anomalies"; ok=$((ok+1))
        fi
        # docker_raw_oversized invariant (2026-04-27 coupling): Docker.raw >100GB AND free <20%
        raw_gb=$(printf '%s' "$s_out" | jq -r '[.top_bloaters[] | select(.label=="docker_raw") | .gb] | first // 0' 2>/dev/null || echo 0)
        free_int=$(printf '%s' "$s_pct" | awk '{printf "%d", $1+0}' 2>/dev/null || echo 100)
        raw_int=$(printf '%s' "$raw_gb" | awk '{printf "%d", $1+0}' 2>/dev/null || echo 0)
        if [[ "$raw_int" -gt 100 && "$free_int" -lt 20 ]]; then
            echo "⚠ docker_raw_oversized: Docker.raw=${raw_gb}GB AND free=${s_pct}% (<20%) — see ~/.claude/skills/storage-health/references/STORAGE-DOCKER-COUPLING.md"; warn=$((warn+1))
        else
            echo "✓ docker_raw_oversized: Docker.raw=${raw_gb}GB, free=${s_pct}%"; ok=$((ok+1))
        fi
    else
        echo "⚠ storage-health probe missing"; warn=$((warn+1))
    fi
    set -e
    echo ""
    # ── system health (G66 2026-04-27; Tier-0; load/CPU saturation) ──
    echo "=== system health ==="
    set +e
    SYS_PROBE="$HOME/.claude/skills/system-health/scripts/health-probe.sh"
    if [[ -x "$SYS_PROBE" ]]; then
        sys_out=$("$SYS_PROBE" --json 2>/dev/null || true)
        sys_tier=$(printf '%s' "$sys_out" | jq -r '.tier // "?"' 2>/dev/null || echo "?")
        sys_load=$(printf '%s' "$sys_out" | jq -r '.load_1m // 0' 2>/dev/null || echo 0)
        sys_cores=$(printf '%s' "$sys_out" | jq -r '.cores // 1' 2>/dev/null || echo 1)
        sys_ratio=$(printf '%s' "$sys_out" | jq -r '.ratio_1m // 0' 2>/dev/null || echo 0)
        sys_phantom=$(printf '%s' "$sys_out" | jq -r '.runtime_phantom_cellar_procs // .phantom_cellar_paths // 0' 2>/dev/null || echo 0)
        sys_bg=$(printf '%s' "$sys_out" | jq -r '.bg_agent_procs // 0' 2>/dev/null || echo 0)
        case "$sys_tier" in
            comfortable|busy)
                echo "✓ load: $sys_load / $sys_cores cores [$sys_tier] (ratio=$sys_ratio)"; ok=$((ok+1)) ;;
            saturated)
                echo "⚠ load: $sys_load / $sys_cores cores [SATURATED] (ratio=$sys_ratio) — pause bg-agents: ~/.claude/skills/system-health/scripts/recovery-ladder.sh 1"; warn=$((warn+1)) ;;
            critical)
                echo "✗ load: $sys_load / $sys_cores cores [CRITICAL] (ratio=$sys_ratio) — halt new dispatches: ~/.claude/skills/system-health/scripts/recovery-ladder.sh 2"; fail=$((fail+1)) ;;
            fire)
                echo "🔥 load: $sys_load / $sys_cores cores [FIRE] (ratio=$sys_ratio) — manual intervention; APPROVE=yes ~/.claude/skills/system-health/scripts/recovery-ladder.sh 3"; fail=$((fail+1)) ;;
            *) echo "  · system probe tier=$sys_tier" ;;
        esac
        # Top CPU summary (3 highest)
        sys_top=$(printf '%s' "$sys_out" | jq -r '.top_cpu | .[0:3] | map((.cmd | split("/") | last) + " (" + (.pct|tostring) + "%)") | join(", ")' 2>/dev/null || echo "")
        [[ -n "$sys_top" ]] && echo "  · top CPU: $sys_top"
        # Phantom-Cellar invariant (cross-couple python-health G34)
        if [[ "$sys_phantom" -gt 0 ]]; then
            echo "⚠ runtime_phantom_cellar_procs: $sys_phantom live process(es) bound to brew Cellar python — see python-health/references/FOREVER-RULES.md rule #5b (live-proc trauma)"; warn=$((warn+1))
        else
            echo "✓ runtime_phantom_cellar_procs: 0 (no brew Cellar python procs in top CPU/RSS)"; ok=$((ok+1))
        fi
        echo "  · bg-agents: $sys_bg"
    else
        echo "⚠ system-health probe missing"; warn=$((warn+1))
    fi
    set -e
    echo ""
    # ── tmux/ntm health (G69 2026-04-27; pane-aware; 7-day-wedged-stdio trauma) ──
    echo "=== tmux/ntm health ==="
    set +e
    if [[ -x "$SYS_PROBE" ]] && [[ -n "${sys_out:-}" ]]; then
        tx_sess=$(printf '%s' "$sys_out" | jq -r '.tmux.sessions_count // 0' 2>/dev/null || echo 0)
        tx_panes=$(printf '%s' "$sys_out" | jq -r '.tmux.panes_count // 0' 2>/dev/null || echo 0)
        tx_stale_mcp=$(printf '%s' "$sys_out" | jq -r '.tmux.stale_mcp_stdio_children | length' 2>/dev/null || echo 0)
        tx_stale_panes=$(printf '%s' "$sys_out" | jq -r '.tmux.panes_attached_no_input_24h | length' 2>/dev/null || echo 0)
        tx_versions=$(printf '%s' "$sys_out" | jq -r '.tmux.version_drift | length' 2>/dev/null || echo 0)
        tx_versions_list=$(printf '%s' "$sys_out" | jq -r '.tmux.version_drift | join(", ")' 2>/dev/null || echo "")
        tx_ghost=$(printf '%s' "$sys_out" | jq -r '.tmux.ghost_panes | length' 2>/dev/null || echo 0)
        tx_wedged=$(printf '%s' "$sys_out" | jq -r '.tmux.wedged_codex_panes | length' 2>/dev/null || echo 0)
        if [[ "$tx_sess" -gt 0 ]]; then
            echo "✓ tmux server running, $tx_sess sessions, $tx_panes panes"; ok=$((ok+1))
        else
            echo "  · tmux not running"
        fi
        if [[ "$tx_stale_mcp" -gt 0 ]]; then
            echo "⚠ $tx_stale_mcp stdio MCP children >24h (potential codex-freeze risk — see system-health probe.sh stale_mcp_stdio_children)"; warn=$((warn+1))
        else
            echo "✓ no stale stdio MCP children"; ok=$((ok+1))
        fi
        if [[ "$tx_versions" -gt 1 ]]; then
            echo "⚠ claude version drift: $tx_versions distinct versions across panes ($tx_versions_list) — restart drifted panes; see PANE-RECOVERY.md §3"; warn=$((warn+1))
        else
            echo "✓ no claude version drift ($tx_versions_list)"; ok=$((ok+1))
        fi
        if [[ "$tx_ghost" -gt 0 ]]; then
            echo "⚠ $tx_ghost ghost ntm sessions (declared in ntm state but no live tmux session) — see PANE-RECOVERY.md §4"; warn=$((warn+1))
        else
            echo "✓ no ghost panes"; ok=$((ok+1))
        fi
        if [[ "$tx_wedged" -gt 0 ]]; then
            echo "🔥 $tx_wedged wedged codex panes (codex+stale 24h+) — see PANE-RECOVERY.md §2 (Ctrl-C twice via tmux send-keys)"; fail=$((fail+1))
        else
            echo "✓ no wedged codex panes"; ok=$((ok+1))
        fi
        if [[ "$tx_stale_panes" -gt 0 ]]; then
            echo "⚠ $tx_stale_panes attached panes idle >24h — review for orphan workers"; warn=$((warn+1))
        fi
    else
        echo "  · tmux probe unavailable (system-health probe missing)"
    fi
    set -e
    echo ""
    # ── idle-pane-watch invariant (G17 partial-close, 2026-04-27) ──
    echo "=== idle-pane-watch invariant ==="
    set +e
    IPW_SCRIPT="$HOME/.claude/skills/.flywheel/scripts/idle-drifted-panes.sh"
    IPW_PLIST="com.zeststream.flywheel-idle-pane-watch"
    IPW_OUT="$HOME/.cache/flywheel/idle-pane-watch.out.log"
    if [[ ! -x "$IPW_SCRIPT" ]]; then
        echo "✗ idle-pane-watch script missing or non-executable: $IPW_SCRIPT"; fail=$((fail+1))
    else
        echo "✓ idle-pane-watch script present + executable"; ok=$((ok+1))
    fi
    if launchctl list 2>/dev/null | grep -q "$IPW_PLIST"; then
        echo "✓ idle-pane-watch plist registered (launchctl)"; ok=$((ok+1))
    else
        echo "⚠ idle-pane-watch plist not registered (launchctl bootstrap gui/\$UID ~/Library/LaunchAgents/$IPW_PLIST.plist)"; warn=$((warn+1))
    fi
    if [[ -f "$IPW_OUT" ]]; then
        ipw_mtime=$(stat -f %m "$IPW_OUT" 2>/dev/null || echo 0)
        ipw_age=$(( $(date +%s) - ipw_mtime ))
        if (( ipw_age < 3600 )); then
            echo "✓ idle-pane-watch last run ${ipw_age}s ago (<1h)"; ok=$((ok+1))
        elif (( ipw_age < 7200 )); then
            echo "⚠ idle-pane-watch last run ${ipw_age}s ago (1-2h, slightly stale)"; warn=$((warn+1))
        else
            echo "⚠ idle-pane-watch last run ${ipw_age}s ago (>2h — plist may be stalled)"; warn=$((warn+1))
        fi
    else
        echo "  · idle-pane-watch log not yet created (first 30-min interval pending)"
    fi
    set -e
    echo ""
    # ── VLAN-dependent gaps (G12/G14/G15 auto-resolver, 2026-04-27) ──
    if [[ "$DOCTOR_DEEP" != "1" ]]; then
        echo "=== VLAN-dependent gaps: G12/G14/G15 status ==="
        echo "○ skipped in fast doctor (run: flywheel doctor --deep)"
        echo ""
    else
    echo "=== VLAN-dependent gaps: G12/G14/G15 status ==="
    set +e
    VLAN_RESOLVER="$HOME/.claude/skills/.flywheel/scripts/vlan-auto-resolver.sh"
    VLAN_LAST="$HOME/.claude/skills/reports/vlan-auto-resolver-last.json"
    if [[ -x "$VLAN_RESOLVER" ]]; then
        # Run probe on each doctor invocation (cheap, idempotent, race-safe via mkdir lock).
        "$VLAN_RESOLVER" >/dev/null 2>&1 || true
        if [[ -f "$VLAN_LAST" ]]; then
            v_state=$(jq -r '.vlan_state // "?"' "$VLAN_LAST" 2>/dev/null || echo "?")
            v_trans=$(jq -r '.transition // "none"' "$VLAN_LAST" 2>/dev/null || echo "none")
            v_acts=$(jq -r '.actions | join(",")' "$VLAN_LAST" 2>/dev/null || echo "")
            if [[ "$v_state" == "up" ]]; then
                v_g12=$(jq -r '.g12.ok' "$VLAN_LAST"); v_g14=$(jq -r '.g14.ok' "$VLAN_LAST"); v_g15=$(jq -r '.g15.ok' "$VLAN_LAST")
                echo "✓ VLAN reachable (10.10.20.10:6333) — G12=$v_g12 G14=$v_g14 G15=$v_g15${v_acts:+ actions=[$v_acts]}"; ok=$((ok+1))
            else
                echo "  · VLAN unreachable (10.10.20.10:6333) — G12/G14/G15 deferred; auto-resolver will close on return (last=$v_trans)"
            fi
        else
            echo "  · vlan-auto-resolver: no last-result yet (first run)"
        fi
    else
        echo "⚠ vlan-auto-resolver script missing or not executable"; warn=$((warn+1))
    fi
    set -e
    echo ""
    fi
    # ── python health (2026-04-27 G33; Tier-0; storage-coupled) ─────
    if [[ "$DOCTOR_DEEP" != "1" ]]; then
        echo "=== python health ==="
        py_inv="$HOME/.local/state/python/inventory.md"
        if [[ -f "$py_inv" ]]; then
            inv_age_d=$(( ( $(date +%s) - $(stat -f %m "$py_inv" 2>/dev/null || echo 0) ) / 86400 ))
            if [[ "$inv_age_d" -gt 14 ]]; then
                echo "⚠ python inventory.md is ${inv_age_d}d stale — run deep doctor or python-health inventory"; warn=$((warn+1))
            else
                echo "✓ python inventory.md fresh (${inv_age_d}d old)"; ok=$((ok+1))
            fi
        else
            echo "⚠ python inventory.md missing — run flywheel doctor --deep"; warn=$((warn+1))
        fi
        echo "○ full venv/cache/version scan skipped in fast doctor (run: flywheel doctor --deep)"
        echo ""
    else
    echo "=== python health ==="
    set +e
    PY_PROBE="$HOME/.claude/skills/python-health/scripts/health-probe.sh"
    if [[ -x "$PY_PROBE" ]]; then
        # Skip the storage gate inside doctor (we already reported storage above)
        py_out=$(PYHEALTH_SKIP_STORAGE=1 "$PY_PROBE" --json 2>/dev/null || true)
        py_status=$(printf '%s' "$py_out" | jq -r '.status // "UNKNOWN"' 2>/dev/null || echo "UNKNOWN")
        py_total=$(printf '%s' "$py_out" | jq -r '.venvs_total // 0' 2>/dev/null || echo 0)
        py_broken=$(printf '%s' "$py_out" | jq -r '.venvs_broken // 0' 2>/dev/null || echo 0)
        py_orphan=$(printf '%s' "$py_out" | jq -r '.venvs_orphan // 0' 2>/dev/null || echo 0)
        py_pip=$(printf '%s' "$py_out" | jq -r '.cache_gb.pip // 0' 2>/dev/null || echo 0)
        py_uv=$(printf '%s' "$py_out" | jq -r '.cache_gb.uv // 0' 2>/dev/null || echo 0)
        py_hf=$(printf '%s' "$py_out" | jq -r '.cache_gb.huggingface // 0' 2>/dev/null || echo 0)
        py_total_cache=$(printf '%s' "$py_out" | jq -r '.cache_gb.total // 0' 2>/dev/null || echo 0)
        py_versions=$(printf '%s' "$py_out" | jq -r '.version_distribution | to_entries | map(.key+"="+ (.value|tostring)) | join(" ")' 2>/dev/null || echo "")
        # Venvs line
        if [[ "$py_broken" -gt 0 || "$py_orphan" -gt 2 ]]; then
            echo "⚠ ${py_total} venvs total, ${py_broken} broken, ${py_orphan} orphan"; warn=$((warn+1))
        else
            echo "✓ ${py_total} venvs healthy (${py_broken} broken, ${py_orphan} orphan)"; ok=$((ok+1))
        fi
        # Cache line
        cache_int=$(printf '%s' "$py_total_cache" | awk '{printf "%d", $1+0}' 2>/dev/null || echo 0)
        if [[ "$cache_int" -gt 30 ]]; then
            echo "✗ python caches: ${py_total_cache}GB total (pip ${py_pip}, uv ${py_uv}, hf ${py_hf}) — run python-health L1"; fail=$((fail+1))
        elif [[ "$cache_int" -gt 10 ]]; then
            echo "⚠ python caches: ${py_total_cache}GB total (pip ${py_pip}, uv ${py_uv}, hf ${py_hf})"; warn=$((warn+1))
        else
            echo "✓ python caches: ${py_total_cache}GB total (pip ${py_pip}, uv ${py_uv}, hf ${py_hf})"; ok=$((ok+1))
        fi
        # Version drift line
        py_distinct=$(printf '%s' "$py_out" | jq -r '.version_distribution | length // 0' 2>/dev/null || echo 0)
        if [[ "$py_distinct" -ge 3 ]]; then
            echo "⚠ python version drift: ${py_distinct} minor versions active across projects (${py_versions})"; warn=$((warn+1))
        else
            echo "✓ python versions: ${py_versions:-none detected}"; ok=$((ok+1))
        fi
        # storage-coupled link
        py_attrib=$(printf '%s' "$s_out" | jq -r '.python_attribution_gb // 0' 2>/dev/null || echo 0)
        py_attrib_int=$(printf '%s' "$py_attrib" | awk '{printf "%d", $1+0}' 2>/dev/null || echo 0)
        if [[ "$py_attrib_int" -gt 10 ]]; then
            echo "⚠ python contributes ${py_attrib}GB to storage top-bloaters — run python-health L1"; warn=$((warn+1))
        fi
        # phantom Cellar invariant (G34 / zesttube forever-rule #5)
        py_phantom=$(printf '%s' "$py_out" | jq -r '.plist_phantom_cellar_pins // .phantom_cellar_paths // 0' 2>/dev/null || echo 0)
        if [[ "$py_phantom" -gt 0 ]]; then
            echo "⚠ plist_phantom_cellar_pins: ${py_phantom} LaunchAgent plist(s) reference brew Cellar python — see python-health/references/FOREVER-RULES.md rule #5a (plist trauma)"; warn=$((warn+1))
        else
            echo "✓ plist_phantom_cellar_pins: 0 (no plist pins brew Cellar python)"; ok=$((ok+1))
        fi
        # inventory freshness (G34 / forever-rule #3)
        py_inv="$HOME/.local/state/python/inventory.md"
        if [[ -f "$py_inv" ]]; then
            inv_age_d=$(( ( $(date +%s) - $(stat -f %m "$py_inv" 2>/dev/null || echo 0) ) / 86400 ))
            if [[ "$inv_age_d" -gt 14 ]]; then
                echo "⚠ python inventory.md is ${inv_age_d}d stale — run inventory.sh or load python-inventory LaunchAgent"; warn=$((warn+1))
            else
                echo "✓ python inventory.md fresh (${inv_age_d}d old)"; ok=$((ok+1))
            fi
        else
            echo "⚠ python inventory.md missing — run ~/.claude/skills/python-health/scripts/inventory.sh"; warn=$((warn+1))
        fi
    else
        echo "⚠ python-health probe missing"; warn=$((warn+1))
    fi
    set -e
    echo ""
    fi
    # ── security posture (2026-04-27 Tier-0; Mythos/Petri response) ──
    # G44 (2026-04-27): orchestrator delegates to 4 stack skills:
    #   mcp-secret-scanner | port-allowlist-manager | mythos-petri-tracker | infisical-rotation-ops
    echo "=== security posture (orchestrator → 4-skill stack) ==="
    set +e
    SEC_PROBE="$HOME/.claude/skills/security-posture/scripts/health-probe.sh"
    if [[ -x "$SEC_PROBE" ]]; then
        sec_out=$("$SEC_PROBE" --json 2>/dev/null || true)
        sec_status=$(printf '%s' "$sec_out" | jq -r '.status // "UNKNOWN"' 2>/dev/null || echo "UNKNOWN")
        sec_crit=$(printf '%s' "$sec_out" | jq -r '.counts.critical // 0' 2>/dev/null || echo 0)
        sec_warn=$(printf '%s' "$sec_out" | jq -r '.counts.warn // 0' 2>/dev/null || echo 0)
        sec_anom=$(printf '%s' "$sec_out" | jq -r '.counts.anomaly // 0' 2>/dev/null || echo 0)
        # MCP plaintext secrets
        mcp_n=$(printf '%s' "$sec_out" | jq -r '[.findings[] | select(.category=="mcp-plaintext-secret")] | length' 2>/dev/null || echo 0)
        if [[ "${mcp_n:-0}" -eq 0 ]]; then
            echo "✓ no plaintext secrets in MCP configs (owner: mcp-secret-scanner)"; ok=$((ok+1))
        else
            echo "✗ $mcp_n plaintext-secret finding(s) in MCP configs (owner: mcp-secret-scanner → infisical-rotation-ops L2)"; fail=$((fail+1))
        fi
        # Exposed ports — measurement-correctness fix (G07-B Ship A 2026-04-27, P08c strike-4)
        # plus G27 anti-green-theatre floor (2026-04-27): PAM probe may silently degrade in
        # subshell context (PATH/jq/race) and return empty → exp_n=0 even when real wildcard
        # listeners exist (observed: stand-alone PAM critical=6, doctor saw exp_n=0 → ✓ branch).
        # Per ZESTSTREAM-LANDMINES.md #2: "doctor headline currently undercounts (reports 1
        # while probe sees 15)" — green-theatre is worse than honest red. Floor: independent
        # lsof probe of wildcard binds; if PAM=0 but wild_n>0, fail with wild_n.
        # Source of truth = canonical producer port-allowlist-manager/scripts/probe.sh --json
        # See PATTERNS.md P08 — every invariant must call canonical producer's counter
        # AND carry an independent floor against degraded-producer green-theatre.
        if [[ "$DOCTOR_DEEP" != "1" ]]; then
            # Fast doctor keeps the current port foundation through the
            # ecosystem-port-security ownership/firewall invariants below.
            # The legacy PAM + raw wildcard floor stays in --deep to avoid
            # running two independent lsof-heavy port classifiers every tick.
            echo "○ legacy port-allowlist probe skipped in fast doctor; ecosystem-port-security ownership invariant runs below"
        else
            PAM_PROBE="$HOME/.claude/skills/port-allowlist-manager/scripts/probe.sh"
            # Sanitize: pipefail can poison `cmd || echo 0` substitutions (jq exits 0 but
            # the `printf|jq` pipe under pipefail returns the upstream code, triggering
            # the fallback AFTER stdout was already emitted → "29\n0" arithmetic crash).
            # Run each capture in a subshell with pipefail OFF and post-strip non-digits.
            _digitize() { tr -cd '0-9' | head -c 12; }
            if [[ -x "$PAM_PROBE" ]]; then
                pam_out=$( ("$PAM_PROBE" --json 2>/dev/null) || true )
                [[ -z "$pam_out" ]] && pam_out='{}'
                exp_n=$(  ( set +o pipefail; printf '%s' "$pam_out" | jq -r '.counts.critical // 0' 2>/dev/null ) | _digitize )
                allow_n=$( ( set +o pipefail; printf '%s' "$pam_out" | jq -r '.allowlist_size // 0' 2>/dev/null ) | _digitize )
                [[ -z "$exp_n" ]] && exp_n=0
                if [[ -z "$allow_n" || "$allow_n" == "0" ]]; then
                    allow_n=$( ( grep -cE '^[0-9]' "$HOME/.claude/skills/port-allowlist-manager/data/listening-ports-allowlist.txt" 2>/dev/null ) | _digitize )
                    [[ -z "$allow_n" ]] && allow_n=0
                fi
            else
                exp_n=$(  ( set +o pipefail; printf '%s' "$sec_out" | jq -r '[.findings[] | select(.category=="exposed-port")] | length' 2>/dev/null ) | _digitize )
                allow_n=$( ( grep -cE '^[0-9]' "$HOME/.claude/skills/security-posture/data/listening-ports-allowlist.txt" 2>/dev/null ) | _digitize )
                [[ -z "$exp_n" ]] && exp_n=0
                [[ -z "$allow_n" ]] && allow_n=0
            fi
            # G27 floor (refined G07-C 2026-04-27): trust PAM probe's .counts.critical when probe ran
            # successfully (pam_out is non-empty JSON). Only fall back to raw wild_n count when probe
            # is genuinely unreachable (pam_out empty/'{}' AND lsof shows wildcards). Prior version
            # FAILed whenever any wildcards existed regardless of allowlist coverage — fully
            # allowlisted wildcards (qdrant/caam/etc) cannot pass that floor by allowlist edits alone.
            wild_n=$(lsof -iTCP -sTCP:LISTEN -n -P 2>/dev/null \
                | awk 'NR>1 {print $9}' \
                | grep -oE '(\*|0\.0\.0\.0):[0-9]+$' \
                | sort -u | wc -l | tr -d ' ')
            [[ -z "$wild_n" ]] && wild_n=0
            pam_alive=0
            [[ -n "$pam_out" && "$pam_out" != "{}" ]] && pam_alive=1
            if [[ "${exp_n:-0}" -eq 0 && "${pam_alive}" -eq 1 ]]; then
                # PAM probe ran and reports 0 critical — wildcards are allowlisted. Trust it.
                echo "✓ no unexpected listening ports (allowlist: $allow_n entries; allowlisted wildcards: $wild_n) (owner: port-allowlist-manager)"; ok=$((ok+1))
            elif [[ "${exp_n:-0}" -eq 0 && "${wild_n:-0}" -eq 0 ]]; then
                # PAM probe degraded but no wildcards exist — green honestly.
                echo "✓ no unexpected listening ports (allowlist: $allow_n entries) (owner: port-allowlist-manager)"; ok=$((ok+1))
            elif [[ "${exp_n:-0}" -eq 0 && "${wild_n:-0}" -gt 0 ]]; then
                # PAM probe degraded AND wildcards exist — can't verify allowlist coverage.
                echo "✗ $wild_n wildcard listener(s) — PAM-probe-degraded (G27 floor); allowlist: $allow_n (owner: port-allowlist-manager)"; fail=$((fail+1))
            else
                echo "✗ $exp_n 0.0.0.0 listener(s) outside allowlist ($allow_n entries; total wildcard: $wild_n) (owner: port-allowlist-manager)"; fail=$((fail+1))
            fi
        fi
        # Infisical fresh
        inf_n=$(printf '%s' "$sec_out" | jq -r '[.findings[] | select(.category=="infisical-stale" or .category=="infisical-perms")] | length' 2>/dev/null || echo 0)
        if [[ "${inf_n:-0}" -eq 0 ]]; then
            echo "✓ infisical cache fresh (<7d) and 600 perms (owner: infisical-rotation-ops)"; ok=$((ok+1))
        else
            echo "⚠ infisical cache issue: $inf_n finding(s) (owner: infisical-rotation-ops L1)"; warn=$((warn+1))
        fi
        # Dep CVEs (advisory — brew-outdated proxy until npm/pip/cargo wired in repo context)
        bo_n=$(printf '%s' "$sec_out" | jq -r '[.findings[] | select(.category=="brew-outdated")] | length' 2>/dev/null || echo 0)
        if [[ "${bo_n:-0}" -eq 0 ]]; then
            echo "✓ no critical CVEs flagged in top-level deps (cross-link: dependency-management)"; ok=$((ok+1))
        else
            echo "⚠ brew-outdated surface elevated (run L1; cross-link: dependency-management)"; warn=$((warn+1))
        fi
        # Anomalies (info only, not fail)
        if [[ "${sec_anom:-0}" -gt 0 ]]; then
            echo "  · $sec_anom localhost-only port anomalies (owner: port-allowlist-manager — review allowlist)"
        fi
        if [[ "$sec_status" == "CRITICAL" ]]; then
            echo "    → run: ~/.claude/skills/security-posture/scripts/recovery-ladder.sh 2"
            echo "    → or per-skill: mcp-secret-scanner | port-allowlist-manager | infisical-rotation-ops"
        fi
        # G44 stack-skill freshness (2026-04-27)
        if [[ "$DOCTOR_DEEP" == "1" ]]; then
            security_sub_probes=(mcp-secret-scanner port-allowlist-manager mythos-petri-tracker infisical-rotation-ops)
        else
            security_sub_probes=(mcp-secret-scanner mythos-petri-tracker infisical-rotation-ops)
        fi
        for sub in "${security_sub_probes[@]}"; do
            sub_probe="$HOME/.claude/skills/$sub/scripts/probe.sh"
            if [[ -x "$sub_probe" ]]; then
                # Probe exit code is non-zero for non-HEALTHY states (1=WARN, 2=CRITICAL, 3=ANOMALY).
                # Under pipefail the non-zero propagates through the `| jq` pipe, triggering the
                # `|| echo UNKNOWN` fallback AFTER jq already printed the real status — yielding
                # a two-line "ANOMALY\nUNKNOWN" value that no case-arm matches, falling to *) and
                # rendering as "· skill: ANOMALY\nUNKNOWN". Sanitize: capture probe stdout first
                # (ignore exit), then jq it; finally collapse to first line + strip non-alnum.
                sub_json=$( ( set +o pipefail; "$sub_probe" --json 2>/dev/null ) || true )
                sub_status=$(printf '%s' "$sub_json" | jq -r '.status // "UNKNOWN"' 2>/dev/null | head -n1 | tr -cd 'A-Za-z')
                [[ -z "$sub_status" ]] && sub_status="UNKNOWN"
                case "$sub_status" in
                    HEALTHY)  echo "  · $sub: HEALTHY" ;;
                    WARN)     echo "  · $sub: WARN" ;;
                    CRITICAL) echo "  · $sub: CRITICAL" ;;
                    ANOMALY)  echo "  · $sub: ANOMALY (review)" ;;
                    *)        echo "  · $sub: ${sub_status}" ;;
                esac
            else
                echo "  · $sub: probe missing"
            fi
        done
    else
        echo "⚠ security-posture health-probe missing"; warn=$((warn+1))
    fi
    set -e
    echo ""
    # ── ecosystem-port-security Phase 2 invariants (2026-04-27) ──
    # Two-sided trust model: tunnel-policy (inbound) + egress-catalog (outbound).
    EPS_DIR="$HOME/.claude/skills/ecosystem-port-security"
    EPS_TUNNEL="$EPS_DIR/scripts/tunnel-probe.sh"
    EPS_EGRESS="$EPS_DIR/scripts/egress-probe.sh"
    echo "=== ecosystem-port-security tunnel-policy invariant ==="
    set +e
    if [[ -x "$EPS_TUNNEL" ]]; then
        tp_json=$("$EPS_TUNNEL" --json 2>/dev/null || echo '{}')
        tp_active=$(printf '%s' "$tp_json" | jq -r '.tunnel_active // false' 2>/dev/null)
        tp_peers=$(printf '%s' "$tp_json" | jq -r '.peers // 0' 2>/dev/null)
        tp_mm=$(printf '%s' "$tp_json" | jq -r '.mismatches_count // 0' 2>/dev/null)
        tp_ns=$(printf '%s' "$tp_json" | jq -r '.not_set // 0' 2>/dev/null)
        if [[ "$tp_active" == "true" ]]; then
            echo "✓ tailscale daemon reachable (peers=$tp_peers)"; ok=$((ok+1))
        else
            echo "✗ tailscale daemon down (peers=$tp_peers)"; fail=$((fail+1))
        fi
        if [[ "${tp_mm:-0}" -eq 0 ]]; then
            echo "✓ tunnel-probe healthy (0 mismatches)"; ok=$((ok+1))
        else
            echo "✗ tunnel-policy-mismatches: $tp_mm (run: $EPS_TUNNEL)"; fail=$((fail+1))
            printf '%s' "$tp_json" | jq -r '.mismatches[]? | "    · port=\(.port) declared=\(.declared) actual=\(.actual) skill=\(.owning_skill)"' 2>/dev/null
        fi
        if [[ "${tp_ns:-0}" -gt 0 ]]; then
            echo "ℹ tunnel-policy-not-set: $tp_ns (rows still defaulted to not-applicable)"
        fi
    else
        echo "⚠ tunnel-probe missing"; warn=$((warn+1))
    fi
    set -e
    echo ""
    echo "=== ecosystem-port-security egress invariant ==="
    set +e
    if [[ -x "$EPS_EGRESS" ]]; then
        # Catalog parses + count agents/services
        EPS_CAT="$EPS_DIR/data/egress-catalog.json"
        if jq -e . "$EPS_CAT" >/dev/null 2>&1; then
            n_agents=$(jq '.agents // {} | length' "$EPS_CAT" 2>/dev/null)
            n_svcs=$(jq '.services // {} | length' "$EPS_CAT" 2>/dev/null)
            echo "✓ egress-catalog parses ($n_agents agents, $n_svcs services)"; ok=$((ok+1))
        else
            echo "✗ egress-catalog parse error"; fail=$((fail+1))
        fi
        if [[ "$DOCTOR_DEEP" != "1" ]]; then
            latest_egress=$(ls -t "$HOME/.local/state/ecosystem-port-security/egress-snapshots/"*.json 2>/dev/null | head -1)
            if [[ -n "$latest_egress" ]]; then
                eg_age_s=$(( $(date +%s) - $(stat -f %m "$latest_egress" 2>/dev/null || stat -c %Y "$latest_egress" 2>/dev/null || echo 0) ))
                echo "○ live egress scan skipped in fast doctor; latest snapshot age=$((eg_age_s/3600))h (run: flywheel doctor --deep)"
            else
                echo "⚠ no egress snapshot present; run flywheel doctor --deep"; warn=$((warn+1))
            fi
        else
            eg_json=$(fw_cmd_timeout 9 "$EPS_EGRESS" --json 2>/dev/null || true)
            eg_total=$(printf '%s' "$eg_json" | jq -rs 'last | .total_conns // 0' 2>/dev/null)
            eg_exp=$(printf '%s' "$eg_json" | jq -rs 'last | .expected // 0' 2>/dev/null)
            eg_un=$(printf '%s' "$eg_json" | jq -rs 'last | .unexpected_count // 0' 2>/dev/null)
            eg_uc=$(printf '%s' "$eg_json" | jq -rs 'last | .uncatalogued_count // 0' 2>/dev/null)
            if [[ -z "$eg_json" ]] || ! jq -e . <<<"$eg_json" >/dev/null 2>&1; then
                echo "⚠ egress-probe timed out or returned no JSON within 9s"; warn=$((warn+1))
            elif [[ "${eg_un:-0}" -eq 0 ]]; then
                echo "✓ egress-probe healthy (total=$eg_total, expected=$eg_exp)"; ok=$((ok+1))
            else
                echo "⚠ unexpected-egress-conns: $eg_un (run: $EPS_EGRESS)"; warn=$((warn+1))
                printf '%s' "$eg_json" | jq -r '.unexpected[]? | "    · \(.cmd) → \(.host):\(.port) (agent=\(.agent_key))"' 2>/dev/null | head -10
            fi
            if [[ "${eg_uc:-0}" -gt 0 ]]; then
                uc_list=$(printf '%s' "$eg_json" | jq -r '.uncatalogued_commands | join(", ")' 2>/dev/null)
                echo "ℹ uncatalogued-commands: $eg_uc (need catalog entry: $uc_list)"
            fi
        fi
    else
        echo "⚠ egress-probe missing"; warn=$((warn+1))
    fi
    set -e
    echo ""
    # ── skill-os kernel context budget (G-OS-1, 2026-04-29) ─────────────
    # Doctrine: the always-on skill kernel is small and bounded so the agent's
    # cold-start context is predictable. Cross-checks substrate-registry
    # (exactly one active row with lifecycle_role=kernel) and the pilot
    # manifest (global-kernel pack, kernel role, count <=10), and verifies
    # each kernel skill carries SKILL.md + SELF-TEST.md + non-empty
    # data/sources.txt with description <=500 chars. Aggregate description
    # budget <=4000 chars / <=1000 estimated tokens.
    echo "=== skill-os-kernel-context-budget invariant ==="
    set +e
    SKILL_OS_KERNEL_BUDGET="$HOME/.claude/skills/.flywheel/scripts/skill-os-kernel-budget.py"
    if [[ ! -f "$SKILL_OS_KERNEL_BUDGET" ]]; then
        echo "✗ skill-os-kernel-budget.py missing"; fail=$((fail+1))
    else
        kb_out=$(python3 "$SKILL_OS_KERNEL_BUDGET" 2>&1)
        kb_rc=$?
        if [[ $kb_rc -eq 0 ]]; then
            kb_n=$(echo "$kb_out" | python3 -c 'import json,sys;d=json.load(sys.stdin);print(d.get("kernel_count",0))' 2>/dev/null)
            kb_chars=$(echo "$kb_out" | python3 -c 'import json,sys;d=json.load(sys.stdin);print(d.get("aggregate_description_chars",0))' 2>/dev/null)
            kb_tok=$(echo "$kb_out" | python3 -c 'import json,sys;d=json.load(sys.stdin);print(d.get("estimated_tokens",0))' 2>/dev/null)
            echo "✓ skill-os kernel budget ok (count=${kb_n:-?}, desc_chars=${kb_chars:-?}, est_tokens=${kb_tok:-?})"; ok=$((ok+1))
        else
            kb_fails=$(echo "$kb_out" | python3 -c 'import json,sys
try:
    d=json.load(sys.stdin)
    print("; ".join(d.get("failures",[])))
except Exception:
    print("(could not parse)")' 2>/dev/null)
            echo "✗ skill-os-kernel-context-budget failed: ${kb_fails:-(no detail)}"; fail=$((fail+1))
        fi
    fi
    set -e
    echo ""

    # ── substrate intake registry invariants (2026-04-28 P19 strike-3) ──
    # The registry prevents flywheel substrate from shipping as scattered files
    # that no future agent can discover or retire. Coherent checks schema/path/ref
    # integrity. Consumed rejects write-only rows by executing each validator.
    SUBSTRATE_REGISTRY_VALIDATE="$HOME/.claude/skills/.flywheel/scripts/substrate-registry-validate.sh"
    echo "=== substrate-registry invariants ==="
    set +e
    if [[ -x "$SUBSTRATE_REGISTRY_VALIDATE" ]]; then
        sr_err="/tmp/flywheel-substrate-registry-validate.err.$$"
        sr_locked=0
        sr_json=$("$SUBSTRATE_REGISTRY_VALIDATE" --json 2>"$sr_err")
        sr_rc=$?
        if [[ "$sr_rc" -eq 75 ]]; then
            sr_locked=1
            sr_lock_msg="$(cat "$sr_err" 2>/dev/null)"
            echo "⚠ substrate-registry-validator-singleton: ${sr_lock_msg:-already running}"; warn=$((warn+1))
            sr_json='{}'
        elif [[ "$sr_rc" -ne 0 ]]; then
            if ! printf '%s' "$sr_json" | jq empty 2>/dev/null; then
                sr_json='{}'
            fi
        fi
        rm -f "$sr_err" 2>/dev/null || true
        sr_running=$(pgrep -f "$SUBSTRATE_REGISTRY_VALIDATE" 2>/dev/null | wc -l | tr -d ' ')
        if [[ "${sr_running:-0}" -le 1 ]]; then
            echo "✓ substrate-registry-validator-singleton: concurrent launch count=$sr_running"; ok=$((ok+1))
        else
            echo "✗ substrate-registry-validator-singleton: concurrent launch count=$sr_running"; fail=$((fail+1))
        fi
        if [[ "$sr_locked" == "1" ]]; then
            echo "⚠ substrate-registry-coherent: skipped while validator lock is held"; warn=$((warn+1))
            echo "⚠ substrate-registry-consumed: skipped while validator lock is held"; warn=$((warn+1))
        else
            sr_coherent=$(printf '%s' "$sr_json" | jq -r '.coherent_ok // false' 2>/dev/null || echo false)
            sr_consumed=$(printf '%s' "$sr_json" | jq -r '.consumed_ok // false' 2>/dev/null || echo false)
            sr_cf=$(printf '%s' "$sr_json" | jq -r '(.coherent_failures // []) | length' 2>/dev/null || echo 0)
            sr_vf=$(printf '%s' "$sr_json" | jq -r '(.consumed_failures // []) | length' 2>/dev/null || echo 0)
            if [[ "$sr_coherent" == "true" ]]; then
                echo "✓ substrate-registry-coherent: schema/path/ref integrity holds"; ok=$((ok+1))
            else
                echo "✗ substrate-registry-coherent: $sr_cf failure(s)"; fail=$((fail+1))
                printf '%s' "$sr_json" | jq -r '.coherent_failures[]? | "    · \(.)"' 2>/dev/null | head -10
            fi
            if [[ "$sr_consumed" == "true" ]]; then
                echo "✓ substrate-registry-consumed: consumers present and validators green"; ok=$((ok+1))
            else
                echo "✗ substrate-registry-consumed: $sr_vf failure(s)"; fail=$((fail+1))
                printf '%s' "$sr_json" | jq -r '.consumed_failures[]? | "    · \(.)"' 2>/dev/null | head -10
            fi
        fi
        if [[ "$sr_locked" != "1" && "${SUBSTRATE_REGISTRY_V11:-0}" == "1" ]]; then
            sr_v11=$(printf '%s' "$sr_json" | jq -r '.v11_ok // false' 2>/dev/null || echo false)
            sr_v11f=$(printf '%s' "$sr_json" | jq -r '(.v11_failures // []) | length' 2>/dev/null || echo 0)
            sr_v11w=$(printf '%s' "$sr_json" | jq -r '(.v11_warnings // []) | length' 2>/dev/null || echo 0)
            sr_capability=$(printf '%s' "$sr_json" | jq -r '.capability_ok // true' 2>/dev/null || echo true)
            sr_capability_f=$(printf '%s' "$sr_json" | jq -r '(.capability_failures // []) | length' 2>/dev/null || echo 0)
            sr_capability_w=$(printf '%s' "$sr_json" | jq -r '(.capability_warnings // []) | length' 2>/dev/null || echo 0)
            if [[ "$sr_v11" == "true" ]]; then
                echo "✓ substrate-lifecycle-stage-valid: v1.1 lifecycle stages valid"; ok=$((ok+1))
            else
                echo "✗ substrate-lifecycle-stage-valid: $sr_v11f failure(s)"; fail=$((fail+1))
                printf '%s' "$sr_json" | jq -r '.v11_failures[]? | "    · \(.)"' 2>/dev/null | head -10
            fi
            if [[ "$sr_capability" != "true" ]]; then
                echo "✗ substrate-capability-admission-shaped: $sr_capability_f failure(s)"; fail=$((fail+1))
                printf '%s' "$sr_json" | jq -r '.capability_failures[]? | "    · \(.)"' 2>/dev/null | head -10
            elif [[ "$sr_capability_w" -gt 0 ]]; then
                echo "⚠ substrate-capability-admission-shaped: $sr_capability_w warning(s)"; warn=$((warn+1))
                printf '%s' "$sr_json" | jq -r '.capability_warnings[]? | "    · \(.)"' 2>/dev/null | head -10
            else
                echo "✓ substrate-capability-admission-shaped: routable capability rows admitted"; ok=$((ok+1))
            fi
            if [[ "$sr_v11w" -eq 0 ]]; then
                echo "✓ substrate-rollback-tested: no active v1.1 rollback gaps"; ok=$((ok+1))
            else
                echo "⚠ substrate-rollback-tested: $sr_v11w warning(s)"; warn=$((warn+1))
                printf '%s' "$sr_json" | jq -r '.v11_warnings[]? | "    · \(.)"' 2>/dev/null | head -10
            fi
        fi
    else
        echo "⚠ substrate-registry validator missing"; warn=$((warn+1))
    fi
    set -e
    echo ""
    # ── jsm-wrapper provenance invariant (2026-04-28 G23+P30 close) ──
    # ~/.local/bin/jsm is load-bearing substrate (G23 trigger gate + P30
    # confidentiality preflight) but lives outside the ~/.claude git repo.
    # Closure: tracked source-of-truth at install-substrate/scripts/jsm-wrapper.sh
    # + sha256 verifier. Doctor asserts (a) live wrapper exists and is exec,
    # (b) live sha256 matches tracked, (c) live references both gate scripts
    # by literal name (catches accidental gate removal during edits).
    JSM_TRACKED="$HOME/.claude/skills/install-substrate/scripts/jsm-wrapper.sh"
    JSM_LIVE="$HOME/.local/bin/jsm"
    JSM_GATE_REF="jsm-validate-triggers.sh"
    JSM_PREFLIGHT_REF="jsm-push-preflight.sh"
    echo "=== jsm-wrapper provenance invariant ==="
    set +e
    if [[ -f "$JSM_TRACKED" && -x "$JSM_LIVE" ]]; then
        jw_tracked_sha=$(shasum -a 256 "$JSM_TRACKED" 2>/dev/null | awk '{print $1}')
        jw_live_sha=$(shasum -a 256 "$JSM_LIVE" 2>/dev/null | awk '{print $1}')
        if [[ -n "$jw_tracked_sha" && "$jw_tracked_sha" == "$jw_live_sha" ]]; then
            echo "✓ jsm-wrapper-provenance: tracked == live (${jw_tracked_sha:0:12}…)"; ok=$((ok+1))
        else
            echo "✗ jsm-wrapper-provenance: drift between tracked and live"; fail=$((fail+1))
            echo "    · tracked: ${jw_tracked_sha:-MISSING}"
            echo "    · live:    ${jw_live_sha:-MISSING}"
            echo "    → run: ~/.claude/skills/install-substrate/scripts/install-jsm-wrapper.sh diff"
        fi
        if grep -q "$JSM_GATE_REF" "$JSM_LIVE" 2>/dev/null; then
            echo "✓ jsm-wrapper-references-g23: live wrapper invokes $JSM_GATE_REF"; ok=$((ok+1))
        else
            echo "✗ jsm-wrapper-references-g23: live wrapper missing $JSM_GATE_REF"; fail=$((fail+1))
        fi
        if grep -q "$JSM_PREFLIGHT_REF" "$JSM_LIVE" 2>/dev/null; then
            echo "✓ jsm-wrapper-references-p30: live wrapper invokes $JSM_PREFLIGHT_REF"; ok=$((ok+1))
        else
            echo "✗ jsm-wrapper-references-p30: live wrapper missing $JSM_PREFLIGHT_REF"; fail=$((fail+1))
        fi
    else
        echo "⚠ jsm-wrapper-provenance: tracked or live missing (tracked=$JSM_TRACKED live=$JSM_LIVE)"; warn=$((warn+1))
    fi
    set -e
    echo ""
    # ── petal9-close provenance invariant (2026-04-28 follow-up to 476ecca) ──
    # ~/.local/bin/petal9-close.sh is load-bearing substrate (Petal-9 Sunday
    # closure artifact producer; embeds Section 7.5 Loop D/E library-growth
    # proposals) but lives outside the ~/.claude git repo. Mirrors the
    # jsm-wrapper provenance pattern from fb7b8fc. Doctor asserts (a) live
    # script exists and is exec, (b) live sha256 matches tracked, (c) live
    # contains the Section 7.5 header literal (catches accidental removal
    # of the Loop D/E embed during edits).
    P9C_TRACKED="$HOME/.claude/skills/install-substrate/scripts/petal9-close.sh"
    P9C_LIVE="$HOME/.local/bin/petal9-close.sh"
    P9C_SECTION_REF="7.5 Library growth proposals"
    echo "=== petal9-close provenance invariant ==="
    set +e
    if [[ -f "$P9C_TRACKED" && -x "$P9C_LIVE" ]]; then
        p9c_tracked_sha=$(shasum -a 256 "$P9C_TRACKED" 2>/dev/null | awk '{print $1}')
        p9c_live_sha=$(shasum -a 256 "$P9C_LIVE" 2>/dev/null | awk '{print $1}')
        if [[ -n "$p9c_tracked_sha" && "$p9c_tracked_sha" == "$p9c_live_sha" ]]; then
            echo "✓ petal9-close-provenance: tracked == live (${p9c_tracked_sha:0:12}…)"; ok=$((ok+1))
        else
            echo "✗ petal9-close-provenance: drift between tracked and live"; fail=$((fail+1))
            echo "    · tracked: ${p9c_tracked_sha:-MISSING}"
            echo "    · live:    ${p9c_live_sha:-MISSING}"
            echo "    → run: ~/.claude/skills/install-substrate/scripts/install-petal9-close.sh diff"
        fi
        if grep -q "$P9C_SECTION_REF" "$P9C_LIVE" 2>/dev/null; then
            echo "✓ petal9-close-section-7-5: live script contains Section 7.5 embed"; ok=$((ok+1))
        else
            echo "✗ petal9-close-section-7-5: live script missing Section 7.5 embed"; fail=$((fail+1))
        fi
    else
        echo "⚠ petal9-close-provenance: tracked or live missing (tracked=$P9C_TRACKED live=$P9C_LIVE)"; warn=$((warn+1))
    fi
    set -e
    echo ""
    # ── research-triad substrate liveness invariant (2026-04-29 P2 follow-up) ──
    # Petal-9 deep-only liveness probe. The fast-path validation_command on the
    # research-triad-substrate registry row covers cheap structural existence
    # (~0.01s). This block runs the full 12-invariant rubric-check.sh (~16s)
    # ONLY under --deep so fast doctor stays cheap. Keeps registry hot path untouched.
    RT_RUBRIC="$HOME/.claude/skills/research-triad/scripts/rubric-check.sh"
    echo "=== research-triad substrate liveness invariant ==="
    set +e
    if [[ "$DOCTOR_DEEP" != "1" ]]; then
        echo "○ skipped in fast doctor (run: flywheel doctor --deep)"
    elif [[ -x "$RT_RUBRIC" ]]; then
        rt_out=$(bash "$RT_RUBRIC" 2>&1)
        rt_total=$(printf '%s\n' "$rt_out" | grep -E '^TOTAL: PASS=' | tail -1)
        rt_pass=$(printf '%s' "$rt_total" | grep -oE 'PASS=[0-9]+' | grep -oE '[0-9]+')
        rt_fail=$(printf '%s' "$rt_total" | grep -oE 'FAIL=[0-9]+' | grep -oE '[0-9]+')
        if [[ -n "$rt_fail" && "$rt_fail" -eq 0 ]]; then
            echo "✓ research-triad-rubric: PASS=${rt_pass} FAIL=0"; ok=$((ok+1))
        else
            echo "✗ research-triad-rubric: PASS=${rt_pass:-0} FAIL=${rt_fail:-?}"; fail=$((fail+1))
            echo "    → run: bash $RT_RUBRIC"
        fi
    else
        echo "⚠ research-triad-rubric: $RT_RUBRIC missing or not executable"; warn=$((warn+1))
    fi
    # P2 trauma-ingest visibility (2026-04-29). Deep-only because it shells
    # out to research-query for the index-status walk. Reports ledger row
    # count (canonical source of truth at ~/.local/state/research/trauma-ingest-log.jsonl;
    # 0 if absent — that's the cold-start state) and stale_files (per-file
    # mtime>built_at signal already emitted by `research index status`).
    # Pure visibility — never fails, never warns; a high stale_files count
    # is informational about ingest debt, not a doctor regression.
    if [[ "$DOCTOR_DEEP" == "1" ]]; then
        TI_LEDGER="${RESEARCH_TRAUMA_LEDGER:-$HOME/.local/state/research/trauma-ingest-log.jsonl}"
        if [[ -f "$TI_LEDGER" ]]; then
            ti_count=$(wc -l < "$TI_LEDGER" 2>/dev/null | tr -d ' ')
        else
            ti_count=0
        fi
        ti_stale="?"
        if [[ -x "$HOME/.local/bin/research" ]]; then
            ti_stale=$("$HOME/.local/bin/research" index status 2>/dev/null \
                | jq -r '.stale_files // "?"' 2>/dev/null || echo "?")
        fi
        echo "  trauma-ingest: ledger=${ti_count:-0} stale=${ti_stale}"
    fi
    set -e
    echo ""
    # ── ecosystem-port-security Phase 3 PF invariant (2026-04-28 P27) ──
    # Registry/allowlist truth is not network enforcement. If the policy has
    # enabled local-only ports, the installed PF anchor must exist and match the
    # rendered hash. Non-root doctor may not read live pfctl state, so the anchor
    # file hash is the machine-visible guardrail proof.
    EPS_FIREWALL="$EPS_DIR/scripts/firewall-policy-probe.sh"
    echo "=== ecosystem-port-security firewall-policy invariant ==="
    set +e
    if [[ -x "$EPS_FIREWALL" ]]; then
        fw_json=$("$EPS_FIREWALL" --json 2>/dev/null || echo '{}')
        fw_ports=$(printf '%s' "$fw_json" | jq -r '.local_only_ports | length // 0' 2>/dev/null || echo 0)
        fw_hash=$(printf '%s' "$fw_json" | jq -r '.rendered_sha256 // "?"' 2>/dev/null || echo "?")
        fw_installed=$(printf '%s' "$fw_json" | jq -r '.installed_file // false' 2>/dev/null || echo false)
        fw_match=$(printf '%s' "$fw_json" | jq -r '.installed_hash_matches // false' 2>/dev/null || echo false)
        fw_wild=$(printf '%s' "$fw_json" | jq -r '.wildcard_listeners | length // 0' 2>/dev/null || echo 0)
        if [[ "${fw_ports:-0}" -eq 0 ]]; then
            echo "✓ firewall-policy: no enabled local-only ports"; ok=$((ok+1))
        elif [[ "$fw_installed" == "true" && "$fw_match" == "true" ]]; then
            echo "✓ firewall-policy installed (ports=$fw_ports wildcard_covered=$fw_wild hash=${fw_hash:0:12})"; ok=$((ok+1))
        else
            echo "✗ firewall-policy not enforced: installed_file=$fw_installed hash_matches=$fw_match ports=$fw_ports"; fail=$((fail+1))
            echo "    → run: sudo $EPS_DIR/scripts/firewall-policy-install.sh --apply"
        fi
    else
        echo "⚠ firewall-policy probe missing"; warn=$((warn+1))
    fi
    set -e
    echo ""
    # ── observability stack (2026-04-27 G46; wrangler ladder) ──
    echo "=== observability ==="
    set +e
    OBS_PROBE="$HOME/.claude/skills/observability-platform/scripts/probe.sh"
    if [[ -x "$OBS_PROBE" ]]; then
        obs_out=$("$OBS_PROBE" --json 2>/dev/null || true)
        obs_status=$(printf '%s' "$obs_out" | jq -r '.status // "UNKNOWN"' 2>/dev/null || echo "UNKNOWN")
        obs_ok=$(printf '%s' "$obs_out" | jq -r '.ok // 0' 2>/dev/null || echo 0)
        obs_warn=$(printf '%s' "$obs_out" | jq -r '.warn // 0' 2>/dev/null || echo 0)
        obs_fail=$(printf '%s' "$obs_out" | jq -r '.fail // 0' 2>/dev/null || echo 0)
        # Probe 1: aggregated sub-skill probe exit codes
        if [[ "${obs_fail:-0}" -eq 0 && "${obs_warn:-0}" -eq 0 ]]; then
            echo "✓ all observability sub-skill probes healthy ($obs_ok ok)"; ok=$((ok+1))
        elif [[ "${obs_fail:-0}" -gt 0 ]]; then
            echo "✗ observability sub-skill probes failing: $obs_fail fail / $obs_warn warn / $obs_ok ok"; fail=$((fail+1))
        else
            echo "⚠ observability sub-skill probes degraded: $obs_warn warn / $obs_ok ok"; warn=$((warn+1))
        fi
        # Probe 2: continuous-monitoring LaunchAgents loaded count
        la_count=$(printf '%s' "$obs_out" | jq -r '.launchagents // 0' 2>/dev/null || echo 0)
        if [[ "${la_count:-0}" -ge 1 ]]; then
            echo "✓ observability LaunchAgents loaded: $la_count"; ok=$((ok+1))
        else
            echo "⚠ no observability LaunchAgents loaded — bake one per Forever-Rule 3 (continuous beats one-shot)"; warn=$((warn+1))
        fi
        # Probe 3: log freshness across sources
        fresh=$(printf '%s' "$obs_out" | jq -r '.fresh_sources // 0' 2>/dev/null || echo 0)
        if [[ "${fresh:-0}" -ge 1 ]]; then
            echo "✓ fresh observability sources (<24h): $fresh"; ok=$((ok+1))
        else
            echo "⚠ no observability source state newer than 24h — probes may not be running"; warn=$((warn+1))
        fi
        if [[ "$obs_status" == "CRITICAL" ]]; then
            echo "    → run sub-probes individually: ~/.claude/skills/{disk-observer,cost-monitoring-infra,uptime-monitoring,log-aggregation}/scripts/*.sh --json"
        fi
    else
        echo "⚠ observability-platform aggregator probe missing"; warn=$((warn+1))
    fi
    set -e
    echo ""
    # ── agent-mail health (G63 2026-04-27; engine-aware: claude+codex paths) ──
    # Mirrors G54 docker engine-aware probe pattern. The previous single-path probe
    # falsely flagged "rotate service token" whenever AGENTMAIL_CF_ACCESS_* drifted
    # from the bare-name CF_ACCESS_CLIENT_* pair that ~/.claude/.mcp.json actually
    # uses (G50-1). Tokens were fine; the probe was wrong. We now test BOTH:
    #   • Claude Code path: direct upstream HTTPS + CF-Access headers (prefer bare
    #     CF_ACCESS_CLIENT_* to match .mcp.json; fall back to AGENTMAIL_* aliases).
    #   • Codex path:       localhost shim http://127.0.0.1:7878/mcp/ (G50).
    # Recommendation only mentions token rotation when BOTH paths return 302/401/403.
    echo "=== agent-mail health ==="
    set +e
    am_url="${AGENT_MAIL_URL:-https://agentmail.zeststream.ai/mcp/}"
    am_shim_port="${CF_SHIM_PORT:-7878}"
    am_shim_url="http://127.0.0.1:${am_shim_port}/mcp/"

    # Source infisical-cache if env not already present (probe is engine-aware,
    # not env-aware). Mirrors how mcp-cf-access-shim wrapper resolves secrets.
    if [[ -z "${CF_ACCESS_CLIENT_ID:-}${AGENTMAIL_CF_ACCESS_CLIENT_ID:-}" ]] \
       && [[ -f "$HOME/.opencode/secrets/infisical-cache.env" ]]; then
        # shellcheck disable=SC1091
        set +u; source "$HOME/.opencode/secrets/infisical-cache.env" 2>/dev/null || true; set -u
    fi
    am_cf_id="${CF_ACCESS_CLIENT_ID:-${AGENTMAIL_CF_ACCESS_CLIENT_ID:-}}"
    am_cf_sec="${CF_ACCESS_CLIENT_SECRET:-${AGENTMAIL_CF_ACCESS_CLIENT_SECRET:-}}"
    am_bearer="${AGENTMAIL_HTTP_BEARER_TOKEN:-${MCP_BEARER_TOKEN:-}}"

    # Probe 1: Claude Code path (direct upstream + CF-Access headers)
    am_claude_code="000"
    if [[ -n "$am_bearer" && -n "$am_cf_id" && -n "$am_cf_sec" ]]; then
        am_claude_code=$(curl -sS -o /dev/null -w "%{http_code}" --max-time 5 \
            -H "CF-Access-Client-Id: $am_cf_id" \
            -H "CF-Access-Client-Secret: $am_cf_sec" \
            -H "Authorization: Bearer $am_bearer" \
            -X POST "$am_url" 2>/dev/null || echo "000")
    else
        am_claude_code="ENV"
    fi

    # Probe 2: Codex path (localhost shim — secrets injected by shim wrapper)
    am_codex_code="000"
    if lsof -iTCP:"$am_shim_port" -sTCP:LISTEN -P >/dev/null 2>&1; then
        am_codex_code=$(curl -sS -o /dev/null -w "%{http_code}" --max-time 6 \
            -X POST "$am_shim_url" -H "Content-Type: application/json" 2>/dev/null || echo "000")
    else
        am_codex_code="DOWN"
    fi

    # Classify each path: pass=2xx/400 (past CF gate), auth=302/401/403, dead=000/DOWN/ENV/5xx
    _am_classify() {
        case "$1" in
            2*|400|404|405) echo "pass" ;;
            302|401|403)    echo "auth" ;;
            000|ENV)        echo "dead" ;;
            DOWN)           echo "down" ;;
            5*)             echo "upstream" ;;
            *)              echo "weird" ;;
        esac
    }
    am_claude_status=$(_am_classify "$am_claude_code")
    am_codex_status=$(_am_classify "$am_codex_code")

    # Combine into a single recommendation. Token rotation is the LAST resort.
    am_recommend=""
    if [[ "$am_claude_status" == "pass" && "$am_codex_status" == "pass" ]]; then
        echo "✓ agent-mail healthy [paths=claude+codex] (claude=HTTP $am_claude_code, codex=HTTP $am_codex_code)"; ok=$((ok+1))
        am_recommend="none"
    elif [[ "$am_claude_status" == "pass" && "$am_codex_status" == "down" ]]; then
        echo "⚠ agent-mail codex path degraded — shim not listening on :$am_shim_port (claude path OK HTTP $am_claude_code)"; warn=$((warn+1))
        echo "    → investigate: launchctl list | grep mcp-cf-access-shim"
        am_recommend="restart-shim"
    elif [[ "$am_claude_status" == "pass" && "$am_codex_status" != "pass" ]]; then
        echo "⚠ agent-mail codex path degraded (claude=HTTP $am_claude_code OK, codex=HTTP $am_codex_code)"; warn=$((warn+1))
        echo "    → tail ~/.cache/mcp-cf-access-shim/$(date -u +%Y-%m-%d).log"
        am_recommend="investigate-shim"
    elif [[ "$am_claude_status" != "pass" && "$am_codex_status" == "pass" ]]; then
        echo "⚠ agent-mail direct CF-Access path degraded (claude=HTTP $am_claude_code, codex via shim OK HTTP $am_codex_code)"; warn=$((warn+1))
        echo "    → bare CF_ACCESS_CLIENT_* may be missing from infisical-cache (G50-1) — token might actually be expired"
        am_recommend="check-bare-cf-vars"
    elif [[ "$am_claude_status" == "auth" && "$am_codex_status" == "auth" ]]; then
        echo "✗ agent-mail CF Access auth failing on BOTH paths (claude=HTTP $am_claude_code, codex=HTTP $am_codex_code) — rotate service token"; fail=$((fail+1))
        am_recommend="rotate-service-token"
    elif [[ "$am_claude_status" == "dead" && "$am_codex_status" == "dead" ]] \
      || [[ "$am_claude_status" == "dead" && "$am_codex_status" == "down" ]]; then
        echo "✗ agent-mail unreachable on both paths (claude=$am_claude_code, codex=$am_codex_code) — upstream agent-mail server down or network broken"; fail=$((fail+1))
        am_recommend="check-upstream-or-network"
    else
        echo "⚠ agent-mail mixed/unexpected (claude=HTTP $am_claude_code, codex=HTTP $am_codex_code)"; warn=$((warn+1))
        am_recommend="manual-triage"
    fi

    # Emit machine-readable JSON line for downstream tooling (CASS, dashboards).
    if command -v jq >/dev/null 2>&1; then
        am_json=$(jq -nc \
            --arg claude_code "$am_claude_code" \
            --arg codex_code  "$am_codex_code" \
            --arg claude_path_status "$am_claude_status" \
            --arg codex_path_status  "$am_codex_status" \
            --arg recommended_action "$am_recommend" \
            --arg url "$am_url" \
            --arg shim "$am_shim_url" \
            '{probe:"agent-mail",url:$url,shim:$shim,
              claude_code:$claude_code,codex_code:$codex_code,
              claude_path_status:$claude_path_status,
              codex_path_status:$codex_path_status,
              recommended_action:$recommended_action}' 2>/dev/null || true)
        [[ -n "$am_json" ]] && echo "  · json: $am_json"
    fi

    # Codex config drift check: codex-cli TOML lacks header support → CF Access bounces
    if [[ -f "$HOME/.codex/config.toml" ]] && grep -q "mcp-agent-mail" "$HOME/.codex/config.toml" 2>/dev/null; then
        if grep -q "CF-Access" "$HOME/.codex/config.toml" 2>/dev/null; then
            echo "✓ codex agent-mail config carries CF-Access headers"; ok=$((ok+1))
        elif grep -q "127.0.0.1:7878" "$HOME/.codex/config.toml" 2>/dev/null; then
            echo "✓ codex agent-mail config routed via mcp-cf-access-shim (G50)"; ok=$((ok+1))
        else
            echo "⚠ codex agent-mail config lacks CF-Access headers AND no shim route — codex panes will fail (G48; needs proxy or CF bypass)"; warn=$((warn+1))
        fi
    fi
    # Codex config drift check: codex-cli TOML lacks header support → CF Access bounces
    if [[ -f "$HOME/.codex/config.toml" ]] && grep -q "mcp-agent-mail" "$HOME/.codex/config.toml" 2>/dev/null; then
        if grep -q "CF-Access" "$HOME/.codex/config.toml" 2>/dev/null; then
            echo "✓ codex agent-mail config carries CF-Access headers"; ok=$((ok+1))
        elif grep -q "127.0.0.1:7878" "$HOME/.codex/config.toml" 2>/dev/null; then
            echo "✓ codex agent-mail config routed via mcp-cf-access-shim (G50)"; ok=$((ok+1))
        else
            echo "⚠ codex agent-mail config lacks CF-Access headers AND no shim route — codex panes will fail (G48; needs proxy or CF bypass)"; warn=$((warn+1))
        fi
    fi
    set -e
    echo ""
    # ── codex pane health (2026-04-27 G55; first-class doctrine) ──────────
    echo "=== codex pane health ==="
    set +e
    # Probe 1: AGENTS.md exists + freshness
    if [[ -f "$HOME/.codex/AGENTS.md" ]]; then
        codex_agents_age_days=$(( ( $(date +%s) - $(stat -f %m "$HOME/.codex/AGENTS.md" 2>/dev/null || echo 0) ) / 86400 ))
        if [[ "$codex_agents_age_days" -le 30 ]]; then
            echo "✓ ~/.codex/AGENTS.md present (mtime ${codex_agents_age_days}d ago)"; ok=$((ok+1))
        else
            echo "⚠ ~/.codex/AGENTS.md stale (${codex_agents_age_days}d > 30d) — drift signal vs ~/.claude/CLAUDE.md"; warn=$((warn+1))
        fi
    else
        echo "✗ ~/.codex/AGENTS.md missing — codex panes have no doctrine"; fail=$((fail+1))
    fi
    # Probe 2: TOML lints clean
    if [[ -f "$HOME/.codex/config.toml" ]]; then
        codex_toml_python=""
        for py in python3.14 python3.13 python3.12 python3.11 python3; do
            if command -v "$py" >/dev/null 2>&1; then
                codex_toml_python="$(command -v "$py")"
                break
            fi
        done
        if [[ -n "$codex_toml_python" ]] && "$codex_toml_python" - "$HOME/.codex/config.toml" 2>/dev/null <<'PY'
import sys
try:
    import tomllib
except ModuleNotFoundError:
    import tomli as tomllib

with open(sys.argv[1], "rb") as f:
    tomllib.load(f)
PY
        then
            echo "✓ ~/.codex/config.toml parses clean (TOML)"; ok=$((ok+1))
        else
            echo "✗ ~/.codex/config.toml fails TOML parse — codex won't load (G48-class)"; fail=$((fail+1))
        fi
    else
        echo "✗ ~/.codex/config.toml missing — codex MCP wiring absent"; fail=$((fail+1))
    fi
    # Probe 3: MCP parity diff (Claude .mcp.json vs codex config.toml)
    if [[ -f "$HOME/.claude/.mcp.json" && -f "$HOME/.codex/config.toml" ]] && command -v jq >/dev/null 2>&1 && command -v python3 >/dev/null 2>&1; then
        cc_servers=$(jq -r '.mcpServers // {} | to_entries[] | select(.value.disabled != true) | .key' "$HOME/.claude/.mcp.json" 2>/dev/null | sort -u)
        codex_servers=$(python3 -c 'import sys,tomllib;d=tomllib.load(open(sys.argv[1],"rb"));print("\n".join(sorted((d.get("mcp_servers") or {}).keys())))' "$HOME/.codex/config.toml" 2>/dev/null)
        claude_only=$(comm -23 <(printf '%s\n' "$cc_servers") <(printf '%s\n' "$codex_servers"))
        codex_only=$(comm -13 <(printf '%s\n' "$cc_servers") <(printf '%s\n' "$codex_servers"))
        if [[ -z "$claude_only" && -z "$codex_only" ]]; then
            echo "✓ MCP parity: Claude Code and codex agree on server list"; ok=$((ok+1))
        else
            [[ -n "$claude_only" ]] && echo "⚠ claude-only MCPs (not in codex): $(echo $claude_only | tr '\n' ' ')" && warn=$((warn+1))
            [[ -n "$codex_only" ]] && echo "⚠ codex-only MCPs (not in claude): $(echo $codex_only | tr '\n' ' ')" && warn=$((warn+1))
            echo "  → triage in ~/.claude/skills/agent-mail/references/MCP-PARITY-MATRIX.md"
        fi
    else
        echo "⚠ MCP parity skipped (jq/python3 missing or config files absent)"; warn=$((warn+1))
    fi
    # Probe 4: skills.bak detection (G51 stale snapshot risk)
    if [[ -d "$HOME/.codex/skills.bak" ]]; then
        echo "⚠ ~/.codex/skills.bak/ exists — frozen pre-G29-H snapshot may surface stale YAML errors"
        echo "  recipe: find ~/.codex/skills.bak -name SKILL.md  (consider archiving)"
        warn=$((warn+1))
    else
        echo "✓ no ~/.codex/skills.bak/ snapshot present"; ok=$((ok+1))
    fi
    set -e
    echo ""
    # ── mcp-cf-shim health (2026-04-27 G50; codex-cli has no `headers` map) ──
    echo "=== mcp-cf-shim health ==="
    set +e
    shim_label="ai.zeststream.mcp-cf-access-shim"
    shim_port="${CF_SHIM_PORT:-7878}"
    # Shim writes log filenames using LOCAL date (`_dt.date.today()` in
    # ~/.local/bin/mcp-cf-access-shim line 64). Probing `date -u` warned
    # spuriously during the UTC/local-overlap window each day. Probe both
    # — whichever is non-empty wins; default to local for the "missing" message.
    shim_log_local="$HOME/.cache/mcp-cf-access-shim/$(date +%Y-%m-%d).log"
    shim_log_utc="$HOME/.cache/mcp-cf-access-shim/$(date -u +%Y-%m-%d).log"
    if [[ -s "$shim_log_local" ]]; then
        shim_log="$shim_log_local"
    elif [[ -s "$shim_log_utc" ]]; then
        shim_log="$shim_log_utc"
    else
        shim_log="$shim_log_local"
    fi
    _lc=$(launchctl list 2>/dev/null || true)
    if printf '%s\n' "$_lc" | grep -q "$shim_label"; then
        echo "✓ LaunchAgent $shim_label registered"; ok=$((ok+1))
    else
        echo "⚠ LaunchAgent $shim_label not loaded — codex panes will fail (run install-shim.sh)"; warn=$((warn+1))
    fi
    if lsof -iTCP:"$shim_port" -sTCP:LISTEN -P >/dev/null 2>&1; then
        echo "✓ shim listening on 127.0.0.1:$shim_port"; ok=$((ok+1))
        shim_code=$(curl -sS -o /dev/null -w "%{http_code}" --max-time 6 \
            -X POST "http://127.0.0.1:$shim_port/mcp/" -H "Content-Type: application/json" 2>/dev/null || echo 000)
        case "$shim_code" in
            2*|400|404|405) echo "✓ shim proxied past CF Access (HTTP $shim_code)"; ok=$((ok+1)) ;;
            302) echo "✗ shim returned 302 — header injection broken (rotate CF service token)"; fail=$((fail+1)) ;;
            502) echo "✗ shim 502 — upstream connection failure (see $shim_log)"; fail=$((fail+1)) ;;
            000) echo "✗ shim unreachable / timeout"; fail=$((fail+1)) ;;
            *)   echo "⚠ shim HTTP $shim_code (unexpected)"; warn=$((warn+1)) ;;
        esac
    else
        echo "⚠ shim NOT listening on $shim_port"; warn=$((warn+1))
    fi
    if [[ -s "$shim_log" ]]; then
        echo "✓ shim NDJSON log fresh ($shim_log)"; ok=$((ok+1))
    else
        echo "⚠ shim NDJSON log empty/missing for today"; warn=$((warn+1))
    fi
    # G73 (2026-04-27): duplicate-Authorization trauma. Codex sends its own
    # `authorization` header (lowercase) via bearer_token_env_var. If the shim
    # forwards it AND injects its own "Authorization" (TitleCase), CF Access
    # rejects with 400 Bad Request HTML. Probe replays this exact failure mode.
    if lsof -iTCP:"$shim_port" -sTCP:LISTEN -P >/dev/null 2>&1; then
        dup_code=$(curl -sS -o /dev/null -w "%{http_code}" --max-time 6 \
            -X POST "http://127.0.0.1:$shim_port/mcp/" \
            -H "Content-Type: application/json" \
            -H "Authorization: Bearer flywheel-doctor-junk-should-be-stripped" \
            -d '{"jsonrpc":"2.0","id":1,"method":"initialize","params":{"protocolVersion":"2025-06-18","capabilities":{},"clientInfo":{"name":"flywheel-doctor","version":"1"}}}' \
            2>/dev/null || echo 000)
        case "$dup_code" in
            2*) echo "✓ shim strips client-supplied Authorization (G73 invariant: HTTP $dup_code)"; ok=$((ok+1)) ;;
            400) echo "✗ shim G73 regression — duplicate Authorization headers reaching upstream (HTTP 400). Patch ~/.local/bin/mcp-cf-access-shim OWNED set."; fail=$((fail+1)) ;;
            *)   echo "⚠ shim G73 probe returned HTTP $dup_code (unexpected)"; warn=$((warn+1)) ;;
        esac
    fi
    # Infisical-cache deployment substrate (shim wrapper sources this)
    cache_env="$HOME/.opencode/secrets/infisical-cache.env"
    if [[ -r "$cache_env" ]]; then
        cache_age_d=$(( ( $(date +%s) - $(stat -f %m "$cache_env" 2>/dev/null || echo 0) ) / 86400 ))
        # Wrapper at ~/.local/bin/mcp-cf-access-shim-wrapper.sh aliases:
        #   CF_ACCESS_CLIENT_ID    ←  AGENTMAIL_CF_ACCESS_CLIENT_ID (fallback)
        #   CF_ACCESS_CLIENT_SECRET ← AGENTMAIL_CF_ACCESS_CLIENT_SECRET (fallback)
        #   MCP_BEARER_TOKEN       ←  AGENTMAIL_HTTP_BEARER_TOKEN (fallback)
        # So the cache only needs ONE name from each pair.
        missing=()
        _has_either() { grep -qE "^($1)=" "$cache_env" 2>/dev/null; }
        _has_either 'CF_ACCESS_CLIENT_ID|AGENTMAIL_CF_ACCESS_CLIENT_ID' || missing+=("CF_ACCESS_CLIENT_ID")
        _has_either 'CF_ACCESS_CLIENT_SECRET|AGENTMAIL_CF_ACCESS_CLIENT_SECRET' || missing+=("CF_ACCESS_CLIENT_SECRET")
        _has_either 'MCP_BEARER_TOKEN|AGENTMAIL_HTTP_BEARER_TOKEN' || missing+=("MCP_BEARER_TOKEN")
        if (( ${#missing[@]} == 0 )); then
            if (( cache_age_d > 30 )); then
                echo "⚠ infisical-cache.env present but ${cache_age_d}d old (rotate via infisical export)"; warn=$((warn+1))
            else
                echo "✓ infisical-cache.env complete + fresh (${cache_age_d}d, all 4 keys present)"; ok=$((ok+1))
            fi
        else
            echo "✗ infisical-cache.env missing keys: ${missing[*]}"; fail=$((fail+1))
        fi
    else
        echo "⚠ infisical-cache.env not found at $cache_env (deployment substrate missing — shim wrapper will fail silently)"; warn=$((warn+1))
    fi
    set -e
    echo ""
    # ── cf-secret-helper-present (2026-04-27 secrets-live-source doctrine) ───
    # Doctrine: scripts source secrets LIVE from secrets.zeststream.ai via the
    # zeststream machine identity, NOT by grepping infisical-cache.env. The
    # cache is a perf/fallback layer only. ~/.local/bin/cf-secret encodes that
    # contract. This invariant catches: (a) helper missing/non-exec, (b) probe
    # failure (identity broken), (c) round-trip failure (Infisical unreachable
    # AND cache stale).
    echo "=== cf-secret-helper-present invariant ==="
    set +e
    cfs="$HOME/.local/bin/cf-secret"
    if [[ ! -x "$cfs" ]]; then
        echo "✗ cf-secret missing or non-executable: $cfs (secrets-live-source doctrine breach)"; fail=$((fail+1))
    else
        echo "✓ cf-secret helper present and executable"; ok=$((ok+1))
        if "$cfs" --probe >/dev/null 2>&1; then
            echo "✓ cf-secret --probe ok (zeststream machine identity healthy)"; ok=$((ok+1))
        else
            echo "✗ cf-secret --probe failed (Infisical unreachable AND cache stale, or identity broken)"; fail=$((fail+1))
        fi
        # Round-trip: pull a known-present secret, confirm length plausible.
        cfs_len=$("$cfs" CF_API_TOKEN 2>/dev/null | head -c 10 | wc -c | tr -d ' ' | head -1)
        if [[ "$cfs_len" =~ ^[0-9]+$ ]] && [[ "$cfs_len" -gt 9 ]]; then
            echo "✓ cf-secret round-trip ok (CF_API_TOKEN loadable)"; ok=$((ok+1))
        else
            echo "✗ cf-secret round-trip failed (CF_API_TOKEN not loadable via helper)"; fail=$((fail+1))
        fi
    fi
    set -e
    echo ""
    # ── infisical secret substrate (2026-04-27 write-path doctrine) ───
    # Doctrine: WRITE-side helper at ~/.local/bin/infisical-set is the canonical
    # path for adding/rotating secrets to Infisical. Stdin-only, read-back
    # verified, audit-logged to flywheel state.db. Companion to cf-secret on the
    # read side. Shared identity lib at ~/.local/share/infisical-helpers/lib.sh.
    # This invariant catches: helper missing, identity drift, and gives 30d
    # write activity as informational signal.
    echo "=== infisical secret substrate ==="
    set +e
    iset="$HOME/.local/bin/infisical-set"
    ihelp_lib="$HOME/.local/share/infisical-helpers/lib.sh"
    if [[ ! -x "$iset" ]]; then
        echo "✗ infisical-set missing or non-executable: $iset (write-path doctrine breach)"; fail=$((fail+1))
    else
        echo "✓ infisical-set present and executable"; ok=$((ok+1))
    fi
    if [[ ! -r "$ihelp_lib" ]]; then
        echo "✗ shared lib missing: $ihelp_lib"; fail=$((fail+1))
    else
        echo "✓ shared identity lib present"; ok=$((ok+1))
    fi
    if [[ -x "$iset" ]]; then
        if "$iset" --probe >/dev/null 2>&1; then
            echo "✓ infisical-set --probe ok (zeststream write identity healthy)"; ok=$((ok+1))
        else
            echo "✗ infisical-set --probe failed (zeststream write identity broken)"; fail=$((fail+1))
        fi
    fi
    # 30d write activity (informational only; non-failing)
    fwdb="$HOME/.claude/skills/.flywheel/state.db"
    if [[ -f "$fwdb" ]]; then
        wcount=$(sqlite3 "$fwdb" "SELECT COUNT(*) FROM events WHERE kind='secret_write' AND ts > datetime('now','-30 days');" 2>/dev/null | head -1)
        if [[ "$wcount" =~ ^[0-9]+$ ]]; then
            echo "ℹ infisical-set: $wcount secret_write events in last 30d (audit trail)"
        fi
    fi
    set -e
    echo ""
    # ── infisical-cache-fallback regression (G-CF-7, 2026-04-28) ───
    # Doctrine: secrets-live-source. ALL load-bearing skill scripts MUST source
    # from `secrets.zeststream.ai` via cf-secret (live-first, cache-fallback
    # <24h) — NOT by grepping ~/.opencode/secrets/infisical-cache.env directly.
    # This invariant scans skill scripts for the cache filename and fails on
    # any non-.bak/.legacy hit. Fix list lives in cache-source-audit-2026-04-28.md.
    echo "=== infisical-cache-fallback regression ==="
    set +e
    # G-CF-21 (2026-04-28): the 6 known hits are ALL legitimate substrate-owners
    # (cf-secret consumers' diagnostic-only refs, infisical-rotation-ops probes,
    # security-posture health-probes, mcp-secret-scanner template-vs-rendered
    # comments). Allowlist them so this fires only on NEW additions.
    cache_allowlist_file="$HOME/.claude/skills/.flywheel/data/cache-fallback-allowlist.txt"
    cache_hits=$(grep -rln 'infisical-cache.env' "$HOME/.claude/skills"/*/scripts/ 2>/dev/null | grep -v -E '\.bak|\.legacy' || true)
    cache_actual_count=0
    cache_allowed_count=0
    cache_new_paths=()
    if [[ -f "$cache_allowlist_file" ]]; then
        # Build allowlist: strip comments/blank lines, prefix with $HOME
        mapfile -t cache_allowlist < <(grep -v -E '^\s*(#|$)' "$cache_allowlist_file" | sed "s|^|$HOME/|")
    else
        cache_allowlist=()
    fi
    if [[ -n "$cache_hits" ]]; then
        while IFS= read -r hit; do
            cache_actual_count=$((cache_actual_count+1))
            is_allowed=0
            for allowed in "${cache_allowlist[@]}"; do
                [[ "$hit" == "$allowed" ]] && { is_allowed=1; break; }
            done
            if [[ $is_allowed -eq 1 ]]; then
                cache_allowed_count=$((cache_allowed_count+1))
            else
                cache_new_paths+=("$hit")
            fi
        done <<< "$cache_hits"
    fi
    cache_new_count=${#cache_new_paths[@]}
    if [[ "$cache_new_count" -gt 0 ]]; then
        echo "✗ cache_fallback_regressions: $cache_new_count (NEW: ${cache_new_paths[*]}) — classify per proposals/skill-cache-regressions-2026-04-28.md, then add to data/cache-fallback-allowlist.txt if legitimate"
        fail=$((fail+1))
    else
        echo "✓ cache_fallback_regressions: 0 ($cache_allowed_count known-legitimate, allowlisted)"
        ok=$((ok+1))
    fi
    set -e
    echo ""
    # ── path-binary cache-fallback regression (G-CF-19 sibling, 2026-04-28) ───
    # Sibling counter to cache_fallback_regressions (which only scans skill
    # scripts under ~/.claude/skills/*/scripts/). This block scans PATH binaries
    # in ~/.local/bin/ for the same cache-source antipattern. Population is
    # tracked separately so each can trend independently as G-CF-19 patches land
    # (recommendation per G-CF-21). WARN (not FAIL) because the patch bundle is
    # Joshua-gated — this is an observability metric, not a hard breakage.
    echo "=== path-binary cache-fallback regression ==="
    set +e
    pbin_allowlist_file="$HOME/.claude/skills/.flywheel/data/path-binary-cache-allowlist.txt"
    pbin_hits=$(find "$HOME/.local/bin" -maxdepth 1 -type f -size -1M ! -name '*bak*' ! -name '*backup*' ! -name '*.legacy' -print0 2>/dev/null | xargs -0 grep -lE 'infisical-cache\.env' 2>/dev/null || true)
    pbin_timeout=0
    pbin_actual_count=0
    pbin_allowed_count=0
    pbin_new_paths=()
    if [[ -f "$pbin_allowlist_file" ]]; then
        mapfile -t pbin_allowlist < <(grep -v -E '^\s*(#|$)' "$pbin_allowlist_file" | sed "s|^|$HOME/|")
    else
        pbin_allowlist=()
    fi
    if [[ -n "$pbin_hits" ]]; then
        while IFS= read -r hit; do
            pbin_actual_count=$((pbin_actual_count+1))
            is_allowed=0
            for allowed in "${pbin_allowlist[@]}"; do
                [[ "$hit" == "$allowed" ]] && { is_allowed=1; break; }
            done
            if [[ $is_allowed -eq 1 ]]; then
                pbin_allowed_count=$((pbin_allowed_count+1))
            else
                pbin_new_paths+=("$hit")
            fi
        done <<< "$pbin_hits"
    fi
    pbin_new_count=${#pbin_new_paths[@]}
    if [[ "$pbin_timeout" -eq 1 ]]; then
        echo "⚠ path_binary_cache_fallback_regressions: scan timed out after 3s — doctor continues; run targeted cache-source audit"; warn=$((warn+1))
    elif [[ "$pbin_new_count" -gt 0 ]]; then
        # Render basenames for readability; full paths preserved in proposal.
        pbin_basenames=()
        for p in "${pbin_new_paths[@]}"; do pbin_basenames+=("$(basename "$p")"); done
        echo "⚠ path_binary_cache_fallback_regressions: $pbin_new_count (${pbin_basenames[*]}) — see proposals/cache-source-audit-2026-04-28.md (G-CF-19 patch bundle, Joshua-gated)"
        warn=$((warn+1))
    else
        echo "✓ path_binary_cache_fallback_regressions: 0 ($pbin_allowed_count known-legitimate, allowlisted)"
        ok=$((ok+1))
    fi
    set -e
    echo ""
    # ── non-ASCII bytes in skill scripts (G-DOC-2 sibling, 2026-04-27) ───
    # Trauma class: U+2026 (typographic ellipsis) and other non-ASCII bytes
    # adjacent to identifiers break shell variable parsing silently. AI output
    # (Claude/Codex) sometimes emits typographic glyphs instead of ASCII.
    # `bash -n` passes; failure surfaces only at runtime when `$VAR…` resolves
    # to empty. WARN not FAIL — legitimate Unicode-in-comments uses exist.
    echo "=== non-ASCII bytes in skill scripts ==="
    set +e
    # Scan ~/.claude/skills/*/scripts/*.sh for non-ASCII bytes (>0x7F).
    # Common offenders: U+2026 horizontal ellipsis, U+201C/D smart quotes,
    # U+2013/2014 en/em dashes — all of which break shell variable parsing
    # when adjacent to identifiers (e.g., `$NAME…` parses as `$NAME...` literally).
    # Use byte-class [\x80-\xFF] (BSD-grep compatible) instead of -P PCRE
    # because system grep on macOS is BSD grep, which lacks -P support.
    non_ascii_files=$(LC_ALL=C grep -rl $'[\x80-\xFF]' "$HOME/.claude/skills"/*/scripts/*.sh 2>/dev/null | grep -v -E '\.bak|\.legacy' || true)
    non_ascii_count=0
    if [[ -n "$non_ascii_files" ]]; then
        non_ascii_count=$(echo "$non_ascii_files" | wc -l | tr -d ' ')
    fi
    if [[ "$non_ascii_count" -gt 0 ]]; then
        # WARN not FAIL — some uses are legitimate (comments referencing Unicode),
        # but every hit deserves a human eye for AI-introduced typographic glyphs.
        basenames=$(echo "$non_ascii_files" | xargs -n1 basename | tr '\n' ' ')
        echo "⚠ non_ascii_in_scripts: $non_ascii_count file(s) ($basenames) — review for AI-introduced typographic chars (U+2026, U+201x smart quotes, U+201x dashes); legitimate uses OK, identifier-adjacent are bugs"
        warn=$((warn+1))
    else
        echo "✓ non_ascii_in_scripts: 0 (no non-ASCII bytes in skill .sh files)"
        ok=$((ok+1))
    fi
    set -e
    echo ""
    # ── josh-ops pipeline freshness ────────────────────────────
    if [[ "$DOCTOR_DEEP" != "1" ]]; then
        echo "=== josh-ops pipeline freshness ==="
        echo "○ skipped in fast doctor (run: flywheel doctor --deep)"
        echo ""
    else
    # G74 (2026-04-27): josh-ops drives 65 launchd plists writing to
    # ~/.claude/skills/reports/. Silent loop death = stale outputs. This
    # invariant catches *any* plist that stopped emitting within the last 48h.
    # Owner skill: josh-ops (~/Developer/josh-ops/launchd/).
    echo "=== josh-ops pipeline freshness ==="
    set +e
    reports_dir="$HOME/.claude/skills/reports"
    if [[ -d "$reports_dir" ]]; then
        # Files we expect refreshed daily (skip weekly-only & deprecated names)
        daily_signals=( grading-sweep.json autoresearch-queue.json bridge-throughput.jsonl
                        compliance-audit-trail.jsonl skill-gaps.jsonl skill-outcomes.jsonl
                        mission-staleness.json self-healing-log.json service-slo.json
                        token-efficiency.json sglang-latency-metrics.json
                        qdrant-search-latency.json search-quality-feedback.json
                        skill-pass-beads.json tick-grades.jsonl )
        stale_signals=()
        missing_signals=()
        for s in "${daily_signals[@]}"; do
            f="$reports_dir/$s"
            if [[ ! -f "$f" ]]; then
                missing_signals+=("$s"); continue
            fi
            age_h=$(( ( $(date +%s) - $(stat -f %m "$f" 2>/dev/null || echo 0) ) / 3600 ))
            if (( age_h > 48 )); then
                stale_signals+=("$s(${age_h}h)")
            fi
        done
        if (( ${#stale_signals[@]} == 0 && ${#missing_signals[@]} == 0 )); then
            echo "✓ all ${#daily_signals[@]} josh-ops daily report signals fresh (<48h)"; ok=$((ok+1))
        else
            (( ${#stale_signals[@]} > 0 )) && { echo "⚠ stale josh-ops signals: ${stale_signals[*]}"; warn=$((warn+1)); }
            (( ${#missing_signals[@]} > 0 )) && { echo "⚠ missing josh-ops signals: ${missing_signals[*]}"; warn=$((warn+1)); }
        fi
        # Plists with non-zero exit codes — classified via plist-classes.json (G02 close, 2026-04-27)
        # Classes: VLAN_DEPENDENT (info), SIGNAL_AS_INTENDED (info, exit=1 IS the alert),
        #          BROKEN (warn, actionable), DEFERRED (info, parked-with-intent),
        #          unclassified (warn, forcing-function for triage). Forever-rule: any non-zero
        #          exit not in the JSON surfaces as ⚠ unclassified broken.
        classes_file="$HOME/.claude/skills/.flywheel/config/plist-classes.json"
        if [[ -f "$classes_file" ]] && command -v jq >/dev/null 2>&1; then
            declare -a vlan_arr=() signal_arr=() broken_arr=() deferred_arr=() unclass_arr=()
            while IFS=' ' read -r exit_code label; do
                [[ -z "$label" ]] && continue
                cls=$(jq -r --arg L "$label" '.classes[$L].class // "UNCLASSIFIED"' "$classes_file" 2>/dev/null)
                case "$cls" in
                    VLAN_DEPENDENT)     vlan_arr+=("$label") ;;
                    SIGNAL_AS_INTENDED) signal_arr+=("$label") ;;
                    BROKEN)             broken_arr+=("$label(exit=$exit_code)") ;;
                    DEFERRED)           deferred_arr+=("$label") ;;
                    *)                  unclass_arr+=("$label(exit=$exit_code)") ;;
                esac
            done < <(launchctl list 2>/dev/null | awk '/com\.(cubcloud|zeststream)/ && $2 != "-" && $2 != "0" {print $2, $3}')
            total_nonzero=$(( ${#vlan_arr[@]} + ${#signal_arr[@]} + ${#broken_arr[@]} + ${#deferred_arr[@]} + ${#unclass_arr[@]} ))
            if (( total_nonzero == 0 )); then
                echo "✓ no josh-ops plists in failed-exit state"; ok=$((ok+1))
            else
                (( ${#signal_arr[@]}   > 0 )) && echo "ℹ ${#signal_arr[@]} signal-as-intended audit(s) firing: ${signal_arr[*]}"
                (( ${#vlan_arr[@]}     > 0 )) && echo "ℹ ${#vlan_arr[@]} VLAN-dependent plist(s) off-network: ${vlan_arr[*]}"
                (( ${#deferred_arr[@]} > 0 )) && echo "ℹ ${#deferred_arr[@]} deferred/parked plist(s): ${deferred_arr[*]}"
                if (( ${#broken_arr[@]} > 0 )); then
                    echo "⚠ BROKEN plists (actionable): ${broken_arr[*]}"; warn=$((warn+1))
                fi
                if (( ${#unclass_arr[@]} > 0 )); then
                    for entry in "${unclass_arr[@]}"; do
                        echo "⚠ unclassified broken: $entry — classify in $classes_file"
                    done
                    warn=$((warn+1))
                fi
                today=$(date +%Y-%m-%d)
                expired=$(jq -r --arg today "$today" '[.classes | to_entries[] | select(.value.review_after != null and .value.review_after < $today) | .key] | join(" ")' "$classes_file" 2>/dev/null)
                if [[ -n "$expired" ]]; then
                    echo "⚠ plist-classes entries past review_after ($today): $expired"; warn=$((warn+1))
                fi
            fi
            unset vlan_arr signal_arr broken_arr deferred_arr unclass_arr
        else
            bad_plists=$(launchctl list 2>/dev/null | awk '/com\.(cubcloud|zeststream)/ && $2 != "-" && $2 != "0" {printf "%s(exit=%s) ", $3, $2}')
            if [[ -z "$bad_plists" ]]; then
                echo "✓ no josh-ops plists in failed-exit state"; ok=$((ok+1))
            else
                echo "⚠ josh-ops plists with non-zero exit (UNCLASSIFIED — config or jq missing): $bad_plists"; warn=$((warn+1))
            fi
        fi
        # ── plist PATH/binary hygiene (P06 encoding, 2026-04-27) ──
        # Encodes PATTERNS.md P06 ("wrapper-script launchers hide dead artifacts")
        # + the docker-maintenance LESSON ("launchd plists are NOT login shells").
        # Two sub-invariants:
        #   plist_path_undeclared  — script under user dirs without EnvironmentVariables.PATH
        #                            (or PATH missing /opt/homebrew/bin)
        #   plist_phantom_binary   — ProgramArguments[0] (or BINARY=/EXEC= inside a wrapper)
        #                            points at a non-existent / non-executable file
        # Hygiene warns only — never fail. Initial sweep state captured in CHANGELOG.
    set -e
        echo "=== plist PATH/binary hygiene ==="
        set +e
        plist_dirs=( "$HOME/Library/LaunchAgents" "$HOME/Developer/josh-ops/launchd" )
        ok_system=0
        ok_absolute=0
        path_undeclared=()
        phantom_binary=()
        absolute_missing=()
        # User-script roots that REQUIRE EnvironmentVariables.PATH
        user_roots_re='^(/Users/[^/]+/(\.local/bin|bin|Developer|\.fleet-commander)/)'
        # System dirs — always OK, no probe needed
        system_dirs_re='^(/usr/bin|/bin|/sbin|/usr/sbin)/'
        # Absolute dirs — OK if extant
        absolute_dirs_re='^(/opt/homebrew|/usr/local|/Applications)/'
        while IFS= read -r label; do
            if [[ -z "$label" ]]; then continue; fi
            plist_file=""
            for d in "${plist_dirs[@]}"; do
                if [[ -f "$d/$label.plist" ]]; then plist_file="$d/$label.plist"; break; fi
            done
            if [[ -z "$plist_file" ]]; then continue; fi
            # Extract PA[0] + PATH via plutil JSON; fall back to "" on failure
            pa0=$(plutil -convert json -o - "$plist_file" 2>/dev/null \
                | python3 -c 'import json,sys
try:
    d=json.load(sys.stdin); pa=d.get("ProgramArguments",[])
    print(pa[0] if pa else "")
except Exception: print("")' 2>/dev/null || true)
            env_path=$(plutil -convert json -o - "$plist_file" 2>/dev/null \
                | python3 -c 'import json,sys
try:
    d=json.load(sys.stdin); ev=d.get("EnvironmentVariables",{}) or {}
    print(ev.get("PATH","") or "")
except Exception: print("")' 2>/dev/null || true)
            if [[ -z "$pa0" ]]; then continue; fi
            # Case (a) system path — always OK
            if [[ "$pa0" =~ $system_dirs_re ]]; then
                ok_system=$((ok_system+1))
                continue
            fi
            # Case (b) absolute /opt/homebrew, /usr/local, /Applications — OK if extant
            if [[ "$pa0" =~ $absolute_dirs_re ]]; then
                if [[ -e "$pa0" ]]; then
                    ok_absolute=$((ok_absolute+1))
                else
                    absolute_missing+=("$label ($pa0)")
                fi
                continue
            fi
            # Case (c) user-script — REQUIRES EnvironmentVariables.PATH containing /opt/homebrew/bin
            if [[ "$pa0" =~ $user_roots_re ]]; then
                if [[ -z "$env_path" ]] || [[ "$env_path" != *"/opt/homebrew/bin"* ]]; then
                    if [[ -z "$env_path" ]]; then
                        path_undeclared+=("$label (script $pa0, no EnvironmentVariables.PATH)")
                    else
                        path_undeclared+=("$label (script $pa0, PATH lacks /opt/homebrew/bin)")
                    fi
                else
                    ok_absolute=$((ok_absolute+1))
                fi
                # Bonus (P06): cat the wrapper, look for BINARY=/EXEC=, probe
                if [[ -f "$pa0" ]]; then
                    while IFS= read -r decl; do
                        # extract RHS (strip quotes, leading spaces, trailing comment)
                        rhs=$(echo "$decl" | sed -E 's/^(BINARY|EXEC)=//; s/[[:space:]]*#.*$//; s/^"//; s/"$//; s/^'\''//; s/'\''$//')
                        # expand $HOME / ~ if present (best-effort)
                        rhs="${rhs//\$HOME/$HOME}"
                        rhs="${rhs/#\~/$HOME}"
                        if [[ -z "$rhs" ]]; then continue; fi
                        # only probe absolute paths
                        if [[ "$rhs" != /* ]]; then continue; fi
                        if [[ ! -x "$rhs" ]]; then
                            phantom_binary+=("$label (wrapper $pa0 -> missing $rhs)")
                        fi
                    done < <(grep -E '^(BINARY|EXEC)=' "$pa0" 2>/dev/null | head -3)
                fi
                continue
            fi
            # Anything else: probe existence; treat as absolute_missing if absent
            if [[ -e "$pa0" ]]; then
                ok_absolute=$((ok_absolute+1))
            else
                absolute_missing+=("$label ($pa0)")
            fi
        done < <(launchctl list 2>/dev/null | awk '/com\.(cubcloud|zeststream)\./ {print $3}' | sort)
        echo "✓ $ok_system plists OK (system path)"
        echo "✓ $ok_absolute plists OK (absolute path + extant binary + declared PATH where required)"
        if (( ${#absolute_missing[@]} > 0 )); then
            for entry in "${absolute_missing[@]}"; do
                echo "⚠ plist_phantom_binary: $entry"; warn=$((warn+1))
            done
        fi
        if (( ${#path_undeclared[@]} > 0 )); then
            for entry in "${path_undeclared[@]}"; do
                echo "⚠ plist_path_undeclared: $entry"; warn=$((warn+1))
            done
        fi
        if (( ${#phantom_binary[@]} > 0 )); then
            for entry in "${phantom_binary[@]}"; do
                echo "⚠ plist_phantom_binary: $entry"; warn=$((warn+1))
            done
        fi
        unset path_undeclared phantom_binary absolute_missing
        # ── FKO phantom-substrate probe (G84, axiom-12, 2026-04-27) ──
        # ~/.claude/references/federated-knowledge-search.md cites FKO at
        # ~/Desktop/Projects/tools/knowledge_graph/fko as "Production Ready".
        # Probe leaf: directory existence. WARN if doctrine-cited but absent.
        _fko_ref="$HOME/.claude/references/federated-knowledge-search.md"
        _fko_path="$HOME/Desktop/Projects/tools/knowledge_graph/fko"
        if [[ -f "$_fko_ref" ]]; then
            if [[ -e "$_fko_path" ]]; then
                echo "✓ fko_phantom_substrate: doctrine ref + leaf path both present ($_fko_path)"; ok=$((ok+1))
            else
                echo "⚠ fko_phantom_substrate: federated-knowledge-search.md cites FKO 'Production Ready' but $_fko_path is absent (G84, axiom-12)"; warn=$((warn+1))
            fi
        else
            echo "✓ fko_phantom_substrate: doctrine ref absent (no claim to probe)"; ok=$((ok+1))
        fi
        unset _fko_ref _fko_path
        # context-integrity-scan defined but unloaded?
        # NOTE: avoid `launchctl list | grep -q` under `set -o pipefail` — grep -q
        # closes stdin early, launchctl gets SIGPIPE (141), pipeline fails even on match.
        # Capture once, then string-test.
        _cis_list="$(launchctl list 2>/dev/null || true)"
        if [[ -f "$HOME/Developer/josh-ops/launchd/com.cubcloud.context-integrity-scan.plist" ]] && \
           [[ "$_cis_list" != *"com.cubcloud.context-integrity-scan"* ]]; then
            echo "⚠ context-integrity-scan plist defined but NOT loaded — prompt-injection scanner offline"; warn=$((warn+1))
        else
            echo "✓ context-integrity-scan loaded (or plist absent)"; ok=$((ok+1))
        fi
        unset _cis_list
    else
        echo "⚠ ~/.claude/skills/reports/ missing — josh-ops pipeline never ran"; warn=$((warn+1))
    fi
        set -e
    echo ""
    fi
    # ── stale knowledge invariants ─────────────────────────────
    if [[ "$DOCTOR_DEEP" != "1" ]]; then
        echo "=== stale knowledge invariants ==="
        echo "○ skipped in fast doctor (run: flywheel doctor --deep)"
        echo ""
    else
    echo "=== stale knowledge invariants ==="
    set +e
    if [[ -x "$FLYWHEEL_HOME/bin/flywheel-stale" ]] && command -v jq >/dev/null 2>&1; then
        stale_json=$("$FLYWHEEL_HOME/bin/flywheel-stale" --json 2>/dev/null || echo '{}')
        for cat in sources_no_latest latest_older_14d sources_fail_streak_3 skill_zero_deltas deltas_unsurfaced_7d description_oversized body_oversized; do
            n=$(printf '%s' "$stale_json" | jq -r --arg k "$cat" '.[$k] | length // 0' 2>/dev/null || echo 0)
            if [[ "$n" -gt 0 ]]; then
                echo "⚠ $cat: $n"; warn=$((warn+1))
            else
                echo "✓ $cat: 0"; ok=$((ok+1))
            fi
        done
    else
        echo "⚠ flywheel-stale or jq unavailable — skipping stale invariants"
        warn=$((warn+1))
    fi
    set -e
    echo ""
    fi
    # ── verdict-capture activity invariant (Loop F / GOAL.md subgoal-3) ──
    # Surfaces the Outcome→Quality gap as visible doctor signal. NOT a gate
    # — Joshua's taste capture is human-driven (/flywheel-verdict). When
    # there are unverdicted deltas accumulating, the doctor warns so the
    # gap is actionable rather than silent.
    if [[ "$DOCTOR_DEEP" != "1" ]]; then
        echo "=== verdict-capture activity ==="
        echo "○ skipped in fast doctor (run: flywheel doctor --deep)"
        echo ""
    else
    echo "=== verdict-capture activity ==="
    set +e
    if command -v sqlite3 >/dev/null 2>&1 && [[ -f "$FLYWHEEL_HOME/state.db" ]]; then
        verdicts_30d=$(sqlite3 "$FLYWHEEL_HOME/state.db" \
            "SELECT COUNT(*) FROM joshua_verdicts WHERE ts >= datetime('now','-30 days');" 2>/dev/null || echo 0)
        unverdicted_7d=$(sqlite3 "$FLYWHEEL_HOME/state.db" "
            SELECT COUNT(*) FROM deltas d
            LEFT JOIN joshua_verdicts jv ON jv.target_kind='delta' AND jv.target_id=d.id
            WHERE d.created_at >= datetime('now','-7 days') AND jv.id IS NULL;" 2>/dev/null || echo 0)
        verdicts_30d="${verdicts_30d:-0}"
        unverdicted_7d="${unverdicted_7d:-0}"
        if [[ "$verdicts_30d" -gt 0 ]]; then
            echo "✓ verdicts_30d: $verdicts_30d (joshua_verdicts table active)"; ok=$((ok+1))
        else
            echo "⚠ verdicts_30d: 0 — Joshua taste signals never captured. Run /flywheel-verdict to record one."; warn=$((warn+1))
        fi
        if [[ "$unverdicted_7d" -gt 0 ]]; then
            echo "ℹ unverdicted_deltas_7d: $unverdicted_7d (run /flywheel-verdict to surface)"
        else
            echo "✓ unverdicted_deltas_7d: 0"; ok=$((ok+1))
        fi
    else
        echo "⚠ sqlite3 or state.db unavailable — skipping verdict-capture activity"
        warn=$((warn+1))
    fi
    set -e
    echo ""
    fi
    # ── skill-index-qdrant invariant (G87 Phase 1 ship 2026-04-27) ──
    if [[ "$DOCTOR_DEEP" != "1" ]]; then
        echo "=== skill-index-qdrant invariant ==="
        echo "○ skipped in fast doctor (run: flywheel doctor --deep)"
        echo ""
    else
    # G-CF-46 fix 2026-04-28: scoped `set +e` guard. Under `set -euo pipefail`,
    # bash 5.3 propagates pipefail through `var=$(pipeline)` even with
    # inherit_errexit=off — `grep -v '/\.'` returning 1 (no matches) silently
    # killed the doctor mid-stream, hiding every block below. Qdrant is
    # VLAN-dependent and often unreachable; this block must NEVER halt doctor.
    echo "=== skill-index-qdrant invariant ==="
    set +e
    SIQ_COLL="${SKILL_INDEX_COLLECTION:-skills_catalog}"
    SIQ_QDRANT="${QDRANT_URL:-http://localhost:6433}"
    if curl -fsS -m 3 "$SIQ_QDRANT/collections/$SIQ_COLL" >/dev/null 2>&1; then
        siq_pts=$(curl -fsS -m 3 "$SIQ_QDRANT/collections/$SIQ_COLL" 2>/dev/null \
            | jq -r '.result.points_count // 0')
        siq_fs=$(find "$HOME/.claude/skills" -maxdepth 2 -name SKILL.md -type f 2>/dev/null \
            | grep -v '/\.' | wc -l | tr -d ' ')
        siq_pts="${siq_pts:-0}"
        siq_fs="${siq_fs:-0}"
        if [[ "$siq_pts" -gt 0 && "$siq_pts" -ge $((siq_fs - 5)) ]]; then
            echo "✓ skills_catalog points=$siq_pts (filesystem=$siq_fs)"; ok=$((ok+1))
        else
            echo "⚠ skills_catalog drift: index=$siq_pts filesystem=$siq_fs"; warn=$((warn+1))
        fi
        SIQ_LOG="$HOME/.local/state/skill-index-qdrant/build.log"
        if [[ -f "$SIQ_LOG" ]]; then
            siq_age=$(( ( $(date +%s) - $(stat -f %m "$SIQ_LOG" 2>/dev/null || stat -c %Y "$SIQ_LOG" 2>/dev/null || echo 0) ) / 86400 ))
            if [[ "$siq_age" -lt 7 ]]; then
                echo "✓ last index build ${siq_age}d ago"; ok=$((ok+1))
            else
                echo "⚠ last index build ${siq_age}d ago (>7d stale)"; warn=$((warn+1))
            fi
        fi
    else
        echo "⚠ skill-index-qdrant: qdrant unreachable at $SIQ_QDRANT (VLAN-dependent — non-fatal)"; warn=$((warn+1))
    fi
    set -e
    echo ""
    fi
    # ── skill-search-mcp invariant (G-OS-2/G-OS-3 ship 2026-04-29) ────────
    # Fast-path proof for the read-only skill routing MCP substrate.
    # Catalog drift is owned by skill-index-qdrant; this block proves the
    # read server/probe can see qdrant, ollama, skills_catalog, and the
    # route freshness gate without writing indexes or client config.
    echo "=== skill-search-mcp invariant ==="
    set +e
    SSM_PROBE="${FLYWHEEL_SKILL_SEARCH_MCP_PROBE:-$HOME/.claude/skills/skill-search-mcp/scripts/probe.sh}"
    if [[ ! -x "$SSM_PROBE" ]]; then
        echo "✗ skill-search-mcp probe missing or not executable ($SSM_PROBE)"; fail=$((fail+1))
    else
        SSM_TIMEOUT="$(command -v timeout 2>/dev/null || command -v gtimeout 2>/dev/null || true)"
        if [[ -n "$SSM_TIMEOUT" ]]; then
            ssm_out="$("$SSM_TIMEOUT" 5 "$SSM_PROBE" 2>&1)"
            ssm_rc=$?
        else
            ssm_out="$("$SSM_PROBE" 2>&1)"
            ssm_rc=$?
        fi
        if [[ $ssm_rc -eq 0 ]]; then
            if ! printf '%s' "$ssm_out" | jq -e . >/dev/null 2>&1; then
                echo "✗ skill-search-mcp probe emitted invalid JSON"; fail=$((fail+1))
            else
                ssm_collection="$(printf '%s' "$ssm_out" | jq -r '.collection // "?"' 2>/dev/null)"
                ssm_total="$(printf '%s' "$ssm_out" | jq -r '.total_skills // "?"' 2>/dev/null)"
                ssm_fs="$(printf '%s' "$ssm_out" | jq -r '.filesystem_skills // "?"' 2>/dev/null)"
                ssm_drift="$(printf '%s' "$ssm_out" | jq -r '.drift_count // 0' 2>/dev/null)"
                ssm_qdrant="$(printf '%s' "$ssm_out" | jq -r '.qdrant_health // false' 2>/dev/null)"
                ssm_ollama="$(printf '%s' "$ssm_out" | jq -r '.ollama_health // false' 2>/dev/null)"
                ssm_route_gate="$(printf '%s' "$ssm_out" | jq -r '.route_gate_enabled // false' 2>/dev/null)"
                ssm_fresh_status="$(printf '%s' "$ssm_out" | jq -r '.freshness_status // "UNKNOWN"' 2>/dev/null)"
                ssm_fresh_pct="$(printf '%s' "$ssm_out" | jq -r '.freshness_pct // -1' 2>/dev/null)"
                ssm_stale_invoked="$(printf '%s' "$ssm_out" | jq -r '.stale_invoked_skills // 0' 2>/dev/null)"
                if [[ "$ssm_qdrant" != "true" || "$ssm_ollama" != "true" || "$ssm_route_gate" != "true" || "$ssm_fresh_status" == "FAIL" ]] \
                    || awk -v v="$ssm_fresh_pct" 'BEGIN{ exit !(v+0 < 70) }'; then
                    echo "✗ skill-search-mcp route gate failed (qdrant=$ssm_qdrant, ollama=$ssm_ollama, route_gate=$ssm_route_gate, freshness=${ssm_fresh_status}/${ssm_fresh_pct}%, stale_invoked=${ssm_stale_invoked})"; fail=$((fail+1))
                elif [[ "$ssm_fresh_status" == "WARN" ]] || awk -v v="$ssm_fresh_pct" 'BEGIN{ exit !(v+0 < 80) }' || [[ "$ssm_drift" -gt 0 ]]; then
                    echo "⚠ skill-search-mcp route gate ok with warning (collection=${ssm_collection:-?}, index=${ssm_total:-?}, filesystem=${ssm_fs:-?}, drift=${ssm_drift:-?}, freshness=${ssm_fresh_status}/${ssm_fresh_pct}%, stale_invoked=${ssm_stale_invoked})"; warn=$((warn+1))
                else
                    echo "✓ skill-search-mcp route gate ok (collection=${ssm_collection:-?}, index=${ssm_total:-?}, filesystem=${ssm_fs:-?}, drift=${ssm_drift:-?}, freshness=${ssm_fresh_status}/${ssm_fresh_pct}%, stale_invoked=${ssm_stale_invoked})"; ok=$((ok+1))
                fi
            fi
        else
            echo "✗ skill-search-mcp probe failed (rc=$ssm_rc)"; fail=$((fail+1))
            printf '%s\n' "$ssm_out" | tail -3 | sed 's/^/    /'
        fi
    fi
    set -e
    echo ""
    # ── research-triad invariant (Layer C ship 2026-04-27) ────────
    # Probes the unified research surface: CLI (Layer A), skill (Layer B),
    # auto-surface hook (Layer C). Each sub-check degrades gracefully — a
    # missing dependency surfaces informationally (·) while doctor stays GREEN
    # for the rest of the system. See proposals/axiom-22-research-before-propose.
    echo "=== research-triad invariant ==="
    set +e
    RT_CLI="$HOME/.local/bin/research"
    RT_SKILL="$HOME/.claude/skills/research-triad/SKILL.md"
    RT_HOOK="$HOME/.claude/hooks/research-triad-hint.sh"
    RT_SETTINGS="$HOME/.claude/settings.json"
    if [[ -x "$RT_CLI" ]]; then
        echo "✓ research CLI present + executable ($RT_CLI)"; ok=$((ok+1))
        if "$RT_CLI" --version >/dev/null 2>&1; then
            echo "✓ research --version smoke test passes"; ok=$((ok+1))
        else
            echo "· research --version not yet wired (degraded: CLI present)"; warn=$((warn+0))
        fi
    else
        echo "· research CLI not yet present ($RT_CLI) — sibling agent owns Layer A"
    fi
    if [[ -f "$RT_SKILL" ]]; then
        echo "✓ research-triad skill present ($RT_SKILL)"; ok=$((ok+1))
        # jsm-validate if available (tier=critical expected per directive)
        if [[ "$DOCTOR_DEEP" != "1" ]]; then
            echo "○ research-triad jsm-validate skipped in fast doctor (run: flywheel doctor --deep)"
        elif command -v jsm >/dev/null 2>&1; then
            if jsm validate "$(dirname "$RT_SKILL")" >/dev/null 2>&1; then
                echo "✓ research-triad skill jsm-valid"; ok=$((ok+1))
            else
                echo "⚠ research-triad skill jsm-validate FAILED"; warn=$((warn+1))
            fi
        fi
    else
        echo "· research-triad skill not yet present ($RT_SKILL) — sibling agent owns Layer B"
    fi
    if [[ -x "$RT_HOOK" ]]; then
        if command -v jq >/dev/null 2>&1 && jq -e --arg c "$RT_HOOK" \
            '.hooks.UserPromptSubmit[0].hooks // [] | map(.command) | any(. == $c or . == "~/.claude/hooks/research-triad-hint.sh")' \
            "$RT_SETTINGS" >/dev/null 2>&1; then
            echo "✓ research-triad-hint.sh hook registered in settings.json"; ok=$((ok+1))
        else
            echo "⚠ research-triad-hint.sh exists but NOT registered in settings.json UserPromptSubmit"; warn=$((warn+1))
        fi
    else
        echo "⚠ research-triad-hint.sh missing or not executable ($RT_HOOK)"; warn=$((warn+1))
    fi
    set -e
    echo ""
    # ── jeff-extraction-gate invariant (2026-04-27 retrofit) ──────
    echo "=== jeff-extraction-gate invariant ==="
    set +e
    JG_LEDGER="$HOME/.local/state/dicklesworthstone-stack/signal-ledger.jsonl"
    JG_OUT="$HOME/.local/state/dicklesworthstone-stack/signal-outcomes.jsonl"
    if [[ -f "$JG_LEDGER" ]]; then
        if ! grep -q '[^[:space:]]' "$JG_LEDGER"; then
            echo "✓ ledger present + parses (empty)"; ok=$((ok+1))
        elif jq -e . "$JG_LEDGER" >/dev/null 2>&1 || jq -c . "$JG_LEDGER" >/dev/null 2>&1; then
            echo "✓ ledger present + parses"; ok=$((ok+1))
        else
            echo "⚠ ledger present but jq parse FAILED"; warn=$((warn+1))
        fi
    else
        echo "⚠ ledger MISSING ($JG_LEDGER)"; warn=$((warn+1))
    fi
    if [[ -f "$JG_OUT" ]]; then
        echo "✓ outcomes log present"; ok=$((ok+1))
    else
        echo "⚠ outcomes log MISSING ($JG_OUT)"; warn=$((warn+1))
    fi
    if [[ -f "$JG_LEDGER" ]]; then
        cutoff14=$(date -u -v-14d +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || date -u -d '14 days ago' +"%Y-%m-%dT%H:%M:%SZ")
        stale_count=$(jq -c --arg c "$cutoff14" 'select(.state=="noted" and .ts_state_changed < $c)' "$JG_LEDGER" 2>/dev/null | wc -l | tr -d ' ')
        if [[ "$stale_count" -gt 0 ]]; then
            echo "⚠ noted-items-stale: $stale_count"; warn=$((warn+1))
        else
            echo "✓ noted-items-stale: 0"; ok=$((ok+1))
        fi
        cutoff90=$(date -u -v-90d +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || date -u -d '90 days ago' +"%Y-%m-%dT%H:%M:%SZ")
        seen90=$(jq -c --arg c "$cutoff90" 'select(.ts_seen >= $c)' "$JG_LEDGER" 2>/dev/null | wc -l | tr -d ' ')
        ext90=$(jq -c --arg c "$cutoff90" 'select(.state=="extracted" and .ts_state_changed >= $c)' "$JG_LEDGER" 2>/dev/null | wc -l | tr -d ' ')
        echo "ℹ extraction rate (last 90d): ${ext90}/${seen90}"
    fi
    set -e
    echo ""

    # ── library invariants (advisory) ──────────────────────────
    if [[ "$DOCTOR_DEEP" != "1" ]]; then
        echo "=== library invariants ==="
        echo "○ skipped in fast doctor (run: flywheel doctor --deep)"
        echo ""
    else
    echo "=== library invariants ==="
    set +e
    JSM_LIST="${FLYWHEEL_JSM_LIST:-$HOME/.claude/skills/.jsm-installed.txt}"
    LIB_INV_FAST="$HOME/.claude/skills/.flywheel/scripts/library-invariants-fast.py"
    lib_json=""
    if [[ -x "$LIB_INV_FAST" ]]; then
        lib_json=$(fw_cmd_timeout 5 "$LIB_INV_FAST" "$FLYWHEEL_SKILLS_DIR" "$JSM_LIST" 2>/dev/null || true)
    fi
    if [[ -z "$lib_json" ]] || ! jq -e . <<<"$lib_json" >/dev/null 2>&1; then
        echo "⚠ library_invariants_scan: fast scan unavailable or timed out after 5s"; warn=$((warn+1))
        lib_json='{"triggers_under_10":[],"references_dir_missing":[],"frontmatter_missing":[],"frontmatter_invalid_yaml":[]}'
    fi
    mapfile -t triggers_under_10 < <(jq -r '.triggers_under_10[]?' <<<"$lib_json")
    mapfile -t references_dir_missing < <(jq -r '.references_dir_missing[]?' <<<"$lib_json")
    mapfile -t frontmatter_missing < <(jq -r '.frontmatter_missing[]?' <<<"$lib_json")
    mapfile -t frontmatter_invalid_yaml < <(jq -r '.frontmatter_invalid_yaml[]?' <<<"$lib_json")

    emit_lib_inv() {
        local label="$1"; shift
        local -a arr=("$@")
        local n=${#arr[@]}
        if [[ "$n" -gt 0 ]]; then
            echo "⚠ $label: $n"; warn=$((warn+1))
            local i=0
            for v in "${arr[@]}"; do
                echo "    · $v"
                i=$((i+1))
                [[ "$i" -ge 5 ]] && { [[ "$n" -gt 5 ]] && echo "    · … ($((n-5)) more)"; break; }
            done
        else
            echo "✓ $label: 0"; ok=$((ok+1))
        fi
    }

    emit_lib_inv "triggers_under_10" "${triggers_under_10[@]+"${triggers_under_10[@]}"}"
    emit_lib_inv "references_dir_missing" "${references_dir_missing[@]+"${references_dir_missing[@]}"}"
    emit_lib_inv "frontmatter_missing" "${frontmatter_missing[@]+"${frontmatter_missing[@]}"}"
    emit_lib_inv "frontmatter_invalid_yaml" "${frontmatter_invalid_yaml[@]+"${frontmatter_invalid_yaml[@]}"}"

    set -e
    echo ""
    fi
    # ─── jsm batch validation pass-rate (2026-04-28, G-CF-29 baseline) ────
    if [[ "$DOCTOR_DEEP" != "1" ]]; then
        echo "=== jsm batch validation pass-rate ==="
        echo "○ skipped in fast doctor (run: flywheel doctor --deep)"
        echo ""
    else
    # Trend metric (NOT a gate). Counts pass/fail across the full skill
    # library via `jsm-validate-batch --json --quiet`. Lets us watch the
    # 29% baseline rise as Waves 1-9 land. 120s timeout — a full sweep is
    # ~5s on M-series with NCPU parallelism. Failure to RUN the batch
    # itself surfaces as ⚠ (warn) so silent regressions on the substrate
    # are visible; the pass-rate ITSELF is informational.
    echo "=== jsm batch validation pass-rate ==="
    set +e
    jsm_vb_bin="$(command -v jsm-validate-batch || true)"
    [[ -z "$jsm_vb_bin" && -x "$HOME/.claude/skills/jsm/scripts/validate-batch.sh" ]] \
        && jsm_vb_bin="$HOME/.claude/skills/jsm/scripts/validate-batch.sh"
    if [[ -z "$jsm_vb_bin" ]]; then
        echo "⚠ jsm-validate-batch not found (expected ~/.local/bin/jsm-validate-batch or skills/jsm/scripts/validate-batch.sh)"; warn=$((warn+1))
    else
        if command -v timeout >/dev/null 2>&1; then
            jsm_vb_json="$(timeout 120 "$jsm_vb_bin" --json --quiet 2>/dev/null || true)"
        elif command -v gtimeout >/dev/null 2>&1; then
            jsm_vb_json="$(gtimeout 120 "$jsm_vb_bin" --json --quiet 2>/dev/null || true)"
        else
            jsm_vb_json="$("$jsm_vb_bin" --json --quiet 2>/dev/null || true)"
        fi
        if [[ -z "$jsm_vb_json" ]] || ! jq -e . <<<"$jsm_vb_json" >/dev/null 2>&1; then
            echo "⚠ jsm-validate-batch produced no JSON (timeout or runtime error)"; warn=$((warn+1))
        else
            jsm_total=$(jq -r '.total    // 0' <<<"$jsm_vb_json")
            jsm_pass=$( jq -r '.pass     // 0' <<<"$jsm_vb_json")
            jsm_fail=$( jq -r '.fail     // 0' <<<"$jsm_vb_json")
            jsm_to=$(   jq -r '.timeouts // 0' <<<"$jsm_vb_json")
            jsm_err=$(  jq -r '.errors   // 0' <<<"$jsm_vb_json")
            jsm_rate=$(awk -v p="$jsm_pass" -v t="$jsm_total" 'BEGIN{ if(t==0){print "0"} else {printf "%.0f", (p/t)*100} }')
            echo "ℹ jsm_pass_rate: ${jsm_rate}% (pass=$jsm_pass fail=$jsm_fail timeouts=$jsm_to errors=$jsm_err total=$jsm_total)"
            jq -r '.by_category | to_entries | sort_by(-.value) | .[0:3] | .[] | "    · \(.value)  \(.key)"' <<<"$jsm_vb_json" 2>/dev/null || true
            if [[ "$jsm_rate" -lt 50 ]]; then
                echo "    hint: see ~/.claude/skills/.flywheel/proposals/ubs-jsm-baseline-2026-04-28.md for fix waves"
            fi
            ok=$((ok+1))
        fi
    fi

    set -e
    echo ""
    fi
    # ─── ecosystem-port-security invariant (2026-04-27, Phase 1 ship) ─────
    # Source-of-truth registry for every listening port; replaces port-allowlist-manager
    # decision-logic. 4 sub-checks: registry parses + probe healthy + drift fresh + plist loaded.
    echo "=== ecosystem port security invariant ==="
    set +e
    eps_dir="$HOME/.claude/skills/ecosystem-port-security"
    eps_reg="$eps_dir/data/port-ownership.json"
    eps_probe="$eps_dir/scripts/ownership-probe.sh"
    eps_snap_dir="$HOME/.local/state/ecosystem-port-security/snapshots"
    eps_label="ai.zeststream.ecosystem-port-security-drift"
    if [[ -f "$eps_reg" ]] && jq -e 'length' "$eps_reg" >/dev/null 2>&1; then
        eps_rows=$(jq 'length' "$eps_reg")
        echo "✓ ecosystem-port-security: registry parses ($eps_rows rows)"; ok=$((ok+1))
    else
        echo "✗ ecosystem-port-security: registry missing or unparseable ($eps_reg)"; fail=$((fail+1))
    fi
    if [[ -r "$eps_probe" ]]; then
        eps_json=$(fw_cmd_timeout 13 bash "$eps_probe" --json 2>/dev/null || true)
        eps_unknown=$(printf '%s' "$eps_json" | jq -r '.unknown // "?"' 2>/dev/null || echo "?")
        eps_known=$(printf '%s' "$eps_json" | jq -r '.known // "?"' 2>/dev/null || echo "?")
        eps_ephem=$(printf '%s' "$eps_json" | jq -r '.ephemeral // "?"' 2>/dev/null || echo "?")
        if [[ -z "$eps_json" ]] || ! jq -e . <<<"$eps_json" >/dev/null 2>&1; then
            echo "⚠ ecosystem-port-security: ownership probe timed out or returned no JSON within 13s"; warn=$((warn+1))
        elif [[ "$eps_unknown" == "0" ]]; then
            echo "✓ ecosystem-port-security: probe healthy (known=$eps_known ephemeral=$eps_ephem unknown=0)"; ok=$((ok+1))
        else
            echo "⚠ ecosystem-port-security: $eps_unknown UNKNOWN listener(s); register or kill (known=$eps_known ephemeral=$eps_ephem)"; warn=$((warn+1))
        fi
    else
        echo "✗ ecosystem-port-security: probe script missing or unreadable ($eps_probe)"; fail=$((fail+1))
    fi
    if [[ -d "$eps_snap_dir" ]]; then
        eps_latest=$(ls -t "$eps_snap_dir"/*.json 2>/dev/null | head -1)
        if [[ -n "$eps_latest" ]]; then
            eps_age_s=$(( $(date +%s) - $(stat -f %m "$eps_latest" 2>/dev/null || stat -c %Y "$eps_latest") ))
            if [[ "$eps_age_s" -lt 172800 ]]; then
                echo "✓ ecosystem-port-security: drift snapshot fresh ($((eps_age_s/3600))h ago)"; ok=$((ok+1))
            else
                echo "⚠ ecosystem-port-security: drift snapshot stale ($((eps_age_s/3600))h old; expected <48h)"; warn=$((warn+1))
            fi
        else
            echo "⚠ ecosystem-port-security: no drift snapshots yet (first LaunchAgent fire pending)"; warn=$((warn+1))
        fi
    else
        echo "⚠ ecosystem-port-security: snapshot dir missing ($eps_snap_dir)"; warn=$((warn+1))
    fi
    if launchctl print "gui/$(id -u)/$eps_label" >/dev/null 2>&1; then
        echo "✓ ecosystem-port-security: LaunchAgent $eps_label loaded"; ok=$((ok+1))
    else
        echo "✗ ecosystem-port-security: LaunchAgent $eps_label NOT loaded"; fail=$((fail+1))
    fi

    set -e
    echo ""
    # ─── zeststream-pr quality-gate invariant (2026-04-27) ────────────────
    # Joshua mandate: NO upstream PR without zeststream-pr skill rigor.
    # Scans proposals/upstream-patches-*/ for drafts marked
    # `Status: READY-TO-SHIP` lacking `QUALITY-GATE-PASSED: YYYY-MM-DD`.
    # Any such draft is a reputation-risk event — emit warn with path.
    # Drafts in DRAFT or DRAFT (quality gate INCOMPLETE) status are fine.
    echo "=== zeststream-pr quality-gate invariant ==="
    set +e
    zspr_violations=()
    zspr_ready=0
    zspr_drafts=0
    while IFS= read -r f; do
        [[ -f "$f" ]] || continue
        zspr_drafts=$((zspr_drafts+1))
        if grep -qE '^\*\*Status:\*\*[[:space:]]*READY-TO-SHIP' "$f" 2>/dev/null; then
            zspr_ready=$((zspr_ready+1))
            if ! grep -qE '^\*\*QUALITY-GATE-PASSED:\*\*[[:space:]]+[0-9]{4}-[0-9]{2}-[0-9]{2}' "$f" 2>/dev/null; then
                zspr_violations+=("${f#$HOME/}")
            fi
        fi
    done < <(find "$FLYWHEEL_HOME/proposals/" -maxdepth 2 -type f -name '*.md' -path '*upstream-patches-*' 2>/dev/null)
    if [[ "${#zspr_violations[@]}" -gt 0 ]]; then
        echo "⚠ zeststream-pr-gate: ${#zspr_violations[@]} READY-TO-SHIP draft(s) missing QUALITY-GATE-PASSED stamp"
        for v in "${zspr_violations[@]}"; do echo "    · ~/$v"; done
        warn=$((warn+1))
    else
        if [[ "$zspr_drafts" -gt 0 ]]; then
            echo "✓ zeststream-pr-gate: $zspr_drafts draft(s) scanned, $zspr_ready READY-TO-SHIP, all gate-stamped"
        else
            echo "✓ zeststream-pr-gate: 0 drafts present (no upstream PRs in flight)"
        fi
        ok=$((ok+1))
    fi

    # ─── gaps_changelog_roundtrip (G10, 2026-04-27) ───────────────────────
    if [[ "$DOCTOR_DEEP" != "1" ]]; then
        echo "=== gaps_changelog_roundtrip ==="
        echo "○ skipped in fast doctor (run: flywheel doctor --deep)"
    else
    # GAPS.md doctrine: every CLOSED gap must produce a CHANGELOG entry citing
    # the G-number; every CHANGELOG "G<NN> closed/RESOLVED" must remove the
    # GAPS.md section (or mark it CLOSED). Bidirectional warn-only check.
    gaps_md="$FLYWHEEL_HOME/GAPS.md"
    changelog_md="$FLYWHEEL_HOME/CHANGELOG.md"
    roundtrip_findings=()
    if [[ -f "$gaps_md" && -f "$changelog_md" ]]; then
        while IFS=$'\t' read -r direction gnum; do
            [[ -z "$gnum" ]] && continue
            roundtrip_findings+=("${gnum}:${direction}")
        done < <(python3 - "$gaps_md" "$changelog_md" 2>/dev/null <<'PYEOF'
import re, sys
gaps = open(sys.argv[1]).read()
chlog = open(sys.argv[2]).read()
# Section-split GAPS.md by "## G<NN>" headers
parts = re.split(r'(?m)^## (G\d+)\b[^\n]*\n', gaps)
gaps_sections = {}  # gnum -> body up to next "## " heading
for i in range(1, len(parts), 2):
    g = parts[i]; body = parts[i+1] if i+1 < len(parts) else ""
    body = re.split(r'(?m)^## ', body, maxsplit=1)[0]
    gaps_sections[g] = body
# Direction A: GAPS section says CLOSED but G<NN> not cited in CHANGELOG
for g, body in gaps_sections.items():
    if re.search(r'\bCLOSED\b', body) or re.search(r'Status:\*\*\s*CLOSED', body):
        if not re.search(r'\b'+re.escape(g)+r'\b', chlog):
            print(f"closed-in-GAPS-no-CHANGELOG-cite\t{g}")
# Direction B: CHANGELOG says "G<NN> closed/RESOLVED" but section in GAPS is still open
for g in set(re.findall(r'\b(G\d+)\s+(?:closed|RESOLVED|CLOSED)\b', chlog)):
    body = gaps_sections.get(g)
    if body is None:  # section already removed — fully closed, OK
        continue
    if re.search(r'\bCLOSED\b', body) or re.search(r'Status:\*\*\s*CLOSED', body):
        continue  # marked closed in-place, OK
    print(f"CHANGELOG-says-closed-still-open-in-GAPS\t{g}")
PYEOF
                 )
    fi
    if [[ "${#roundtrip_findings[@]}" -gt 0 ]]; then
        echo "⚠ gaps_changelog_roundtrip: ${#roundtrip_findings[@]}"; warn=$((warn+1))
        rti=0
        for v in "${roundtrip_findings[@]}"; do
            echo "    · $v"
            rti=$((rti+1))
            [[ "$rti" -ge 5 ]] && { [[ "${#roundtrip_findings[@]}" -gt 5 ]] && echo "    · … ($((${#roundtrip_findings[@]}-5)) more)"; break; }
        done
    else
        echo "✓ gaps_changelog_roundtrip: 0"; ok=$((ok+1))
    fi
    fi

    # ─── mission-anchor invariants (2026-04-28 P26 strike-1 ship) ─────────
    # Three invariants encode the doctrine at ~/.claude/references/mission-anchor-protocol.md.
    # Promotion: 30 days clean → invariants 1+2 promote from warn to fail (per § 8 calculus).
    echo ""
    echo "=== mission-anchor invariants ==="

    # 1. mission-anchor-opted-in-projects-health
    #    For every ~/.local/state/<sess>/mission_state.json, last_validated_ts must be
    #    <14d old AND commits_since_validation <50. WARN (not fail) until 30-day promotion.
    ma_state_glob="$HOME/.local/state/*/mission_state.json"
    ma_count=0; ma_stale=0
    for sf in $ma_state_glob; do
        [[ -f "$sf" ]] || continue
        ma_count=$((ma_count+1))
        ma_validated=$(jq -r '.last_validated_ts // "never"' "$sf" 2>/dev/null)
        ma_commits=$(jq -r '.commits_since_validation // 0' "$sf" 2>/dev/null)
        if [[ "$ma_validated" != "never" ]]; then
            ma_epoch=$(date -j -f "%Y-%m-%dT%H:%M:%SZ" "$ma_validated" +%s 2>/dev/null || date -d "$ma_validated" +%s 2>/dev/null || echo 0)
            ma_age_days=$(( ($(date +%s) - ma_epoch) / 86400 ))
            if [[ "$ma_age_days" -gt 14 ]] || [[ "$ma_commits" -gt 50 ]]; then
                ma_stale=$((ma_stale+1))
            fi
        fi
    done
    if [[ "$ma_count" -eq 0 ]]; then
        echo "○ mission-anchor-opted-in-projects-health: no opted-in projects (mission-anchor-init not yet invoked anywhere)"
    elif [[ "$ma_stale" -gt 0 ]]; then
        echo "⚠ mission-anchor-opted-in-projects-health: $ma_stale of $ma_count opted-in projects stale (>14d or >50 commits since validation)"
        warn=$((warn+1))
    else
        echo "✓ mission-anchor-opted-in-projects-health: $ma_count projects opted-in, all fresh"
        ok=$((ok+1))
    fi

    # 2. pending-insights-uncleared
    #    Files in any .pending_insights/ older than 14 days = signal hoarding (same trauma class
    #    as feedback_jeff_extraction_gate.md). WARN until 30-day promotion.
    pi_stale_total=0
    for sf in $ma_state_glob; do
        [[ -f "$sf" ]] || continue
        mp=$(jq -r '.mission_path // ""' "$sf" 2>/dev/null)
        [[ -z "$mp" ]] && continue
        repo_dir=$(dirname "$mp")
        pi_dir="$repo_dir/.pending_insights"
        [[ -d "$pi_dir" ]] || continue
        # find files older than 14d
        pi_old=$(find "$pi_dir" -type f -mtime +14 2>/dev/null | wc -l | tr -d ' ')
        pi_stale_total=$((pi_stale_total + pi_old))
    done
    if [[ "$pi_stale_total" -gt 0 ]]; then
        echo "⚠ pending-insights-uncleared: $pi_stale_total insight(s) >14d old across all opted-in projects (signal hoarding — review at next petal9-close)"
        warn=$((warn+1))
    else
        echo "✓ pending-insights-uncleared: 0 stale insights"
        ok=$((ok+1))
    fi

    # 3. pivot-history-append-only (Tier-0 — fail, not warn)
    #    For every MISSION.md tracked by git, git log must show § 8 pivot_history rows
    #    only added, never deleted/edited. Per arxiv:1707.03869v3 cognitive bias literature
    #    — externalization requires permanence.
    ph_violations=0; ph_checked=0
    for sf in $ma_state_glob; do
        [[ -f "$sf" ]] || continue
        mp=$(jq -r '.mission_path // ""' "$sf" 2>/dev/null)
        [[ -z "$mp" || ! -f "$mp" ]] && continue
        repo_dir=$(dirname "$mp")
        # Skip if not a git repo (test fixtures, etc.)
        ( cd "$repo_dir" && git rev-parse --git-dir >/dev/null 2>&1 ) || continue
        ph_checked=$((ph_checked+1))
        # Look for deletions in MISSION.md history under § 8 pivot_history table
        # Heuristic: count lines starting with "| " that were removed in any commit touching MISSION.md
        deletions=$( cd "$repo_dir" && git log --diff-filter=D --pretty=format: -p -- "$(basename "$mp")" 2>/dev/null | grep -cE '^-\| [0-9]{4}-' )
        if [[ "$deletions" -gt 0 ]]; then
            ph_violations=$((ph_violations+1))
            echo "✗ pivot-history-append-only: $repo_dir/$(basename "$mp") — $deletions row deletion(s) detected in git history"
        fi
    done
    if [[ "$ph_checked" -eq 0 ]]; then
        echo "○ pivot-history-append-only: no git-tracked MISSION.md files yet"
    elif [[ "$ph_violations" -eq 0 ]]; then
        echo "✓ pivot-history-append-only: $ph_checked MISSION.md(s) checked, append-only invariant holds"
        ok=$((ok+1))
    else
        # Tier-0 violation per doctrine § 8 — pivot history tampering FAILS the doctor
        fail=$((fail + ph_violations))
    fi

    # ── mission_fitness_drift invariant ──────────────────────────────────────
    echo "=== mission_fitness_drift ==="
    set +e
    MFD_PROBE="$HOME/Developer/flywheel/.flywheel/scripts/mission-fitness-doctor.sh"
    if [[ -x "$MFD_PROBE" ]]; then
        mfd_json=$(fw_cmd_timeout 30 bash "$MFD_PROBE" --repo "$HOME/Developer/flywheel" --json 2>/dev/null || true)
        mfd_status=$(printf '%s' "$mfd_json" | jq -r '.status // "error"' 2>/dev/null || echo error)
        mfd_drift_pct=$(printf '%s' "$mfd_json" | jq -r '.drift_pct // "?"' 2>/dev/null || echo "?")
        mfd_total=$(printf '%s' "$mfd_json" | jq -r '.total_closes // "?"' 2>/dev/null || echo "?")
        mfd_anchor=$(printf '%s' "$mfd_json" | jq -r '.anchor // "?"' 2>/dev/null || echo "?")
        mfd_direct=$(printf '%s' "$mfd_json" | jq -r '.by_class.direct // "?"' 2>/dev/null || echo "?")
        case "$mfd_status" in
            pass) echo "✓ mission_fitness_drift: drift=${mfd_drift_pct}% direct=${mfd_direct}/${mfd_total} anchor=${mfd_anchor}"; ok=$((ok+1)) ;;
            warn) echo "⚠ mission_fitness_drift: drift=${mfd_drift_pct}% (>=20%) direct=${mfd_direct}/${mfd_total} anchor=${mfd_anchor}"; warn=$((warn+1)) ;;
            fail) echo "✗ mission_fitness_drift: drift=${mfd_drift_pct}% (>=40%) direct=${mfd_direct}/${mfd_total} anchor=${mfd_anchor}"; fail=$((fail+1)) ;;
            *)    echo "⚠ mission_fitness_drift: probe error or no beads yet"; warn=$((warn+1)) ;;
        esac
        [[ -n "$mfd_json" ]] && echo "  · json: $mfd_json"
    else
        echo "⚠ mission_fitness_drift: probe not found at $MFD_PROBE"
        warn=$((warn+1))
    fi
    set -e

    # ── dispatch_log_fitness_coverage invariant ──────────────────────────────
    echo "=== dispatch_log_fitness_coverage ==="
    set +e
    dlf_json="$(fw_dispatch_log_fitness_json)"
    dlf_status="$(printf '%s' "$dlf_json" | jq -r '.status // "FAIL"' 2>/dev/null || echo FAIL)"
    dlf_coverage="$(printf '%s' "$dlf_json" | jq -r '.coverage_pct // "?"' 2>/dev/null || echo "?")"
    dlf_drift="$(printf '%s' "$dlf_json" | jq -r '.drift_count // "?"' 2>/dev/null || echo "?")"
    dlf_total="$(printf '%s' "$dlf_json" | jq -r '.total // "?"' 2>/dev/null || echo "?")"
    case "$dlf_status" in
        PASS) echo "✓ dispatch_log_fitness_coverage: coverage=${dlf_coverage}% drift=${dlf_drift} checked=${dlf_total}/50"; ok=$((ok+1)) ;;
        WARN) echo "⚠ dispatch_log_fitness_coverage: coverage=${dlf_coverage}% drift=${dlf_drift} checked=${dlf_total}/50"; warn=$((warn+1)) ;;
        FAIL) echo "✗ dispatch_log_fitness_coverage: coverage=${dlf_coverage}% drift=${dlf_drift} checked=${dlf_total}/50"; fail=$((fail+1)) ;;
        *)    echo "✗ dispatch_log_fitness_coverage: probe error"; fail=$((fail+1)) ;;
    esac
    [[ -n "$dlf_json" ]] && echo "  · json: $dlf_json"
    set -e

    set -e
    echo ""
    echo "RESULT: $ok ok, $warn warn, $fail fail"
    exit "$fail"
    ;;

# ───────────────────── stale-knowledge invariants ─────────────────────
stale)
    fw_require_db
    "$FLYWHEEL_HOME/bin/flywheel-stale" "$@"
    ;;

# ───────────────────── inject Latest-intel pointer line ─────────────────────
inject-latest-line)
    "$FLYWHEEL_HOME/bin/flywheel-inject-latest-line" "$@"
    ;;

# ───────────────────── source sync ─────────────────────
sync-sources)
    fw_require_db
    t0=$(fw_now_ms)
    added=0; existing=0
    for skill_dir in "$FLYWHEEL_SKILLS_DIR"/*/; do
        sources_file="$skill_dir/data/sources.txt"
        [[ -f "$sources_file" ]] || continue
        skill=$(basename "$skill_dir")
        while IFS= read -r line || [[ -n "$line" ]]; do
            classified=$(fw_classify_source "$line")
            [[ -z "$classified" ]] && continue
            kind="${classified%%|*}"; body="${classified#*|}"
            url=$(fw_normalize_url "$kind" "$body")
            existing_id=$(fw_sql "SELECT id FROM sources WHERE skill=$(fw_quote "$skill") AND url=$(fw_quote "$url");")
            if [[ -z "$existing_id" ]]; then
                fw_sql "INSERT INTO sources(skill, url, kind) VALUES ($(fw_quote "$skill"), $(fw_quote "$url"), $(fw_quote "$kind"));"
                added=$((added+1))
            else
                existing=$((existing+1))
            fi
        done < "$sources_file"
    done
    dur=$(($(fw_now_ms) - t0))
    fw_event "sync_sources.ok" "" "$dur" "{\"added\":$added,\"existing\":$existing}"
    echo "OK: sync-sources — added $added, existing $existing (${dur}ms)"
    ;;

# ───────────────────── refresh (records snapshots in DB) ─────────────────────
refresh)
    fw_require_db
    target_skill="${1:-}"
    if [[ -n "$target_skill" ]]; then
        skill_dirs=("$FLYWHEEL_SKILLS_DIR/$target_skill")
    else
        skill_dirs=()
        # use fw_sql to enumerate skills with sources
        while IFS= read -r s; do skill_dirs+=("$FLYWHEEL_SKILLS_DIR/$s"); done < <(fw_sql "SELECT DISTINCT skill FROM sources;")
    fi
    "$FLYWHEEL_HOME/bin/flywheel-refresh-source" "${skill_dirs[@]}"
    # T1.1: auto-chain summarize-pending so new snapshots become deltas without manual call
    if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
        "$FLYWHEEL_HOME/bin/flywheel-summarize" --pending 2>/dev/null || true
    fi
    # T1.2 (Agent D): render-latest will be chained here once the binary exists
    if [[ -x "$FLYWHEEL_HOME/bin/flywheel-render-latest" ]]; then
        "$FLYWHEEL_HOME/bin/flywheel-render-latest" 2>/dev/null || true
    fi
    ;;

# ───────────────────── summarize a snapshot ─────────────────────
summarize)
    fw_require_db
    snapshot_id="${1:?snapshot_id required}"
    "$FLYWHEEL_HOME/bin/flywheel-summarize" "$snapshot_id"
    ;;

summarize-pending)
    fw_require_db
    "$FLYWHEEL_HOME/bin/flywheel-summarize" --pending
    ;;

# ───────────────────── deltas ─────────────────────
deltas)
    fw_require_db
    only_unsurfaced=0
    [[ "${1:-}" == "--unsurfaced" ]] && only_unsurfaced=1
    if [[ "$only_unsurfaced" == "1" ]]; then
        fw_sql -header -column "
            SELECT d.id, d.skill, d.severity, substr(d.bullets, 1, 80) AS bullets, d.created_at
            FROM deltas d
            WHERE d.surfaced_at IS NULL
            ORDER BY CASE d.severity
                WHEN 'breaking' THEN 1 WHEN 'major' THEN 2 WHEN 'minor' THEN 3 ELSE 4 END,
                d.created_at DESC
            LIMIT 20;"
    else
        fw_sql -header -column "
            SELECT d.id, d.skill, d.severity, d.surfaced_count, substr(d.bullets,1,60) AS bullets
            FROM deltas d ORDER BY d.created_at DESC LIMIT 30;"
    fi
    ;;

surface)
    fw_require_db
    [[ $# -eq 0 ]] && { echo "Usage: flywheel surface <delta_id>..."; exit 1; }
    for id in "$@"; do
        fw_sql "UPDATE deltas SET surfaced_at=COALESCE(surfaced_at,datetime('now')), surfaced_count=surfaced_count+1 WHERE id=$id;"
    done
    fw_event "deltas.surfaced" "" "" "{\"ids\":[$(IFS=,; echo "$*")]}"
    echo "OK: surfaced $# delta(s)"
    ;;

# ───────────────────── repo anchors (socraticode bridge) ─────────────────────
anchor)
    fw_require_db
    sub="${1:?anchor subcommand required: add|query|seed|list|approve}"; shift || true
    "$FLYWHEEL_HOME/bin/flywheel-anchor" "$sub" "$@"
    ;;

# ───────────────────── outcome capture ─────────────────────
outcome)
    fw_require_db
    "$FLYWHEEL_HOME/bin/flywheel-outcome" "$@"
    ;;

# ───────────────────── quality recompute ─────────────────────
quality)
    fw_require_db
    "$FLYWHEEL_HOME/bin/flywheel-quality" "$@"
    ;;

# ───────────────────── goal freshness ratio ─────────────────────
freshness)
    fw_require_db
    FORMAT="text"
    ALIAS_FILE="${FLYWHEEL_SKILL_ALIASES:-$FLYWHEEL_HOME/config/skill-aliases.json}"
    EXCLUSION_FILE="${FLYWHEEL_FRESHNESS_EXCLUSIONS:-$FLYWHEEL_HOME/config/freshness-outcome-exclusions.json}"
    for arg in "$@"; do
        case "$arg" in
            --json) FORMAT="json" ;;
            --text) FORMAT="text" ;;
            -h|--help)
                cat <<'EOF'
Usage: flywheel freshness [--text|--json]

Reports the GOAL.md freshness ratio:
of skills auto-invoked in the last 7 days, what fraction have at least one
source refreshed successfully in the last 7 days.
EOF
                exit 0
                ;;
            *) echo "usage: flywheel freshness [--text|--json]" >&2; exit 64 ;;
        esac
    done
    alias_cte="aliases(alias, canonical) AS (SELECT NULL, NULL WHERE 0)"
    if [[ -f "$ALIAS_FILE" ]]; then
        alias_cte="aliases(alias, canonical) AS (
  SELECT key, value
  FROM json_each(readfile($(fw_quote "$ALIAS_FILE")), '$.aliases')
)"
    fi
    exclusion_cte="excluded_skills(skill) AS (SELECT NULL WHERE 0)"
    if [[ -f "$EXCLUSION_FILE" ]]; then
        exclusion_cte="excluded_skills(skill) AS (
  SELECT key
  FROM json_each(readfile($(fw_quote "$EXCLUSION_FILE")), '$.excluded_skills')
)"
    fi
    row=$(fw_sql -noheader -separator '|' "
WITH
$alias_cte,
$exclusion_cte,
normalized_outcomes AS (
  SELECT COALESCE(a.canonical, o.skill) AS skill
  FROM outcomes o
  LEFT JOIN aliases a ON a.alias = o.skill
  LEFT JOIN excluded_skills e ON e.skill = COALESCE(a.canonical, o.skill)
  WHERE o.ts >= datetime('now','-7 days')
    AND e.skill IS NULL
),
invoked AS (
  SELECT skill, COUNT(*) AS outcome_count
  FROM normalized_outcomes
  GROUP BY skill
),
per_skill AS (
  SELECT
    i.skill,
    i.outcome_count,
    COUNT(s.id) AS source_count,
    MAX(s.last_ok_at) AS freshest_source_at,
    MAX(CASE WHEN s.last_ok_at IS NOT NULL
              AND julianday('now') - julianday(s.last_ok_at) < 7
             THEN 1 ELSE 0 END) AS fresh
  FROM invoked i
  LEFT JOIN sources s ON s.skill = i.skill
  GROUP BY i.skill
)
SELECT
  COUNT(*) AS invoked_skills,
  COALESCE(SUM(fresh),0) AS fresh_skills,
  COUNT(*) - COALESCE(SUM(fresh),0) AS stale_skills,
  COALESCE(ROUND(100.0 * COALESCE(SUM(fresh),0) / NULLIF(COUNT(*),0), 1), 0) AS freshness_pct
FROM per_skill;
")
    stale_rows=$(fw_sql -noheader -separator $'\t' "
WITH
$alias_cte,
$exclusion_cte,
normalized_outcomes AS (
  SELECT COALESCE(a.canonical, o.skill) AS skill
  FROM outcomes o
  LEFT JOIN aliases a ON a.alias = o.skill
  LEFT JOIN excluded_skills e ON e.skill = COALESCE(a.canonical, o.skill)
  WHERE o.ts >= datetime('now','-7 days')
    AND e.skill IS NULL
),
invoked AS (
  SELECT skill, COUNT(*) AS outcome_count
  FROM normalized_outcomes
  GROUP BY skill
),
per_skill AS (
  SELECT
    i.skill,
    i.outcome_count,
    COUNT(s.id) AS source_count,
    MAX(s.last_ok_at) AS freshest_source_at,
    MAX(CASE WHEN s.last_ok_at IS NOT NULL
              AND julianday('now') - julianday(s.last_ok_at) < 7
             THEN 1 ELSE 0 END) AS fresh
  FROM invoked i
  LEFT JOIN sources s ON s.skill = i.skill
  GROUP BY i.skill
)
SELECT
  skill,
  source_count,
  COALESCE(freshest_source_at,''),
  CASE WHEN freshest_source_at IS NULL
       THEN ''
       ELSE printf('%.1f', julianday('now') - julianday(freshest_source_at))
  END,
  outcome_count
FROM per_skill
WHERE fresh = 0
ORDER BY
  CASE WHEN freshest_source_at IS NULL THEN 1 ELSE 0 END DESC,
  julianday('now') - julianday(freshest_source_at) DESC,
  skill ASC;
")
    IFS='|' read -r invoked_skills fresh_skills stale_skills freshness_pct <<< "$row"
    invoked_skills="${invoked_skills:-0}"
    fresh_skills="${fresh_skills:-0}"
    stale_skills="${stale_skills:-0}"
    freshness_pct="${freshness_pct:-0}"
    status="NO_DATA"
    if [[ "$invoked_skills" != "0" ]]; then
        status=$(awk -v v="$freshness_pct" 'BEGIN{ if (v+0 >= 80) print "PASS"; else if (v+0 >= 70) print "WARN"; else print "FAIL" }')
    fi
    if [[ "$FORMAT" == "json" ]]; then
        stale_details=$(printf '%s\n' "$stale_rows" | jq -R -s '
            split("\n")
            | map(select(length > 0) | split("\t") | {
                skill: .[0],
                source_count: (.[1] | tonumber),
                last_ok_at: (if .[2] == "" then null else .[2] end),
                age_days: (if .[3] == "" then null else (.[3] | tonumber) end),
                outcome_count: (.[4] | tonumber)
              })')
        jq -nc \
            --arg status "$status" \
            --argjson invoked "$invoked_skills" \
            --argjson fresh "$fresh_skills" \
            --argjson stale "$stale_skills" \
            --argjson pct "$freshness_pct" \
            --argjson stale_details "$stale_details" \
            --arg exclusion_file "$EXCLUSION_FILE" \
            '{status:$status, freshness_pct:$pct, invoked_skills:$invoked, fresh_skills:$fresh, stale_skills:$stale, window_days:7, target_pct:80, exclusion_file:$exclusion_file, stale_invoked_skills:$stale_details}'
    else
        echo "=== flywheel freshness ==="
        echo "window_days: 7"
        echo "target_pct: 80"
        echo "alias_file: $ALIAS_FILE"
        echo "exclusion_file: $EXCLUSION_FILE"
        echo "status: $status"
        echo "freshness_pct: $freshness_pct"
        echo "invoked_skills: $invoked_skills"
        echo "fresh_skills: $fresh_skills"
        echo "stale_skills: $stale_skills"
        if [[ "$invoked_skills" == "0" ]]; then
            echo "note: no outcomes in the last 7 days"
        fi
        echo ""
        echo "stale_invoked_skills:"
        if [[ -z "$stale_rows" ]]; then
            echo "- none"
        else
            echo "skill	source_count	last_ok_at	age_days	outcome_count"
            printf '%s\n' "$stale_rows"
        fi
    fi
    fw_event "freshness.report" "" "" "{\"status\":\"$status\",\"freshness_pct\":$freshness_pct,\"invoked_skills\":$invoked_skills,\"fresh_skills\":$fresh_skills,\"stale_skills\":$stale_skills}"
    ;;

# ───────────────────── quality gate (Petal-9 proposal) ─────────────────────
quality-gate)
    fw_require_db
    "$FLYWHEEL_HOME/bin/flywheel-quality-gate" "$@"
    ;;

# ───────────────────── Yuzu loop measurement (G-OS-4) ─────────────────────
yuzu)
    fw_require_db
    sub="${1:-}"; [[ $# -gt 0 ]] && shift || true
    case "$sub" in
        recipe)
            cat <<'EOF'
Yuzu operator recipe:
  1. Route intentionally:
     skill-search-mcp/scripts/run-server.sh --query "<task>" --record-yuzu --yuzu-stage peel --task-id "<stable-task-id>"
  2. If the routed skill was used:
     flywheel yuzu record --skill "<skill>" --event used --yuzu-stage press --task-id "<same-stable-task-id>" --pack "<pack>" --note "used routed skill"
  3. If the routed skill was noise:
     flywheel yuzu record --skill "<skill>" --event noise --yuzu-stage press --task-id "<same-stable-task-id>" --pack "<pack>" --note "loaded but unused"

Rules: reuse task_id; do not record used automatically from loaded; do not record noise without operator judgment.
EOF
            ;;
        record)
            skill=""; event=""; yuzu_stage=""; task_id=""; pack=""; note=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --skill) skill="$2"; shift 2 ;;
                    --event) event="$2"; shift 2 ;;
                    --yuzu-stage|--stage) yuzu_stage="$2"; shift 2 ;;
                    --task-id) task_id="$2"; shift 2 ;;
                    --pack) pack="$2"; shift 2 ;;
                    --note) note="$2"; shift 2 ;;
                    *) echo "ERR: unknown yuzu record flag $1" >&2; exit 2 ;;
                esac
            done
            [[ -n "$skill" ]] || { echo "ERR: yuzu record requires --skill" >&2; exit 2; }
            case "$event" in
                loaded|used|miss|noise) ;;
                *) echo "ERR: --event must be loaded|used|miss|noise" >&2; exit 2 ;;
            esac
            case "$yuzu_stage" in
                peel|press|pour) ;;
                *) echo "ERR: --yuzu-stage must be peel|press|pour" >&2; exit 2 ;;
            esac
            detail=$(jq -nc \
                --arg event "$event" \
                --arg yuzu_stage "$yuzu_stage" \
                --arg task_id "$task_id" \
                --arg pack "$pack" \
                --arg note "$note" \
                '{event:$event,yuzu_stage:$yuzu_stage}
                 + (if $task_id == "" then {} else {task_id:$task_id} end)
                 + (if $pack == "" then {} else {pack:$pack} end)
                 + (if $note == "" then {} else {note:$note} end)')
            fw_event "yuzu.skill_load" "$skill" "" "$detail"
            echo "OK: yuzu event=$event stage=$yuzu_stage skill=$skill"
            ;;
        report)
            FORMAT="text"; DAYS=7
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --json) FORMAT="json"; shift ;;
                    --days) DAYS="$2"; shift 2 ;;
                    *) echo "ERR: unknown yuzu report flag $1" >&2; exit 2 ;;
                esac
            done
            [[ "$DAYS" =~ ^[0-9]+$ ]] || { echo "ERR: --days must be an integer" >&2; exit 2; }
            row=$(fw_sql "
WITH y AS (
  SELECT
    skill,
    json_extract(detail,'$.event') AS event,
    json_extract(detail,'$.yuzu_stage') AS yuzu_stage
  FROM events
  WHERE kind='yuzu.skill_load'
    AND ts >= datetime('now','-$DAYS days')
)
SELECT
  COUNT(*),
  SUM(CASE WHEN event='loaded' THEN 1 ELSE 0 END),
  SUM(CASE WHEN event='used' THEN 1 ELSE 0 END),
  SUM(CASE WHEN event='miss' THEN 1 ELSE 0 END),
  SUM(CASE WHEN event='noise' THEN 1 ELSE 0 END),
  COUNT(DISTINCT skill),
  printf('%.1f', 100.0 * SUM(CASE WHEN event='miss' THEN 1 ELSE 0 END) /
      CASE WHEN SUM(CASE WHEN event IN ('loaded','miss') THEN 1 ELSE 0 END)=0 THEN 1 ELSE SUM(CASE WHEN event IN ('loaded','miss') THEN 1 ELSE 0 END) END),
  printf('%.1f', 100.0 * SUM(CASE WHEN event='noise' THEN 1 ELSE 0 END) /
      CASE WHEN SUM(CASE WHEN event='loaded' THEN 1 ELSE 0 END)=0 THEN 1 ELSE SUM(CASE WHEN event='loaded' THEN 1 ELSE 0 END) END)
FROM y;
")
            IFS='|' read -r total loaded used missed noise distinct_skills miss_rate noise_rate <<< "$row"
            total="${total:-0}"; loaded="${loaded:-0}"; used="${used:-0}"; missed="${missed:-0}"; noise="${noise:-0}"; distinct_skills="${distinct_skills:-0}"
            miss_rate="${miss_rate:-0.0}"; noise_rate="${noise_rate:-0.0}"
            min_sample=20; enforce_sample=50
            warn_miss_pct=10; fail_miss_pct=20
            warn_noise_pct=25; fail_noise_pct=40
            route_opportunities=$((loaded + missed))
            if [[ "$route_opportunities" -lt "$min_sample" ]]; then
                sample_status="INSUFFICIENT_SAMPLE"
                route_quality_status="INSUFFICIENT_SAMPLE"
            else
                if [[ "$route_opportunities" -lt "$enforce_sample" ]]; then
                    sample_status="ADVISORY"
                else
                    sample_status="ENFORCEABLE"
                fi
                if awk -v miss="$miss_rate" -v noise="$noise_rate" -v fm="$fail_miss_pct" -v fn="$fail_noise_pct" 'BEGIN { exit !((miss+0) >= fm || (noise+0) >= fn) }'; then
                    route_quality_status="FAIL"
                elif awk -v miss="$miss_rate" -v noise="$noise_rate" -v wm="$warn_miss_pct" -v wn="$warn_noise_pct" 'BEGIN { exit !((miss+0) >= wm || (noise+0) >= wn) }'; then
                    route_quality_status="WARN"
                else
                    route_quality_status="PASS"
                fi
            fi
            if [[ "$FORMAT" == "json" ]]; then
                jq -nc \
                    --argjson days "$DAYS" \
                    --argjson total "$total" \
                    --argjson loaded "$loaded" \
                    --argjson used "$used" \
                    --argjson missed "$missed" \
                    --argjson noise "$noise" \
                    --argjson distinct_skills "$distinct_skills" \
                    --argjson miss_rate_pct "$miss_rate" \
                    --argjson noise_rate_pct "$noise_rate" \
                    --argjson route_opportunities "$route_opportunities" \
                    --arg sample_status "$sample_status" \
                    --arg route_quality_status "$route_quality_status" \
                    --argjson min_sample "$min_sample" \
                    --argjson enforce_sample "$enforce_sample" \
                    --argjson warn_miss_pct "$warn_miss_pct" \
                    --argjson fail_miss_pct "$fail_miss_pct" \
                    --argjson warn_noise_pct "$warn_noise_pct" \
                    --argjson fail_noise_pct "$fail_noise_pct" \
                    '{window_days:$days,total_events:$total,loaded:$loaded,used:$used,missed:$missed,noise:$noise,distinct_skills:$distinct_skills,route_opportunities:$route_opportunities,miss_rate_pct:$miss_rate_pct,noise_rate_pct:$noise_rate_pct,sample_status:$sample_status,route_quality_status:$route_quality_status,thresholds:{min_sample:$min_sample,enforce_sample:$enforce_sample,warn_miss_pct:$warn_miss_pct,fail_miss_pct:$fail_miss_pct,warn_noise_pct:$warn_noise_pct,fail_noise_pct:$fail_noise_pct}}'
            else
                echo "=== flywheel yuzu ==="
                echo "window_days: $DAYS"
                echo "total_events: $total"
                echo "loaded: $loaded"
                echo "used: $used"
                echo "missed: $missed"
                echo "noise: $noise"
                echo "distinct_skills: $distinct_skills"
                echo "route_opportunities: $route_opportunities"
                echo "miss_rate_pct: $miss_rate"
                echo "noise_rate_pct: $noise_rate"
                echo "sample_status: $sample_status"
                echo "route_quality_status: $route_quality_status"
            fi
            ;;
        *)
            echo "usage: flywheel yuzu record --skill <skill> --event loaded|used|miss|noise --yuzu-stage peel|press|pour [--task-id id] [--pack name] [--note text]" >&2
            echo "       flywheel yuzu report [--days N] [--json]" >&2
            echo "       flywheel yuzu recipe" >&2
            exit 2
            ;;
    esac
    ;;

# ───────────────────── joshua taste verdict ─────────────────────
verdict)
    fw_require_db
    "$FLYWHEEL_HOME/bin/flywheel-verdict" "$@"
    ;;

# ───────────────────── digest ─────────────────────
digest)
    fw_require_db
    "$FLYWHEEL_HOME/bin/flywheel-digest" "$@"
    ;;

# ───────────────────── CASS × freshness correlation (G12) ─────────────────────
cass-correlate)
    fw_require_db
    "$FLYWHEEL_HOME/bin/flywheel-cass-correlate" "$@"
    ;;

# ───────────────────── pattern detector ─────────────────────
pattern)
    fw_require_db
    "$FLYWHEEL_HOME/bin/flywheel-pattern" "$@"
    ;;

# ───────────────────── observability ─────────────────────
observe)
    fw_require_db
    echo "=== events (last 24h) ==="
    fw_sql -header -column "
        SELECT kind, COUNT(*) AS n, AVG(duration_ms) AS avg_ms
        FROM events WHERE ts >= datetime('now','-1 day')
        GROUP BY kind ORDER BY n DESC;"
    echo ""
    echo "=== sources health ==="
    fw_sql -header -column "
        SELECT
            (SELECT COUNT(*) FROM sources) AS total,
            (SELECT COUNT(*) FROM sources WHERE fail_streak >= 3) AS dead,
            (SELECT COUNT(*) FROM sources WHERE last_ok_at >= datetime('now','-8 days')) AS fresh_7d,
            (SELECT printf('%.2f', AVG(quality_score)) FROM sources) AS avg_quality;"
    echo ""
    echo "=== deltas pending ==="
    fw_sql -header -column "
        SELECT severity, COUNT(*) AS n FROM deltas
        WHERE surfaced_at IS NULL GROUP BY severity;"
    echo ""
    echo "=== repo anchors ==="
    fw_sql -header -column "
        SELECT
            (SELECT COUNT(*) FROM repo_anchors) AS total,
            (SELECT COUNT(*) FROM repo_anchors WHERE approved_by_joshua=1) AS approved,
            (SELECT COUNT(DISTINCT skill) FROM repo_anchors WHERE approved_by_joshua=1) AS skills_with_anchor;"
    ;;

dashboard)
    fw_require_db
    "$FLYWHEEL_HOME/bin/flywheel-dashboard" "$@"
    ;;

# ───────────────────── render LATEST.md per skill ─────────────────────
render-latest)
    fw_require_db
    "$FLYWHEEL_HOME/bin/flywheel-render-latest" "$@"
    ;;

# ───────── continuity v0: event / rehydrate / ledger ─────────
# Append-only event row writer. Reuses existing events table; no schema
# migration. Detail must be valid JSON when supplied.
event)
    fw_require_db
    sub="${1:-}"
    [[ "$sub" != "append" ]] && { echo "usage: flywheel event append --kind K [--skill S] [--detail JSON]" >&2; exit 2; }
    shift
    e_kind=""; e_skill=""; e_detail=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --kind)   e_kind="$2"; shift 2 ;;
            --skill)  e_skill="$2"; shift 2 ;;
            --detail) e_detail="$2"; shift 2 ;;
            *) echo "unknown event-append flag: $1" >&2; exit 2 ;;
        esac
    done
    [[ -z "$e_kind" ]] && { echo "ERR: --kind required" >&2; exit 2; }
    if [[ -n "$e_detail" ]]; then
        printf '%s' "$e_detail" | python3 -c 'import json,sys; json.loads(sys.stdin.read())' 2>/dev/null \
            || { echo "ERR: --detail not valid JSON" >&2; exit 2; }
    fi
    fw_event "$e_kind" "$e_skill" "" "$e_detail"
    echo "OK: event appended kind=$e_kind"
    ;;

# Read-only selective recall: pull recent events + outcomes scoped by query.
# Default: regex match against events.kind, events.skill, and outcomes.note.
rehydrate)
    fw_require_db
    query="${1:-}"
    [[ -z "$query" ]] && { echo "usage: flywheel rehydrate QUERY [--since DAYS] [--json]" >&2; exit 2; }
    shift || true
    since_days=7
    fmt="text"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --since) since_days="${2%d}"; shift 2 ;;
            --json) fmt="json"; shift ;;
            *) echo "unknown rehydrate flag: $1" >&2; exit 2 ;;
        esac
    done
    q_quoted="$(printf '%s' "$query" | sed "s/'/''/g")"
    if [[ "$fmt" == "json" ]]; then
        fw_sql -json "
            SELECT 'event' AS source, kind, skill, ts, detail FROM events
            WHERE ts >= datetime('now','-${since_days} days')
              AND (kind LIKE '%${q_quoted}%' OR IFNULL(skill,'') LIKE '%${q_quoted}%' OR IFNULL(detail,'') LIKE '%${q_quoted}%')
            ORDER BY ts DESC LIMIT 25;
        "
        fw_sql -json "
            SELECT 'outcome' AS source, skill, ts, joshua_verdict, success, note FROM outcomes
            WHERE ts >= datetime('now','-${since_days} days')
              AND (IFNULL(skill,'') LIKE '%${q_quoted}%' OR IFNULL(note,'') LIKE '%${q_quoted}%')
            ORDER BY ts DESC LIMIT 25;
        "
    else
        echo "# rehydrate query='$query' since=${since_days}d"
        echo "## events"
        fw_sql "
            SELECT ts || '  ' || kind || '  ' || COALESCE(skill,'-')
            FROM events
            WHERE ts >= datetime('now','-${since_days} days')
              AND (kind LIKE '%${q_quoted}%' OR IFNULL(skill,'') LIKE '%${q_quoted}%' OR IFNULL(detail,'') LIKE '%${q_quoted}%')
            ORDER BY ts DESC LIMIT 15;"
        echo "## outcomes"
        fw_sql "
            SELECT ts || '  ' || skill || '  verdict=' || COALESCE(joshua_verdict,'-') ||
                   '  success=' || COALESCE(success,'-') ||
                   CASE WHEN note IS NOT NULL AND note <> '' THEN '  note=' || substr(note,1,80) ELSE '' END
            FROM outcomes
            WHERE ts >= datetime('now','-${since_days} days')
              AND (IFNULL(skill,'') LIKE '%${q_quoted}%' OR IFNULL(note,'') LIKE '%${q_quoted}%')
            ORDER BY ts DESC LIMIT 15;"
    fi
    ;;

# Derived JSONL export from state.db. Not the source of truth.
ledger)
    fw_require_db
    sub="${1:-}"
    [[ "$sub" != "export" ]] && { echo "usage: flywheel ledger export [PATH|--stdout] [--since DAYS]" >&2; exit 2; }
    shift
    out_path=""
    since_days=30
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --stdout) out_path="-"; shift ;;
            --since) since_days="${2%d}"; shift 2 ;;
            -*) echo "unknown ledger-export flag: $1" >&2; exit 2 ;;
            *) out_path="$1"; shift ;;
        esac
    done
    [[ -z "$out_path" ]] && { echo "ERR: PATH or --stdout required" >&2; exit 2; }
    sql="
        SELECT json_object(
            'source','event','kind',kind,'skill',skill,
            'duration_ms',duration_ms,'detail',json(IFNULL(detail,'null')),'ts',ts
        ) FROM events WHERE ts >= datetime('now','-${since_days} days')
        UNION ALL
        SELECT json_object(
            'source','outcome','skill',skill,'task_id',task_id,
            'used_intel',used_intel,'success',success,'joshua_verdict',joshua_verdict,
            'note',note,'ts',ts
        ) FROM outcomes WHERE ts >= datetime('now','-${since_days} days')
        ORDER BY 1;
    "
    if [[ "$out_path" == "-" ]]; then
        fw_sql "$sql"
    else
        mkdir -p "$(dirname "$out_path")"
        fw_sql "$sql" > "$out_path"
        echo "OK: ledger exported to $out_path ($(wc -l <"$out_path" | tr -d ' ') rows, last ${since_days}d)"
    fi
    ;;

# ───────── meta-gap lane 3: joshua override v0 ─────────
# Typed wrapper over events.kind='joshua.override'. Captures explicit
# disagreement only — no passive inference, no correctness claim, no UI.
# Forbidden detail keys (correctness inference) are stripped/refused at
# write time per pane2 contract review.
override)
    fw_require_db
    sub="${1:-}"
    shift || true
    case "$sub" in
      record)
        ov_skill=""; ov_kind=""; ov_reason=""; ov_task=""; ov_lane=""; ov_source=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --skill)                  ov_skill="$2"; shift 2 ;;
                --override-kind)          ov_kind="$2"; shift 2 ;;
                --reason)                 ov_reason="$2"; shift 2 ;;
                --task-id)                ov_task="$2"; shift 2 ;;
                --lane)                   ov_lane="$2"; shift 2 ;;
                --recommendation-source)  ov_source="$2"; shift 2 ;;
                *) echo "unknown override-record flag: $1" >&2; exit 2 ;;
            esac
        done
        [[ -z "$ov_skill" ]] && { echo "ERR: --skill required" >&2; exit 2; }
        case "$ov_kind" in
            ignored|rejected|reversed|deferred) : ;;
            "") echo "ERR: --override-kind required (ignored|rejected|reversed|deferred)" >&2; exit 2 ;;
            *)  echo "ERR: --override-kind '$ov_kind' not in enum {ignored,rejected,reversed,deferred}" >&2; exit 2 ;;
        esac
        if [[ -n "$ov_reason" ]] && (( ${#ov_reason} > 200 )); then
            echo "ERR: --reason too long (${#ov_reason} chars; cap=200; transcripts forbidden)" >&2
            exit 2
        fi
        if [[ -n "$ov_source" ]]; then
            case "$ov_source" in
                yuzu|skill-search|hook|manual) : ;;
                *) echo "ERR: --recommendation-source '$ov_source' not in enum {yuzu,skill-search,hook,manual}" >&2; exit 2 ;;
            esac
        fi
        # Build detail JSON via python (handles quoting + omits empties).
        detail=$(python3 - "$ov_kind" "$ov_reason" "$ov_task" "$ov_lane" "$ov_source" <<'PY'
import json, sys
kind, reason, task, lane, source = sys.argv[1:6]
d = {"override_kind": kind, "schema_version": 1}
if reason: d["reason"] = reason
if task:   d["task_id"] = task
if lane:   d["lane"] = lane
if source: d["recommendation_source"] = source
# Hard-strip any correctness-claiming keys if a future caller smuggles them.
for forbidden in ("correct","system_wrong","joshua_right","correctness"):
    d.pop(forbidden, None)
print(json.dumps(d, sort_keys=True))
PY
)
        fw_event "joshua.override" "$ov_skill" "" "$detail"
        echo "OK: joshua.override recorded skill=$ov_skill kind=$ov_kind"
        ;;
      list)
        fmt="text"; days=14; filter_skill=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --json)  fmt="json"; shift ;;
                --days)  days="${2%d}"; shift 2 ;;
                --skill) filter_skill="$2"; shift 2 ;;
                *) echo "unknown override-list flag: $1" >&2; exit 2 ;;
            esac
        done
        skill_clause=""
        if [[ -n "$filter_skill" ]]; then
            sq=$(printf '%s' "$filter_skill" | sed "s/'/''/g")
            skill_clause=" AND skill='$sq'"
        fi
        if [[ "$fmt" == "json" ]]; then
            fw_sql -json "
                SELECT ts, skill, detail FROM events
                WHERE kind='joshua.override' AND ts >= datetime('now','-${days} days')${skill_clause}
                ORDER BY ts DESC;"
        else
            echo "# joshua.override list (window=${days}d${filter_skill:+ skill=$filter_skill})"
            fw_sql "
                SELECT ts || '  ' || skill || '  ' ||
                       json_extract(detail,'\$.override_kind') ||
                       CASE WHEN json_extract(detail,'\$.reason') IS NOT NULL
                            THEN '  reason=' || substr(json_extract(detail,'\$.reason'),1,80)
                            ELSE '' END
                FROM events
                WHERE kind='joshua.override' AND ts >= datetime('now','-${days} days')${skill_clause}
                ORDER BY ts DESC;"
        fi
        ;;
      report)
        fmt="text"; days=14
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --json) fmt="json"; shift ;;
                --days) days="${2%d}"; shift 2 ;;
                *) echo "unknown override-report flag: $1" >&2; exit 2 ;;
            esac
        done
        total=$(fw_sql "SELECT COUNT(*) FROM events WHERE kind='joshua.override' AND ts >= datetime('now','-${days} days')")
        unique_skills=$(fw_sql "SELECT COUNT(DISTINCT skill) FROM events WHERE kind='joshua.override' AND ts >= datetime('now','-${days} days')")
        if [[ "$fmt" == "json" ]]; then
            python3 - "$days" "$total" "$unique_skills" "$FLYWHEEL_DB" <<'PY'
import json, sqlite3, sys
days, total, unique_skills, db = int(sys.argv[1]), int(sys.argv[2]), int(sys.argv[3]), sys.argv[4]
con = sqlite3.connect(db); cur = con.cursor()
def kindq():
    rows = cur.execute(f"SELECT json_extract(detail,'$.override_kind') AS k, COUNT(*) FROM events WHERE kind='joshua.override' AND ts >= datetime('now','-{days} days') GROUP BY k").fetchall()
    return {k or "(unknown)": n for k, n in rows}
def topq():
    rows = cur.execute(f"SELECT skill, COUNT(*) AS n FROM events WHERE kind='joshua.override' AND ts >= datetime('now','-{days} days') GROUP BY skill ORDER BY n DESC LIMIT 5").fetchall()
    return [{"skill": s, "count": n} for s, n in rows]
def srcq():
    rows = cur.execute(f"SELECT json_extract(detail,'$.recommendation_source') AS s, COUNT(*) FROM events WHERE kind='joshua.override' AND ts >= datetime('now','-{days} days') GROUP BY s").fetchall()
    return {(s or "unspecified"): n for s, n in rows}
print(json.dumps({
    "schema_version": 1,
    "window_days": days,
    "total_overrides": total,
    "unique_skills_overridden": unique_skills,
    "by_override_kind": kindq(),
    "top_skills": topq(),
    "by_recommendation_source": srcq(),
    "correctness": {"status": "UNAVAILABLE", "reason": "v0 records disagreement only; correctness needs a paired adjudication event"},
}, indent=2, sort_keys=True))
PY
        else
            echo "# joshua-override report (window=${days}d)"
            echo ""
            echo "## summary"
            printf '  total_overrides            %s\n' "$total"
            printf '  unique_skills_overridden   %s\n' "$unique_skills"
            echo ""
            echo "## by override_kind"
            fw_sql "
                SELECT '  ' || COALESCE(json_extract(detail,'\$.override_kind'),'(unknown)') || '  ' || COUNT(*)
                FROM events
                WHERE kind='joshua.override' AND ts >= datetime('now','-${days} days')
                GROUP BY json_extract(detail,'\$.override_kind')
                ORDER BY COUNT(*) DESC;"
            echo ""
            echo "## top skills (by override count)"
            fw_sql "
                SELECT '  ' || skill || '  ' || COUNT(*)
                FROM events
                WHERE kind='joshua.override' AND ts >= datetime('now','-${days} days')
                GROUP BY skill ORDER BY COUNT(*) DESC LIMIT 5;"
            echo ""
            echo "## by recommendation_source"
            fw_sql "
                SELECT '  ' || COALESCE(json_extract(detail,'\$.recommendation_source'),'unspecified') || '  ' || COUNT(*)
                FROM events
                WHERE kind='joshua.override' AND ts >= datetime('now','-${days} days')
                GROUP BY json_extract(detail,'\$.recommendation_source')
                ORDER BY COUNT(*) DESC;"
            echo ""
            echo "## correctness"
            echo "  UNAVAILABLE — v0 records disagreement only; needs paired adjudication event"
        fi
        ;;
      *)
        echo "usage: flywheel override {record|list|report} ..." >&2
        exit 2
        ;;
    esac
    ;;

# ───────── meta-gap lane 2 v0.1: typed pattern denominator events ─────────
# Typed rows over events.kind='pattern.strike' / 'pattern.promoted'. These
# only create denominator evidence for learning-rate; they never promote
# PATTERNS.md or infer correctness.
pattern-event)
    fw_require_db
    sub="${1:-}"
    shift || true
    [[ "$sub" != "record" ]] && { echo "usage: flywheel pattern-event record --kind pattern.strike|pattern.promoted --pattern-id ID --source-kind KIND --source-ref REF [--summary TEXT] [--proposal-ref PATH] [--evidence-commit SHA] [--promotion-commit SHA] [--detail JSON]" >&2; exit 2; }
    pe_kind=""; pe_pattern_id=""; pe_source_kind=""; pe_source_ref=""
    pe_summary=""; pe_evidence_commit=""; pe_proposal_ref=""; pe_promotion_commit=""; pe_extra="{}"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --kind) pe_kind="$2"; shift 2 ;;
            --pattern-id) pe_pattern_id="$2"; shift 2 ;;
            --source-kind) pe_source_kind="$2"; shift 2 ;;
            --source-ref) pe_source_ref="$2"; shift 2 ;;
            --summary) pe_summary="$2"; shift 2 ;;
            --evidence-commit) pe_evidence_commit="$2"; shift 2 ;;
            --proposal-ref) pe_proposal_ref="$2"; shift 2 ;;
            --promotion-commit) pe_promotion_commit="$2"; shift 2 ;;
            --detail) pe_extra="$2"; shift 2 ;;
            *) echo "unknown pattern-event-record flag: $1" >&2; exit 2 ;;
        esac
    done
    detail=$(python3 - "$pe_kind" "$pe_pattern_id" "$pe_source_kind" "$pe_source_ref" "$pe_summary" "$pe_evidence_commit" "$pe_proposal_ref" "$pe_promotion_commit" "$pe_extra" <<'PY'
import json, re, sys

kind, pattern_id, source_kind, source_ref, summary, evidence_commit, proposal_ref, promotion_commit, extra_raw = sys.argv[1:10]
forbidden = {"score", "system_right", "joshua_wrong", "auto_promote", "correct", "correctness"}
reserved = {"schema_version", "pattern_id", "source_kind", "source_ref", "summary", "evidence_commit", "proposal_ref", "promotion_commit", "disposition"}

def fail(msg):
    print(f"ERR: {msg}", file=sys.stderr)
    raise SystemExit(2)

if kind not in {"pattern.strike", "pattern.promoted"}:
    fail("--kind must be pattern.strike or pattern.promoted")
if not re.fullmatch(r"[a-z][a-z0-9-]{2,80}", pattern_id or ""):
    fail("--pattern-id must be lowercase kebab-case")
if not source_ref:
    fail("--source-ref required")

strike_sources = {"proposal", "incident", "dispatch", "review", "commit"}
promoted_sources = {"petal9", "patterns_md", "manual"}
if kind == "pattern.strike":
    if source_kind not in strike_sources:
        fail("--source-kind for pattern.strike must be proposal|incident|dispatch|review|commit")
    if not summary:
        fail("--summary required for pattern.strike")
    if len(summary) > 240:
        fail("--summary too long (cap=240)")
else:
    if source_kind not in promoted_sources:
        fail("--source-kind for pattern.promoted must be petal9|patterns_md|manual")
    if source_kind != "patterns_md" and not proposal_ref:
        fail("--proposal-ref required for pattern.promoted unless source-kind=patterns_md")

try:
    extra = json.loads(extra_raw or "{}")
except Exception:
    fail("--detail not valid JSON")
if not isinstance(extra, dict):
    fail("--detail must be a JSON object")
bad = sorted(forbidden & set(extra))
if bad:
    fail("forbidden detail fields: " + ",".join(bad))
bad_reserved = sorted(reserved & set(extra))
if bad_reserved:
    fail("reserved detail fields: " + ",".join(bad_reserved))

d = {
    "schema_version": 1,
    "pattern_id": pattern_id,
    "source_kind": source_kind,
    "source_ref": source_ref,
}
if kind == "pattern.strike":
    d["summary"] = summary
    if evidence_commit:
        d["evidence_commit"] = evidence_commit
else:
    d["disposition"] = "promoted"
    if proposal_ref:
        d["proposal_ref"] = proposal_ref
    if promotion_commit:
        d["promotion_commit"] = promotion_commit
d.update(extra)
print(json.dumps(d, sort_keys=True))
PY
)
    fw_event "$pe_kind" "" "" "$detail"
    echo "OK: $pe_kind recorded pattern_id=$pe_pattern_id"
    ;;

# ───────── meta-gap lane 2: learning-rate report ─────────
# Read-only summary answering "is the flywheel getting smarter, not just
# fresher?" — emits durable metrics where we have a source, marks the rest
# as unavailable with a reason. NEVER mutates state.db.
# --days N scopes EVERY metric in this report, including the
# pattern.strike + pattern.promoted join used by time_to_pattern. Increase
# --days to widen the lifecycle window; the JSON exposes window_days on
# time_to_pattern so consumers can see the active scope.
learning-rate)
    fw_require_db
    fmt="text"
    days=30
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json) fmt="json"; shift ;;
            --days) days="${2%d}"; shift 2 ;;
            *) echo "unknown learning-rate flag: $1" >&2; exit 2 ;;
        esac
    done
    PATTERNS_MD="${FLYWHEEL_PATTERNS_MD:-$FLYWHEEL_HOME/PATTERNS.md}"
    PROPOSALS_DIR="${FLYWHEEL_PROPOSALS_DIR:-$FLYWHEEL_HOME/proposals}"

    # Available metrics --------------------------------------------------
    outcome_total=$(fw_sql "SELECT COUNT(*) FROM outcomes WHERE ts >= datetime('now','-${days} days')")
    outcome_success=$(fw_sql "SELECT COALESCE(SUM(CASE WHEN success=1 THEN 1 ELSE 0 END),0) FROM outcomes WHERE ts >= datetime('now','-${days} days')")
    verdict_up=$(fw_sql "SELECT COUNT(*) FROM outcomes WHERE ts >= datetime('now','-${days} days') AND joshua_verdict='thumbs_up'")
    verdict_dn=$(fw_sql "SELECT COUNT(*) FROM outcomes WHERE ts >= datetime('now','-${days} days') AND joshua_verdict='thumbs_down'")
    verdict_total=$((verdict_up + verdict_dn))
    cont_event_total=$(fw_sql "SELECT COUNT(*) FROM events WHERE ts >= datetime('now','-${days} days') AND kind IN ('dispatch.opened','dispatch.closed','commit.landed','cost.line','joshua.override')")
    joshua_override_total=$(fw_sql "SELECT COUNT(*) FROM events WHERE ts >= datetime('now','-${days} days') AND kind='joshua.override'")
    # Override v0 breakdown — counts only, no correctness.
    override_kind_breakdown=$(python3 - "$days" "$FLYWHEEL_DB" <<'PY'
import json, sqlite3, sys
days, db = int(sys.argv[1]), sys.argv[2]
con = sqlite3.connect(db); cur = con.cursor()
rows = cur.execute(f"SELECT json_extract(detail,'$.override_kind') AS k, COUNT(*) FROM events WHERE kind='joshua.override' AND ts >= datetime('now','-{days} days') GROUP BY k").fetchall()
print(json.dumps({(k or "(unknown)"): n for k, n in rows}, sort_keys=True))
PY
)
    override_top_skills=$(python3 - "$days" "$FLYWHEEL_DB" <<'PY'
import json, sqlite3, sys
days, db = int(sys.argv[1]), sys.argv[2]
con = sqlite3.connect(db); cur = con.cursor()
rows = cur.execute(f"SELECT skill, COUNT(*) AS n FROM events WHERE kind='joshua.override' AND ts >= datetime('now','-{days} days') GROUP BY skill ORDER BY n DESC LIMIT 5").fetchall()
print(json.dumps([{"skill": s, "count": n} for s, n in rows]))
PY
)
    time_to_pattern_json=$(python3 - "$days" "$FLYWHEEL_DB" <<'PY'
import datetime as dt
import json
import sqlite3
import statistics
import sys

days, db = int(sys.argv[1]), sys.argv[2]
con = sqlite3.connect(db)
con.row_factory = sqlite3.Row
rows = con.execute(
    """
    SELECT kind, ts, detail
    FROM events
    WHERE kind IN ('pattern.strike','pattern.promoted')
      AND ts >= datetime('now', ?)
    ORDER BY ts ASC, id ASC
    """,
    (f"-{days} days",),
).fetchall()

def parse_ts(value):
    text = str(value).replace("Z", "+00:00")
    if "T" not in text and "+" not in text:
        text = text.replace(" ", "T") + "+00:00"
    return dt.datetime.fromisoformat(text)

strikes = {}
promotions = {}
warnings = []
for row in rows:
    try:
        detail = json.loads(row["detail"] or "{}")
    except Exception:
        warnings.append(f"invalid_json:{row['kind']}")
        continue
    pattern_id = detail.get("pattern_id")
    if not pattern_id:
        warnings.append(f"missing_pattern_id:{row['kind']}")
        continue
    try:
        ts = parse_ts(row["ts"])
    except Exception:
        warnings.append(f"invalid_ts:{pattern_id}")
        continue
    target = strikes if row["kind"] == "pattern.strike" else promotions
    if pattern_id not in target or ts < target[pattern_id][0]:
        target[pattern_id] = (ts, row["ts"])

patterns = []
promoted_without_strike = 0
promoted_before_strike = 0
for pattern_id, (promoted_ts, promoted_raw) in sorted(promotions.items()):
    if pattern_id not in strikes:
        promoted_without_strike += 1
        continue
    strike_ts, strike_raw = strikes[pattern_id]
    if promoted_ts <= strike_ts:
        promoted_before_strike += 1
        continue
    hours = (promoted_ts - strike_ts).total_seconds() / 3600.0
    patterns.append({
        "pattern_id": pattern_id,
        "strike_ts": strike_raw,
        "promoted_ts": promoted_raw,
        "hours": round(hours, 3),
    })

if not patterns:
    print(json.dumps({
        "status": "UNAVAILABLE",
        "reason": "no joined pattern.strike + pattern.promoted events with shared pattern_id",
        "count": 0,
        "window_days": days,
        "excluded": {
            "promoted_without_strike": promoted_without_strike,
            "promoted_before_or_at_strike": promoted_before_strike,
        },
        "warnings": warnings,
    }, sort_keys=True))
else:
    values = [p["hours"] for p in patterns]
    print(json.dumps({
        "status": "MEASURED",
        "count": len(patterns),
        "window_days": days,
        "median_hours": round(statistics.median(values), 3),
        "min_hours": round(min(values), 3),
        "max_hours": round(max(values), 3),
        "patterns": patterns,
        "excluded": {
            "promoted_without_strike": promoted_without_strike,
            "promoted_before_or_at_strike": promoted_before_strike,
        },
        "warnings": warnings,
    }, sort_keys=True))
PY
)
    time_to_pattern_measured=$(printf '%s' "$time_to_pattern_json" | python3 -c 'import json,sys; print(1 if json.load(sys.stdin).get("status")=="MEASURED" else 0)')

    # Route-quality denominator (read-only over yuzu.skill_load events).
    # Mirrors the existing `flywheel yuzu report` thresholds exactly. Reports
    # operator route-quality, NEVER claims correctness of the routed skill.
    route_quality_json=$(python3 - "$days" "$FLYWHEEL_DB" <<'PY'
import json, sqlite3, sys
days, db = int(sys.argv[1]), sys.argv[2]
con = sqlite3.connect(db)
rows = con.execute(
    """
    SELECT json_extract(detail,'$.event') AS event
    FROM events
    WHERE kind='yuzu.skill_load'
      AND ts >= datetime('now', ?)
    """,
    (f"-{days} days",),
).fetchall()
total = len(rows)
loaded = sum(1 for (e,) in rows if e == "loaded")
used   = sum(1 for (e,) in rows if e == "used")
missed = sum(1 for (e,) in rows if e == "miss")
noise  = sum(1 for (e,) in rows if e == "noise")
opps = loaded + missed
miss_rate  = round(100.0 * missed / opps, 1) if opps else 0.0
noise_rate = round(100.0 * noise  / loaded, 1) if loaded else 0.0
min_sample, enforce_sample = 20, 50
warn_miss, fail_miss = 10, 20
warn_noise, fail_noise = 25, 40
if opps < min_sample:
    sample_status = "INSUFFICIENT_SAMPLE"
    rq_status = "INSUFFICIENT_SAMPLE"
else:
    sample_status = "ENFORCEABLE" if opps >= enforce_sample else "ADVISORY"
    if miss_rate >= fail_miss or noise_rate >= fail_noise:
        rq_status = "FAIL"
    elif miss_rate >= warn_miss or noise_rate >= warn_noise:
        rq_status = "WARN"
    else:
        rq_status = "PASS"
print(json.dumps({
    "source": "events.kind=yuzu.skill_load",
    "window_days": days,
    "total_events": total,
    "loaded": loaded,
    "used": used,
    "missed": missed,
    "noise": noise,
    "route_opportunities": opps,
    "miss_rate_pct": miss_rate,
    "noise_rate_pct": noise_rate,
    "sample_status": sample_status,
    "route_quality_status": rq_status,
    "thresholds": {
        "min_sample": min_sample, "enforce_sample": enforce_sample,
        "warn_miss_pct": warn_miss, "fail_miss_pct": fail_miss,
        "warn_noise_pct": warn_noise, "fail_noise_pct": fail_noise,
    },
}, sort_keys=True))
PY
)
    route_quality_enforceable=$(printf '%s' "$route_quality_json" | python3 -c 'import json,sys; d=json.load(sys.stdin); print(0 if d.get("sample_status")=="INSUFFICIENT_SAMPLE" else 1)')

    if [[ -f "$PATTERNS_MD" ]]; then
        pattern_count_total=$(grep -cE '^## P[0-9]+ —' "$PATTERNS_MD" 2>/dev/null || true)
        [[ "$pattern_count_total" =~ ^[0-9]+$ ]] || pattern_count_total=0
        patterns_last_modified=$(stat -f '%Sm' -t '%Y-%m-%dT%H:%M:%SZ' "$PATTERNS_MD" 2>/dev/null || stat -c '%y' "$PATTERNS_MD" 2>/dev/null)
    else
        pattern_count_total="unavailable"
        patterns_last_modified="unavailable"
    fi

    if [[ -d "$PROPOSALS_DIR" ]]; then
        proposals_recent=$(find "$PROPOSALS_DIR" -maxdepth 1 -type f -name '*.md' -mtime -"${days}" 2>/dev/null | wc -l | tr -d ' ')
        proposals_total=$(find "$PROPOSALS_DIR" -maxdepth 1 -type f -name '*.md' 2>/dev/null | wc -l | tr -d ' ')
    else
        proposals_recent="unavailable"
        proposals_total="unavailable"
    fi

    # Unavailable metrics + honest reasons -------------------------------
    skill_kill_reason="no skill.retired or skill.killed event kind in events table; encode demotion as a durable event before measuring"
    trauma_restrike_reason="no trauma.restrike or pattern.restrike event kind exists; PATTERNS.md strike counts are markdown-internal, not queryable"
    time_to_pattern_reason="no joined pattern.strike + pattern.promoted events with shared pattern_id"
    joshua_override_correctness_reason="joshua.override has no follow-up correctness verdict; needs a paired outcome row or override.adjudicated event"
    route_quality_reason="route_opportunities (loaded+miss) below min_sample threshold; record more yuzu.skill_load events via flywheel yuzu record"
    route_correctness_reason="yuzu.skill_load used is an operator route signal, not correctness; correctness needs a paired adjudication event"

    if [[ "$fmt" == "json" ]]; then
        python3 -c "
import json
print(json.dumps({
    'window_days': $days,
    'outcomes': {
        'total': $outcome_total,
        'success_count': $outcome_success,
        'success_rate': (($outcome_success * 1.0) / $outcome_total) if $outcome_total else None,
    },
    'joshua_verdicts': {
        'thumbs_up': $verdict_up,
        'thumbs_down': $verdict_dn,
        'total': $verdict_total,
    },
    'continuity_events': {
        'total': $cont_event_total,
        'joshua_override': $joshua_override_total,
    },
    'joshua_override_kind_breakdown': $override_kind_breakdown,
    'joshua_override_top_skills': $override_top_skills,
    'patterns': {
        'count_total': '$pattern_count_total',
        'last_modified': '$patterns_last_modified',
    },
    'proposals': {
        'recent': '$proposals_recent',
        'total': '$proposals_total',
    },
    'time_to_pattern': $time_to_pattern_json,
    'route_quality': $route_quality_json,
    'unavailable': {
        'skill_kill_rate': '$skill_kill_reason',
        'trauma_restrike_rate': '$trauma_restrike_reason',
        **({} if $time_to_pattern_measured else {'time_to_pattern': '$time_to_pattern_reason'}),
        'joshua_override_correctness': '$joshua_override_correctness_reason',
        **({} if $route_quality_enforceable else {'route_quality': '$route_quality_reason'}),
        'route_correctness': '$route_correctness_reason',
    },
}, indent=2))
"
    else
        echo "# flywheel learning-rate (window=${days}d)"
        echo ""
        echo "## available"
        printf '  outcomes_total              %s\n' "$outcome_total"
        printf '  outcomes_success            %s\n' "$outcome_success"
        if [[ "$outcome_total" -gt 0 ]]; then
            printf '  outcomes_success_rate       %.3f\n' "$(python3 -c "print($outcome_success / $outcome_total)")"
        else
            printf '  outcomes_success_rate       n/a (zero outcomes in window)\n'
        fi
        printf '  joshua_verdicts_up          %s\n' "$verdict_up"
        printf '  joshua_verdicts_down        %s\n' "$verdict_dn"
        printf '  joshua_verdicts_total       %s\n' "$verdict_total"
        printf '  continuity_events_total     %s\n' "$cont_event_total"
        printf '  joshua_override_count       %s\n' "$joshua_override_total"
        printf '  patterns_count_total        %s\n' "$pattern_count_total"
        printf '  patterns_last_modified      %s\n' "$patterns_last_modified"
        printf '  proposals_recent            %s\n' "$proposals_recent"
        printf '  proposals_total             %s\n' "$proposals_total"
        if [[ "$time_to_pattern_measured" == "1" ]]; then
            printf '  time_to_pattern             %s\n' "$(printf '%s' "$time_to_pattern_json" | python3 -c 'import json,sys; d=json.load(sys.stdin); print(f"measured count={d[\"count\"]} median_hours={d[\"median_hours\"]}")')"
        fi
        echo ""
        echo "## route_quality (operator route signal, not correctness)"
        python3 - "$route_quality_json" <<'PY'
import json, sys
d = json.loads(sys.argv[1])
print(f"  source                      {d['source']}")
print(f"  total_events                {d['total_events']}")
print(f"  loaded/used/missed/noise    {d['loaded']}/{d['used']}/{d['missed']}/{d['noise']}")
print(f"  route_opportunities         {d['route_opportunities']}")
print(f"  miss_rate_pct               {d['miss_rate_pct']}")
print(f"  noise_rate_pct              {d['noise_rate_pct']}")
print(f"  sample_status               {d['sample_status']}")
print(f"  route_quality_status        {d['route_quality_status']}")
PY
        echo ""
        echo "## unavailable (honest gaps)"
        printf '  skill_kill_rate             unavailable: %s\n' "$skill_kill_reason"
        printf '  trauma_restrike_rate        unavailable: %s\n' "$trauma_restrike_reason"
        if [[ "$time_to_pattern_measured" != "1" ]]; then
            printf '  time_to_pattern             unavailable: %s\n' "$time_to_pattern_reason"
        fi
        printf '  joshua_override_correctness unavailable: %s\n' "$joshua_override_correctness_reason"
    fi
    ;;

# ───────────────────── tests ─────────────────────
test)
    "$FLYWHEEL_HOME/tests/run-tests.sh" "$@"
    ;;

# ───────────────────── install hooks ─────────────────────
install-hooks)
    "$FLYWHEEL_HOME/bin/flywheel-install-hooks" "$@"
    ;;

# ───────────────────── help ─────────────────────
help|-h|--help|"")
    sed -n '2,30p' "$0"
    ;;

*)
    echo "ERR: unknown command: $CMD" >&2
    echo "Run: flywheel help" >&2
    exit 1
    ;;
esac
