+scaffold_emit_info() {
+  if ! command -v cli_emit_info >/dev/null; then
+    jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg name "flywheel-loop" \
+      '{schema_version:$sv,command:"info",name:$name,helper_lib_missing:true}'
+    return 0
+  fi
+  cli_emit_info \
+    "flywheel-loop" \
+    "scaffolded-v0" \
+    "$SCAFFOLD_SCHEMA_VERSION" \
+    "doctor,health,repair,validate,audit,why,quickstart,help,completion" \
+    "SCAFFOLD_AUDIT_LOG" \
+    '{}'
+}
+
+scaffold_emit_examples() {
+  local jsonl
+  jsonl="$(jq -nc '{name:"default run",invocation:"flywheel-loop",purpose:"backward-compatible original behavior"}'
+)"$'\n'"$(jq -nc '{name:"doctor",invocation:"flywheel-loop doctor --json",purpose:"probe substrate health"}'
+)"
+  if command -v cli_emit_examples >/dev/null; then
