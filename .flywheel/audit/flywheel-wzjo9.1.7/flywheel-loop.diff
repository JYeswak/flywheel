+scaffold_cmd_validate() {
+  local subject="${1:-}" target="${2:-}"
+  case "$subject" in
+    helper_lib)
+      local helper="${target:-${_SCAFFOLD_HELPER_LIB:-$_SCAFFOLD_REPO_ROOT/.flywheel/lib/canonical-cli-helpers.sh}}"
+      if [[ ! -r "$helper" ]]; then
+        jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg p "$helper" \
+          '{schema_version:$sv,command:"validate",scope:"scaffold-meta",subject:"helper_lib",status:"fail",path:$p,reason:"missing_or_unreadable"}'
+        return 1
+      fi
+      if grep -qE '^cli_audit_append\(\)|^cli_emit_audit_tail\(\)' "$helper"; then
+        jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg p "$helper" \
+          '{schema_version:$sv,command:"validate",scope:"scaffold-meta",subject:"helper_lib",status:"pass",path:$p,has_audit_append:true,has_emit_audit_tail:true}'
+        return 0
+      fi
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg p "$helper" \
+        '{schema_version:$sv,command:"validate",scope:"scaffold-meta",subject:"helper_lib",status:"fail",path:$p,reason:"missing_canonical_helpers"}'
+      return 1
+      ;;
+    audit_log)
+      local log="${target:-$SCAFFOLD_AUDIT_LOG}"
+      local dir; dir="$(dirname "$log")"
+      if [[ ! -d "$dir" ]]; then
+        jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg p "$log" \
+          '{schema_version:$sv,command:"validate",scope:"scaffold-meta",subject:"audit_log",status:"fail",path:$p,reason:"dir_missing"}'
+        return 1
+      fi
+      if [[ -e "$log" && ! -w "$log" ]]; then
+        jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg p "$log" \
+          '{schema_version:$sv,command:"validate",scope:"scaffold-meta",subject:"audit_log",status:"fail",path:$p,reason:"unwritable"}'
+        return 1
+      fi
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg p "$log" \
+        '{schema_version:$sv,command:"validate",scope:"scaffold-meta",subject:"audit_log",status:"pass",path:$p,exists:'"$([[ -e "$log" ]] && echo true || echo false)"'}'
+      return 0
+      ;;
+    env)
+      local fw="${FLYWHEEL_HOME:-}"
+      if [[ -z "$fw" || ! -d "$fw" ]]; then
+        jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg fw "$fw" \
+          '{schema_version:$sv,command:"validate",scope:"scaffold-meta",subject:"env",status:"fail",FLYWHEEL_HOME:$fw,reason:"FLYWHEEL_HOME_missing_or_invalid"}'
+        return 1
+      fi
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg fw "$fw" --arg log "$SCAFFOLD_AUDIT_LOG" \
+        '{schema_version:$sv,command:"validate",scope:"scaffold-meta",subject:"env",status:"pass",FLYWHEEL_HOME:$fw,SCAFFOLD_AUDIT_LOG:$log}'
+      return 0
+      ;;
+    "")
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+        '{schema_version:$sv,command:"validate",scope:"scaffold-meta",status:"refused",reason:"--subject required",valid_subjects:["helper_lib","audit_log","env"]}'
+      return 64
+      ;;
+    *)
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg s "$subject" \
+        '{schema_version:$sv,command:"validate",scope:"scaffold-meta",status:"refused",reason:"unknown subject",subject:$s,valid_subjects:["helper_lib","audit_log","env"]}'
+      return 64
+      ;;
+  esac
+}
