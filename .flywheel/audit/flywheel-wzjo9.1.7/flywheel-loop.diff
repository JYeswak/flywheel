+scaffold_emit_schema() {
+  local surface="${1:-default}"
+  case "$surface" in
+    doctor)
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+        '{schema_version:$sv,command:"schema",surface:"doctor",scope:"scaffold-meta",fields:{ts:"ISO8601",status:"pass|warn|fail",checks:"array of {name,status,detail?}"},note:"scaffold-meta-doctor probes the canonical-cli scaffold layer; native flywheel-loop doctor (portable_doctor) handles substrate-wide probes — bypassed by colliding-verb intercept"}'
+      ;;
+    health)
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+        '{schema_version:$sv,command:"schema",surface:"health",fields:{ts:"ISO8601",status:"pass|warn|fail",audit_log:"path",last_run_ts:"ISO8601 or null",age_seconds:"int or null",recent_runs:"int (last 20)",total_runs:"int"},env:"SCAFFOLD_AUDIT_LOG"}'
+      ;;
+    repair)
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+        '{schema_version:$sv,command:"schema",surface:"repair",scopes:["audit_log_dir","audit_log_truncate"],contract:{requires_idempotency_key_when_apply:true,refusal_exit_code:3,dry_run_default:true},note:"scaffold-meta-repair affects only scaffold audit ledger; native flywheel-loop repair (if it had one) would affect substrate"}'
+      ;;
+    validate)
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+        '{schema_version:$sv,command:"schema",surface:"validate",subjects:["helper_lib","audit_log","env"],contract:{rejects_with_rc1:"on schema violation"}}'
+      ;;
+    audit)
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+        '{schema_version:$sv,command:"schema",surface:"audit",audit_log_env:"SCAFFOLD_AUDIT_LOG",row_shape:{ts:"ISO8601",action:"string",status:"string"},limit_default:20}'
+      ;;
+    why)
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+        '{schema_version:$sv,command:"schema",surface:"why",input:"id (ts OR idempotency_key OR run_id)",states:["found","not_found","unavailable"],source:"SCAFFOLD_AUDIT_LOG"}'
+      ;;
+    audit-row)
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+        '{schema_version:$sv,command:"schema",surface:"audit-row",required_fields:["ts","action"],optional_fields:["status","sha256","scope","mode","idempotency_key"]}'
+      ;;
+    default|*)
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+        '{schema_version:$sv,command:"schema",surfaces:["doctor","health","repair","validate","audit","why","audit-row"],note:"flywheel-loop canonical-cli surface; native verbs (doctor/health/repair/validate/audit/why/quickstart) bypass to portable_* dispatchers via _scaffold_is_canonical_arg colliding-verb guard"}'
