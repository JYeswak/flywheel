+scaffold_cmd_doctor() {
+  # Scaffold-meta-doctor: probes the canonical-cli scaffold layer.
+  # Native flywheel-loop doctor (portable_doctor) handles substrate-wide probes
+  # and is reached via the colliding-verb bypass at _scaffold_is_canonical_arg.
+  local fw_home="${FLYWHEEL_HOME:-$HOME/.claude/skills/.flywheel}"
+  local helper_lib="${_SCAFFOLD_HELPER_LIB:-$_SCAFFOLD_REPO_ROOT/.flywheel/lib/canonical-cli-helpers.sh}"
+  local audit_log="$SCAFFOLD_AUDIT_LOG"
+  local audit_log_dir; audit_log_dir="$(dirname "$audit_log")"
+  local fw_status="fail" lib_status="fail" helper_status="fail"
+  local audit_dir_status="fail" audit_writable="fail" schema_status="fail"
+  local overall="pass"
+
+  if [[ -d "$fw_home" ]]; then fw_status="pass"; fi
+  if [[ -d "$fw_home/lib" ]]; then lib_status="pass"; fi
+  if [[ -r "$helper_lib" ]]; then helper_status="pass"; fi
+  if [[ -d "$audit_log_dir" ]]; then audit_dir_status="pass"; fi
+  if [[ -w "$audit_log_dir" || ( ! -e "$audit_log_dir" && -w "$(dirname "$audit_log_dir")" ) ]]; then audit_writable="pass"; fi
+  if [[ -n "$SCAFFOLD_SCHEMA_VERSION" ]]; then schema_status="pass"; fi
+
+  for st in "$fw_status" "$lib_status" "$helper_status" "$schema_status"; do
+    if [[ "$st" == "fail" ]]; then overall="fail"; fi
+  done
+  if [[ "$overall" == "pass" ]]; then
+    for st in "$audit_dir_status" "$audit_writable"; do
+      if [[ "$st" == "fail" ]]; then overall="warn"; fi
+    done
+  fi
+
+  jq -nc \
+    --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+    --arg ts "$(iso_now 2>/dev/null || date -u +%Y-%m-%dT%H:%M:%SZ)" \
+    --arg overall "$overall" \
+    --arg fw_home "$fw_home" --arg fw_status "$fw_status" \
+    --arg lib_dir "$fw_home/lib" --arg lib_status "$lib_status" \
+    --arg helper_lib "$helper_lib" --arg helper_status "$helper_status" \
+    --arg audit_dir "$audit_log_dir" --arg audit_dir_status "$audit_dir_status" --arg audit_writable "$audit_writable" \
+    --arg audit_log "$audit_log" \
+    --arg schema_status "$schema_status" --arg schema_version "$SCAFFOLD_SCHEMA_VERSION" \
+    '{schema_version:$sv,command:"doctor",scope:"scaffold-meta",ts:$ts,status:$overall,
+      checks:[
+        {name:"flywheel_home",path:$fw_home,status:$fw_status},
+        {name:"lib_dir",path:$lib_dir,status:$lib_status},
+        {name:"helper_lib",path:$helper_lib,status:$helper_status},
+        {name:"audit_log_dir",path:$audit_dir,status:$audit_dir_status},
+        {name:"audit_log_writable",status:$audit_writable},
+        {name:"schema_version_set",status:$schema_status,detail:$schema_version}
+      ],
+      audit_log:$audit_log,
+      note:"native flywheel-loop doctor: see portable_doctor (substrate); use `flywheel-loop doctor --repo PATH --json`"
+    }'
+}
+
+scaffold_cmd_health() {
+  local audit_log="${SCAFFOLD_AUDIT_LOG:-$HOME/.local/state/flywheel/flywheel-loop-audit.jsonl}"
+  local now ts last_run_ts="" age_seconds total_runs=0 recent_runs=0 status="pass"
+  local stale_threshold="${LOOP_HEALTH_STALE_THRESHOLD_SECONDS:-86400}"
+  ts="$(iso_now 2>/dev/null || date -u +%Y-%m-%dT%H:%M:%SZ)"
+  if [[ ! -r "$audit_log" ]]; then
+    jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg ts "$ts" --arg log "$audit_log" \
+      '{schema_version:$sv,command:"health",scope:"scaffold-meta",ts:$ts,status:"warn",audit_log:$log,reason:"audit_log_missing",last_run_ts:null,age_seconds:null,recent_runs:0,total_runs:0}'
+    return 0
+  fi
+  total_runs="$(wc -l < "$audit_log" 2>/dev/null | tr -d ' ' || echo 0)"
+  recent_runs="$(tail -20 "$audit_log" 2>/dev/null | wc -l | tr -d ' ' || echo 0)"
+  last_run_ts="$(tail -1 "$audit_log" 2>/dev/null | jq -r '.ts // empty' 2>/dev/null || true)"
+  if [[ -n "$last_run_ts" ]]; then
+    now="$(date -u +%s)"
+    local last_epoch
+    last_epoch="$(date -u -j -f '%Y-%m-%dT%H:%M:%SZ' "$last_run_ts" +%s 2>/dev/null \
+                  || date -u -d "$last_run_ts" +%s 2>/dev/null \
+                  || echo 0)"
+    age_seconds=$((now - last_epoch))
+    if [[ "$age_seconds" -gt "$stale_threshold" ]]; then status="warn"; fi
+  else
+    age_seconds=null
+    status="warn"
+  fi
+  jq -nc \
+    --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg ts "$ts" --arg status "$status" \
+    --arg log "$audit_log" --arg last_run_ts "$last_run_ts" \
+    --argjson age "${age_seconds:-null}" \
+    --argjson total "$total_runs" --argjson recent "$recent_runs" \
+    --argjson stale "$stale_threshold" \
+    '{schema_version:$sv,command:"health",scope:"scaffold-meta",ts:$ts,status:$status,audit_log:$log,
+      last_run_ts:(if $last_run_ts == "" then null else $last_run_ts end),
+      age_seconds:$age, recent_runs:$recent, total_runs:$total,
+      stale_threshold_seconds:$stale}'
+}
+
+scaffold_cmd_repair() {
+  local scope="" mode="dry_run" idem_key=""
+  while [[ $# -gt 0 ]]; do
+    case "$1" in
+      -h|--help) scaffold_emit_topic_help repair; return 0 ;;
+      --scope) scope="${2:-}"; shift 2 ;;
+      --dry-run) mode="dry_run"; shift ;;
+      --apply) mode="apply"; shift ;;
+      --idempotency-key) idem_key="${2:-}"; shift 2 ;;
+      --idempotency-key=*) idem_key="${1#--idempotency-key=}"; shift ;;
+      --json) shift ;;
+      *) printf 'ERR: unknown repair arg %s\n' "$1" >&2; return 64 ;;
+    esac
+  done
+  if [[ "$mode" == "apply" && -z "$idem_key" ]]; then
+    if command -v cli_refuse_apply_without_idem_key >/dev/null; then
+      cli_refuse_apply_without_idem_key "$SCAFFOLD_SCHEMA_VERSION" "repair" "$scope"
+    else
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg scope "$scope" \
+        '{schema_version:$sv,command:"repair",status:"refused",mode:"apply",scope:$scope,reason:"--apply requires --idempotency-key"}'
+      exit 3
+    fi
+  fi
+  local audit_log="${SCAFFOLD_AUDIT_LOG:-$HOME/.local/state/flywheel/flywheel-loop-audit.jsonl}"
+  local audit_log_dir; audit_log_dir="$(dirname "$audit_log")"
+  local action="" status="ok"
+  case "$scope" in
+    audit_log_dir)
+      if [[ -d "$audit_log_dir" ]]; then
+        action="audit_log_dir_exists_noop"
+      elif [[ "$mode" == "apply" ]]; then
+        if mkdir -p "$audit_log_dir" 2>/dev/null; then
+          action="audit_log_dir_created"
+        else
+          action="audit_log_dir_create_failed"; status="fail"
+        fi
+      else
+        action="audit_log_dir_create_planned"
+      fi
+      ;;
+    audit_log_truncate)
+      if [[ ! -f "$audit_log" ]]; then
+        action="audit_log_absent_noop"
+      elif [[ "$mode" == "apply" ]]; then
+        if : > "$audit_log" 2>/dev/null; then
+          action="audit_log_truncated"
+        else
+          action="audit_log_truncate_failed"; status="fail"
+        fi
+      else
+        action="audit_log_truncate_planned"
+      fi
+      ;;
+    "")
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+        '{schema_version:$sv,command:"repair",scope:"scaffold-meta",status:"refused",reason:"--scope required",valid_scopes:["audit_log_dir","audit_log_truncate"]}'
+      return 64
+      ;;
+    *)
+      jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg scope "$scope" \
+        '{schema_version:$sv,command:"repair",scope:"scaffold-meta",status:"refused",reason:"unknown scope",scope_in:$scope,valid_scopes:["audit_log_dir","audit_log_truncate"]}'
+      return 64
+      ;;
+  esac
+  local envelope
+  envelope="$(jq -nc --arg sv "$SCAFFOLD_SCHEMA_VERSION" --arg scope "$scope" --arg mode "$mode" --arg idem "$idem_key" --arg action "$action" --arg status "$status" \
+    '{schema_version:$sv,command:"repair",scope:$scope,status:$status,mode:$mode,idempotency_key:$idem,action:$action}')"
+  printf '%s\n' "$envelope"
+  if command -v cli_audit_append >/dev/null 2>&1; then
+    cli_audit_append "$audit_log" "repair" "$status" \
+      "$(jq -nc --arg scope "$scope" --arg mode "$mode" --arg idem "$idem_key" --arg act "$action" \
+          '{scope:$scope,mode:$mode,idempotency_key:$idem,action:$act}')"
+  fi
+}
