+scaffold_emit_topic_help() {
+  local topic="${1:-}"
+  case "$topic" in
+    run)      printf 'topic: run — default backward-compatible invocation routes to native flywheel-loop dispatcher (sources lib/*.sh and dispatches to portable_doctor/portable_health/etc.); see flywheel-loop --help for native subcommand list\n' ;;
+    doctor)   printf 'topic: doctor — colliding verb. flywheel-loop doctor goes to native portable_doctor (substrate-wide); scaffold-meta-doctor (only reachable via direct scaffold_main call) probes scaffold layer: helper_lib path, FLYWHEEL_HOME, audit_log writability, schema version\n' ;;
+    health)   printf 'topic: health — colliding verb. flywheel-loop health goes to native portable_health; scaffold-meta-health tails $SCAFFOLD_AUDIT_LOG (separate ledger from substrate health), reports last_run_ts, age_seconds, recent_runs, total_runs\n' ;;
+    repair)   printf 'topic: repair — colliding verb. flywheel-loop repair (if implemented natively) handles substrate; scaffold-meta-repair scopes: audit_log_dir, audit_log_truncate. Apply contract: --apply requires --idempotency-key (rc=3 refusal)\n' ;;
+    validate) printf 'topic: validate — colliding verb. flywheel-loop validate (loop|receipt) goes to native; scaffold-meta-validate subjects: helper_lib (canonical helpers presence), audit_log (writability), env (FLYWHEEL_HOME / SCAFFOLD_AUDIT_LOG)\n' ;;
+    audit)    printf 'topic: audit — colliding verb. flywheel-loop audit goes to native; scaffold-meta-audit tails $SCAFFOLD_AUDIT_LOG via cli_emit_audit_tail (path-then-schema positional order); --limit N\n' ;;
+    why)      printf 'topic: why — colliding verb. flywheel-loop why <id> goes to native; scaffold-meta-why <id> matches against $SCAFFOLD_AUDIT_LOG ts/idempotency_key/run_id (states: found/not_found/unavailable)\n' ;;
+    quickstart) printf 'topic: quickstart — colliding verb. flywheel-loop quickstart goes to native; scaffold-meta-quickstart emits canonical-cli surface listing\n' ;;
+    completion) printf 'topic: completion <bash|zsh> — emit shell completion script for canonical-cli verbs (bypasses native dispatch)\n' ;;
+    *)        printf 'topics: run | doctor | health | repair | validate | audit | why | quickstart | completion\n' ;;
+  esac
+}
+
+scaffold_emit_completion() {
+  local shell="${1:-bash}"
+  case "$shell" in
+    -h|--help) scaffold_emit_topic_help completion 2>/dev/null \
+                 || printf 'topic: completion <bash|zsh> — emit shell completion script\n'
+               return 0 ;;
+    bash) command -v cli_emit_completion_bash >/dev/null \
+            && cli_emit_completion_bash "flywheel-loop" "doctor,health,repair,validate,audit,why,quickstart,help,completion" "--json,--apply,--dry-run,--idempotency-key,--info,--schema,--examples" \
+            || printf '# helper lib missing — completion unavailable\n' ;;
+    zsh)  command -v cli_emit_completion_zsh >/dev/null \
+            && cli_emit_completion_zsh "flywheel-loop" "doctor,health,repair,validate,audit,why,quickstart,help,completion" \
+            || printf '# helper lib missing — completion unavailable\n' ;;
+    *) printf 'ERR: unknown shell %s (use bash|zsh)\n' "$shell" >&2; return 64 ;;
+  esac
+}
