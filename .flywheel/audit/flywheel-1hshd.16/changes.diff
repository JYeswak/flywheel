+scaffold_cmd_doctor() {
+  local repo_root; repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd -P)"
+  local lease_bin="$repo_root/.flywheel/scripts/capacity-halt-lease-primitive.sh"
+  local auth_bin="$repo_root/.flywheel/scripts/capacity-halt-pane-authorization.sh"
+  local budget_bin="$repo_root/.flywheel/scripts/capacity-halt-burst-budget.sh"
+  local audit_log_dir; audit_log_dir="$(dirname "$SCAFFOLD_AUDIT_LOG")"
+  local bash_status="fail" jq_status="fail" mktemp_status="fail" python_status="fail" tmux_status="fail"
+  local lease_status="warn" auth_status="warn" budget_status="warn" audit_dir_status="fail"
+  local overall="pass"
+
+  if command -v bash >/dev/null 2>&1; then bash_status="pass"; fi
+  if command -v jq >/dev/null 2>&1; then jq_status="pass"; fi
+  if command -v mktemp >/dev/null 2>&1; then mktemp_status="pass"; fi
+  if command -v python3 >/dev/null 2>&1; then python_status="pass"; fi
+  if command -v tmux >/dev/null 2>&1; then tmux_status="pass"; fi
+  if [[ -x "$lease_bin" ]]; then lease_status="pass"; fi
+  if [[ -x "$auth_bin" ]]; then auth_status="pass"; fi
+  if [[ -x "$budget_bin" ]]; then budget_status="pass"; fi
+  if [[ -d "$audit_log_dir" && -w "$audit_log_dir" ]]; then audit_dir_status="pass"; fi
+
+  for st in "$bash_status" "$jq_status" "$mktemp_status" "$python_status" "$tmux_status"; do
+    if [[ "$st" == "fail" ]]; then overall="fail"; fi
+  done
+  if [[ "$overall" == "pass" ]]; then
+    for st in "$lease_status" "$auth_status" "$budget_status" "$audit_dir_status"; do
+      if [[ "$st" == "warn" || "$st" == "fail" ]]; then overall="warn"; fi
+    done
+  fi
+
+  jq -nc \
+    --arg sv "$SCAFFOLD_SCHEMA_VERSION" \
+    --arg ts "$(iso_now 2>/dev/null || date -u +%Y-%m-%dT%H:%M:%SZ)" \
+    --arg overall "$overall" \
+    --arg bash_status "$bash_status" --arg jq_status "$jq_status" \
+    --arg mktemp_status "$mktemp_status" --arg python_status "$python_status" --arg tmux_status "$tmux_status" \
+    --arg lease "$lease_bin" --arg lease_status "$lease_status" \
+    --arg auth "$auth_bin" --arg auth_status "$auth_status" \
+    --arg budget "$budget_bin" --arg budget_status "$budget_status" \
+    --arg audit_dir "$audit_log_dir" --arg audit_dir_status "$audit_dir_status" \
+    '{schema_version:$sv,command:"doctor",ts:$ts,status:$overall,
+      checks:[
+        {name:"bash_available",status:$bash_status},
+        {name:"jq_available",status:$jq_status},
+        {name:"mktemp_available",status:$mktemp_status},
+        {name:"python3_available",status:$python_status,detail:"load-bearing for recovery heredoc"},
+        {name:"tmux_available",status:$tmux_status,detail:"load-bearing — sends bare-Enter via tmux send-keys"},
+        {name:"capacity_halt_lease_executable",status:$lease_status,path:$lease,detail:"load-bearing for lease coordination"},
+        {name:"capacity_halt_auth_executable",status:$auth_status,path:$auth,detail:"load-bearing for pane authorization"},
+        {name:"capacity_halt_budget_executable",status:$budget_status,path:$budget,detail:"load-bearing for burst-budget enforcement"},
+        {name:"audit_log_dir_writable",status:$audit_dir_status,path:$audit_dir}
+      ]
+    }'
+}
