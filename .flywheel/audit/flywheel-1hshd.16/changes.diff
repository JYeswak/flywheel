+    repair)   printf 'topic: repair --scope <fallback_ledger_dir|audit_log_dir> [--dry-run|--apply --idempotency-key KEY] — apply contract: --apply requires --idempotency-key (rc=3 refusal); scopes: fallback_ledger_dir (mkdir -p dirname of fallback_ledger), audit_log_dir\n' ;;
