+# Early-dispatch intercept: if argv[0] looks like a canonical subcommand
+# or introspection flag, run the canonical surface and exit BEFORE the
+# target's original arg parser sees the args. Works for both `main "$@"`
+# style and inline `while [[ $# -gt 0 ]]` style targets.
+_scaffold_is_canonical_arg() {
+  # WZJO9.1.7 NUANCED-PARTIAL-BYPASS: codex-queued-not-submitted-bare-
+  # enter-primitive.sh natively implements --info AND --examples in the
+  # python heredoc with rich canonical envelopes (codex-queued-not-
+  # submitted-bare-enter.info.v1 with full metadata + verbs list +
+  # exit_codes; codex-queued-not-submitted-bare-enter.examples.v1 with
+  # examples list). Native does NOT implement --schema (errors with
+  # usage), so scaffold owns it. Verb subcommands NOT natively supported
+  # — scaffold owns those too. Sister to 5ke66.8 + 1hshd.11.
+  case "${1:-}" in
+    doctor|health|repair|validate|audit|why|quickstart|completion) return 0 ;;
+    --info|--examples) return 1 ;;  # NUANCED-PARTIAL-BYPASS to native
+    --schema) return 0 ;;            # NOT bypassed — scaffold owns
+    -h|--help) return 0 ;;
+    help)
+      # Intercept `help <topic>` and `help --help`; bare `help` could be
+      # a legacy subcommand of the target so it falls through.
+      case "${2:-}" in run|doctor|health|repair|validate|audit|why|-h|--help) return 0 ;; esac
+      return 1 ;;
+    *) return 1 ;;
+  esac
+}
