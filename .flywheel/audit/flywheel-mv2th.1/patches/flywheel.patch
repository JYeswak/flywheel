--- .flywheel/audit/flywheel-mv2th.1/patches/flywheel.original	2026-05-11 12:23:29
+++ .flywheel/audit/flywheel-mv2th.1/patches/flywheel.proposed	2026-05-11 12:25:20
@@ -265,9 +265,126 @@
   if [[ -z "$archetype" && ( -f "$target/manage.py" || -f "$target/wsgi.py" || -f "$target/asgi.py" ) ]]; then
     archetype="backend-service"
     reasons+=("Python web framework markers present (manage.py/wsgi.py/asgi.py)")
+  fi
+
+  # Mobile app — react-native / expo in package.json OR ios/android folders
+  if [[ -z "$archetype" && -f "$target/package.json" ]]; then
+    if grep -qE '"(react-native|expo|@react-native|@react-navigation)"' "$target/package.json" 2>/dev/null; then
+      archetype="mobile-app"
+      reasons+=("package.json has react-native/expo dep")
+    fi
   fi
+  if [[ -z "$archetype" && ( -d "$target/ios" || -d "$target/android" ) ]]; then
+    archetype="mobile-app"
+    reasons+=("ios/ or android/ folder present")
+  fi
 
+  # Ruby web — Gemfile with rails/sinatra
+  if [[ -z "$archetype" && -f "$target/Gemfile" ]]; then
+    if grep -qE "gem ['\"](rails|sinatra|hanami|grape|roda)['\"]" "$target/Gemfile" 2>/dev/null; then
+      archetype="backend-service"
+      reasons+=("Gemfile has rails/sinatra/hanami/grape/roda dep")
+    fi
+  fi
+
+  # flywheel-mv2th.1: subdir-scan for fullstack / multi-dir-project layouts.
+  # The previous heuristics only check $target root; many real projects
+  # carry markers in standard subdirectories (frontend/, backend/, next-app/,
+  # web/, app/, api/, server/, mobile/, client/). Detect those.
   if [[ -z "$archetype" ]]; then
+    local has_frontend_marker=0
+    local has_backend_marker=0
+    local has_mobile_marker=0
+    local frontend_reason=""
+    local backend_reason=""
+    local mobile_reason=""
+    for subdir in frontend web app next-app client mobile; do
+      local sd="$target/$subdir"
+      [[ -d "$sd" ]] || continue
+      if [[ -f "$sd/package.json" ]]; then
+        if grep -qE '"(react-native|expo|@react-native)"' "$sd/package.json" 2>/dev/null; then
+          has_mobile_marker=1
+          mobile_reason="$subdir/package.json has react-native/expo"
+        elif grep -qE '"(react|vue|svelte|next|astro|vite|@vue/cli|@angular/core)"' "$sd/package.json" 2>/dev/null; then
+          has_frontend_marker=1
+          frontend_reason="$subdir/package.json has frontend framework dep"
+          # flywheel-mv2th.1: Next.js with co-located API routes (app/api or
+          # pages/api) carries BOTH frontend AND backend semantics in a single
+          # subdir. Set has_backend_marker too so the classify block below
+          # routes to "fullstack" rather than "frontend-spa".
+          if grep -qE '"next"' "$sd/package.json" 2>/dev/null; then
+            if [[ -d "$sd/app/api" || -d "$sd/pages/api" || -d "$sd/src/app/api" || -d "$sd/src/pages/api" ]]; then
+              has_backend_marker=1
+              backend_reason="$subdir/ is Next.js with co-located API routes (app/api or pages/api)"
+            fi
+          fi
+        fi
+      fi
+      if [[ -d "$sd/ios" || -d "$sd/android" ]]; then
+        has_mobile_marker=1
+        mobile_reason="$subdir/ contains ios/ or android/"
+      fi
+    done
+    for subdir in backend server api; do
+      local sd="$target/$subdir"
+      [[ -d "$sd" ]] || continue
+      if [[ -f "$sd/package.json" ]] && grep -qE '"(express|fastify|koa|hapi|nestjs|@nestjs/core)"' "$sd/package.json" 2>/dev/null; then
+        has_backend_marker=1
+        backend_reason="$subdir/package.json has backend framework dep"
+      elif [[ -f "$sd/requirements.txt" ]] && grep -qE '(django|flask|fastapi|starlette|tornado|aiohttp)' "$sd/requirements.txt" 2>/dev/null; then
+        has_backend_marker=1
+        backend_reason="$subdir/requirements.txt has python web framework dep"
+      elif [[ -f "$sd/pyproject.toml" ]] && grep -qE '(django|flask|fastapi|starlette|tornado|aiohttp)' "$sd/pyproject.toml" 2>/dev/null; then
+        has_backend_marker=1
+        backend_reason="$subdir/pyproject.toml has python web framework dep"
+      elif [[ -f "$sd/Gemfile" ]] && grep -qE "gem ['\"](rails|sinatra|hanami|grape|roda)['\"]" "$sd/Gemfile" 2>/dev/null; then
+        has_backend_marker=1
+        backend_reason="$subdir/Gemfile has ruby web framework dep"
+      elif [[ -f "$sd/manage.py" || -f "$sd/wsgi.py" || -f "$sd/asgi.py" ]]; then
+        has_backend_marker=1
+        backend_reason="$subdir/ has Django/WSGI/ASGI markers"
+      fi
+    done
+    if [[ "$has_mobile_marker" -eq 1 && "$has_backend_marker" -eq 1 ]]; then
+      archetype="fullstack"
+      reasons+=("$mobile_reason" "$backend_reason" "mobile+backend → fullstack")
+    elif [[ "$has_frontend_marker" -eq 1 && "$has_backend_marker" -eq 1 ]]; then
+      archetype="fullstack"
+      reasons+=("$frontend_reason" "$backend_reason" "frontend+backend → fullstack")
+    elif [[ "$has_mobile_marker" -eq 1 ]]; then
+      archetype="mobile-app"
+      reasons+=("$mobile_reason")
+    elif [[ "$has_backend_marker" -eq 1 ]]; then
+      archetype="backend-service"
+      reasons+=("$backend_reason")
+    elif [[ "$has_frontend_marker" -eq 1 ]]; then
+      archetype="frontend-spa"
+      reasons+=("$frontend_reason")
+    fi
+  fi
+
+  # mobile-eats-style single-subdir Next.js fullstack (next-app/ with API routes
+  # but no sibling backend/ dir). Treat as fullstack when Next.js + api/ routes.
+  if [[ -z "$archetype" ]]; then
+    for subdir in next-app web app; do
+      local sd="$target/$subdir"
+      [[ -d "$sd" ]] || continue
+      if [[ -f "$sd/package.json" ]] && grep -qE '"next"' "$sd/package.json" 2>/dev/null; then
+        # Next.js with app/api/ or pages/api/ routes → fullstack (API + frontend in one)
+        if [[ -d "$sd/app/api" || -d "$sd/pages/api" || -d "$sd/src/app/api" || -d "$sd/src/pages/api" ]]; then
+          archetype="fullstack"
+          reasons+=("$subdir/ is Next.js with API routes (single-subdir fullstack)")
+          break
+        else
+          archetype="frontend-spa"
+          reasons+=("$subdir/ is Next.js (no API routes detected)")
+          break
+        fi
+      fi
+    done
+  fi
+
+  if [[ -z "$archetype" ]]; then
     archetype="unknown"
     reasons+=("no archetype matched; expand heuristics or pass --archetype")
   fi
