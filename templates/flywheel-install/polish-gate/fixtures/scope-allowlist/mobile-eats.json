{
  "version": "1",
  "profile_name": "mobile-eats",
  "domain": "product-app",
  "allowlist_paths": [".flywheel/"],
  "blocklist_paths": [
    "next-app/",
    "docs/product/",
    "wireframes/",
    ".beads/",
    ".vercel/",
    "public/",
    "app/",
    "src/",
    "provider-config/"
  ],
  "blocklist_reason_default": "product-domain-not-substrate",
  "domain_collision_terms": [
    "doctor",
    "ledger",
    "worker",
    "dispatch",
    "tick",
    "router",
    "menu",
    "order",
    "vendor"
  ],
  "requires_word_boundary": true,
  "rationale": "Mobile Eats audit defaults to repo-local flywheel substrate; product app code remains excluded until the owner expands scope."
}
