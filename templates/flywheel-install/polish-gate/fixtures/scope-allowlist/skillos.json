{
  "version": "1",
  "profile_name": "skillos",
  "domain": "skill-substrate",
  "allowlist_paths": [
    ".flywheel/",
    "scripts/",
    "tests/",
    "state/",
    "AGENTS.md",
    "README.md"
  ],
  "blocklist_paths": [
    ".beads/",
    ".ntm/",
    ".cass/",
    "outputs/",
    "AGENTS.md.archive/",
    "*.bak",
    "*.bak.*",
    "caches/"
  ],
  "blocklist_reason_default": "historical-or-generated-not-active-substrate",
  "domain_collision_terms": [
    "skill",
    "agent",
    "dispatch",
    "tick",
    "worker",
    "state"
  ],
  "requires_word_boundary": false,
  "rationale": "Skillos is a control-plane repo; active flywheel, script, test, state, and root doctrine surfaces are valid audit substrate."
}
