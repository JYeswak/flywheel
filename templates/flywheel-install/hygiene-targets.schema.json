{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zeststream.ai/schemas/flywheel/hygiene-targets/v1.schema.json",
  "title": "Flywheel repo hygiene targets v1",
  "description": "Declarative residue contract read by repo-hygiene prompt/tick surfaces. YAML files are validated as this JSON shape.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "repo_path",
    "doctrine_version",
    "provenance",
    "safety_contract",
    "trauma_classes",
    "gitignore_gaps"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "repo_path": {
      "type": "string",
      "pattern": "^/"
    },
    "doctrine_version": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}(\\.[A-Za-z0-9_-]+)?$"
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_plan",
        "source_artifact",
        "source_sections",
        "generated_by"
      ],
      "properties": {
        "source_plan": {
          "type": "string",
          "minLength": 1
        },
        "source_artifact": {
          "type": "string",
          "minLength": 1
        },
        "source_sections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "generated_by": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "safety_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dry_run_default",
        "idempotency_key_required",
        "refuses_tracked_files",
        "receipt_dir"
      ],
      "properties": {
        "dry_run_default": {
          "const": true
        },
        "idempotency_key_required": {
          "const": true
        },
        "refuses_tracked_files": {
          "const": true
        },
        "receipt_dir": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "trauma_classes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/trauma_class"
      }
    },
    "gitignore_gaps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/gitignore_gap"
      }
    }
  },
  "$defs": {
    "trauma_class": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "patterns",
        "safety",
        "applicable_skills",
        "provenance"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "patterns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "min_age_days": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "max_total_mb": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "safety": {
          "enum": [
            "always-safe",
            "age-gated",
            "never-delete-only-document"
          ]
        },
        "applicable_skills": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "storage-health",
              "dev-cache-janitor",
              "apfs-snapshot-ops",
              "docker-storage-ops",
              "orbstack-ops",
              "storage-ballast-helper",
              "disk-observer",
              "path-rationalization",
              "canonical-cli-scoping",
              "extreme-software-optimization"
            ]
          },
          "uniqueItems": true
        },
        "provenance": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "gitignore_gap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pattern",
        "disposition",
        "root_cause_fix_tier",
        "provenance"
      ],
      "properties": {
        "pattern": {
          "type": "string",
          "minLength": 1
        },
        "disposition": {
          "enum": [
            "add-to-gitignore",
            "add-to-hygiene-targets",
            "no-action",
            "never-delete-only-document"
          ]
        },
        "root_cause_fix_tier": {
          "enum": [
            "gitignore",
            "hygiene-target",
            "document-only",
            "no-action"
          ]
        },
        "provenance": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    }
  }
}
