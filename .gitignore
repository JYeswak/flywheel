# bv (beads viewer) local config and caches
.bv/

# Beads backup and failed-repair snapshots
/.beads.bak.*/
/.beads.failed.*/

# .beads/ RCA evidence (br-db corruption mitigation snapshots; never commit)
.beads/beads.db.bak.*
.beads/beads.db-shm.bak.*
.beads/beads.db-wal.bak.*
.beads/beads.db.aside.*
.beads/beads.db-shm.aside.*
.beads/beads.db-wal.aside.*
.beads/beads.db*.malformed-*
.beads/beads.db*.corrupt-*.aside.*
.beads/beads.db*.malformed.*
.beads/beads.db*.corrupt-*.bak.*
.beads/issues.jsonl.bak.*
# Flywheel generated doctrine/state backups
/.flywheel/AGENTS-CANONICAL.md.bak.*
/.flywheel/MISSION.md.bak.*
/.flywheel/GOAL.md.bak.*
/.flywheel/STATE.md.bak.*
/.flywheel/.STATE.md.preview.*
/.flywheel/*.md.preview.*
/.flywheel/.reconcile-*.diff
/.flywheel/scripts/*.bak.*
/.flywheel/validation-schema/v1/*.bak.*
/.flywheel/PLANS/**/*.bak.*

# Root/template generated backups
/AGENTS.md.bak.*
/templates/flywheel-install/*.bak.*
/templates/flywheel-install/tests/*.bak.*

# Runtime caches and scratch state
__pycache__/
*.pyc
.pytest_cache/
/.cass/
/.claude/scheduled_tasks.lock
/.claude/get-shit-done
/.continue-here.md

# SQLite runtime state and sidecars
*.db-wal
*.db-shm
*-wal
*-shm
/state.db
/storage.sqlite3

# Sediment + backups (archive under .git-archive/, never commit)
AGENTS.md.bak.*
.beads.bak.*
.beads.failed.*
.git-archive/
.git-archive/*
!.git-archive/.gitkeep

# Cache
.ruff_cache/
.pytest_cache/

# Continue/transient files
.continue-here.md

# Recovery scratch
.flywheel/.STATE.md.preview.*
.flywheel/.reconcile-*.diff

# === @zeststream/security-hygiene canonical .env guard ===
# Canonical @zeststream/security-hygiene gitignore env block — v0.0.1
#
# Append this block to a repo's .gitignore to enforce the
# "never-commit-real-secrets; only-template-files-commit" policy.
#
# Hardened across 3 ratifications:
#   - terratitle b15qk (commit e33d1dc) — initial fold
#   - josh-ops htv0d (commit 6bd3423)   — second fold
#   - alpsinsurance (pre-existing)      — independent convergence
#
# Behavior:
#   - .env / .env.* matches all environment variants (.env.prod,
#     .env.staging, .env.dev, .env.local, future variants)
#   - !.env.example / !.env.local.example bang-overrides re-allow
#     template files at any depth
#   - **/.env.example / **/.env.local.example explicit-depth variants
#     cover sub-directory templates (frontend/.env.example etc.)

# Environment — never commit real secrets; only .env.example variants
.env
.env.*
!.env.example
!.env.local.example
!**/.env.example
!**/.env.local.example
